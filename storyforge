#!/usr/bin/env python3
"""Storyforge CLI — novel-writing toolkit for Claude Code.

Usage: ./storyforge <command> [options]

This is the main entry point. It dispatches to Python command modules
in scripts/lib/python/storyforge/cmd_*.py.
"""

import os
import sys

# Add the Python library to the path
script_dir = os.path.dirname(os.path.abspath(__file__))
python_lib = os.path.join(script_dir, 'scripts', 'lib', 'python')
sys.path.insert(0, python_lib)

from storyforge.__main__ import main

if __name__ == '__main__':
    main()

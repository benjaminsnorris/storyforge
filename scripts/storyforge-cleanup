#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-cleanup — Project structure cleanup and migration
#
# Fixes structural drift in Storyforge novel projects: updates gitignore,
# creates missing directories, migrates storyforge.yaml, adds CSV columns,
# removes junk files, deletes legacy artifacts, and reports integrity issues.
#
# Usage:
#   ./storyforge cleanup                  # Apply all fixes and commit
#   ./storyforge cleanup --dry-run        # Report what would change
#   ./storyforge cleanup --verbose        # Detailed output
# ============================================================================

# --- Allow sourcing for tests ---
if [[ "${1:-}" == "--source-only" ]]; then
    _CLEANUP_SOURCE_ONLY=true
    shift
fi

# --- Locate script directory and source libraries ---
if [[ "${_CLEANUP_SOURCE_ONLY:-}" != "true" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    LIB_DIR="${SCRIPT_DIR}/lib"

    if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
        echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
        exit 1
    fi
    source "${LIB_DIR}/common.sh"
fi

# ============================================================================
# Gitignore
# ============================================================================

GITIGNORE_REQUIRED=(
    "working/logs/"
    "working/scores/**/.batch-requests.jsonl"
    "working/evaluations/**/.status-*"
    "working/scores/**/.markers-*"
    ".DS_Store"
    "working/.autopilot"
    "working/.interactive"
)

update_gitignore() {
    local project_dir="$1"
    local gitignore="${project_dir}/.gitignore"

    if [[ ! -f "$gitignore" ]]; then
        cat > "$gitignore" << 'GIEOF'
# Storyforge — Novel Project .gitignore

# macOS
.DS_Store

GIEOF
    fi

    local content
    content=$(cat "$gitignore")
    local added=false

    for entry in "${GITIGNORE_REQUIRED[@]}"; do
        if ! grep -qF "$entry" "$gitignore"; then
            added=true
        fi
    done

    if $added; then
        local new_content="$content"
        [[ "${new_content: -1}" != $'\n' ]] && new_content="${new_content}"$'\n'

        if ! grep -qF "working/logs/" "$gitignore"; then
            new_content+=$'\n'"# Logs (debugging output, value extracted at write time)"$'\n'
            new_content+="working/logs/"$'\n'
        fi

        if ! grep -qF "working/scores/**/.batch-requests.jsonl" "$gitignore"; then
            new_content+=$'\n'"# Batch API payloads (keep only latest for debugging)"$'\n'
            new_content+="working/scores/**/.batch-requests.jsonl"$'\n'
        fi

        if ! grep -qF "working/evaluations/**/.status-*" "$gitignore"; then
            new_content+=$'\n'"# Intermediate scoring/eval state"$'\n'
            new_content+="working/evaluations/**/.status-*"$'\n'
        fi

        if ! grep -qF "working/scores/**/.markers-*" "$gitignore"; then
            new_content+="working/scores/**/.markers-*"$'\n'
        fi

        if ! grep -qF "working/.interactive" "$gitignore"; then
            if grep -qF "working/.autopilot" "$gitignore" && ! grep -qF "working/.interactive" "$gitignore"; then
                new_content=$(echo "$new_content" | sed '/working\/.autopilot/a\
working/.interactive')
            else
                new_content+=$'\n'"# Temporary flag files (cleaned up by scripts)"$'\n'
                new_content+="working/.autopilot"$'\n'
                new_content+="working/.interactive"$'\n'
            fi
        fi

        echo "$new_content" > "$gitignore"
    fi
}

# ============================================================================
# Missing directories
# ============================================================================

EXPECTED_DIRS=(
    "manuscript/press-kit"
    "working/logs"
    "working/evaluations"
    "working/plans"
    "working/recommendations"
)

create_missing_dirs() {
    local project_dir="$1"
    local created=""
    for dir in "${EXPECTED_DIRS[@]}"; do
        if [[ ! -d "${project_dir}/${dir}" ]]; then
            mkdir -p "${project_dir}/${dir}"
            touch "${project_dir}/${dir}/.gitkeep"
            created+="${dir}"$'\n'
        fi
    done
    echo -n "$created"
}

# ============================================================================
# Junk file cleanup
# ============================================================================

clean_junk_files() {
    local project_dir="$1"
    find "${project_dir}/working/evaluations" -name ".status-*" -delete 2>/dev/null || true
    find "${project_dir}/working/scores" -name ".markers-*" -delete 2>/dev/null || true
    find "${project_dir}/working/scores" -name ".batch-requests.jsonl" -not -path "*/latest/*" -delete 2>/dev/null || true
    if [[ -d "${project_dir}/working/logs" ]]; then
        find "${project_dir}/working/logs" -type f -delete 2>/dev/null || true
    fi
    for dir in enrich coaching backups scenes-setup; do
        local target="${project_dir}/working/${dir}"
        if [[ -d "$target" ]] && [[ -z "$(ls -A "$target" 2>/dev/null)" ]]; then
            rmdir "$target"
        fi
    done
}

# ============================================================================
# Legacy files and reorganization
# ============================================================================

delete_legacy_files() {
    local project_dir="$1"
    for f in "working/pipeline.yaml" "working/assemble.py"; do
        if [[ -f "${project_dir}/${f}" ]]; then
            rm "${project_dir}/${f}"
        fi
    done
}

reorganize_loose_files() {
    local project_dir="$1"
    mkdir -p "${project_dir}/working/recommendations"
    for f in "${project_dir}"/working/recommendations*.md; do
        [[ -f "$f" ]] || continue
        mv -n "$f" "${project_dir}/working/recommendations/"
    done
}

# ============================================================================
# Pipeline CSV migration
# ============================================================================

PIPELINE_EXPECTED="cycle|started|status|evaluation|scoring|plan|review|recommendations|summary"

migrate_pipeline_csv() {
    local project_dir="$1"
    local csv="${project_dir}/working/pipeline.csv"
    [[ -f "$csv" ]] || return 0
    local header
    header=$(head -1 "$csv")
    [[ "$header" == "$PIPELINE_EXPECTED" ]] && return 0

    local tmp="${csv}.tmp"
    awk -F'|' -v expected="$PIPELINE_EXPECTED" '
    BEGIN { n_exp = split(expected, exp_cols, "|") }
    NR == 1 {
        n_old = split($0, old_cols, "|")
        for (i = 1; i <= n_old; i++) old_pos[old_cols[i]] = i
        printf "%s\n", expected
        next
    }
    {
        n_old = split($0, vals, "|")
        for (i = 1; i <= n_exp; i++) {
            if (i > 1) printf "|"
            col = exp_cols[i]
            if (col in old_pos) printf "%s", vals[old_pos[col]]
        }
        printf "\n"
    }
    ' "$csv" > "$tmp"
    mv "$tmp" "$csv"
}

# ============================================================================
# Pipeline review deduplication
# ============================================================================

# Pipeline reviews named pipeline-review-YYYYMMDD-HHMMSS.md
# Same YYYYMMDD = same cycle. Keep only latest timestamp per date.
# Standalone review-YYYYMMDD.md files are always kept.
dedup_pipeline_reviews() {
    local project_dir="$1"
    local reviews_dir="${project_dir}/working/reviews"
    [[ -d "$reviews_dir" ]] || return 0

    local prev_date=""
    # Reverse sort: latest timestamp per date seen first
    for f in $(ls -r "${reviews_dir}"/pipeline-review-*.md 2>/dev/null); do
        local basename
        basename=$(basename "$f")
        local date
        date=$(echo "$basename" | sed 's/pipeline-review-\([0-9]*\)-.*/\1/')
        if [[ "$date" == "$prev_date" ]]; then
            rm "$f"
        else
            prev_date="$date"
        fi
    done
}

# ============================================================================
# storyforge.yaml migration
# ============================================================================

migrate_storyforge_yaml() {
    local project_dir="$1"
    local yaml="${project_dir}/storyforge.yaml"
    [[ -f "$yaml" ]] || return 0

    local content
    content=$(cat "$yaml")
    local modified=false

    # --- Move misplaced chapter_map to under artifacts ---
    if echo "$content" | grep -q '^chapter_map:'; then
        local cm_exists cm_path cm_updated
        cm_exists=$(echo "$content" | sed -n '/^chapter_map:/,/^[^ ]/{/exists:/{ s/.*exists: *//; p; };}')
        cm_path=$(echo "$content" | sed -n '/^chapter_map:/,/^[^ ]/{/path:/{ s/.*path: *//; p; };}')
        cm_updated=$(echo "$content" | sed -n '/^chapter_map:/,/^[^ ]/{/updated:/{ s/.*updated: *//; p; };}')

        # Remove the top-level chapter_map block
        content=$(echo "$content" | awk '
            /^chapter_map:/ { skip=1; next }
            skip && /^  / { next }
            skip { skip=0 }
            { print }
        ')
        # Remove consecutive blank lines left behind
        content=$(echo "$content" | awk 'NR==1{print;prev=$0;next} /^$/{if(prev==""){next}} {print;prev=$0}')

        # Insert chapter_map under artifacts using awk
        content=$(echo "$content" | awk -v ce="$cm_exists" -v cp="$cm_path" -v cu="$cm_updated" '
            /^artifacts:/ { in_art=1; print; next }
            in_art && /^[^ ]/ {
                print "  chapter_map:"
                print "    exists: " ce
                print "    path: " cp
                print "    updated: " cu
                in_art=0
            }
            { print }
        ')
        modified=true
    fi

    # --- Add missing sections ---
    if ! echo "$content" | grep -q '^scene_extensions:'; then
        content+=$'\n'"scene_extensions: []"$'\n'
        modified=true
    fi
    if ! echo "$content" | grep -q '^evaluation:'; then
        content+=$'\n'"evaluation:"$'\n'"  custom_evaluators: []"$'\n'
        modified=true
    fi
    if ! echo "$content" | grep -q '^production:' && ! echo "$content" | grep -q '^# production:'; then
        content+=$'\n'"# production:"$'\n'"#   author: \"\""$'\n'"#   language: en"$'\n'"#   scene_break: ornamental"$'\n'"#   default_heading: numbered-titled"$'\n'
        modified=true
    fi
    if ! echo "$content" | grep -q '^parts:' && ! echo "$content" | grep -q '^# parts:'; then
        content+=$'\n'"# parts:"$'\n'"#   - number: 1"$'\n'"#     title: \"Part One\""$'\n'
        modified=true
    fi

    # --- Add missing artifact entries for files on disk ---
    local artifact_files
    artifact_files=(
        "characters:reference/characters.csv"
        "locations:reference/locations.csv"
        "threads:reference/threads.csv"
        "motif_taxonomy:reference/motif-taxonomy.csv"
        "scene_intent:reference/scene-intent.csv"
        "scene_log:reference/scene-log.md"
        "resolved_threads:reference/resolved-threads.md"
        "title_development:reference/title-development.md"
    )
    for entry in "${artifact_files[@]}"; do
        local aid="${entry%%:*}"
        local apath="${entry#*:}"
        if [[ -f "${project_dir}/${apath}" ]] && ! echo "$content" | grep -q "  ${aid}:"; then
            content=$(echo "$content" | awk -v aid="$aid" -v apath="$apath" '
                /^artifacts:/ { in_art=1; print; next }
                in_art && /^[^ ]/ {
                    print "  " aid ":"
                    print "    exists: true"
                    print "    path: " apath
                    print "    updated:"
                    in_art=0
                }
                { print }
            ')
            modified=true
        fi
    done

    # --- Fix exists flags using awk block-level awareness ---
    content=$(echo "$content" | awk -v proj="$project_dir" '
    /^  [a-z_]+:$/ || /^  [a-z_]+: *$/ {
        block_name = $0; block_lines[0] = $0; block_count = 1; in_block = 1; next
    }
    in_block && /^    exists:/ { block_lines[block_count++] = $0; next }
    in_block && /^    path:/ {
        block_lines[block_count++] = $0
        sub(/^    path: */, ""); gsub(/"/, ""); gsub(/ *$/, "")
        block_path = $0; next
    }
    in_block && /^    updated:/ {
        block_lines[block_count++] = $0
        cmd = "test -e \"" proj "/" block_path "\" && echo yes || echo no"
        cmd | getline disk_exists; close(cmd)
        for (i = 0; i < block_count; i++) {
            line = block_lines[i]
            if (line ~ /exists: false/ && disk_exists == "yes") sub(/exists: false/, "exists: true", line)
            else if (line ~ /exists: true/ && disk_exists == "no") sub(/exists: true/, "exists: false", line)
            print line
        }
        in_block = 0; block_count = 0; block_path = ""; next
    }
    in_block && !/^    / {
        for (i = 0; i < block_count; i++) print block_lines[i]
        in_block = 0; block_count = 0; print; next
    }
    in_block { block_lines[block_count++] = $0; next }
    { print }
    ')
    modified=true

    if $modified; then
        echo "$content" > "$yaml"
    fi
}

# ============================================================================
# Main (skip if sourced for testing)
# ============================================================================

if [[ "${_CLEANUP_SOURCE_ONLY:-}" == "true" ]]; then
    return 0 2>/dev/null || true
fi

#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-cleanup — Project structure cleanup and migration
#
# Fixes structural drift in Storyforge novel projects: updates gitignore,
# creates missing directories, migrates storyforge.yaml, adds CSV columns,
# removes junk files, deletes legacy artifacts, and reports integrity issues.
#
# Usage:
#   ./storyforge cleanup                  # Apply all fixes and commit
#   ./storyforge cleanup --dry-run        # Report what would change
#   ./storyforge cleanup --verbose        # Detailed output
# ============================================================================

# --- Allow sourcing for tests ---
if [[ "${1:-}" == "--source-only" ]]; then
    _CLEANUP_SOURCE_ONLY=true
    shift
fi

# --- Locate script directory and source libraries ---
if [[ "${_CLEANUP_SOURCE_ONLY:-}" != "true" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    LIB_DIR="${SCRIPT_DIR}/lib"

    if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
        echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
        exit 1
    fi
    source "${LIB_DIR}/common.sh"
fi

# ============================================================================
# Gitignore
# ============================================================================

GITIGNORE_REQUIRED=(
    "working/logs/"
    "working/scores/**/.batch-requests.jsonl"
    "working/evaluations/**/.status-*"
    "working/scores/**/.markers-*"
    ".DS_Store"
    "working/.autopilot"
    "working/.interactive"
)

update_gitignore() {
    local project_dir="$1"
    local gitignore="${project_dir}/.gitignore"

    if [[ ! -f "$gitignore" ]]; then
        cat > "$gitignore" << 'GIEOF'
# Storyforge — Novel Project .gitignore

# macOS
.DS_Store

GIEOF
    fi

    local content
    content=$(cat "$gitignore")
    local added=false

    for entry in "${GITIGNORE_REQUIRED[@]}"; do
        if ! grep -qF "$entry" "$gitignore"; then
            added=true
        fi
    done

    if $added; then
        local new_content="$content"
        [[ "${new_content: -1}" != $'\n' ]] && new_content="${new_content}"$'\n'

        if ! grep -qF "working/logs/" "$gitignore"; then
            new_content+=$'\n'"# Logs (debugging output, value extracted at write time)"$'\n'
            new_content+="working/logs/"$'\n'
        fi

        if ! grep -qF "working/scores/**/.batch-requests.jsonl" "$gitignore"; then
            new_content+=$'\n'"# Batch API payloads (keep only latest for debugging)"$'\n'
            new_content+="working/scores/**/.batch-requests.jsonl"$'\n'
        fi

        if ! grep -qF "working/evaluations/**/.status-*" "$gitignore"; then
            new_content+=$'\n'"# Intermediate scoring/eval state"$'\n'
            new_content+="working/evaluations/**/.status-*"$'\n'
        fi

        if ! grep -qF "working/scores/**/.markers-*" "$gitignore"; then
            new_content+="working/scores/**/.markers-*"$'\n'
        fi

        if ! grep -qF "working/.interactive" "$gitignore"; then
            if grep -qF "working/.autopilot" "$gitignore" && ! grep -qF "working/.interactive" "$gitignore"; then
                new_content=$(echo "$new_content" | sed '/working\/.autopilot/a\
working/.interactive')
            else
                new_content+=$'\n'"# Temporary flag files (cleaned up by scripts)"$'\n'
                new_content+="working/.autopilot"$'\n'
                new_content+="working/.interactive"$'\n'
            fi
        fi

        echo "$new_content" > "$gitignore"
    fi
}

# ============================================================================
# Missing directories
# ============================================================================

EXPECTED_DIRS=(
    "manuscript/press-kit"
    "working/logs"
    "working/evaluations"
    "working/plans"
    "working/recommendations"
)

create_missing_dirs() {
    local project_dir="$1"
    local created=""
    for dir in "${EXPECTED_DIRS[@]}"; do
        if [[ ! -d "${project_dir}/${dir}" ]]; then
            mkdir -p "${project_dir}/${dir}"
            touch "${project_dir}/${dir}/.gitkeep"
            created+="${dir}"$'\n'
        fi
    done
    echo -n "$created"
}

# ============================================================================
# Junk file cleanup
# ============================================================================

clean_junk_files() {
    local project_dir="$1"
    find "${project_dir}/working/evaluations" -name ".status-*" -delete 2>/dev/null || true
    find "${project_dir}/working/scores" -name ".markers-*" -delete 2>/dev/null || true
    find "${project_dir}/working/scores" -name ".batch-requests.jsonl" -not -path "*/latest/*" -delete 2>/dev/null || true
    if [[ -d "${project_dir}/working/logs" ]]; then
        find "${project_dir}/working/logs" -type f -delete 2>/dev/null || true
    fi
    for dir in enrich coaching backups scenes-setup; do
        local target="${project_dir}/working/${dir}"
        if [[ -d "$target" ]] && [[ -z "$(ls -A "$target" 2>/dev/null)" ]]; then
            rmdir "$target"
        fi
    done
}

# ============================================================================
# Legacy files and reorganization
# ============================================================================

delete_legacy_files() {
    local project_dir="$1"
    for f in "working/pipeline.yaml" "working/assemble.py"; do
        if [[ -f "${project_dir}/${f}" ]]; then
            rm "${project_dir}/${f}"
        fi
    done
}

reorganize_loose_files() {
    local project_dir="$1"
    mkdir -p "${project_dir}/working/recommendations"
    for f in "${project_dir}"/working/recommendations*.md; do
        [[ -f "$f" ]] || continue
        mv -n "$f" "${project_dir}/working/recommendations/"
    done
}

# ============================================================================
# Pipeline CSV migration
# ============================================================================

PIPELINE_EXPECTED="cycle|started|status|evaluation|scoring|plan|review|recommendations|summary"

migrate_pipeline_csv() {
    local project_dir="$1"
    local csv="${project_dir}/working/pipeline.csv"
    [[ -f "$csv" ]] || return 0
    local header
    header=$(head -1 "$csv")
    [[ "$header" == "$PIPELINE_EXPECTED" ]] && return 0

    local tmp="${csv}.tmp"
    awk -F'|' -v expected="$PIPELINE_EXPECTED" '
    BEGIN { n_exp = split(expected, exp_cols, "|") }
    NR == 1 {
        n_old = split($0, old_cols, "|")
        for (i = 1; i <= n_old; i++) old_pos[old_cols[i]] = i
        printf "%s\n", expected
        next
    }
    {
        n_old = split($0, vals, "|")
        for (i = 1; i <= n_exp; i++) {
            if (i > 1) printf "|"
            col = exp_cols[i]
            if (col in old_pos) printf "%s", vals[old_pos[col]]
        }
        printf "\n"
    }
    ' "$csv" > "$tmp"
    mv "$tmp" "$csv"
}

# ============================================================================
# Pipeline review deduplication
# ============================================================================

# Pipeline reviews named pipeline-review-YYYYMMDD-HHMMSS.md
# Same YYYYMMDD = same cycle. Keep only latest timestamp per date.
# Standalone review-YYYYMMDD.md files are always kept.
dedup_pipeline_reviews() {
    local project_dir="$1"
    local reviews_dir="${project_dir}/working/reviews"
    [[ -d "$reviews_dir" ]] || return 0

    local prev_date=""
    # Reverse sort: latest timestamp per date seen first
    for f in $(ls -r "${reviews_dir}"/pipeline-review-*.md 2>/dev/null); do
        local basename
        basename=$(basename "$f")
        local date
        date=$(echo "$basename" | sed 's/pipeline-review-\([0-9]*\)-.*/\1/')
        if [[ "$date" == "$prev_date" ]]; then
            rm "$f"
        else
            prev_date="$date"
        fi
    done
}

# ============================================================================
# storyforge.yaml migration
# ============================================================================

migrate_storyforge_yaml() {
    local project_dir="$1"
    local yaml="${project_dir}/storyforge.yaml"
    [[ -f "$yaml" ]] || return 0

    local content
    content=$(cat "$yaml")
    local modified=false

    # --- Move misplaced chapter_map to under artifacts ---
    if echo "$content" | grep -q '^chapter_map:'; then
        local cm_exists cm_path cm_updated
        cm_exists=$(echo "$content" | sed -n '/^chapter_map:/,/^[^ ]/{/exists:/{ s/.*exists: *//; p; };}')
        cm_path=$(echo "$content" | sed -n '/^chapter_map:/,/^[^ ]/{/path:/{ s/.*path: *//; p; };}')
        cm_updated=$(echo "$content" | sed -n '/^chapter_map:/,/^[^ ]/{/updated:/{ s/.*updated: *//; p; };}')

        # Remove the top-level chapter_map block
        content=$(echo "$content" | awk '
            /^chapter_map:/ { skip=1; next }
            skip && /^  / { next }
            skip { skip=0 }
            { print }
        ')
        # Remove consecutive blank lines left behind
        content=$(echo "$content" | awk 'NR==1{print;prev=$0;next} /^$/{if(prev==""){next}} {print;prev=$0}')

        # Insert chapter_map under artifacts using awk
        content=$(echo "$content" | awk -v ce="$cm_exists" -v cp="$cm_path" -v cu="$cm_updated" '
            /^artifacts:/ { in_art=1; print; next }
            in_art && /^[^ ]/ {
                print "  chapter_map:"
                print "    exists: " ce
                print "    path: " cp
                print "    updated: " cu
                in_art=0
            }
            { print }
        ')
        modified=true
    fi

    # --- Add missing sections ---
    if ! echo "$content" | grep -q '^scene_extensions:'; then
        content+=$'\n'"scene_extensions: []"$'\n'
        modified=true
    fi
    if ! echo "$content" | grep -q '^evaluation:'; then
        content+=$'\n'"evaluation:"$'\n'"  custom_evaluators: []"$'\n'
        modified=true
    fi
    if ! echo "$content" | grep -q '^production:' && ! echo "$content" | grep -q '^# production:'; then
        content+=$'\n'"# production:"$'\n'"#   author: \"\""$'\n'"#   language: en"$'\n'"#   scene_break: ornamental"$'\n'"#   default_heading: numbered-titled"$'\n'
        modified=true
    fi
    if ! echo "$content" | grep -q '^parts:' && ! echo "$content" | grep -q '^# parts:'; then
        content+=$'\n'"# parts:"$'\n'"#   - number: 1"$'\n'"#     title: \"Part One\""$'\n'
        modified=true
    fi

    # --- Add missing artifact entries for files on disk ---
    local artifact_files
    artifact_files=(
        "characters:reference/characters.csv"
        "locations:reference/locations.csv"
        "threads:reference/threads.csv"
        "motif_taxonomy:reference/motif-taxonomy.csv"
        "scene_intent:reference/scene-intent.csv"
        "scene_log:reference/scene-log.md"
        "resolved_threads:reference/resolved-threads.md"
        "title_development:reference/title-development.md"
    )
    for entry in "${artifact_files[@]}"; do
        local aid="${entry%%:*}"
        local apath="${entry#*:}"
        if [[ -f "${project_dir}/${apath}" ]] && ! echo "$content" | grep -q "  ${aid}:"; then
            content=$(echo "$content" | awk -v aid="$aid" -v apath="$apath" '
                /^artifacts:/ { in_art=1; print; next }
                in_art && /^[^ ]/ {
                    print "  " aid ":"
                    print "    exists: true"
                    print "    path: " apath
                    print "    updated:"
                    in_art=0
                }
                { print }
            ')
            modified=true
        fi
    done

    # --- Fix exists flags using awk block-level awareness ---
    content=$(echo "$content" | awk -v proj="$project_dir" '
    /^  [a-z_]+:$/ || /^  [a-z_]+: *$/ {
        block_name = $0; block_lines[0] = $0; block_count = 1; in_block = 1; next
    }
    in_block && /^    exists:/ { block_lines[block_count++] = $0; next }
    in_block && /^    path:/ {
        block_lines[block_count++] = $0
        sub(/^    path: */, ""); gsub(/"/, ""); gsub(/ *$/, "")
        block_path = $0; next
    }
    in_block && /^    updated:/ {
        block_lines[block_count++] = $0
        cmd = "test -e \"" proj "/" block_path "\" && echo yes || echo no"
        cmd | getline disk_exists; close(cmd)
        for (i = 0; i < block_count; i++) {
            line = block_lines[i]
            if (line ~ /exists: false/ && disk_exists == "yes") sub(/exists: false/, "exists: true", line)
            else if (line ~ /exists: true/ && disk_exists == "no") sub(/exists: true/, "exists: false", line)
            print line
        }
        in_block = 0; block_count = 0; block_path = ""; next
    }
    in_block && !/^    / {
        for (i = 0; i < block_count; i++) print block_lines[i]
        in_block = 0; block_count = 0; print; next
    }
    in_block { block_lines[block_count++] = $0; next }
    { print }
    ')
    modified=true

    if $modified; then
        echo "$content" > "$yaml"
    fi
}

# ============================================================================
# CSV Integrity Report
# ============================================================================

report_csv_integrity() {
    local project_dir="$1"
    local meta_csv="${project_dir}/reference/scene-metadata.csv"
    local intent_csv="${project_dir}/reference/scene-intent.csv"
    local chapter_csv="${project_dir}/reference/chapter-map.csv"
    local chars_csv="${project_dir}/reference/characters.csv"
    local scenes_dir="${project_dir}/scenes"

    # Scene files vs metadata
    if [[ -f "$meta_csv" ]] && [[ -d "$scenes_dir" ]]; then
        local meta_ids file_ids
        meta_ids=$(tail -n +2 "$meta_csv" | cut -d'|' -f1 | sort)
        file_ids=$(ls "${scenes_dir}"/*.md 2>/dev/null | xargs -I{} basename {} .md | sort)
        comm -23 <(echo "$file_ids") <(echo "$meta_ids") | while IFS= read -r id; do
            [[ -n "$id" ]] && echo "ORPHAN_FILE:${id}"
        done
        comm -13 <(echo "$file_ids") <(echo "$meta_ids") | while IFS= read -r id; do
            [[ -n "$id" ]] && echo "ORPHAN_META:${id}"
        done
    fi

    # Metadata vs intent
    if [[ -f "$meta_csv" ]] && [[ -f "$intent_csv" ]]; then
        local meta_ids intent_ids
        meta_ids=$(tail -n +2 "$meta_csv" | cut -d'|' -f1 | sort)
        intent_ids=$(tail -n +2 "$intent_csv" | cut -d'|' -f1 | sort)
        comm -23 <(echo "$meta_ids") <(echo "$intent_ids") | while IFS= read -r id; do
            [[ -n "$id" ]] && echo "MISSING_INTENT:${id}"
        done
        comm -13 <(echo "$meta_ids") <(echo "$intent_ids") | while IFS= read -r id; do
            [[ -n "$id" ]] && echo "EXTRA_INTENT:${id}"
        done
    fi

    # Chapter map references
    if [[ -f "$chapter_csv" ]] && [[ -f "$meta_csv" ]]; then
        local meta_ids
        meta_ids=$(tail -n +2 "$meta_csv" | cut -d'|' -f1 | sort)
        tail -n +2 "$chapter_csv" | cut -d'|' -f5 | tr ';' '\n' | sed 's/^ *//;s/ *$//' | grep -v '^$' | sort -u | while IFS= read -r id; do
            if ! echo "$meta_ids" | grep -qx "$id"; then
                echo "BAD_CHAPTER_REF:${id}"
            fi
        done
    fi

    # Sequence gaps or non-integer seq values
    if [[ -f "$meta_csv" ]]; then
        local needs_renumber=false
        local prev=0
        while IFS= read -r seq; do
            [[ -z "$seq" ]] && continue
            # Non-integer seq (e.g., 20.5) means renumber is needed
            if [[ "$seq" == *.* ]]; then
                needs_renumber=true
            fi
            # Gap detection (integer comparison, skip non-integers)
            if [[ "$seq" =~ ^[0-9]+$ ]] && (( seq > prev + 1 )); then
                needs_renumber=true
            fi
            if [[ "$seq" =~ ^[0-9]+$ ]]; then
                prev=$seq
            fi
        done < <(tail -n +2 "$meta_csv" | cut -d'|' -f2 | sort -n)
        if [[ "$needs_renumber" == true ]]; then
            echo "SEQ_NEEDS_RENUMBER:gaps or non-integer seq values found"
        fi
    fi

    # Unknown characters
    if [[ -f "$intent_csv" ]] && [[ -f "$chars_csv" ]]; then
        local known used
        known=$(tail -n +2 "$chars_csv" | cut -d'|' -f2,3 | tr '|' ';' | tr ';' '\n' | sed 's/^ *//;s/ *$//' | grep -v '^$' | sort -u)
        used=$(tail -n +2 "$intent_csv" | cut -d'|' -f4 | tr ';' '\n' | sed 's/^ *//;s/ *$//' | grep -v '^$' | sort -u)
        comm -23 <(echo "$used") <(echo "$known") | while IFS= read -r name; do
            [[ -n "$name" ]] && echo "UNKNOWN_CHARACTER:${name}"
        done
    fi
}

# ============================================================================
# Unexpected Files Report
# ============================================================================

EXPECTED_TOP_DIRS="scenes reference working manuscript storyforge .git"
EXPECTED_TOP_FILES="storyforge.yaml CLAUDE.md .gitignore .DS_Store storyforge"
EXPECTED_WORKING_DIRS="logs evaluations plans scores costs reviews recommendations coaching enrich timeline backups scenes-setup"
EXPECTED_WORKING_FILES="pipeline.csv craft-weights.csv overrides.csv exemplars.csv dashboard.html"

report_unexpected_files() {
    local project_dir="$1"

    for d in "${project_dir}"/*/; do
        [[ -d "$d" ]] || continue
        local name
        name=$(basename "$d")
        if ! echo " $EXPECTED_TOP_DIRS " | grep -q " $name "; then
            echo "UNEXPECTED_DIR:${name}"
        fi
    done

    for f in "${project_dir}"/*; do
        [[ -f "$f" ]] || continue
        local name
        name=$(basename "$f")
        if ! echo " $EXPECTED_TOP_FILES " | grep -q " $name "; then
            echo "UNEXPECTED_FILE:${name}"
        fi
    done

    if [[ -d "${project_dir}/working" ]]; then
        for d in "${project_dir}"/working/*/; do
            [[ -d "$d" ]] || continue
            local name
            name=$(basename "$d")
            if ! echo " $EXPECTED_WORKING_DIRS " | grep -q " $name "; then
                echo "UNEXPECTED_DIR:working/${name}"
            fi
        done
        for f in "${project_dir}"/working/*; do
            [[ -f "$f" ]] || continue
            local name
            name=$(basename "$f")
            if ! echo " $EXPECTED_WORKING_FILES " | grep -q " $name "; then
                echo "UNEXPECTED_FILE:working/${name}"
            fi
        done
    fi
}

# ============================================================================
# Main (skip if sourced for testing)
# ============================================================================

if [[ "${_CLEANUP_SOURCE_ONLY:-}" == "true" ]]; then
    return 0 2>/dev/null || true
fi

# ============================================================================
# Argument Parsing
# ============================================================================

DRY_RUN=false
VERBOSE=false

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Clean up and migrate a Storyforge novel project.

Options:
  --dry-run     Report what would change without modifying anything
  --verbose     Detailed output for each step
  -h, --help    Show this help
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage ;;
        --dry-run) DRY_RUN=true; shift ;;
        --verbose) VERBOSE=true; shift ;;
        *) echo "ERROR: Unknown option '$1'" >&2; exit 1 ;;
    esac
done

# ============================================================================
# Main Execution
# ============================================================================

detect_project_root
log "Project root: ${PROJECT_DIR}"

vlog() { $VERBOSE && log "$1" || true; }

if $DRY_RUN; then
    log "=== DRY RUN — no changes will be made ==="
fi

# Step 1: Gitignore
log "Checking .gitignore..."
if $DRY_RUN; then
    DRY_TMP="${TMPDIR}/cleanup-dry-$$"
    mkdir -p "$DRY_TMP"
    cp "${PROJECT_DIR}/.gitignore" "$DRY_TMP/.gitignore" 2>/dev/null || touch "$DRY_TMP/.gitignore"
    update_gitignore "$DRY_TMP"
    if ! diff -q "${PROJECT_DIR}/.gitignore" "$DRY_TMP/.gitignore" > /dev/null 2>&1; then
        log "  Would update .gitignore with missing entries"
    fi
    rm -rf "$DRY_TMP"
else
    update_gitignore "$PROJECT_DIR"
    if command -v git > /dev/null 2>&1 && [[ -d "${PROJECT_DIR}/.git" ]]; then
        ignored_tracked=$(cd "$PROJECT_DIR" && git ls-files -i --exclude-standard 2>/dev/null || true)
        if [[ -n "$ignored_tracked" ]]; then
            log "  Untracking $(echo "$ignored_tracked" | wc -l | tr -d ' ') newly-gitignored files"
            cd "$PROJECT_DIR" && echo "$ignored_tracked" | xargs git rm --cached -q 2>/dev/null || true
        fi
    fi
fi

# Step 2: Missing directories
log "Checking directories..."
if $DRY_RUN; then
    for dir in "${EXPECTED_DIRS[@]}"; do
        [[ ! -d "${PROJECT_DIR}/${dir}" ]] && log "  Would create ${dir}/"
    done
else
    CREATED=$(create_missing_dirs "$PROJECT_DIR")
    [[ -n "$CREATED" ]] && echo "$CREATED" | while IFS= read -r d; do
        [[ -n "$d" ]] && vlog "  Created ${d}/"
    done
fi

# Step 3: storyforge.yaml migration
log "Checking storyforge.yaml..."
if $DRY_RUN; then
    DRY_TMP="${TMPDIR}/cleanup-dry-yaml-$$"
    mkdir -p "$DRY_TMP/reference"
    cp "${PROJECT_DIR}/storyforge.yaml" "$DRY_TMP/storyforge.yaml" 2>/dev/null
    cp -R "${PROJECT_DIR}/reference/" "$DRY_TMP/reference/" 2>/dev/null || true
    migrate_storyforge_yaml "$DRY_TMP"
    if ! diff -q "${PROJECT_DIR}/storyforge.yaml" "$DRY_TMP/storyforge.yaml" > /dev/null 2>&1; then
        log "  Would migrate storyforge.yaml (missing sections, artifact flags)"
    fi
    rm -rf "$DRY_TMP"
else
    migrate_storyforge_yaml "$PROJECT_DIR"
fi

# Step 4: Pipeline CSV
log "Checking pipeline.csv..."
if $DRY_RUN; then
    HEADER=$(head -1 "${PROJECT_DIR}/working/pipeline.csv" 2>/dev/null || echo "")
    [[ "$HEADER" != "$PIPELINE_EXPECTED" ]] && log "  Would add missing columns to pipeline.csv"
else
    migrate_pipeline_csv "$PROJECT_DIR"
fi

# Step 5: Junk files
log "Cleaning junk files..."
if $DRY_RUN; then
    COUNT=$(find "${PROJECT_DIR}/working/evaluations" -name ".status-*" 2>/dev/null | wc -l | tr -d ' ')
    (( COUNT > 0 )) && log "  Would remove $COUNT .status-* files"
    COUNT=$(find "${PROJECT_DIR}/working/scores" -name ".markers-*" 2>/dev/null | wc -l | tr -d ' ')
    (( COUNT > 0 )) && log "  Would remove $COUNT .markers-* files"
    COUNT=$(find "${PROJECT_DIR}/working/scores" -name ".batch-requests.jsonl" -not -path "*/latest/*" 2>/dev/null | wc -l | tr -d ' ')
    (( COUNT > 0 )) && log "  Would remove $COUNT .batch-requests.jsonl files"
    COUNT=$(find "${PROJECT_DIR}/working/logs" -type f 2>/dev/null | wc -l | tr -d ' ')
    (( COUNT > 0 )) && log "  Would remove $COUNT log files"
else
    clean_junk_files "$PROJECT_DIR"
fi

# Step 6: Legacy files
log "Checking legacy files..."
if $DRY_RUN; then
    for f in "working/pipeline.yaml" "working/assemble.py"; do
        [[ -f "${PROJECT_DIR}/${f}" ]] && log "  Would delete ${f}"
    done
else
    delete_legacy_files "$PROJECT_DIR"
fi

# Step 7: Reorganize loose files
log "Reorganizing loose files..."
if $DRY_RUN; then
    COUNT=$(ls "${PROJECT_DIR}"/working/recommendations*.md 2>/dev/null | wc -l | tr -d ' ')
    (( COUNT > 0 )) && log "  Would move $COUNT recommendation files to working/recommendations/"
else
    reorganize_loose_files "$PROJECT_DIR"
fi

# Step 8: Pipeline review dedup
log "Deduplicating pipeline reviews..."
if $DRY_RUN; then
    log "  Would deduplicate pipeline reviews (keep latest per day)"
else
    dedup_pipeline_reviews "$PROJECT_DIR"
fi

# Step 9: CSV integrity report
log ""
log "=== CSV Integrity Report ==="
report_csv_integrity "$PROJECT_DIR"

# Step 10: Unexpected files report
log ""
log "=== Unexpected Files Report ==="
report_unexpected_files "$PROJECT_DIR"

# Step 11: Commit (unless dry-run)
if ! $DRY_RUN; then
    if command -v git > /dev/null 2>&1 && [[ -d "${PROJECT_DIR}/.git" ]]; then
        cd "$PROJECT_DIR"
        if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
            log ""
            log "Committing changes..."
            git add -A
            git commit -m "Cleanup: project structure and working files"
            git push 2>/dev/null || log "WARNING: git push failed (no remote or auth issue)"
        else
            log "No changes to commit."
        fi
    fi
fi

log ""
log "Cleanup complete."

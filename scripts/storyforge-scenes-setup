#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-scenes-setup — Prepare manuscript into formatted scene files
#
# Handles three input scenarios:
#   --rename           Rename existing scene files to proper slugs
#   --split-chapters   Split chapter files into individual scenes
#   --split-manuscript Split a single manuscript file into scenes
#
# Usage:
#   ./storyforge-scenes-setup --rename
#   ./storyforge-scenes-setup --split-chapters --source chapters/
#   ./storyforge-scenes-setup --split-manuscript --source manuscript.md
#   ./storyforge-scenes-setup --split-chapters --dry-run
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"
PYTHON_LIB="${SCRIPT_DIR}/lib/python"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# --- Default options ---
MODE=""
DRY_RUN=false
AUTO_YES=false
SOURCE_PATH=""
PARALLEL=${STORYFORGE_SCENES_PARALLEL:-6}
SETUP_MODE="${STORYFORGE_SETUP_MODE:-batch}"

# --- Argument parsing ---
usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Prepare a manuscript into properly formatted scene files.

Modes (exactly one required):
  --rename            Rename existing scene files to slugs (Mode 1)
  --split-chapters    Split chapter files into scenes (Mode 2)
  --split-manuscript  Split a single manuscript file (Mode 3)

Options:
  --source PATH       Source directory (for chapters) or file (for manuscript)
  --direct            Use direct API calls instead of batch (default: batch)
  --dry-run           Show what would happen without making changes
  --yes               Skip interactive confirmation of splits
  --parallel N        Workers for Claude calls (default: 6)
  -h, --help          Show this help
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --rename)
            MODE="rename"
            shift
            ;;
        --split-chapters)
            MODE="split-chapters"
            shift
            ;;
        --split-manuscript)
            MODE="split-manuscript"
            shift
            ;;
        --source)
            SOURCE_PATH="${2:?ERROR: --source requires a path}"
            shift 2
            ;;
        --direct)
            SETUP_MODE="direct"
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --yes)
            AUTO_YES=true
            shift
            ;;
        --parallel)
            PARALLEL="${2:?ERROR: --parallel requires a number}"
            shift 2
            ;;
        -*)
            echo "ERROR: Unknown option: $1" >&2
            usage
            ;;
        *)
            echo "ERROR: Unexpected argument: $1" >&2
            usage
            ;;
    esac
done

if [[ -z "$MODE" ]]; then
    echo "ERROR: Must specify one of --rename, --split-chapters, or --split-manuscript" >&2
    usage
fi

# --- Detect project root ---
detect_project_root
log "Project root: ${PROJECT_DIR}"

# --- API key check (required for both batch and direct modes) ---
if [[ "$DRY_RUN" != true && -z "${ANTHROPIC_API_KEY:-}" ]]; then
    log "ERROR: ANTHROPIC_API_KEY is required. Set it with: export ANTHROPIC_API_KEY=your-key"
    exit 1
fi

# --- Project info ---
PROJECT_TITLE=$(read_yaml_field "project.title" 2>/dev/null || read_yaml_field "title" 2>/dev/null || echo "Unknown")

# --- Resolve paths ---
SCENES_DIR="${PROJECT_DIR}/scenes"
METADATA_CSV="${PROJECT_DIR}/reference/scene-metadata.csv"
INTENT_CSV="${PROJECT_DIR}/reference/scene-intent.csv"
CHAPTER_MAP_CSV="${PROJECT_DIR}/reference/chapter-map.csv"
LOG_DIR="${PROJECT_DIR}/working/logs"
WORK_DIR="${PROJECT_DIR}/working/scenes-setup"

mkdir -p "$LOG_DIR"
mkdir -p "$WORK_DIR"
mkdir -p "$SCENES_DIR"
mkdir -p "${PROJECT_DIR}/reference"

# Move CSVs from old location if needed
if [[ -f "${PROJECT_DIR}/scenes/metadata.csv" ]] && [[ ! -f "${PROJECT_DIR}/reference/scene-metadata.csv" ]]; then
    mv "${PROJECT_DIR}/scenes/metadata.csv" "${PROJECT_DIR}/reference/scene-metadata.csv"
    log "Moved scenes/metadata.csv → reference/scene-metadata.csv"
fi
if [[ -f "${PROJECT_DIR}/scenes/intent.csv" ]] && [[ ! -f "${PROJECT_DIR}/reference/scene-intent.csv" ]]; then
    mv "${PROJECT_DIR}/scenes/intent.csv" "${PROJECT_DIR}/reference/scene-intent.csv"
    log "Moved scenes/intent.csv → reference/scene-intent.csv"
fi

# --- Select model (analytical task -> Sonnet) ---
MODEL=$(select_model "evaluation")

# ============================================================================
# Shared utility: slugify
# ============================================================================

slugify() {
    local input="$1"
    local slug
    # Lowercase
    slug=$(echo "$input" | tr '[:upper:]' '[:lower:]')
    # Replace em-dashes, en-dashes, and ellipses with hyphens/nothing
    slug=$(echo "$slug" | sed 's/—/-/g; s/–/-/g; s/\.\.\.//g')
    # Remove special chars: quotes, colons, parentheses, commas, periods, semicolons, exclamation, question
    slug=$(echo "$slug" | sed "s/[\"'\`():;,.!?]//g")
    # Replace spaces, underscores, and slashes with hyphens
    slug=$(echo "$slug" | sed 's/[[:space:]_\/]/-/g')
    # Remove any remaining non-alphanumeric chars except hyphens
    slug=$(echo "$slug" | sed 's/[^a-z0-9-]//g')
    # Collapse multiple hyphens
    slug=$(echo "$slug" | sed 's/-\{2,\}/-/g')
    # Strip leading/trailing hyphens
    slug=$(echo "$slug" | sed 's/^-//; s/-$//')
    # Strip leading "the-"
    slug=$(echo "$slug" | sed 's/^the-//')
    # Truncate to 50 chars
    slug=$(echo "$slug" | cut -c1-50)
    # Strip trailing hyphen after truncation
    slug=$(echo "$slug" | sed 's/-$//')
    echo "$slug"
}

# ============================================================================
# Shared utility: resolve slug collisions
# ============================================================================

# Track used slugs to detect collisions (uses a temp file because
# unique_slug is called via $() which runs in a subshell — variables
# don't persist across subshell boundaries)
USED_SLUGS_FILE=$(mktemp "${TMPDIR:-/tmp}/sf-slugs.XXXXXX")
trap 'rm -f "$USED_SLUGS_FILE"' EXIT

# Returns a unique slug, appending -2, -3, etc. if needed
unique_slug() {
    local base_slug="$1"
    local candidate="$base_slug"
    local counter=2

    while grep -q "^${candidate}$" "$USED_SLUGS_FILE" 2>/dev/null; do
        candidate="${base_slug}-${counter}"
        counter=$((counter + 1))
    done

    echo "$candidate" >> "$USED_SLUGS_FILE"
    echo "$candidate"
}

# ============================================================================
# Shared utility: derive title from file content
# ============================================================================

title_from_file() {
    local file="$1"
    local title=""
    # Try first markdown heading
    title=$(grep -m1 '^#' "$file" 2>/dev/null | sed 's/^#\+[[:space:]]*//' || true)
    # Fall back to first non-empty line
    if [[ -z "$title" ]]; then
        title=$(grep -m1 '[^[:space:]]' "$file" 2>/dev/null | head -c 80 || true)
    fi
    [[ -z "$title" ]] && title=$(basename "$file" .md)
    echo "$title"
}

# ============================================================================
# Shared utility: ensure CSV files exist with proper headers
# ============================================================================

ensure_metadata_csv() {
    if [[ ! -f "$METADATA_CSV" ]]; then
        echo "id|seq|title|pov|location|part|type|timeline_day|time_of_day|status|word_count|target_words" > "$METADATA_CSV"
        log "Created reference/scene-metadata.csv"
    fi
}

ensure_intent_csv() {
    if [[ ! -f "$INTENT_CSV" ]]; then
        echo "id|function|emotional_arc|characters|threads|motifs|notes" > "$INTENT_CSV"
        log "Created reference/scene-intent.csv"
    fi
}

# ============================================================================
# Shared utility: count words in text
# ============================================================================

count_words() {
    echo "$1" | wc -w | tr -d ' '
}

# ============================================================================
# Shared utility: get lines range from text
# ============================================================================

get_lines() {
    local text="$1"
    local start="$2"
    local end="$3"
    echo "$text" | sed -n "${start},${end}p"
}

# ============================================================================
# Mode 1: Rename existing scenes
# ============================================================================

do_rename() {
    log "============================================"
    log "Mode: Rename existing scene files to slugs"
    log "============================================"

    ensure_metadata_csv
    ensure_intent_csv

    # Collect scene files
    SCENE_FILES=()
    for f in "${SCENES_DIR}"/*.md; do
        [[ -f "$f" ]] || continue
        SCENE_FILES+=("$f")
    done

    if [[ ${#SCENE_FILES[@]} -eq 0 ]]; then
        log "ERROR: No scene files found in ${SCENES_DIR}"
        exit 1
    fi

    log "Found ${#SCENE_FILES[@]} scene files"

    # Build rename plan
    RENAME_COUNT=0
    RENAME_OLD=()
    RENAME_NEW=()
    RENAME_OLD_IDS=()
    RENAME_NEW_IDS=()

    for scene_file in "${SCENE_FILES[@]}"; do
        old_id=$(basename "$scene_file" .md)

        # Try to get title from metadata.csv first
        title=$(get_csv_field "$METADATA_CSV" "$old_id" "title" 2>/dev/null || true)
        # Fall back to file content
        if [[ -z "$title" ]]; then
            title=$(title_from_file "$scene_file")
        fi

        new_slug=$(slugify "$title")
        if [[ -z "$new_slug" ]]; then
            new_slug=$(slugify "$old_id")
        fi
        new_slug=$(unique_slug "$new_slug")

        # Only rename if different
        if [[ "$old_id" != "$new_slug" ]]; then
            RENAME_OLD+=("$scene_file")
            RENAME_NEW+=("${SCENES_DIR}/${new_slug}.md")
            RENAME_OLD_IDS+=("$old_id")
            RENAME_NEW_IDS+=("$new_slug")
            RENAME_COUNT=$((RENAME_COUNT + 1))
        else
            # Still track the slug as used
            true
        fi
    done

    if [[ $RENAME_COUNT -eq 0 ]]; then
        log "No files need renaming. All files already have slug names."
        exit 0
    fi

    # Show plan
    log ""
    log "Rename plan:"
    for (( i=0; i<RENAME_COUNT; i++ )); do
        log "  ${RENAME_OLD_IDS[$i]}.md -> ${RENAME_NEW_IDS[$i]}.md"
    done
    log ""

    if [[ "$DRY_RUN" == true ]]; then
        log "DRY RUN — no changes made"
        exit 0
    fi

    # Execute renames
    (
        cd "$PROJECT_DIR"
        for (( i=0; i<RENAME_COUNT; i++ )); do
            old_rel="scenes/${RENAME_OLD_IDS[$i]}.md"
            new_rel="scenes/${RENAME_NEW_IDS[$i]}.md"

            if git ls-files --error-unmatch "$old_rel" >/dev/null 2>&1; then
                git mv "$old_rel" "$new_rel"
            else
                mv "${RENAME_OLD[$i]}" "${RENAME_NEW[$i]}"
            fi
            log "  Renamed ${RENAME_OLD_IDS[$i]} -> ${RENAME_NEW_IDS[$i]}"
        done
    )

    # Update metadata.csv — replace old IDs with new IDs
    for (( i=0; i<RENAME_COUNT; i++ )); do
        old_id="${RENAME_OLD_IDS[$i]}"
        new_id="${RENAME_NEW_IDS[$i]}"
        # Replace the ID in the first column
        sed -i '' "s/^${old_id}|/${new_id}|/" "$METADATA_CSV"
    done

    # Update intent.csv
    for (( i=0; i<RENAME_COUNT; i++ )); do
        old_id="${RENAME_OLD_IDS[$i]}"
        new_id="${RENAME_NEW_IDS[$i]}"
        sed -i '' "s/^${old_id}|/${new_id}|/" "$INTENT_CSV"
    done

    # Update chapter-map.csv if it exists
    if [[ -f "$CHAPTER_MAP_CSV" ]]; then
        for (( i=0; i<RENAME_COUNT; i++ )); do
            old_id="${RENAME_OLD_IDS[$i]}"
            new_id="${RENAME_NEW_IDS[$i]}"
            # Scene IDs appear in the scenes column, separated by ;
            sed -i '' "s/${old_id}/${new_id}/g" "$CHAPTER_MAP_CSV"
        done
        log "Updated reference/chapter-map.csv"
    fi

    log ""
    log "Renamed ${RENAME_COUNT} scene files"
}

# ============================================================================
# Mode 2: Split chapters into scenes
# ============================================================================

# Detect scene break markers in chapter text
# Returns line numbers where breaks occur (excluding the first line)
detect_explicit_breaks() {
    local text="$1"
    local breaks=""
    local line_num=0
    local blank_count=0
    local prev_blank=false

    while IFS= read -r line; do
        line_num=$((line_num + 1))

        # Check for explicit markers
        stripped=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        case "$stripped" in
            "***"|"---"|"# # #"|"* * *")
                if [[ $line_num -gt 1 ]]; then
                    breaks="${breaks} ${line_num}"
                fi
                blank_count=0
                prev_blank=false
                continue
                ;;
        esac

        # Check for 3+ blank lines
        if [[ -z "$stripped" ]]; then
            blank_count=$((blank_count + 1))
            if [[ $blank_count -ge 3 ]] && [[ "$prev_blank" == false ]]; then
                breaks="${breaks} ${line_num}"
                prev_blank=true
            fi
        else
            blank_count=0
            prev_blank=false
        fi
    done <<< "$text"

    echo "$breaks" | sed 's/^[[:space:]]*//'
}

# Find the first non-empty, non-marker line after a given line number
find_content_start() {
    local text="$1"
    local after_line="$2"
    local line_num=0

    while IFS= read -r line; do
        line_num=$((line_num + 1))
        (( line_num <= after_line )) && continue
        stripped=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        case "$stripped" in
            ""|"***"|"---"|"# # #"|"* * *") continue ;;
        esac
        echo "$line_num"
        return
    done <<< "$text"

    echo "$after_line"
}

# Build the scene detection prompt for a chapter (delegates to Python)
build_scene_prompt() {
    local chapter_text="$1"
    local tmp_chapter="${WORK_DIR}/.tmp-chapter-prompt.$$"
    echo "$chapter_text" > "$tmp_chapter"
    PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scenes build-boundary-prompt "$tmp_chapter"
    rm -f "$tmp_chapter"
}

# Use direct API to detect scene boundaries (single chapter)
claude_detect_scenes() {
    local chapter_text="$1"
    local chapter_id="$2"
    local log_file="${LOG_DIR}/scenes-setup-detect-${chapter_id}.json"

    prompt=$(build_scene_prompt "$chapter_text")

    _SF_INVOCATION_START=$(date +%s)
    export _SF_INVOCATION_START

    begin_healing_zone "scene boundary detection"

    invoke_anthropic_api "$prompt" "$MODEL" "$log_file" 4096 || true

    end_healing_zone

    # Parse response
    response=$(extract_api_response "$log_file" 2>/dev/null || true)

    # Log usage
    log_api_usage "$log_file" "scene-detect" "$chapter_id" "$MODEL"

    echo "$response"
}

# Build a JSONL batch file with all chapter prompts
# Arguments: array of chapter files (via CLAUDE_CHAPTERS global)
# Writes batch file to WORK_DIR/.batch-input.jsonl
build_scene_batch() {
    local batch_file="${WORK_DIR}/.batch-input.jsonl"
    rm -f "$batch_file"

    for cf in "${CLAUDE_CHAPTERS[@]}"; do
        ch_name=$(basename "$cf" .md)
        chapter_text=$(cat "$cf")
        prompt=$(build_scene_prompt "$chapter_text")

        # Build JSON request line
        json_prompt=$(jq -Rs '.' <<< "$prompt")
        cat <<BATCHEOF >> "$batch_file"
{"custom_id": "${ch_name}", "params": {"model": "${MODEL}", "max_tokens": 4096, "messages": [{"role": "user", "content": ${json_prompt}}]}}
BATCHEOF
    done

    echo "$batch_file"
}

# Parse SCENE: lines into arrays
# Sets SPLIT_LINES, SPLIT_TITLES, SPLIT_REASONS, SPLIT_COUNT
parse_scene_lines() {
    local response="$1"
    SPLIT_LINES=()
    SPLIT_TITLES=()
    SPLIT_REASONS=()
    SPLIT_COUNT=0

    while IFS= read -r line; do
        if echo "$line" | grep -q "^SCENE:"; then
            raw=$(echo "$line" | sed 's/^SCENE:[[:space:]]*//')
            line_num=$(echo "$raw" | cut -d'|' -f1 | sed 's/[[:space:]]//g')
            title=$(echo "$raw" | cut -d'|' -f2 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            reason=$(echo "$raw" | cut -d'|' -f3- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

            if [[ "$line_num" =~ ^[0-9]+$ ]]; then
                SPLIT_LINES+=("$line_num")
                SPLIT_TITLES+=("$title")
                SPLIT_REASONS+=("$reason")
                SPLIT_COUNT=$((SPLIT_COUNT + 1))
            fi
        fi
    done <<< "$response"
}

# Build splits from explicit break markers
build_splits_from_markers() {
    local chapter_text="$1"
    local break_lines="$2"
    SPLIT_LINES=(1)
    SPLIT_TITLES=()
    SPLIT_REASONS=()
    SPLIT_COUNT=1

    # Get title for first segment
    first_title=$(echo "$chapter_text" | head -1 | sed 's/^[[:space:]]*//')
    [[ -z "$first_title" ]] && first_title="Opening"
    SPLIT_TITLES+=("$first_title")
    SPLIT_REASONS+=("Chapter opening")

    for brk in $break_lines; do
        # Find the first content line after the break
        content_start=$(find_content_start "$chapter_text" "$brk")
        SPLIT_LINES+=("$content_start")
        # Derive title from first content line
        seg_title=$(echo "$chapter_text" | sed -n "${content_start}p" | sed 's/^[[:space:]]*//' | head -c 60)
        [[ -z "$seg_title" ]] && seg_title="Scene $((SPLIT_COUNT + 1))"
        SPLIT_TITLES+=("$seg_title")
        SPLIT_REASONS+=("Explicit scene break marker")
        SPLIT_COUNT=$((SPLIT_COUNT + 1))
    done
}

# Display proposed splits and get confirmation
confirm_splits() {
    local chapter_name="$1"
    local chapter_text="$2"
    local total_lines
    total_lines=$(echo "$chapter_text" | wc -l | tr -d ' ')
    local total_words
    total_words=$(count_words "$chapter_text")

    echo ""
    echo "${chapter_name} (${total_words} words)"
    echo "  Proposed splits:"

    for (( s=0; s<SPLIT_COUNT; s++ )); do
        start_line=${SPLIT_LINES[$s]}
        if (( s + 1 < SPLIT_COUNT )); then
            end_line=$(( ${SPLIT_LINES[$((s+1))]} - 1 ))
        else
            end_line=$total_lines
        fi
        seg_text=$(get_lines "$chapter_text" "$start_line" "$end_line")
        seg_words=$(count_words "$seg_text")
        title="${SPLIT_TITLES[$s]}"
        reason="${SPLIT_REASONS[$s]}"
        echo "    Scene $((s+1)): \"${title}\" (lines ${start_line}-${end_line}, ~${seg_words} words) -- ${reason}"
    done

    if [[ "$AUTO_YES" == true ]]; then
        echo "  Auto-accepting (--yes)"
        return 0
    fi

    printf "  Accept? [Y/n/edit] "
    read -r answer </dev/tty 2>/dev/null || answer="y"
    case "$answer" in
        n|N)
            return 1
            ;;
        edit|e|E)
            echo "  Enter new line numbers (space-separated, first scene always starts at 1):"
            printf "  Lines: "
            read -r new_lines </dev/tty 2>/dev/null || new_lines=""
            if [[ -n "$new_lines" ]]; then
                SPLIT_LINES=()
                SPLIT_TITLES=()
                SPLIT_REASONS=()
                SPLIT_COUNT=0
                for ln in $new_lines; do
                    if [[ "$ln" =~ ^[0-9]+$ ]]; then
                        SPLIT_LINES+=("$ln")
                        seg_title=$(echo "$chapter_text" | sed -n "${ln}p" | sed 's/^[[:space:]]*//' | head -c 60)
                        [[ -z "$seg_title" ]] && seg_title="Scene $((SPLIT_COUNT + 1))"
                        SPLIT_TITLES+=("$seg_title")
                        SPLIT_REASONS+=("Manual edit")
                        SPLIT_COUNT=$((SPLIT_COUNT + 1))
                    fi
                done
            fi
            return 0
            ;;
        *)
            return 0
            ;;
    esac
}

# Write scene files from splits
write_scene_files() {
    local chapter_text="$1"
    local chapter_num="$2"
    local part_num="$3"
    local seq_start="$4"
    local total_lines
    total_lines=$(echo "$chapter_text" | wc -l | tr -d ' ')

    ensure_metadata_csv
    ensure_intent_csv

    WRITTEN_SCENE_IDS=()

    for (( s=0; s<SPLIT_COUNT; s++ )); do
        start_line=${SPLIT_LINES[$s]}
        if (( s + 1 < SPLIT_COUNT )); then
            end_line=$(( ${SPLIT_LINES[$((s+1))]} - 1 ))
        else
            end_line=$total_lines
        fi

        # Extract scene text, skip break markers
        scene_text=$(echo "$chapter_text" | sed -n "${start_line},${end_line}p" | grep -vE '^\s*(\*\*\*|---|# # #|\* \* \*)$' | sed '/./,$!d')

        # Generate slug from title
        title="${SPLIT_TITLES[$s]}"
        slug=$(slugify "$title")
        [[ -z "$slug" ]] && slug="scene-ch${chapter_num}-$((s+1))"
        slug=$(unique_slug "$slug")

        scene_file="${SCENES_DIR}/${slug}.md"

        if [[ "$DRY_RUN" == false ]]; then
            # Write pure prose (no frontmatter)
            echo "$scene_text" > "$scene_file"

            # Add metadata.csv row
            seq_num=$((seq_start + s))
            word_count=$(count_words "$scene_text")
            append_csv_row "$METADATA_CSV" "${slug}|${seq_num}|${title}|||${part_num}|||||${word_count}|"

            # Add intent.csv row
            append_csv_row "$INTENT_CSV" "${slug}||||||"

            log "  Created scenes/${slug}.md (${word_count} words)"
        else
            log "  [DRY RUN] Would create scenes/${slug}.md"
        fi

        WRITTEN_SCENE_IDS+=("$slug")
    done
}

# Process a single chapter (find breaks, confirm, write scenes)
process_chapter() {
    local chapter_file="$1"
    local chapter_num="$2"
    local part_num="$3"
    local seq_start="$4"

    chapter_name=$(basename "$chapter_file" .md)
    chapter_text=$(cat "$chapter_file")
    total_words=$(count_words "$chapter_text")

    log ""
    log "Processing chapter ${chapter_num}: ${chapter_name} (${total_words} words)"

    # Step 1: Look for explicit break markers
    breaks=$(detect_explicit_breaks "$chapter_text")

    if [[ -n "$breaks" ]]; then
        log "  Found explicit scene break markers"
        build_splits_from_markers "$chapter_text" "$breaks"
    else
        log "  No explicit markers — using Claude for scene boundary detection"
        if [[ "$DRY_RUN" == true ]]; then
            log "  [DRY RUN] Would invoke Claude to detect scene boundaries"
            SPLIT_COUNT=0
            return
        fi
        response=$(claude_detect_scenes "$chapter_text" "$chapter_name")
        parse_scene_lines "$response"

        if [[ $SPLIT_COUNT -eq 0 ]]; then
            log "  WARNING: Claude returned no scene boundaries. Treating as single scene."
            SPLIT_LINES=(1)
            title=$(title_from_file "$chapter_file")
            SPLIT_TITLES+=("$title")
            SPLIT_REASONS+=("Single scene (no boundaries detected)")
            SPLIT_COUNT=1
        fi
    fi

    # Step 2: Confirm splits
    if [[ $SPLIT_COUNT -gt 0 ]]; then
        if ! confirm_splits "Chapter ${chapter_num}: \"${chapter_name}\"" "$chapter_text"; then
            log "  Skipped chapter ${chapter_num}"
            return
        fi

        # Step 3: Write scene files
        write_scene_files "$chapter_text" "$chapter_num" "$part_num" "$seq_start"
    fi
}

do_split_chapters() {
    log "============================================"
    log "Mode: Split chapter files into scenes"
    log "============================================"

    # Determine source directory
    src_dir=""
    if [[ -n "$SOURCE_PATH" ]]; then
        src_dir="$SOURCE_PATH"
        # Resolve relative paths
        if [[ "$src_dir" != /* ]]; then
            src_dir="${PROJECT_DIR}/${src_dir}"
        fi
    else
        # Auto-detect: chapters/ or manuscript/ or chapters in project root
        if [[ -d "${PROJECT_DIR}/chapters" ]]; then
            src_dir="${PROJECT_DIR}/chapters"
        elif [[ -d "${PROJECT_DIR}/manuscript" ]]; then
            src_dir="${PROJECT_DIR}/manuscript"
        else
            log "ERROR: No chapter directory found. Use --source to specify."
            exit 1
        fi
    fi

    if [[ ! -d "$src_dir" ]]; then
        log "ERROR: Source directory does not exist: ${src_dir}"
        exit 1
    fi

    log "Source directory: ${src_dir}"

    # Collect chapter files (sorted)
    CHAPTER_FILES=()
    for f in "${src_dir}"/*.md; do
        [[ -f "$f" ]] || continue
        CHAPTER_FILES+=("$f")
    done

    # Also check for .txt files
    for f in "${src_dir}"/*.txt; do
        [[ -f "$f" ]] || continue
        CHAPTER_FILES+=("$f")
    done

    if [[ ${#CHAPTER_FILES[@]} -eq 0 ]]; then
        log "ERROR: No chapter files found in ${src_dir}"
        exit 1
    fi

    # Sort chapter files
    IFS=$'\n' CHAPTER_FILES=($(printf '%s\n' "${CHAPTER_FILES[@]}" | sort)); unset IFS

    log "Found ${#CHAPTER_FILES[@]} chapter files"

    ensure_metadata_csv
    ensure_intent_csv

    # Find the next available seq number
    max_seq=0
    while IFS= read -r seq_val; do
        [[ -z "$seq_val" ]] && continue
        if [[ "$seq_val" =~ ^[0-9]+$ ]] && (( seq_val > max_seq )); then
            max_seq="$seq_val"
        fi
    done < <(get_csv_column "$METADATA_CSV" "seq")

    # Determine part numbers: chapters 1-5 = part 1, 6-10 = part 2, etc.
    chapter_num=0
    total_new_scenes=0

    # For Claude-based detection, use parallel batches
    # First pass: collect chapters that need Claude detection
    CLAUDE_CHAPTERS=()
    MARKER_CHAPTERS=()

    if [[ "$DRY_RUN" == false ]]; then
        for chapter_file in "${CHAPTER_FILES[@]}"; do
            chapter_text=$(cat "$chapter_file")
            breaks=$(detect_explicit_breaks "$chapter_text")
            if [[ -n "$breaks" ]]; then
                MARKER_CHAPTERS+=("$chapter_file")
            else
                CLAUDE_CHAPTERS+=("$chapter_file")
            fi
        done

        log "${#MARKER_CHAPTERS[@]} chapters have explicit markers, ${#CLAUDE_CHAPTERS[@]} need Claude detection"
    fi

    # Process chapters that need Claude detection
    if [[ "$DRY_RUN" == false ]] && [[ ${#CLAUDE_CHAPTERS[@]} -gt 0 ]]; then
        CLAUDE_TOTAL=${#CLAUDE_CHAPTERS[@]}

        if [[ "$SETUP_MODE" == "batch" ]]; then
            # --- Batch mode: submit all chapters as a single batch ---
            log "Submitting ${CLAUDE_TOTAL} chapters to Batch API..."

            _SF_INVOCATION_START=$(date +%s)
            export _SF_INVOCATION_START

            batch_file=$(build_scene_batch)
            batch_id=$(submit_batch "$batch_file")

            if [[ -z "$batch_id" ]]; then
                log "ERROR: Batch submission failed. Falling back to direct mode."
                SETUP_MODE="direct"
            else
                log "  Batch submitted: ${batch_id}"
                log "  Polling for results..."

                poll_batch "$batch_id"

                log "  Downloading results..."
                download_batch_results "$batch_id" "$WORK_DIR" "$LOG_DIR"

                # Move results into detect files and log usage
                for cf in "${CLAUDE_CHAPTERS[@]}"; do
                    ch_name=$(basename "$cf" .md)
                    txt_file="${LOG_DIR}/${ch_name}.txt"
                    json_file="${LOG_DIR}/${ch_name}.json"
                    status_file="${WORK_DIR}/.status-${ch_name}"

                    if [[ -f "$status_file" ]] && [[ "$(cat "$status_file")" == "ok" ]]; then
                        # Copy text response for later parsing
                        if [[ -f "$txt_file" ]]; then
                            cp "$txt_file" "${WORK_DIR}/.detect-${ch_name}.txt"
                        fi
                        # Log usage from the JSON response
                        if [[ -f "$json_file" ]]; then
                            log_api_usage "$json_file" "scene-detect" "$ch_name" "$MODEL"
                        fi
                    else
                        log "  WARNING: Batch item failed for ${ch_name}"
                    fi

                    rm -f "$status_file" "$txt_file" "$json_file"
                done

                rm -f "$batch_file"
                log "  Batch processing complete"
            fi
        fi

        if [[ "$SETUP_MODE" == "direct" ]]; then
            # --- Direct mode: parallel API calls ---
            log "Processing ${CLAUDE_TOTAL} chapters via direct API (parallel=${PARALLEL})..."
            batch_start=0

            while (( batch_start < CLAUDE_TOTAL )); do
                batch_pids=()
                batch_ids=()
                batch_end=$(( batch_start + PARALLEL ))
                (( batch_end > CLAUDE_TOTAL )) && batch_end=$CLAUDE_TOTAL

                for (( i=batch_start; i<batch_end; i++ )); do
                    cf="${CLAUDE_CHAPTERS[$i]}"
                    ch_name=$(basename "$cf" .md)
                    batch_ids+=("$ch_name")
                    log "  Launching scene detection for ${ch_name}..."

                    (
                        chapter_text=$(cat "$cf")
                        response=$(claude_detect_scenes "$chapter_text" "$ch_name")
                        # Write response to temp file
                        echo "$response" > "${WORK_DIR}/.detect-${ch_name}.txt"
                    ) &
                    batch_pids+=($!)
                    register_child_pid $!
                done

                for pid in "${batch_pids[@]}"; do
                    wait "$pid" 2>/dev/null || true
                    unregister_child_pid "$pid" 2>/dev/null || true
                done

                batch_start=$batch_end
            done
        fi
    fi

    # Now process all chapters sequentially (for confirmation and writing)
    for chapter_file in "${CHAPTER_FILES[@]}"; do
        chapter_num=$((chapter_num + 1))
        part_num=$(( (chapter_num - 1) / 5 + 1 ))
        seq_start=$((max_seq + total_new_scenes + 1))

        ch_name=$(basename "$chapter_file" .md)
        chapter_text=$(cat "$chapter_file")

        # Check if we have a cached Claude response
        detect_file="${WORK_DIR}/.detect-${ch_name}.txt"
        breaks=$(detect_explicit_breaks "$chapter_text")

        if [[ -n "$breaks" ]]; then
            log ""
            log "Processing chapter ${chapter_num}: ${ch_name}"
            log "  Found explicit scene break markers"
            build_splits_from_markers "$chapter_text" "$breaks"
        elif [[ -f "$detect_file" ]]; then
            log ""
            log "Processing chapter ${chapter_num}: ${ch_name}"
            response=$(cat "$detect_file")
            parse_scene_lines "$response"
            rm -f "$detect_file"

            if [[ $SPLIT_COUNT -eq 0 ]]; then
                log "  WARNING: No scene boundaries detected. Treating as single scene."
                SPLIT_LINES=(1)
                title=$(title_from_file "$chapter_file")
                SPLIT_TITLES=("$title")
                SPLIT_REASONS=("Single scene (no boundaries detected)")
                SPLIT_COUNT=1
            fi
        elif [[ "$DRY_RUN" == true ]]; then
            log ""
            log "Processing chapter ${chapter_num}: ${ch_name}"
            total_words=$(count_words "$chapter_text")
            if [[ -n "$breaks" ]]; then
                log "  Has explicit markers"
            else
                log "  [DRY RUN] Would invoke Claude for scene detection (${total_words} words)"
            fi
            continue
        else
            # Fallback: single scene
            log ""
            log "Processing chapter ${chapter_num}: ${ch_name}"
            SPLIT_LINES=(1)
            title=$(title_from_file "$chapter_file")
            SPLIT_TITLES=("$title")
            SPLIT_REASONS=("Single scene")
            SPLIT_COUNT=1
        fi

        # Confirm
        if [[ $SPLIT_COUNT -gt 0 ]]; then
            if ! confirm_splits "Chapter ${chapter_num}: \"${ch_name}\"" "$chapter_text"; then
                log "  Skipped chapter ${chapter_num}"
                continue
            fi

            # Write scene files
            write_scene_files "$chapter_text" "$chapter_num" "$part_num" "$seq_start"
            total_new_scenes=$((total_new_scenes + ${#WRITTEN_SCENE_IDS[@]}))
        fi
    done

    log ""
    log "Split complete: ${total_new_scenes} new scenes created from ${#CHAPTER_FILES[@]} chapters"
}

# ============================================================================
# Mode 3: Split manuscript into scenes
# ============================================================================

do_split_manuscript() {
    log "============================================"
    log "Mode: Split manuscript file into scenes"
    log "============================================"

    # Determine source file
    src_file=""
    if [[ -n "$SOURCE_PATH" ]]; then
        src_file="$SOURCE_PATH"
        if [[ "$src_file" != /* ]]; then
            src_file="${PROJECT_DIR}/${src_file}"
        fi
    else
        # Auto-detect
        for candidate in "${PROJECT_DIR}/manuscript.md" "${PROJECT_DIR}/manuscript/manuscript.md" "${PROJECT_DIR}/manuscript.txt"; do
            if [[ -f "$candidate" ]]; then
                src_file="$candidate"
                break
            fi
        done
    fi

    if [[ -z "$src_file" ]] || [[ ! -f "$src_file" ]]; then
        log "ERROR: Manuscript file not found. Use --source to specify."
        exit 1
    fi

    log "Source file: ${src_file}"

    manuscript_text=$(cat "$src_file")
    total_words=$(count_words "$manuscript_text")
    total_lines=$(echo "$manuscript_text" | wc -l | tr -d ' ')
    log "Manuscript: ${total_words} words, ${total_lines} lines"

    # Step 1: Detect chapter boundaries
    # Look for: # Chapter, ## Chapter, # Part, CHAPTER, lines that are just numbers, etc.
    CHAPTER_STARTS=()
    CHAPTER_NAMES=()
    line_num=0

    while IFS= read -r line; do
        line_num=$((line_num + 1))
        stripped=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

        # Markdown headings with "Chapter" or "Part"
        if echo "$stripped" | grep -qiE '^#{1,2}[[:space:]]+(Chapter|Part)'; then
            CHAPTER_STARTS+=("$line_num")
            name=$(echo "$stripped" | sed 's/^#\+[[:space:]]*//')
            CHAPTER_NAMES+=("$name")
            continue
        fi

        # ALL CAPS chapter headings
        if echo "$stripped" | grep -qE '^CHAPTER[[:space:]]'; then
            CHAPTER_STARTS+=("$line_num")
            CHAPTER_NAMES+=("$stripped")
            continue
        fi

        # Standalone "Chapter N" or "Chapter WORD"
        if echo "$stripped" | grep -qiE '^Chapter[[:space:]]+[0-9IVXivx]+'; then
            CHAPTER_STARTS+=("$line_num")
            CHAPTER_NAMES+=("$stripped")
            continue
        fi

        # Just a number on its own line (likely a chapter number)
        if echo "$stripped" | grep -qE '^[0-9]+$' && [[ ${#stripped} -le 3 ]]; then
            # Only if surrounded by blank lines (check prev line is blank)
            if (( line_num > 1 )); then
                prev_line=$(echo "$manuscript_text" | sed -n "$((line_num - 1))p" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                if [[ -z "$prev_line" ]]; then
                    CHAPTER_STARTS+=("$line_num")
                    CHAPTER_NAMES+=("Chapter ${stripped}")
                fi
            fi
            continue
        fi
    done <<< "$manuscript_text"

    CHAPTER_COUNT=${#CHAPTER_STARTS[@]}

    if [[ $CHAPTER_COUNT -eq 0 ]]; then
        log "No chapter headings found. Treating entire manuscript as one chapter."
        CHAPTER_STARTS=(1)
        CHAPTER_NAMES=("Manuscript")
        CHAPTER_COUNT=1
    else
        log "Found ${CHAPTER_COUNT} chapter boundaries"
    fi

    # Step 2: Create temporary chapter files
    TMP_CHAPTERS_DIR="${WORK_DIR}/chapters"
    mkdir -p "$TMP_CHAPTERS_DIR"

    for (( c=0; c<CHAPTER_COUNT; c++ )); do
        start_line=${CHAPTER_STARTS[$c]}
        if (( c + 1 < CHAPTER_COUNT )); then
            end_line=$(( ${CHAPTER_STARTS[$((c+1))]} - 1 ))
        else
            end_line=$total_lines
        fi

        ch_name="${CHAPTER_NAMES[$c]}"
        ch_slug=$(slugify "$ch_name")
        [[ -z "$ch_slug" ]] && ch_slug="chapter-$((c+1))"
        ch_file="${TMP_CHAPTERS_DIR}/${ch_slug}.md"

        echo "$manuscript_text" | sed -n "${start_line},${end_line}p" > "$ch_file"
        ch_words=$(wc -w < "$ch_file" | tr -d ' ')
        log "  Chapter $((c+1)): \"${ch_name}\" (lines ${start_line}-${end_line}, ${ch_words} words)"
    done

    # Step 3: Use split-chapters logic on the temp directory
    SOURCE_PATH="$TMP_CHAPTERS_DIR"
    do_split_chapters

    # Clean up temp files
    rm -rf "$TMP_CHAPTERS_DIR"
}

# ============================================================================
# Main execution
# ============================================================================

case "$MODE" in
    rename)
        if [[ "$DRY_RUN" == false ]]; then
            create_branch "scenes-setup" "$PROJECT_DIR"

            # Commit any pre-existing changes
            (
                cd "$PROJECT_DIR"
                git add -A 2>/dev/null || true
                git commit -m "Scenes setup: pre-rename state" 2>/dev/null || true
            )

            ensure_branch_pushed "$PROJECT_DIR"
        fi

        do_rename

        if [[ "$DRY_RUN" == false ]]; then
            # Commit and push
            (
                cd "$PROJECT_DIR"
                git add scenes/ 2>/dev/null || true
                git add reference/scene-metadata.csv reference/scene-intent.csv 2>/dev/null || true
                git add reference/chapter-map.csv 2>/dev/null || true
                git commit -m "Scenes setup: rename ${RENAME_COUNT} scene files to slugs" 2>/dev/null || true
                git push 2>/dev/null || true
            )

            # Create PR
            PR_BODY="## Scene File Rename

**Project:** ${PROJECT_TITLE}
**Renamed:** ${RENAME_COUNT} files

### Tasks
- [x] Generate slugs from titles
- [x] Rename files with git mv
- [x] Update metadata.csv and intent.csv
- [x] Update chapter-map.csv"

            create_draft_pr "Scenes setup: rename ${RENAME_COUNT} scene files" "$PR_BODY" "$PROJECT_DIR" "drafting" 2>/dev/null || true
            log "Committed and pushed rename results"
        fi
        ;;

    split-chapters)
        if [[ "$DRY_RUN" == false ]]; then
            create_branch "scenes-setup" "$PROJECT_DIR"

            (
                cd "$PROJECT_DIR"
                git add -A 2>/dev/null || true
                git commit -m "Scenes setup: pre-split state" 2>/dev/null || true
            )

            ensure_branch_pushed "$PROJECT_DIR"

            # Cost forecast for Claude-based detection
            # Only estimate if we might need Claude
            src_dir_est=""
            if [[ -n "$SOURCE_PATH" ]]; then
                src_dir_est="$SOURCE_PATH"
                [[ "$src_dir_est" != /* ]] && src_dir_est="${PROJECT_DIR}/${src_dir_est}"
            elif [[ -d "${PROJECT_DIR}/chapters" ]]; then
                src_dir_est="${PROJECT_DIR}/chapters"
            elif [[ -d "${PROJECT_DIR}/manuscript" ]]; then
                src_dir_est="${PROJECT_DIR}/manuscript"
            fi

            if [[ -n "$src_dir_est" ]] && [[ -d "$src_dir_est" ]]; then
                ch_count=0
                avg_words=0
                for cf in "${src_dir_est}"/*.md "${src_dir_est}"/*.txt; do
                    [[ -f "$cf" ]] || continue
                    ch_count=$((ch_count + 1))
                    wc_val=$(wc -w < "$cf" | tr -d ' ')
                    avg_words=$((avg_words + wc_val))
                done
                if (( ch_count > 0 )); then
                    avg_words=$((avg_words / ch_count))
                    SPLIT_COST=$(estimate_cost "evaluate" "$ch_count" "$avg_words" "$MODEL")
                    log "Cost forecast (max): ~\$${SPLIT_COST} (${ch_count} chapters, avg ${avg_words} words)"
                    check_cost_threshold "$SPLIT_COST" || { log "Cost threshold check declined. Aborting."; exit 1; }
                fi
            fi
        fi

        do_split_chapters

        if [[ "$DRY_RUN" == false ]]; then
            # Commit and push
            (
                cd "$PROJECT_DIR"
                git add scenes/ 2>/dev/null || true
                git add reference/scene-metadata.csv reference/scene-intent.csv 2>/dev/null || true
                git add working/ 2>/dev/null || true
                git commit -m "Scenes setup: split chapters into ${total_new_scenes:-0} scenes" 2>/dev/null || true
                git push 2>/dev/null || true
            )

            PR_BODY="## Chapter Split into Scenes

**Project:** ${PROJECT_TITLE}
**Chapters processed:** ${#CHAPTER_FILES[@]}
**Scenes created:** ${total_new_scenes:-0}

### Tasks
- [x] Detect scene break markers
- [x] Claude scene boundary detection (where needed)
- [x] Write scene files
- [x] Update metadata.csv and intent.csv"

            create_draft_pr "Scenes setup: split chapters into scenes" "$PR_BODY" "$PROJECT_DIR" "drafting" 2>/dev/null || true

            print_cost_summary "scene-detect"
            log "Committed and pushed split results"
        fi
        ;;

    split-manuscript)
        if [[ "$DRY_RUN" == false ]]; then
            create_branch "scenes-setup" "$PROJECT_DIR"

            (
                cd "$PROJECT_DIR"
                git add -A 2>/dev/null || true
                git commit -m "Scenes setup: pre-split state" 2>/dev/null || true
            )

            ensure_branch_pushed "$PROJECT_DIR"
        fi

        do_split_manuscript

        if [[ "$DRY_RUN" == false ]]; then
            # Commit and push
            (
                cd "$PROJECT_DIR"
                git add scenes/ 2>/dev/null || true
                git add reference/scene-metadata.csv reference/scene-intent.csv 2>/dev/null || true
                git add working/ 2>/dev/null || true
                git commit -m "Scenes setup: split manuscript into scenes" 2>/dev/null || true
                git push 2>/dev/null || true
            )

            PR_BODY="## Manuscript Split into Scenes

**Project:** ${PROJECT_TITLE}
**Scenes created:** ${total_new_scenes:-0}

### Tasks
- [x] Detect chapter boundaries
- [x] Split chapters into scenes
- [x] Write scene files
- [x] Update metadata.csv and intent.csv"

            create_draft_pr "Scenes setup: split manuscript into scenes" "$PR_BODY" "$PROJECT_DIR" "drafting" 2>/dev/null || true

            print_cost_summary "scene-detect"
            log "Committed and pushed split results"
        fi
        ;;
esac

log "============================================"
log "Scenes setup complete (mode: ${MODE})"
log "============================================"

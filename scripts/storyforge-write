#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-write — Autonomous scene drafting for Storyforge projects
#
# One claude -p invocation per scene. Each invocation reads all reference
# material, drafts the scene, runs a quality review, updates continuity,
# and commits to git.
#
# Usage:
#   ./storyforge-write                        # Draft all remaining scenes
#   ./storyforge-write act1-sc01              # Draft a single scene
#   ./storyforge-write act1-sc01 act1-sc15    # Draft a range (by position in index)
#   ./storyforge-write --act 2                # Draft all scenes in act 2
#   ./storyforge-write --part 2               # Draft all scenes in part 2
#   ./storyforge-write --dry-run act1-sc01    # Build prompt without invoking Claude
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"
PYTHON_LIB="${SCRIPT_DIR}/lib/python"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi
if [[ ! -f "${LIB_DIR}/prompt-builder.sh" ]]; then
    echo "ERROR: Cannot find lib/prompt-builder.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"
# shellcheck source=lib/prompt-builder.sh
source "${LIB_DIR}/prompt-builder.sh"

# --- Detect project root ---
detect_project_root
log "Project root: ${PROJECT_DIR}"

# --- Configuration ---
SCENES_DIR="${PROJECT_DIR}/scenes"
LOG_DIR="${PROJECT_DIR}/working/logs"
LOG_FILE="${LOG_DIR}/drafting-log.txt"
export LOG_FILE

# Optional: uncomment and set a per-scene budget limit
# BUDGET_FLAG="--max-budget-usd 20"
BUDGET_FLAG=""

# Ensure directories exist
mkdir -p "$SCENES_DIR" "$LOG_DIR"
mkdir -p "${PROJECT_DIR}/working/coaching"

# ============================================================================
# Helper: extract scene prose from API response (delegates to Python)
# ============================================================================
_extract_scene_from_response() {
    local log_file="$1"
    local scene_file="$2"
    local python_lib="${SCRIPT_DIR}/lib/python"

    PYTHONPATH="$python_lib" python3 -m storyforge.parsing extract-single "$log_file" "$scene_file" 2>/dev/null || {
        log "WARNING: Python scene extraction failed, falling back to raw response"
        extract_api_response "$log_file" > "$scene_file" 2>/dev/null || true
    }
    log "Wrote scene file: ${scene_file}"
}

# ============================================================================
# Argument parsing
# ============================================================================

DRY_RUN=false
INTERACTIVE=false
COACHING_LEVEL=""
WRITE_MODE="batch"      # batch (default) | direct | interactive
FILTER_MODE="all"       # all | single | range | act | from_seq | scenes
FILTER_VALUE=""
FILTER_SCENES=""
FILTER_FROM_SEQ=""
RANGE_START=""
RANGE_END=""

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Draft scenes autonomously using Claude.

Scope:
  (no args)                   Draft all remaining (pending) scenes
  SCENE_ID                    Draft a single scene
  SCENE_ID SCENE_ID           Draft a range of scenes (inclusive, by index position)
  --scenes ID,ID              Draft specific scenes (comma-separated slug IDs)
  --act N                     Draft all scenes in act/part N
  --from-seq N                Draft scenes from sequence number N onward
  --from-seq N-M              Draft scenes in sequence range N through M

Options:
  --direct                    Use direct API calls (one at a time, not batch)
  --coaching LEVEL            Set coaching level: full, coach, or strict
  --interactive               Draft with supervision — watch, give feedback, redirect
  --dry-run                   Build prompts without invoking Claude
  -h, --help                  Show this help

Environment:
  ANTHROPIC_API_KEY           Required for batch/direct modes (not interactive)
  STORYFORGE_MODEL            Override model (default: opus for drafting)
  STORYFORGE_COACHING         Override coaching level (default: from storyforge.yaml or full)
  STORYFORGE_REJOIN_TIMEOUT   Seconds to wait for 'i' keypress in autopilot (default: 5)

Examples:
  $(basename "$0")
  $(basename "$0") act1-sc05
  $(basename "$0") --interactive
  $(basename "$0") --act 2
  $(basename "$0") --from-seq 32
  $(basename "$0") --from-seq 5-10
  $(basename "$0") --scenes claires-cold,pewter-town
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --coaching)
            COACHING_LEVEL="${2:?ERROR: --coaching requires a value (full, coach, or strict)}"
            case "$COACHING_LEVEL" in
                full|coach|strict) ;;
                *) echo "ERROR: Invalid coaching level '${COACHING_LEVEL}'. Must be full, coach, or strict." >&2; exit 1 ;;
            esac
            shift 2
            ;;
        --direct)
            WRITE_MODE="direct"
            shift
            ;;
        --interactive|-i)
            INTERACTIVE=true
            shift
            ;;
        --act|--part)
            FILTER_MODE="act"
            FILTER_VALUE="${2:?ERROR: $1 requires a value}"
            shift 2
            ;;
        --scenes)
            FILTER_MODE="scenes"
            FILTER_SCENES="${2:?ERROR: --scenes requires comma-separated scene IDs}"
            shift 2
            ;;
        --from-seq)
            FILTER_MODE="from_seq"
            FILTER_FROM_SEQ="${2:?ERROR: --from-seq requires a sequence number}"
            shift 2
            ;;
        -*)
            echo "ERROR: Unknown option: $1" >&2
            usage
            ;;
        *)
            if [[ -z "$RANGE_START" ]]; then
                RANGE_START="$1"
                FILTER_MODE="single"
            elif [[ "$FILTER_MODE" == "single" ]]; then
                RANGE_END="$1"
                FILTER_MODE="range"
            else
                echo "ERROR: Too many positional arguments" >&2
                usage
            fi
            shift
            ;;
    esac
done

# ============================================================================
# Coaching level
# ============================================================================

if [[ -n "$COACHING_LEVEL" ]]; then
    STORYFORGE_COACHING="$COACHING_LEVEL"
    export STORYFORGE_COACHING
fi

# Resolve effective coaching level for conditional logic in this script
EFFECTIVE_COACHING=$(get_coaching_level)

# --- Resolve write mode ---
if [[ "$INTERACTIVE" == true ]]; then
    WRITE_MODE="interactive"
fi

# --- API key check for non-interactive modes ---
if [[ "$DRY_RUN" != true && "$WRITE_MODE" != "interactive" && -z "${ANTHROPIC_API_KEY:-}" ]]; then
    log "ERROR: ANTHROPIC_API_KEY not set. Required for batch/direct API modes."
    log "  Set it with: export ANTHROPIC_API_KEY=your-key"
    log "  Or use --interactive to run via claude -p instead."
    exit 1
fi

# ============================================================================
# Prerequisites
# ============================================================================


# Voice guide — check common locations
VOICE_GUIDE_FOUND=false
for vg in "reference/voice-guide.md" "reference/persistent-prompt.md"; do
    if [[ -f "${PROJECT_DIR}/${vg}" ]]; then
        VOICE_GUIDE_FOUND=true
        break
    fi
done

# Also check storyforge.yaml for a custom voice guide path
CUSTOM_VG=$(read_yaml_field "reference.voice_guide" 2>/dev/null || true)
if [[ -z "$CUSTOM_VG" ]]; then
    CUSTOM_VG=$(read_yaml_field "voice_guide" 2>/dev/null || true)
fi
if [[ -n "$CUSTOM_VG" && -f "${PROJECT_DIR}/${CUSTOM_VG}" ]]; then
    VOICE_GUIDE_FOUND=true
fi

if [[ "$VOICE_GUIDE_FOUND" == false ]]; then
    log "WARNING: No voice guide found. Drafting will proceed without voice constraints."
    log "  Expected: reference/voice-guide.md or reference/persistent-prompt.md"
fi

# ============================================================================
# Build scene list from metadata.csv
# ============================================================================

METADATA_CSV="${PROJECT_DIR}/reference/scene-metadata.csv"
# Fallback to old location
[[ ! -f "$METADATA_CSV" ]] && METADATA_CSV="${SCENES_DIR}/metadata.csv"

build_scene_list "$METADATA_CSV"

# ============================================================================
# Filter scenes based on arguments
# ============================================================================

case "$FILTER_MODE" in
    all)       apply_scene_filter "$METADATA_CSV" "all" ;;
    single)    apply_scene_filter "$METADATA_CSV" "single" "$RANGE_START" ;;
    range)     apply_scene_filter "$METADATA_CSV" "range" "$RANGE_START" "$RANGE_END" ;;
    scenes)    apply_scene_filter "$METADATA_CSV" "scenes" "$FILTER_SCENES" ;;
    act)       apply_scene_filter "$METADATA_CSV" "act" "$FILTER_VALUE" ;;
    from_seq)  apply_scene_filter "$METADATA_CSV" "from_seq" "$FILTER_FROM_SEQ" ;;
esac

# ============================================================================
# Filter out already-drafted scenes (unless explicitly targeting a single scene)
# ============================================================================

PENDING_IDS=()
SKIPPED=0

for id in "${FILTERED_IDS[@]}"; do
    status=$(get_scene_status "$id" "$PROJECT_DIR")
    case "$status" in
        drafted|revised|final)
            if [[ "$FILTER_MODE" == "single" ]]; then
                # User explicitly requested this scene — include it
                PENDING_IDS+=("$id")
                log "NOTE: Scene ${id} has status '${status}' but was explicitly requested"
            else
                SKIPPED=$((SKIPPED + 1))
            fi
            ;;
        *)
            PENDING_IDS+=("$id")
            ;;
    esac
done

if [[ ${#PENDING_IDS[@]} -eq 0 ]]; then
    log "Nothing to draft — all ${#FILTERED_IDS[@]} matching scenes are already drafted (${SKIPPED} skipped)."
    exit 0
fi

# ============================================================================
# Cost forecasting
# ============================================================================

if [[ "$DRY_RUN" != true ]]; then
    # Calculate average word count from metadata.csv
    AVG_WORDS=$(awk -F'|' '
        NR == 1 {
            for (i = 1; i <= NF; i++) {
                if ($i == "target_words") col = i
            }
            next
        }
        col && $col+0 > 0 { sum += $col; count++ }
        END { if (count > 0) printf "%d", sum / count; else print 2000 }
    ' "$METADATA_CSV")
    FORECAST_MODEL=$(select_model "drafting")
    ESTIMATED_COST=$(estimate_cost "draft" "${#PENDING_IDS[@]}" "$AVG_WORDS" "$FORECAST_MODEL")
    # Batch mode gets 50% discount on API pricing
    if [[ "$WRITE_MODE" == "batch" ]]; then
        ESTIMATED_COST=$(awk "BEGIN { printf \"%.2f\", ${ESTIMATED_COST} * 0.5 }")
    fi
    log "Cost forecast: ~\$${ESTIMATED_COST} for ${#PENDING_IDS[@]} scenes (avg ${AVG_WORDS} words, model ${FORECAST_MODEL}, mode ${WRITE_MODE})"
    if ! check_cost_threshold "$ESTIMATED_COST"; then
        log "Aborting — cost threshold exceeded."
        exit 0
    fi
fi

# Set up interactive mode file
INTERACTIVE_FILE="${PROJECT_DIR}/working/.interactive"
rm -f "$INTERACTIVE_FILE"
if [[ "$INTERACTIVE" == true ]]; then
    touch "$INTERACTIVE_FILE"
fi

# ============================================================================
# Session start
# ============================================================================

SESSION_START=$(date +%s)

# --- Branch + PR setup ---
if [[ "$DRY_RUN" != true ]]; then
    create_branch "write" "$PROJECT_DIR"

    # Advance project phase before pushing — gives the branch an initial commit
    CURRENT_PHASE=$(read_yaml_field "phase" 2>/dev/null || echo "")
    if [[ "$CURRENT_PHASE" != "drafting" && "$CURRENT_PHASE" != "evaluation" && "$CURRENT_PHASE" != "revision" && "$CURRENT_PHASE" != "complete" ]]; then
        sed -i '' "s/^[[:space:]]*phase:.*/phase: drafting/" "${PROJECT_DIR}/storyforge.yaml" 2>/dev/null || true
        log "Project phase advanced to: drafting"
    fi

    ensure_branch_pushed "$PROJECT_DIR"

    WRITE_TITLE=$(read_yaml_field 'project.title' 2>/dev/null || read_yaml_field 'title' 2>/dev/null || echo 'Unknown')
    PR_BODY="## Drafting Session

**Project:** ${WRITE_TITLE}
**Scenes to draft:** ${#PENDING_IDS[@]}

### Tasks
"
    for id in "${PENDING_IDS[@]}"; do
        PR_BODY="${PR_BODY}- [ ] Draft scene ${id}
"
    done
    PR_BODY="${PR_BODY}- [ ] Review"

    create_draft_pr "Draft: ${WRITE_TITLE} (${#PENDING_IDS[@]} scenes)" "$PR_BODY" "$PROJECT_DIR" "drafting"
fi

log "============================================"
log "Starting Storyforge drafting session"
log "Project: $(read_yaml_field 'project.title' 2>/dev/null || read_yaml_field 'title' 2>/dev/null || echo 'Unknown')"
log "Mode: ${WRITE_MODE}"
log "Coaching level: ${EFFECTIVE_COACHING}"
log "Scenes to draft: ${#PENDING_IDS[@]} (${SKIPPED} already-drafted skipped)"
log "Scene list: ${PENDING_IDS[*]}"
log "============================================"

# ============================================================================
# Main drafting loop
# ============================================================================

DRAFTED_COUNT=0
TOTAL_WORDS=0

# --- Helper: verify and commit a single drafted scene ---
# Usage: verify_and_commit_scene SCENE_ID SCENE_LOG [HEAD_BEFORE]
verify_and_commit_scene() {
    local vid="$1"
    local vlog="$2"
    local vhead_before="${3:-$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")}"
    local vscene_file="${SCENES_DIR}/${vid}.md"
    local vword_count=0

    if [[ "$EFFECTIVE_COACHING" == "coach" || "$EFFECTIVE_COACHING" == "strict" ]]; then
        if [[ "$EFFECTIVE_COACHING" == "coach" ]]; then
            local vcoaching="${PROJECT_DIR}/working/coaching/brief-${vid}.md"
        else
            local vcoaching="${PROJECT_DIR}/working/coaching/constraints-${vid}.md"
        fi
        if [[ ! -f "$vcoaching" ]]; then
            log "WARNING: Coaching output not created: ${vcoaching}"
        fi
        [[ -f "$vcoaching" ]] && vword_count=$(wc -w < "$vcoaching" | tr -d ' ')
    else
        if [[ ! -f "$vscene_file" ]]; then
            log "ERROR: Scene file not created: ${vscene_file}"
            return 1
        fi
        vword_count=$(wc -w < "$vscene_file" | tr -d ' ')
        if (( vword_count < 100 )); then
            log "ERROR: Scene file suspiciously short (${vword_count} words): ${vscene_file}"
            return 1
        fi
        update_csv_field "$METADATA_CSV" "$vid" "word_count" "$vword_count"
        update_csv_field "$METADATA_CSV" "$vid" "status" "drafted"
        log "Updated metadata.csv: ${vid} word_count=${vword_count} status=drafted"
    fi

    # Check/create git commit
    local vhead_after
    vhead_after=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")
    if [[ "$vhead_before" == "$vhead_after" ]]; then
        log "Creating commit for scene ${vid}..."
        (
            cd "$PROJECT_DIR"
            if [[ "$EFFECTIVE_COACHING" == "coach" || "$EFFECTIVE_COACHING" == "strict" ]]; then
                git add working/coaching/ 2>/dev/null || true
                git add working/logs/ 2>/dev/null || true
                git commit -m "${EFFECTIVE_COACHING^}: ${vid}" 2>/dev/null || true
            else
                git add "scenes/${vid}.md" 2>/dev/null || true
                git add reference/ 2>/dev/null || true
                git add working/logs/ 2>/dev/null || true
                git commit -m "Draft scene ${vid}" 2>/dev/null || true
            fi
        )
    fi

    # Push (warn on failure)
    local vcommit_short
    vcommit_short=$(git -C "$PROJECT_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    if ! git -C "$PROJECT_DIR" push 2>/dev/null; then
        log "WARNING: git push failed for scene ${vid} (commit ${vcommit_short}). Continuing."
    fi

    DRAFTED_COUNT=$((DRAFTED_COUNT + 1))
    TOTAL_WORDS=$((TOTAL_WORDS + vword_count))
    log "SUCCESS: Scene ${vid} — ${vword_count} words, commit ${vcommit_short}"
    update_pr_task "Draft scene ${vid}" "$PROJECT_DIR"
}

# ============================================================================
# Batch mode — build all prompts, submit batch, download and process results
# ============================================================================

if [[ "$WRITE_MODE" == "batch" && "$DRY_RUN" != true ]]; then
    log "Building prompts for batch submission..."
    BATCH_JSONL="${LOG_DIR}/drafting-batch-$$.jsonl"
    BATCH_SCENE_MODEL=$(select_model "drafting")
    BATCH_SCENE_IDS=()

    for (( i=0; i<${#PENDING_IDS[@]}; i++ )); do
        SCENE_ID="${PENDING_IDS[$i]}"
        SCENE_FILE="${SCENES_DIR}/${SCENE_ID}.md"

        # Skip scenes that already have substantial content
        if [[ -f "$SCENE_FILE" && "$FILTER_MODE" != "single" ]]; then
            existing_wc=$(wc -w < "$SCENE_FILE" 2>/dev/null | tr -d ' ')
            if (( existing_wc > 200 )); then
                log "Scene ${SCENE_ID} already has ${existing_wc} words, skipping"
                continue
            fi
        fi

        # Detect API mode flag (skip for dry-run — prompts should show claude -p format)
        API_FLAG=""
        [[ "$DRY_RUN" != true && -n "${ANTHROPIC_API_KEY:-}" ]] && API_FLAG="--api-mode"

        PROMPT=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.prompts build-scene "$SCENE_ID" "$PROJECT_DIR" --coaching "$EFFECTIVE_COACHING" $API_FLAG)
        if [[ -z "$PROMPT" ]]; then
            log "ERROR: Failed to build prompt for scene ${SCENE_ID}"
            exit 1
        fi

        # Build JSONL line for batch request
        json_prompt=$(jq -Rs '.' <<< "$PROMPT")
        printf '{"custom_id":"%s","params":{"model":"%s","max_tokens":8192,"messages":[{"role":"user","content":%s}]}}\n' \
            "$SCENE_ID" "$BATCH_SCENE_MODEL" "$json_prompt" >> "$BATCH_JSONL"
        BATCH_SCENE_IDS+=("$SCENE_ID")
    done

    if [[ ${#BATCH_SCENE_IDS[@]} -eq 0 ]]; then
        log "No scenes to submit in batch."
    else
        log "Submitting batch with ${#BATCH_SCENE_IDS[@]} scenes..."
        _SF_INVOCATION_START=$(date +%s)
        export _SF_INVOCATION_START

        begin_healing_zone "batch drafting ${#BATCH_SCENE_IDS[@]} scenes"

        BATCH_ID=$(submit_batch "$BATCH_JSONL")
        if [[ -z "$BATCH_ID" ]]; then
            log "ERROR: Failed to submit batch."
            false
        fi
        log "Batch submitted: ${BATCH_ID}"

        log "Polling batch for completion..."
        poll_batch "$BATCH_ID"
        log "Batch complete. Downloading results..."

        BATCH_OUTPUT_DIR="${LOG_DIR}/batch-$$"
        mkdir -p "$BATCH_OUTPUT_DIR"
        download_batch_results "$BATCH_ID" "$BATCH_OUTPUT_DIR" "$BATCH_OUTPUT_DIR"

        end_healing_zone

        # Process each scene result
        for SCENE_ID in "${BATCH_SCENE_IDS[@]}"; do
            SCENE_FILE="${SCENES_DIR}/${SCENE_ID}.md"
            SCENE_LOG="${BATCH_OUTPUT_DIR}/${SCENE_ID}.json"

            HEAD_BEFORE=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")

            # Check batch status for this scene
            batch_status="fail"
            [[ -f "${BATCH_OUTPUT_DIR}/.status-${SCENE_ID}" ]] && batch_status=$(cat "${BATCH_OUTPUT_DIR}/.status-${SCENE_ID}")

            if [[ "$batch_status" != "ok" ]]; then
                log "ERROR: Batch failed for scene ${SCENE_ID}. Skipping."
                continue
            fi

            # Write scene text from batch result
            SCENE_JSON_FILE="${BATCH_OUTPUT_DIR}/${SCENE_ID}.json"
            if [[ -f "$SCENE_JSON_FILE" ]]; then
                _extract_scene_from_response "$SCENE_JSON_FILE" "$SCENE_FILE"
            fi

            # Log usage from the per-scene JSON response
            log_api_usage "$SCENE_LOG" "draft" "$SCENE_ID" "$BATCH_SCENE_MODEL"

            # Verify and commit
            verify_and_commit_scene "$SCENE_ID" "$SCENE_LOG" "$HEAD_BEFORE"
        done

        rm -f "$BATCH_JSONL"
        rm -rf "$BATCH_OUTPUT_DIR"
    fi

# ============================================================================
# Direct / Interactive mode — one scene at a time
# ============================================================================

else
    for (( i=0; i<${#PENDING_IDS[@]}; i++ )); do
        SCENE_ID="${PENDING_IDS[$i]}"
        SCENE_FILE="${SCENES_DIR}/${SCENE_ID}.md"
        SCENE_NUM=$((i + 1))

        log "--- Scene ${SCENE_ID} (${SCENE_NUM}/${#PENDING_IDS[@]}) ---"

        # --- Check if scene file already has substantial content (defensive) ---
        if [[ -f "$SCENE_FILE" && "$FILTER_MODE" != "single" ]]; then
            existing_wc=$(wc -w < "$SCENE_FILE" 2>/dev/null | tr -d ' ')
            if (( existing_wc > 200 )); then
                log "Scene file already has ${existing_wc} words, skipping"
                continue
            fi
        fi

        # --- Build the prompt (outside zone — needed for dry-run check) ---
        # Skip API mode for dry-run — prompts should show claude -p format
        API_FLAG=""
        [[ "$DRY_RUN" != true && -n "${ANTHROPIC_API_KEY:-}" ]] && API_FLAG="--api-mode"

        PROMPT=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.prompts build-scene "$SCENE_ID" "$PROJECT_DIR" --coaching "$EFFECTIVE_COACHING" $API_FLAG)

        if [[ -z "$PROMPT" ]]; then
            log "ERROR: Failed to build prompt for scene ${SCENE_ID}"
            log "Stopping — prompt generation failed."
            exit 1
        fi

        # --- Dry-run mode: print prompt and continue (outside zone) ---
        if [[ "$DRY_RUN" == true ]]; then
            echo "===== DRY RUN: ${SCENE_ID} ====="
            echo "$PROMPT"
            echo "===== END DRY RUN: ${SCENE_ID} ====="
            echo ""
            DRAFTED_COUNT=$((DRAFTED_COUNT + 1))
            continue
        fi

        # --- Check interactive mode (outside zone) ---
        if [[ "$WRITE_MODE" == "interactive" && ! -f "$INTERACTIVE_FILE" ]]; then
            offer_interactive "$PROJECT_DIR" "${SCENE_ID} (${SCENE_NUM}/${#PENDING_IDS[@]})" || true
        fi

        # --- Healing zone: invoke → verify → commit ---
        begin_healing_zone "drafting scene ${SCENE_ID} (${SCENE_NUM}/${#PENDING_IDS[@]})"

        # --- Record git HEAD before invocation ---
        HEAD_BEFORE=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")

        # --- Per-scene log file ---
        SCENE_LOG="${LOG_DIR}/drafting-${SCENE_ID}.log"

        START_TIME=$(date +%s)

        if [[ "$WRITE_MODE" == "interactive" && -f "$INTERACTIVE_FILE" ]]; then
            # --- Interactive mode (claude -p) ---
            show_interactive_banner "Scene ${SCENE_NUM} of ${#PENDING_IDS[@]}" "multi"

            INTERACTIVE_SYSTEM=$(build_interactive_system_prompt "$PROJECT_DIR" "scene")
            SCENE_MODEL=$(select_model "drafting")

            set +e
            claude "$PROMPT" \
                --model "$SCENE_MODEL" \
                --dangerously-skip-permissions \
                --append-system-prompt "$INTERACTIVE_SYSTEM"
            EXIT_CODE=$?
            set -e
        elif [[ "$WRITE_MODE" == "direct" ]]; then
            # --- Direct API mode ---
            SCENE_MODEL=$(select_model "drafting")
            log "Invoking API for scene ${SCENE_ID} (model: ${SCENE_MODEL})..."
            log "  Per-scene log: ${SCENE_LOG}"

            # Start background monitor
            monitor_progress "$SCENE_ID" "$HEAD_BEFORE" "$START_TIME" &
            MONITOR_PID=$!
            register_child_pid $MONITOR_PID

            _SF_INVOCATION_START=$(date +%s)
            export _SF_INVOCATION_START

            set +e
            invoke_anthropic_api "$PROMPT" "$SCENE_MODEL" "$SCENE_LOG" 8192
            EXIT_CODE=$?
            set -e

            # Stop the monitor
            kill "$MONITOR_PID" 2>/dev/null || true
            wait "$MONITOR_PID" 2>/dev/null || true

            # Extract response and write scene file
            if (( EXIT_CODE == 0 )); then
                _extract_scene_from_response "$SCENE_LOG" "$SCENE_FILE"
            fi

            # Log usage/cost data
            log_api_usage "$SCENE_LOG" "draft" "$SCENE_ID" "$SCENE_MODEL"
        else
            # --- Headless interactive (offer_interactive switched to headless) ---
            SCENE_MODEL=$(select_model "drafting")
            log "Invoking API for scene ${SCENE_ID} (model: ${SCENE_MODEL})..."
            log "  Per-scene log: ${SCENE_LOG}"

            # Start background monitor
            monitor_progress "$SCENE_ID" "$HEAD_BEFORE" "$START_TIME" &
            MONITOR_PID=$!
            register_child_pid $MONITOR_PID

            _SF_INVOCATION_START=$(date +%s)
            export _SF_INVOCATION_START

            set +e
            invoke_anthropic_api "$PROMPT" "$SCENE_MODEL" "$SCENE_LOG" 16384
            EXIT_CODE=$?
            set -e

            # Stop the monitor
            kill "$MONITOR_PID" 2>/dev/null || true
            wait "$MONITOR_PID" 2>/dev/null || true

            # Extract response and write scene file
            if (( EXIT_CODE == 0 )); then
                _extract_scene_from_response "$SCENE_LOG" "$SCENE_FILE"
            fi

            # Log usage/cost data
            log_api_usage "$SCENE_LOG" "draft" "$SCENE_ID" "$SCENE_MODEL"
        fi

        # --- Timing ---
        END_TIME=$(date +%s)
        DURATION=$(( END_TIME - START_TIME ))
        MINUTES=$(( DURATION / 60 ))
        SECS=$(( DURATION % 60 ))

        if (( EXIT_CODE != 0 )); then
            log "ERROR: API call failed with code ${EXIT_CODE} for scene ${SCENE_ID} after ${MINUTES}m${SECS}s"
            log "See full output: ${SCENE_LOG}"
            log "Stopping — continuity may be broken."
            false  # Trigger healing
        fi

        # --- Verify and commit ---
        verify_and_commit_scene "$SCENE_ID" "$SCENE_LOG" "$HEAD_BEFORE"

        end_healing_zone

        log "  Time: ${MINUTES}m${SECS}s"

        # --- Pause between scenes (headless only) ---
        if (( i < ${#PENDING_IDS[@]} - 1 )) && [[ ! -f "$INTERACTIVE_FILE" ]]; then
            log "Pausing 10s before next scene..."
            sleep 10
        fi
    done
fi

# Clean up interactive file
rm -f "$INTERACTIVE_FILE"

# ============================================================================
# Session complete
# ============================================================================

SESSION_END=$(date +%s)
SESSION_DURATION=$(( SESSION_END - SESSION_START ))
SESSION_MINS=$(( SESSION_DURATION / 60 ))
SESSION_SECS=$(( SESSION_DURATION % 60 ))

log "============================================"
log "Drafting session complete!"
log "Scenes drafted: ${DRAFTED_COUNT}/${#PENDING_IDS[@]}"
log "Total words: ${TOTAL_WORDS}"
log "Total time: ${SESSION_MINS}m${SESSION_SECS}s"
log "============================================"

# --- Cost summary ---
if [[ "$DRY_RUN" != true && $DRAFTED_COUNT -gt 0 ]]; then
    print_cost_summary "draft"
fi

# --- Review phase ---
if [[ "$DRY_RUN" != true && $DRAFTED_COUNT -gt 0 ]]; then
    run_review_phase "drafting" "$PROJECT_DIR"
fi

#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-write — Autonomous scene drafting for Storyforge projects
#
# One claude -p invocation per scene. Each invocation reads all reference
# material, drafts the scene, runs a quality review, updates continuity,
# and commits to git.
#
# Usage:
#   ./storyforge-write                        # Draft all remaining scenes
#   ./storyforge-write act1-sc01              # Draft a single scene
#   ./storyforge-write act1-sc01 act1-sc15    # Draft a range (by position in index)
#   ./storyforge-write --act 2                # Draft all scenes in act 2
#   ./storyforge-write --part 2               # Draft all scenes in part 2
#   ./storyforge-write --dry-run act1-sc01    # Build prompt without invoking Claude
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi
if [[ ! -f "${LIB_DIR}/prompt-builder.sh" ]]; then
    echo "ERROR: Cannot find lib/prompt-builder.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"
# shellcheck source=lib/prompt-builder.sh
source "${LIB_DIR}/prompt-builder.sh"

# --- Detect project root ---
detect_project_root
log "Project root: ${PROJECT_DIR}"

# --- Configuration ---
SCENE_INDEX="${PROJECT_DIR}/scenes/scene-index.yaml"
SCENES_DIR="${PROJECT_DIR}/scenes"
LOG_DIR="${PROJECT_DIR}/working/logs"
LOG_FILE="${LOG_DIR}/drafting-log.txt"
export LOG_FILE

# Optional: uncomment and set a per-scene budget limit
# BUDGET_FLAG="--max-budget-usd 20"
BUDGET_FLAG=""

# Ensure directories exist
mkdir -p "$SCENES_DIR" "$LOG_DIR"
mkdir -p "${PROJECT_DIR}/working/coaching"

# ============================================================================
# Argument parsing
# ============================================================================

DRY_RUN=false
INTERACTIVE=false
COACHING_LEVEL=""
FILTER_MODE="all"       # all | single | range | act | part
FILTER_VALUE=""
RANGE_START=""
RANGE_END=""

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Draft scenes autonomously using Claude.

Options:
  (no args)                   Draft all remaining (pending) scenes
  SCENE_ID                    Draft a single scene
  SCENE_ID SCENE_ID           Draft a range of scenes (inclusive, by index position)
  --act N                     Draft all scenes in act N
  --part N                    Draft all scenes in part N
  --coaching LEVEL            Set coaching level: full, coach, or strict
  --interactive               Draft with supervision — watch, give feedback, redirect
  --dry-run                   Build prompts without invoking Claude
  -h, --help                  Show this help

Environment:
  STORYFORGE_MODEL            Override model (default: opus for drafting)
  STORYFORGE_COACHING         Override coaching level (default: from storyforge.yaml or full)
  STORYFORGE_REJOIN_TIMEOUT   Seconds to wait for 'i' keypress in autopilot (default: 5)

Examples:
  $(basename "$0")
  $(basename "$0") act1-sc05
  $(basename "$0") --interactive
  $(basename "$0") --act 2
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --coaching)
            COACHING_LEVEL="${2:?ERROR: --coaching requires a value (full, coach, or strict)}"
            case "$COACHING_LEVEL" in
                full|coach|strict) ;;
                *) echo "ERROR: Invalid coaching level '${COACHING_LEVEL}'. Must be full, coach, or strict." >&2; exit 1 ;;
            esac
            shift 2
            ;;
        --interactive|-i)
            INTERACTIVE=true
            shift
            ;;
        --act)
            FILTER_MODE="act"
            FILTER_VALUE="${2:?ERROR: --act requires a value}"
            shift 2
            ;;
        --part)
            FILTER_MODE="part"
            FILTER_VALUE="${2:?ERROR: --part requires a value}"
            shift 2
            ;;
        -*)
            echo "ERROR: Unknown option: $1" >&2
            usage
            ;;
        *)
            if [[ -z "$RANGE_START" ]]; then
                RANGE_START="$1"
                FILTER_MODE="single"
            elif [[ "$FILTER_MODE" == "single" ]]; then
                RANGE_END="$1"
                FILTER_MODE="range"
            else
                echo "ERROR: Too many positional arguments" >&2
                usage
            fi
            shift
            ;;
    esac
done

# ============================================================================
# Coaching level
# ============================================================================

if [[ -n "$COACHING_LEVEL" ]]; then
    STORYFORGE_COACHING="$COACHING_LEVEL"
    export STORYFORGE_COACHING
fi

# Resolve effective coaching level for conditional logic in this script
EFFECTIVE_COACHING=$(get_coaching_level)

# ============================================================================
# Prerequisites
# ============================================================================

check_file_exists "$SCENE_INDEX" "Scene index (scene-index.yaml)"

# Voice guide — check common locations
VOICE_GUIDE_FOUND=false
for vg in "reference/voice-guide.md" "reference/persistent-prompt.md"; do
    if [[ -f "${PROJECT_DIR}/${vg}" ]]; then
        VOICE_GUIDE_FOUND=true
        break
    fi
done

# Also check storyforge.yaml for a custom voice guide path
CUSTOM_VG=$(read_yaml_field "reference.voice_guide" 2>/dev/null || true)
if [[ -z "$CUSTOM_VG" ]]; then
    CUSTOM_VG=$(read_yaml_field "voice_guide" 2>/dev/null || true)
fi
if [[ -n "$CUSTOM_VG" && -f "${PROJECT_DIR}/${CUSTOM_VG}" ]]; then
    VOICE_GUIDE_FOUND=true
fi

if [[ "$VOICE_GUIDE_FOUND" == false ]]; then
    log "WARNING: No voice guide found. Drafting will proceed without voice constraints."
    log "  Expected: reference/voice-guide.md or reference/persistent-prompt.md"
fi

# ============================================================================
# Build scene list — CSV-first with YAML fallback
# ============================================================================

METADATA_CSV="${SCENES_DIR}/metadata.csv"
CSV_MODE=false

ALL_SCENE_IDS=()
if [[ -f "$METADATA_CSV" ]]; then
    CSV_MODE=true
    # Read scene IDs from metadata.csv, sorted by seq column, filtering out cut status
    while IFS= read -r id; do
        [[ -z "$id" ]] && continue
        local_status=$(get_csv_field "$METADATA_CSV" "$id" "status")
        if [[ "$local_status" != "cut" ]]; then
            ALL_SCENE_IDS+=("$id")
        fi
    done < <(awk -F'|' '
        NR == 1 {
            for (i = 1; i <= NF; i++) {
                if ($i == "seq") seq_col = i
            }
            next
        }
        seq_col { print $1 "|" $seq_col }
    ' "$METADATA_CSV" | sort -t'|' -k2 -n | cut -d'|' -f1)
    log "Found ${#ALL_SCENE_IDS[@]} scenes in metadata.csv (CSV mode)"
else
    # YAML fallback
    while IFS= read -r id; do
        [[ -z "$id" ]] && continue
        ALL_SCENE_IDS+=("$id")
    done < <(grep -E '^[[:space:]]*- id:[[:space:]]*' "$SCENE_INDEX" \
        | sed 's/^[[:space:]]*- id:[[:space:]]*//' \
        | sed 's/[[:space:]]*$//')
    log "Found ${#ALL_SCENE_IDS[@]} scenes in scene-index.yaml (YAML mode)"
fi

if [[ ${#ALL_SCENE_IDS[@]} -eq 0 ]]; then
    log "ERROR: No scenes found in ${METADATA_CSV:-$SCENE_INDEX}"
    exit 1
fi

# ============================================================================
# Filter scenes based on arguments
# ============================================================================

FILTERED_IDS=()

case "$FILTER_MODE" in
    all)
        FILTERED_IDS=("${ALL_SCENE_IDS[@]}")
        ;;

    single)
        # Verify the scene exists in the index
        found=false
        for id in "${ALL_SCENE_IDS[@]}"; do
            if [[ "$id" == "$RANGE_START" ]]; then
                found=true
                break
            fi
        done
        if [[ "$found" == false ]]; then
            log "ERROR: Scene '${RANGE_START}' not found in scene-index.yaml"
            exit 1
        fi
        FILTERED_IDS=("$RANGE_START")
        ;;

    range)
        # Collect all scenes between RANGE_START and RANGE_END (inclusive)
        in_range=false
        for id in "${ALL_SCENE_IDS[@]}"; do
            if [[ "$id" == "$RANGE_START" ]]; then
                in_range=true
            fi
            if [[ "$in_range" == true ]]; then
                FILTERED_IDS+=("$id")
            fi
            if [[ "$id" == "$RANGE_END" ]]; then
                break
            fi
        done
        if [[ ${#FILTERED_IDS[@]} -eq 0 ]]; then
            log "ERROR: Could not find range ${RANGE_START} to ${RANGE_END} in scene-index.yaml"
            exit 1
        fi
        ;;

    act)
        # Match scenes whose ID starts with "act{N}" (case-insensitive)
        local_pattern="act${FILTER_VALUE}"
        for id in "${ALL_SCENE_IDS[@]}"; do
            if [[ "${id,,}" == "${local_pattern,,}"* ]]; then
                FILTERED_IDS+=("$id")
            fi
        done
        if [[ ${#FILTERED_IDS[@]} -eq 0 ]]; then
            log "ERROR: No scenes found matching act ${FILTER_VALUE}"
            exit 1
        fi
        ;;

    part)
        # Match scenes whose ID starts with "part{N}" or whose metadata has part: N
        local_pattern="part${FILTER_VALUE}"
        for id in "${ALL_SCENE_IDS[@]}"; do
            if [[ "${id,,}" == "${local_pattern,,}"* ]]; then
                FILTERED_IDS+=("$id")
            else
                # Check metadata for part field
                local_part=$(read_scene_field "$id" "$PROJECT_DIR" "part" 2>/dev/null || true)
                if [[ "$local_part" == "$FILTER_VALUE" ]]; then
                    FILTERED_IDS+=("$id")
                fi
            fi
        done
        if [[ ${#FILTERED_IDS[@]} -eq 0 ]]; then
            log "ERROR: No scenes found matching part ${FILTER_VALUE}"
            exit 1
        fi
        ;;
esac

# ============================================================================
# Filter out already-drafted scenes (unless explicitly targeting a single scene)
# ============================================================================

PENDING_IDS=()
SKIPPED=0

for id in "${FILTERED_IDS[@]}"; do
    status=$(get_scene_status "$id" "$PROJECT_DIR")
    case "$status" in
        drafted|revised|final)
            if [[ "$FILTER_MODE" == "single" ]]; then
                # User explicitly requested this scene — include it
                PENDING_IDS+=("$id")
                log "NOTE: Scene ${id} has status '${status}' but was explicitly requested"
            else
                SKIPPED=$((SKIPPED + 1))
            fi
            ;;
        *)
            PENDING_IDS+=("$id")
            ;;
    esac
done

if [[ ${#PENDING_IDS[@]} -eq 0 ]]; then
    log "Nothing to draft — all ${#FILTERED_IDS[@]} matching scenes are already drafted (${SKIPPED} skipped)."
    exit 0
fi

# ============================================================================
# Cost forecasting
# ============================================================================

if [[ "$DRY_RUN" != true && "$CSV_MODE" == true ]]; then
    # Calculate average word count from metadata.csv
    AVG_WORDS=$(awk -F'|' '
        NR == 1 {
            for (i = 1; i <= NF; i++) {
                if ($i == "target_words") col = i
            }
            next
        }
        col && $col+0 > 0 { sum += $col; count++ }
        END { if (count > 0) printf "%d", sum / count; else print 2000 }
    ' "$METADATA_CSV")
    FORECAST_MODEL=$(select_model "drafting")
    ESTIMATED_COST=$(estimate_cost "draft" "${#PENDING_IDS[@]}" "$AVG_WORDS" "$FORECAST_MODEL")
    log "Cost forecast: ~\$${ESTIMATED_COST} for ${#PENDING_IDS[@]} scenes (avg ${AVG_WORDS} words, model ${FORECAST_MODEL})"
    if ! check_cost_threshold "$ESTIMATED_COST"; then
        log "Aborting — cost threshold exceeded."
        exit 0
    fi
fi

# Set up interactive mode file
INTERACTIVE_FILE="${PROJECT_DIR}/working/.interactive"
rm -f "$INTERACTIVE_FILE"
if [[ "$INTERACTIVE" == true ]]; then
    touch "$INTERACTIVE_FILE"
fi

# ============================================================================
# Session start
# ============================================================================

SESSION_START=$(date +%s)

# --- Branch + PR setup ---
if [[ "$DRY_RUN" != true ]]; then
    create_branch "write" "$PROJECT_DIR"

    # Advance project phase before pushing — gives the branch an initial commit
    CURRENT_PHASE=$(read_yaml_field "phase" 2>/dev/null || echo "")
    if [[ "$CURRENT_PHASE" != "drafting" && "$CURRENT_PHASE" != "evaluation" && "$CURRENT_PHASE" != "revision" && "$CURRENT_PHASE" != "complete" ]]; then
        sed -i '' "s/^[[:space:]]*phase:.*/phase: drafting/" "${PROJECT_DIR}/storyforge.yaml" 2>/dev/null || true
        log "Project phase advanced to: drafting"
    fi

    ensure_branch_pushed "$PROJECT_DIR"

    WRITE_TITLE=$(read_yaml_field 'project.title' 2>/dev/null || read_yaml_field 'title' 2>/dev/null || echo 'Unknown')
    PR_BODY="## Drafting Session

**Project:** ${WRITE_TITLE}
**Scenes to draft:** ${#PENDING_IDS[@]}

### Tasks
"
    for id in "${PENDING_IDS[@]}"; do
        PR_BODY="${PR_BODY}- [ ] Draft scene ${id}
"
    done
    PR_BODY="${PR_BODY}- [ ] Review"

    create_draft_pr "Draft: ${WRITE_TITLE} (${#PENDING_IDS[@]} scenes)" "$PR_BODY" "$PROJECT_DIR" "drafting"
fi

log "============================================"
log "Starting Storyforge drafting session"
log "Project: $(read_yaml_field 'project.title' 2>/dev/null || read_yaml_field 'title' 2>/dev/null || echo 'Unknown')"
log "Coaching level: ${EFFECTIVE_COACHING}"
log "Scenes to draft: ${#PENDING_IDS[@]} (${SKIPPED} already-drafted skipped)"
log "Scene list: ${PENDING_IDS[*]}"
log "============================================"

# ============================================================================
# Main drafting loop
# ============================================================================

DRAFTED_COUNT=0
TOTAL_WORDS=0

for (( i=0; i<${#PENDING_IDS[@]}; i++ )); do
    SCENE_ID="${PENDING_IDS[$i]}"
    SCENE_FILE="${SCENES_DIR}/${SCENE_ID}.md"
    SCENE_NUM=$((i + 1))

    log "--- Scene ${SCENE_ID} (${SCENE_NUM}/${#PENDING_IDS[@]}) ---"

    # --- Check if scene file already has substantial content (defensive) ---
    if [[ -f "$SCENE_FILE" && "$FILTER_MODE" != "single" ]]; then
        existing_wc=$(wc -w < "$SCENE_FILE" 2>/dev/null | tr -d ' ')
        if (( existing_wc > 200 )); then
            log "Scene file already has ${existing_wc} words, skipping"
            continue
        fi
    fi

    # --- Build the prompt (outside zone — needed for dry-run check) ---
    PROMPT=$(build_scene_prompt "$SCENE_ID" "$PROJECT_DIR")

    if [[ -z "$PROMPT" ]]; then
        log "ERROR: Failed to build prompt for scene ${SCENE_ID}"
        log "Stopping — prompt generation failed."
        exit 1
    fi

    # --- Dry-run mode: print prompt and continue (outside zone) ---
    if [[ "$DRY_RUN" == true ]]; then
        echo "===== DRY RUN: ${SCENE_ID} ====="
        echo "$PROMPT"
        echo "===== END DRY RUN: ${SCENE_ID} ====="
        echo ""
        DRAFTED_COUNT=$((DRAFTED_COUNT + 1))
        continue
    fi

    # --- Check interactive mode (outside zone) ---
    # Offer mode switch if currently headless (including before first step)
    if [[ ! -f "$INTERACTIVE_FILE" ]]; then
        offer_interactive "$PROJECT_DIR" "${SCENE_ID} (${SCENE_NUM}/${#PENDING_IDS[@]})" || true
    fi

    # --- Healing zone: invoke → verify → commit ---
    begin_healing_zone "drafting scene ${SCENE_ID} (${SCENE_NUM}/${#PENDING_IDS[@]})"

    # --- Record git HEAD before invocation ---
    HEAD_BEFORE=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")

    # --- Per-scene log file ---
    SCENE_LOG="${LOG_DIR}/drafting-${SCENE_ID}.log"

    START_TIME=$(date +%s)

    if [[ -f "$INTERACTIVE_FILE" ]]; then
        # --- Interactive mode ---
        show_interactive_banner "Scene ${SCENE_NUM} of ${#PENDING_IDS[@]}" "multi"

        INTERACTIVE_SYSTEM=$(build_interactive_system_prompt "$PROJECT_DIR" "scene")
        SCENE_MODEL=$(select_model "drafting")

        set +e
        claude "$PROMPT" \
            --model "$SCENE_MODEL" \
            --dangerously-skip-permissions \
            --append-system-prompt "$INTERACTIVE_SYSTEM"
        EXIT_CODE=$?
        set -e
    else
        # --- Headless mode ---
        SCENE_MODEL=$(select_model "drafting")
        log "Invoking claude for scene ${SCENE_ID} (model: ${SCENE_MODEL})..."
        log "  Per-scene log: ${SCENE_LOG} (tail -f for live output)"

        # Start background monitor
        monitor_progress "$SCENE_ID" "$HEAD_BEFORE" "$START_TIME" &
        MONITOR_PID=$!
        register_child_pid $MONITOR_PID

        _SF_INVOCATION_START=$(date +%s)
        set +e
        claude -p "$PROMPT" \
            --model "$SCENE_MODEL" \
            --dangerously-skip-permissions \
            --output-format stream-json \
            --verbose \
            $BUDGET_FLAG \
            > "$SCENE_LOG" 2>&1
        EXIT_CODE=$?
        set -e

        # Stop the monitor
        kill "$MONITOR_PID" 2>/dev/null || true
        wait "$MONITOR_PID" 2>/dev/null || true

        # Log usage/cost data
        log_usage "$SCENE_LOG" "draft" "$SCENE_ID" "$SCENE_MODEL"
    fi

    # --- Timing ---
    END_TIME=$(date +%s)
    DURATION=$(( END_TIME - START_TIME ))
    MINUTES=$(( DURATION / 60 ))
    SECS=$(( DURATION % 60 ))

    if (( EXIT_CODE != 0 )); then
        log "ERROR: claude exited with code ${EXIT_CODE} for scene ${SCENE_ID} after ${MINUTES}m${SECS}s"
        log "See full output: ${SCENE_LOG}"
        log "Stopping — continuity may be broken."
        false  # Trigger healing
    fi

    # --- Verification ---

    if [[ "$EFFECTIVE_COACHING" == "coach" || "$EFFECTIVE_COACHING" == "strict" ]]; then
        # Coach/strict mode: check for coaching output instead of scene file
        if [[ "$EFFECTIVE_COACHING" == "coach" ]]; then
            COACHING_OUTPUT="${PROJECT_DIR}/working/coaching/brief-${SCENE_ID}.md"
        else
            COACHING_OUTPUT="${PROJECT_DIR}/working/coaching/constraints-${SCENE_ID}.md"
        fi

        if [[ ! -f "$COACHING_OUTPUT" ]]; then
            log "WARNING: Coaching output not created: ${COACHING_OUTPUT}"
            log "See full output: ${SCENE_LOG}"
        fi

        WORD_COUNT=0
        if [[ -f "$COACHING_OUTPUT" ]]; then
            WORD_COUNT=$(wc -w < "$COACHING_OUTPUT" | tr -d ' ')
        fi
    else
        # Full mode: check scene file was created
        # 1. Check scene file was created
        if [[ ! -f "$SCENE_FILE" ]]; then
            log "ERROR: Scene file not created: ${SCENE_FILE}"
            log "Claude ran successfully but did not produce the file."
            log "See full output: ${SCENE_LOG}"
            log "Stopping — cannot continue without the scene."
            false  # Trigger healing
        fi

        # 2. Get word count and sanity-check
        WORD_COUNT=$(wc -w < "$SCENE_FILE" | tr -d ' ')

        if (( WORD_COUNT < 100 )); then
            log "ERROR: Scene file suspiciously short (${WORD_COUNT} words): ${SCENE_FILE}"
            log "See full output: ${SCENE_LOG}"
            log "Stopping — likely incomplete draft."
            false  # Trigger healing
        fi

        # Update metadata.csv with word count and status
        if [[ "$CSV_MODE" == true ]]; then
            update_csv_field "$METADATA_CSV" "$SCENE_ID" "word_count" "$WORD_COUNT"
            update_csv_field "$METADATA_CSV" "$SCENE_ID" "status" "drafted"
            log "Updated metadata.csv: ${SCENE_ID} word_count=${WORD_COUNT} status=drafted"
        fi
    fi

    # 3. Check/create git commit
    HEAD_AFTER=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")

    if [[ "$HEAD_BEFORE" == "$HEAD_AFTER" ]]; then
        log "WARNING: No git commit detected. Attempting manual commit..."
        (
            cd "$PROJECT_DIR"
            if [[ "$EFFECTIVE_COACHING" == "coach" || "$EFFECTIVE_COACHING" == "strict" ]]; then
                git add working/coaching/ 2>/dev/null || true
                git add working/logs/ 2>/dev/null || true
                git commit -m "${EFFECTIVE_COACHING^}: ${SCENE_ID}" 2>/dev/null || true
            else
                git add "scenes/${SCENE_ID}.md" 2>/dev/null || true
                git add reference/ 2>/dev/null || true
                git add working/logs/ 2>/dev/null || true
                git commit -m "Draft scene ${SCENE_ID}" 2>/dev/null || true
            fi
        )
        HEAD_AFTER=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")

        if [[ "$HEAD_BEFORE" == "$HEAD_AFTER" ]]; then
            log "ERROR: Could not create git commit for scene ${SCENE_ID}"
            log "Stopping — next scene needs committed state."
            false  # Trigger healing
        fi
        log "Manual commit created."
    fi

    end_healing_zone

    COMMIT_SHORT=$(git -C "$PROJECT_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")

    # 4. Push to remote (warn on failure, don't stop)
    if ! git -C "$PROJECT_DIR" push 2>/dev/null; then
        log "WARNING: git push failed for scene ${SCENE_ID} (commit ${COMMIT_SHORT}). Continuing."
    fi

    # --- Success ---
    DRAFTED_COUNT=$((DRAFTED_COUNT + 1))
    TOTAL_WORDS=$((TOTAL_WORDS + WORD_COUNT))
    log "SUCCESS: Scene ${SCENE_ID} — ${WORD_COUNT} words, ${MINUTES}m${SECS}s, commit ${COMMIT_SHORT}"
    update_pr_task "Draft scene ${SCENE_ID}" "$PROJECT_DIR"

    # --- Pause between scenes (headless only) ---
    if (( i < ${#PENDING_IDS[@]} - 1 )) && [[ ! -f "$INTERACTIVE_FILE" ]]; then
        log "Pausing 10s before next scene..."
        sleep 10
    fi
done

# Clean up interactive file
rm -f "$INTERACTIVE_FILE"

# ============================================================================
# Session complete
# ============================================================================

SESSION_END=$(date +%s)
SESSION_DURATION=$(( SESSION_END - SESSION_START ))
SESSION_MINS=$(( SESSION_DURATION / 60 ))
SESSION_SECS=$(( SESSION_DURATION % 60 ))

log "============================================"
log "Drafting session complete!"
log "Scenes drafted: ${DRAFTED_COUNT}/${#PENDING_IDS[@]}"
log "Total words: ${TOTAL_WORDS}"
log "Total time: ${SESSION_MINS}m${SESSION_SECS}s"
log "============================================"

# --- Cost summary ---
if [[ "$DRY_RUN" != true && $DRAFTED_COUNT -gt 0 ]]; then
    print_cost_summary "draft"
fi

# --- Review phase ---
if [[ "$DRY_RUN" != true && $DRAFTED_COUNT -gt 0 ]]; then
    run_review_phase "drafting" "$PROJECT_DIR"
fi

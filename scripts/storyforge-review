#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-review — Run a pipeline review for the current branch
#
# Standalone entry point for the review phase. Can be run interactively
# or as part of an autonomous pipeline. Finds the PR for the current
# branch (if any), runs a Claude-powered quality review, posts results
# as a PR comment, and updates labels.
#
# Usage:
#   ./storyforge review                    # Auto-detect review type
#   ./storyforge review --type drafting    # Specify review type
#   ./storyforge review --dry-run          # Show what would be done
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# --- Detect project root ---
detect_project_root
log "Project root: ${PROJECT_DIR}"

# --- Configuration ---
LOG_DIR="${PROJECT_DIR}/working/logs"
LOG_FILE="${LOG_DIR}/review-log.txt"
export LOG_FILE

mkdir -p "$LOG_DIR"

# ============================================================================
# Argument parsing
# ============================================================================

DRY_RUN=false
export DRY_RUN
INTERACTIVE=false
export INTERACTIVE
REVIEW_TYPE="manual"

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Run a pipeline review for the current branch.

Options:
  --type TYPE         Review type: drafting, evaluation, revision, assembly, manual (default: manual)
  --interactive       Run the review interactively — discuss findings with Claude
  --dry-run           Show what would be done without doing it
  -h, --help          Show this help

Environment:
  STORYFORGE_MODEL    Override model selection (e.g., claude-opus-4-6)

The review reads all changed files on the current branch, assesses quality,
saves a review to working/reviews/, and (if a PR exists) posts the review
as a PR comment and updates labels.

Examples:
  $(basename "$0")
  $(basename "$0") --type revision
  $(basename "$0") --interactive
  $(basename "$0") --dry-run
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --interactive|-i)
            INTERACTIVE=true
            shift
            ;;
        --type)
            REVIEW_TYPE="${2:?ERROR: --type requires a value (drafting, evaluation, revision, assembly, manual)}"
            shift 2
            ;;
        -*)
            echo "ERROR: Unknown option: $1" >&2
            usage
            ;;
        *)
            echo "ERROR: Unexpected argument: $1" >&2
            usage
            ;;
    esac
done

# ============================================================================
# Detect branch and PR context
# ============================================================================

BRANCH=$(current_branch "$PROJECT_DIR")

if [[ -z "$BRANCH" ]]; then
    log "ERROR: Not in a git repository"
    exit 1
fi

log "Branch: ${BRANCH}"

# Auto-detect review type from branch name if not specified
if [[ "$REVIEW_TYPE" == "manual" && "$BRANCH" == storyforge/* ]]; then
    branch_command="${BRANCH#storyforge/}"
    branch_command="${branch_command%%-*}"
    case "$branch_command" in
        write)    REVIEW_TYPE="drafting" ;;
        evaluate) REVIEW_TYPE="evaluation" ;;
        revise)   REVIEW_TYPE="revision" ;;
        assemble) REVIEW_TYPE="assembly" ;;
    esac
    if [[ "$REVIEW_TYPE" != "manual" ]]; then
        log "Auto-detected review type: ${REVIEW_TYPE} (from branch name)"
    fi
fi

# Try to find associated PR
STORYFORGE_PR_NUMBER=""
if has_gh; then
    STORYFORGE_PR_NUMBER=$(cd "$PROJECT_DIR" && gh pr view --json number --jq '.number' 2>/dev/null || echo "")
    if [[ -n "$STORYFORGE_PR_NUMBER" ]]; then
        log "Found PR #${STORYFORGE_PR_NUMBER}"
    else
        log "No PR found for branch ${BRANCH}"
    fi
fi
export STORYFORGE_PR_NUMBER

# Set up interactive mode file
INTERACTIVE_FILE="${PROJECT_DIR}/working/.interactive"
if [[ "$INTERACTIVE" == true ]]; then
    touch "$INTERACTIVE_FILE"
fi

# ============================================================================
# Run review
# ============================================================================

log "============================================"
log "Storyforge Pipeline Review"
log "Project: $(read_yaml_field 'project.title' 2>/dev/null || echo 'Unknown')"
log "Type: ${REVIEW_TYPE}"
log "Branch: ${BRANCH}"
if [[ -n "$STORYFORGE_PR_NUMBER" ]]; then
    log "PR: #${STORYFORGE_PR_NUMBER}"
fi
log "============================================"

run_review_phase "$REVIEW_TYPE" "$PROJECT_DIR"

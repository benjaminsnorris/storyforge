#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-revise — Execute revision passes from a revision plan
#
# Reads working/plans/revision-plan.yaml and executes each pass in order.
# All passes run autonomously via `claude -p`. Creative decisions are
# documented as guidance entries in the plan — the author steers by editing
# guidance before execution or by redirecting after reviewing output.
#
# Progress is tracked durably in the YAML — the script updates pass status
# after each step so it can resume cleanly after restarts.
#
# Usage:
#   storyforge-revise            # Start from first pending pass
#   storyforge-revise 3          # Start from pass number 3 (1-indexed)
#   storyforge-revise --dry-run  # Print prompts without invoking Claude
# ============================================================================

# --- Resolve script and library paths ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"
PYTHON_LIB="${SCRIPT_DIR}/lib/python"

# Source shared libraries
source "${LIB_DIR}/common.sh"

# --- Detect project root ---
detect_project_root
# PROJECT_DIR is now set and exported

# --- Pipeline manifest: resolve plan file for current cycle ---
ensure_pipeline_manifest
CYCLE_ID=$(get_current_cycle)
PLAN_FILE=$(get_cycle_plan_file "$CYCLE_ID")

# Fallback: if manifest has no plan and legacy file exists, use it
if [[ ! -f "$PLAN_FILE" && -f "${PROJECT_DIR}/working/plans/revision-plan.yaml" ]]; then
    PLAN_FILE="${PROJECT_DIR}/working/plans/revision-plan.yaml"
fi

# --- Check for CSV revision plan (CSV-first, YAML fallback) ---
CSV_PLAN_FILE="${PROJECT_DIR}/working/plans/revision-plan.csv"
USE_CSV_PLAN=false
if [[ -f "$CSV_PLAN_FILE" ]]; then
    USE_CSV_PLAN=true
    log "Using CSV revision plan: ${CSV_PLAN_FILE}"
elif [[ -f "$PLAN_FILE" ]]; then
    log "DEPRECATION: Using YAML revision plan. Migrate to working/plans/revision-plan.csv."
fi

LOG_DIR="${PROJECT_DIR}/working/logs"
LOG_FILE="${LOG_DIR}/revision-log.txt"
export LOG_FILE

mkdir -p "$LOG_DIR"

# --- Arguments ---
DRY_RUN=false
INTERACTIVE=false
COACHING_LEVEL=""
START_PASS=0  # 0 means "find first pending"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --coaching)
            COACHING_LEVEL="${2:?ERROR: --coaching requires a value (full, coach, or strict)}"
            case "$COACHING_LEVEL" in
                full|coach|strict) ;;
                *) echo "ERROR: Invalid coaching level '${COACHING_LEVEL}'. Must be full, coach, or strict." >&2; exit 1 ;;
            esac
            shift 2
            ;;
        --interactive|-i)
            INTERACTIVE=true
            shift
            ;;
        -h|--help)
            echo "Usage: storyforge-revise [--dry-run] [--interactive] [--coaching LEVEL] [PASS_NUM]"
            echo ""
            echo "Options:"
            echo "  --dry-run       Build and print prompts without invoking Claude"
            echo "  --interactive   Supervise each pass — watch, give feedback, redirect"
            echo "  --coaching LVL  Set coaching level: full, coach, or strict"
            echo "  PASS_NUM        Start from this pass number (1-indexed; default: first pending)"
            echo ""
            echo "Environment:"
            echo "  ANTHROPIC_API_KEY           Required for non-interactive mode"
            echo "  STORYFORGE_MODEL            Override model (default: opus for creative, sonnet for mechanical)"
            echo "  STORYFORGE_COACHING         Override coaching level (default: from storyforge.yaml or full)"
            echo "  STORYFORGE_REJOIN_TIMEOUT   Seconds to wait for 'i' keypress in autopilot (default: 5)"
            exit 0
            ;;
        [0-9]*)
            START_PASS="$1"
            shift
            ;;
        *)
            echo "Error: Unknown argument '$1'" >&2
            exit 1
            ;;
    esac
done

# ============================================================================
# Coaching level
# ============================================================================

if [[ -n "$COACHING_LEVEL" ]]; then
    STORYFORGE_COACHING="$COACHING_LEVEL"
    export STORYFORGE_COACHING
fi

EFFECTIVE_COACHING=$(get_coaching_level)

# --- API key check for non-interactive mode ---
if [[ "$DRY_RUN" != true && "$INTERACTIVE" != true && -z "${ANTHROPIC_API_KEY:-}" ]]; then
    log "ERROR: ANTHROPIC_API_KEY not set. Required for direct API mode."
    log "  Set it with: export ANTHROPIC_API_KEY=your-key"
    log "  Or use --interactive to run via claude -p instead."
    exit 1
fi

# Ensure coaching directory exists
mkdir -p "${PROJECT_DIR}/working/coaching"

# ============================================================================
# CSV helpers for revision-plan.csv
#
# CSV format: id|name|purpose|scope|targets|guidance|protection|findings|status|model_tier
# The id column is the pass number (1, 2, 3, ...).
# ============================================================================

# Count passes in the CSV plan file.
count_csv_passes() {
    [[ -f "$CSV_PLAN_FILE" ]] || { echo "0"; return; }
    awk -F'|' 'NR > 1 { count++ } END { print count+0 }' "$CSV_PLAN_FILE"
}

# Read a field from a CSV pass by pass number.
# Usage: read_csv_pass_field 1 "name"
read_csv_pass_field() {
    local pass_num="$1"
    local field="$2"
    get_csv_field "$CSV_PLAN_FILE" "$pass_num" "$field" "pass"
}

# Update a field in the CSV plan for a given pass number.
# Usage: update_csv_pass_field 1 "status" "completed"
update_csv_pass_field() {
    local pass_num="$1"
    local field="$2"
    local value="$3"
    update_csv_field "$CSV_PLAN_FILE" "$pass_num" "$field" "$value" "pass"
}

# ============================================================================
# Unified accessors — dispatch to CSV or YAML depending on USE_CSV_PLAN
# ============================================================================

unified_count_passes() {
    if [[ "$USE_CSV_PLAN" == true ]]; then
        count_csv_passes
    else
        count_passes
    fi
}

unified_read_pass_field() {
    local pass_num="$1"
    local field="$2"
    if [[ "$USE_CSV_PLAN" == true ]]; then
        read_csv_pass_field "$pass_num" "$field"
    else
        read_pass_field "$pass_num" "$field"
    fi
}

unified_read_pass_scope() {
    local pass_num="$1"
    if [[ "$USE_CSV_PLAN" == true ]]; then
        read_csv_pass_field "$pass_num" "scope"
    else
        read_pass_scope "$pass_num"
    fi
}

unified_update_pass_field() {
    local pass_num="$1"
    local field="$2"
    local value="$3"
    if [[ "$USE_CSV_PLAN" == true ]]; then
        update_csv_pass_field "$pass_num" "$field" "$value"
    else
        update_pass_field "$pass_num" "$field" "$value"
    fi
}

# ============================================================================
# New scene registration
#
# When a revision pass creates new scenes (NEW: prefix in targets),
# this function adds rows to scene-metadata.csv and scene-intent.csv
# for any scenes that were actually written to disk.
# ============================================================================

_register_new_scenes() {
    local project_dir="$1"
    local targets="$2"
    local pass_name="$3"
    local meta_csv="${project_dir}/reference/scene-metadata.csv"
    local intent_csv="${project_dir}/reference/scene-intent.csv"

    # Extract NEW: prefixed scene IDs
    local new_ids=()
    IFS=';' read -ra target_parts <<< "$targets"
    for t in "${target_parts[@]}"; do
        t=$(echo "$t" | sed 's/^ *//;s/ *$//')
        if [[ "$t" == NEW:* ]]; then
            new_ids+=("${t#NEW:}")
        fi
    done

    (( ${#new_ids[@]} == 0 )) && return 0

    # Find the current max sequence number
    local max_seq=0
    if [[ -f "$meta_csv" ]]; then
        max_seq=$(tail -n +2 "$meta_csv" | cut -d'|' -f2 | sort -n | tail -1)
        max_seq=${max_seq:-0}
    fi

    local registered=0
    for sid in "${new_ids[@]}"; do
        local scene_file="${project_dir}/scenes/${sid}.md"

        # Only register if the scene file was actually created
        [[ -f "$scene_file" ]] || continue

        # Skip if already in metadata (idempotent)
        if [[ -f "$meta_csv" ]] && grep -q "^${sid}|" "$meta_csv"; then
            continue
        fi

        max_seq=$((max_seq + 1))
        local wc
        wc=$(wc -w < "$scene_file" | tr -d ' ')

        # Generate a title from the slug: the-rupture → The Rupture
        local title
        title=$(echo "$sid" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')

        # Append to scene-metadata.csv
        if [[ -f "$meta_csv" ]]; then
            append_csv_row "$meta_csv" "${sid}|${max_seq}|${title}|||||||drafted|${wc}|"
            log "  Registered new scene in metadata: ${sid} (seq ${max_seq})"
        fi

        # Append to scene-intent.csv
        if [[ -f "$intent_csv" ]]; then
            append_csv_row "$intent_csv" "${sid}|Created by revision pass: ${pass_name}|||||"
            log "  Registered new scene in intent: ${sid}"
        fi

        registered=$((registered + 1))
    done

    if (( registered > 0 )); then
        log "  Registered ${registered} new scene(s) in metadata and intent CSVs"
    fi
}

# ============================================================================
# YAML helpers for revision-plan.yaml
#
# The revision plan has nested YAML: top-level passes may contain subtasks
# with their own "- name:" entries. These helpers use indentation to
# distinguish top-level passes (shallow indent) from subtask entries.
# ============================================================================

# Extract the raw YAML block for the Nth top-level pass (1-indexed).
# Detects the indentation of the first pass entry and only treats entries
# at that same level as pass boundaries.
_get_pass_block() {
    local pass_num=$1
    awk -v target="$pass_num" '
        BEGIN { count = 0; found = 0; first_indent = -1 }
        /^passes:/ { in_passes = 1; next }
        !in_passes { next }
        /^[^ \t]/ { if (found) exit; in_passes = 0; next }
        /^[[:space:]]*-[[:space:]]+name:/ {
            match($0, /^[[:space:]]*/); indent = RLENGTH
            if (first_indent < 0) first_indent = indent
            if (indent == first_indent) {
                if (found) exit
                count++
                if (count == target) found = 1
            }
        }
        found { print }
    ' "$PLAN_FILE"
}

# Count the number of top-level passes in the plan.
count_passes() {
    awk '
        BEGIN { count = 0; first_indent = -1 }
        /^passes:/ { in_passes = 1; next }
        !in_passes { next }
        /^[^ \t]/ { exit }
        /^[[:space:]]*-[[:space:]]+name:/ {
            match($0, /^[[:space:]]*/); indent = RLENGTH
            if (first_indent < 0) first_indent = indent
            if (indent == first_indent) count++
        }
        END { print count + 0 }
    ' "$PLAN_FILE"
}

# Read a field from a specific pass (1-indexed).
# Usage: read_pass_field 2 "name"  =>  "voice-consistency"
# Handles both "field: value" and "- field: value" (list-start) formats.
read_pass_field() {
    local pass_num=$1
    local field="$2"

    local block
    block=$(_get_pass_block "$pass_num")

    # Extract the field value. The grep handles both:
    #   "    name: foo"     (regular mapping key)
    #   "  - name: foo"     (YAML list-start item)
    local value
    value=$(echo "$block" \
        | grep -E "^[[:space:]]+(- )?${field}:" \
        | head -1 \
        | sed "s/.*${field}:[[:space:]]*//" \
        | sed 's/^["'"'"']//' \
        | sed 's/["'"'"']$//' \
        | sed 's/[[:space:]]*$//'
    ) || true

    echo "$value"
}

# Read the scope for a specific pass, handling both string and YAML list formats.
# String format:  "scope: full"           => "full"
# List format:    "scope:\n  - a\n  - b"  => "a,b"
read_pass_scope() {
    local pass_num=$1

    local block
    block=$(_get_pass_block "$pass_num")

    # Try inline value first (e.g., "scope: full" or "scope: targeted")
    local inline
    inline=$(echo "$block" \
        | grep -E "^[[:space:]]+(- )?scope:" \
        | head -1 \
        | sed 's/.*scope:[[:space:]]*//' \
        | sed 's/^["'"'"']//' \
        | sed 's/["'"'"']$//' \
        | sed 's/[[:space:]]*$//'
    ) || true

    if [[ -n "$inline" ]]; then
        echo "$inline"
        return 0
    fi

    # Scope is a YAML list — collect items and return comma-separated
    local items="" in_scope=false
    while IFS= read -r line; do
        if [[ "$in_scope" == false ]]; then
            if echo "$line" | grep -qE "^[[:space:]]+scope:[[:space:]]*$"; then
                in_scope=true
            fi
            continue
        fi
        # Skip comment lines
        if echo "$line" | grep -qE "^[[:space:]]*#"; then
            continue
        fi
        # Collect list items
        if echo "$line" | grep -qE "^[[:space:]]+-[[:space:]]"; then
            local item
            item=$(echo "$line" \
                | sed 's/^[[:space:]]*-[[:space:]]*//' \
                | sed 's/^["'"'"']//' \
                | sed 's/["'"'"']$//' \
                | sed 's/[[:space:]]*$//')
            [[ -n "$item" ]] && items="${items:+${items},}${item}"
        else
            break
        fi
    done <<< "$block"

    echo "$items"
}

# Update a field for a specific pass (1-indexed) in revision-plan.yaml.
# Usage: update_pass_field 2 "status" "completed"
update_pass_field() {
    local pass_num=$1
    local field="$2"
    local new_value="$3"

    local tmp_file="${PLAN_FILE}.tmp"

    awk -v target="$pass_num" -v field="$field" -v newval="$new_value" '
    BEGIN { count = 0; in_passes = 0; found_block = 0; replaced = 0; first_indent = -1 }
    /^passes:/ { in_passes = 1; print; next }
    !in_passes { print; next }
    /^[^ \t]/ { in_passes = 0; found_block = 0; print; next }

    # Detect start of a new top-level pass entry (same indent as first)
    /^[[:space:]]*-[[:space:]]+name:/ {
        match($0, /^[[:space:]]*/); indent = RLENGTH
        if (first_indent < 0) first_indent = indent
        if (indent == first_indent) {
            count++
            found_block = (count == target) ? 1 : 0
            if (found_block) replaced = 0
        }
    }

    # If we are in the target block and find the field, replace it
    found_block && !replaced && $0 ~ "^[[:space:]]+" field ":" {
        match($0, /^[[:space:]]+/)
        indent_str = substr($0, RSTART, RLENGTH)
        print indent_str field ": " newval
        replaced = 1
        next
    }

    { print }
    ' "$PLAN_FILE" > "$tmp_file"

    mv "$tmp_file" "$PLAN_FILE"
}

# ============================================================================
# Background progress monitor (simplified)
# ============================================================================

# Poll every 30 seconds for heartbeat and commit detection.
# Usage: revision_monitor "pass-name" "$HEAD_BEFORE" "$START_TIME" &
revision_monitor() {
    local pass_name="$1"
    local head_before="$2"
    local start_time="$3"

    local commit_detected=false
    local ticks=0

    while true; do
        sleep 30
        ticks=$((ticks + 1))
        local elapsed=$(( $(date +%s) - start_time ))
        local mins=$(( elapsed / 60 ))

        # Git commit made?
        if [[ "$commit_detected" == false ]]; then
            local head_now
            head_now=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "")
            if [[ -n "$head_now" && "$head_now" != "$head_before" ]]; then
                commit_detected=true
                log "  [${pass_name}] Git commit detected [${mins}m]"
            fi
        fi

        # Check for scene file changes
        if (( ticks % 2 == 0 )); then
            local changed_count
            changed_count=$(git -C "$PROJECT_DIR" diff --name-only -- scenes/ 2>/dev/null | wc -l | tr -d ' ')
            if (( changed_count > 0 )); then
                log "  [${pass_name}] ${changed_count} scene file(s) modified [${mins}m]"
            fi
        fi

        # Heartbeat every 2 minutes (4 ticks x 30s)
        if (( ticks % 4 == 0 )); then
            log "  [${pass_name}] ${mins}m elapsed..."
        fi
    done
}

# ============================================================================
# Prerequisite checks
# ============================================================================

if [[ "$USE_CSV_PLAN" != true && ! -f "$PLAN_FILE" ]]; then
    log "ERROR: Revision plan not found at ${PLAN_FILE}"
    log "Run the storyforge-plan-revision skill first to create a revision plan."
    exit 1
fi

TOTAL_PASSES=$(unified_count_passes)

if (( TOTAL_PASSES == 0 )); then
    log "ERROR: No passes found in ${PLAN_FILE}"
    exit 1
fi

# ============================================================================
# Determine start point
# ============================================================================

if (( START_PASS == 0 )); then
    # Find the first pending or in_progress pass
    for (( i = 1; i <= TOTAL_PASSES; i++ )); do
        local_status=$(unified_read_pass_field "$i" "status")
        # Normalize common mismatch: "planned" should be "pending"
        if [[ "$local_status" == "planned" ]]; then
            log "WARNING: Pass $i has status 'planned' — normalizing to 'pending'"
            unified_update_pass_field "$i" "status" "pending"
            local_status="pending"
        fi
        if [[ "$local_status" == "pending" || "$local_status" == "in_progress" ]]; then
            START_PASS=$i
            break
        fi
        # Warn on unrecognized status values
        if [[ "$local_status" != "completed" && -n "$local_status" ]]; then
            log "WARNING: Pass $i has unrecognized status '${local_status}' — skipping"
        fi
    done

    if (( START_PASS == 0 )); then
        log "All passes are already completed. Nothing to do."
        exit 0
    fi
fi

if (( START_PASS < 1 || START_PASS > TOTAL_PASSES )); then
    log "ERROR: Pass number ${START_PASS} is out of range (1-${TOTAL_PASSES})"
    exit 1
fi

# ============================================================================
# Read project title for log messages
# ============================================================================

PROJECT_TITLE=$(read_yaml_field "project.title")
if [[ -z "$PROJECT_TITLE" ]]; then
    PROJECT_TITLE="(untitled project)"
fi

# Set up interactive mode file
INTERACTIVE_FILE="${PROJECT_DIR}/working/.interactive"
rm -f "$INTERACTIVE_FILE"
if [[ "$INTERACTIVE" == true ]]; then
    touch "$INTERACTIVE_FILE"
fi

# ============================================================================
# Main execution loop
# ============================================================================

# --- Branch + PR setup ---
if [[ "$DRY_RUN" != true ]]; then
    create_branch "revise" "$PROJECT_DIR"

    # Ensure phase is set to revision before pushing (gives the branch an initial commit)
    CURRENT_PHASE=$(read_yaml_field "phase" 2>/dev/null || echo "")
    if [[ "$CURRENT_PHASE" != "revision" ]]; then
        sed -i '' "s/^[[:space:]]*phase:.*/phase: revision/" "${PROJECT_DIR}/storyforge.yaml" 2>/dev/null || true
    fi

    ensure_branch_pushed "$PROJECT_DIR"

    TASK_CHECKLIST="### Progress
"
    for (( _i = 1; _i <= TOTAL_PASSES; _i++ )); do
        _pname=$(unified_read_pass_field "$_i" "name")
        TASK_CHECKLIST="${TASK_CHECKLIST}- [ ] Pass: ${_pname}
"
    done
    TASK_CHECKLIST="${TASK_CHECKLIST}- [ ] Review"

    PR_BODY="## Revision

**Project:** ${PROJECT_TITLE}
**Passes:** ${TOTAL_PASSES}

${TASK_CHECKLIST}"

    create_draft_pr "Revise: ${PROJECT_TITLE}" "$PR_BODY" "$PROJECT_DIR" "revision"

    # If the PR already existed (created by plan-revision skill), append the
    # task checklist to the existing body so progress can be tracked.
    if has_gh && [[ -n "${STORYFORGE_PR_NUMBER:-}" ]]; then
        existing_body=$(cd "$PROJECT_DIR" && gh pr view "$STORYFORGE_PR_NUMBER" --json body --jq '.body' 2>/dev/null || echo "")
        if [[ -n "$existing_body" && ! "$existing_body" =~ "### Progress" ]]; then
            updated_body="${existing_body}

---

${TASK_CHECKLIST}"
            (cd "$PROJECT_DIR" && gh pr edit "$STORYFORGE_PR_NUMBER" --body "$updated_body" 2>/dev/null) || {
                log "WARNING: Failed to update PR body with task checklist"
            }
            log "Updated PR #${STORYFORGE_PR_NUMBER} with task checklist"
        fi
    fi
fi

# Update pipeline cycle status to revising
if [[ "$DRY_RUN" != true && "$CYCLE_ID" != "0" ]]; then
    update_cycle_field "$CYCLE_ID" "status" "revising"
fi

log "============================================"
log "Storyforge Revision — ${PROJECT_TITLE}"
log "Plan: ${PLAN_FILE}"
log "Cycle: ${CYCLE_ID}"
log "Coaching level: ${EFFECTIVE_COACHING}"
log "Starting from pass: ${START_PASS} of ${TOTAL_PASSES}"
log "============================================"

# --- Cost forecast ---
if [[ "$DRY_RUN" != true ]]; then
    PENDING_PASSES=0
    for (( _fc = START_PASS; _fc <= TOTAL_PASSES; _fc++ )); do
        _fc_status=$(unified_read_pass_field "$_fc" "status")
        [[ "$_fc_status" != "completed" ]] && PENDING_PASSES=$((PENDING_PASSES + 1))
    done

    # Estimate average word count from metadata.csv or scene files
    METADATA_CSV="${PROJECT_DIR}/reference/scene-metadata.csv"
    [[ ! -f "$METADATA_CSV" ]] && METADATA_CSV="${PROJECT_DIR}/scenes/metadata.csv"
    AVG_WORDS=0
    if [[ -f "$METADATA_CSV" ]]; then
        TOTAL_WC=0
        WC_COUNT=0
        while IFS= read -r wc; do
            [[ -z "$wc" || "$wc" == "0" ]] && continue
            TOTAL_WC=$((TOTAL_WC + wc))
            WC_COUNT=$((WC_COUNT + 1))
        done < <(get_csv_column "$METADATA_CSV" "word_count")
        if (( WC_COUNT > 0 )); then
            AVG_WORDS=$((TOTAL_WC / WC_COUNT))
        fi
    fi
    if (( AVG_WORDS == 0 )); then
        # Estimate from scene files in scenes directory
        TOTAL_WC=0
        WC_COUNT=0
        for sf in "${PROJECT_DIR}"/scenes/*.md; do
            [[ -f "$sf" ]] || continue
            wc_val=$(wc -w < "$sf" | tr -d ' ')
            TOTAL_WC=$((TOTAL_WC + wc_val))
            WC_COUNT=$((WC_COUNT + 1))
        done
        if (( WC_COUNT > 0 )); then
            AVG_WORDS=$((TOTAL_WC / WC_COUNT))
        else
            AVG_WORDS=3000
        fi
        [[ $WC_COUNT -eq 0 ]] && WC_COUNT=1
    fi

    # Each pass reads all scenes in scope
    SCENE_COUNT="${WC_COUNT:-1}"
    REVISE_MODEL_FORECAST=$(select_revision_model "prose" "prose revision" 2>/dev/null || select_model "revision" 2>/dev/null || echo "sonnet")
    PER_PASS_COST=$(estimate_cost "revise" "$SCENE_COUNT" "$AVG_WORDS" "$REVISE_MODEL_FORECAST")
    TOTAL_FORECAST=$(awk "BEGIN { printf \"%.2f\", ${PER_PASS_COST} * ${PENDING_PASSES} }")

    log "Cost forecast: ~\$${TOTAL_FORECAST} (${PENDING_PASSES} passes @ ~\$${PER_PASS_COST})"
    check_cost_threshold "$TOTAL_FORECAST" || { log "Cost threshold check declined. Aborting."; exit 1; }
fi

for (( PASS_NUM = START_PASS; PASS_NUM <= TOTAL_PASSES; PASS_NUM++ )); do
    # --- Read pass configuration ---
    PASS_NAME=$(unified_read_pass_field "$PASS_NUM" "name")
    PASS_SCOPE=$(unified_read_pass_scope "$PASS_NUM")
    PASS_PURPOSE=$(unified_read_pass_field "$PASS_NUM" "purpose")
    PASS_STATUS=$(unified_read_pass_field "$PASS_NUM" "status")

    # Normalize "planned" → "pending"
    if [[ "$PASS_STATUS" == "planned" ]]; then
        unified_update_pass_field "$PASS_NUM" "status" "pending"
        PASS_STATUS="pending"
    fi

    # --- Skip completed passes ---
    if [[ "$PASS_STATUS" == "completed" ]]; then
        log "Pass ${PASS_NUM}/${TOTAL_PASSES}: ${PASS_NAME} — already completed, skipping."
        continue
    fi

    log "--- Pass ${PASS_NUM}/${TOTAL_PASSES}: ${PASS_NAME} ---"
    log "  Purpose: ${PASS_PURPOSE}"
    log "  Scope: ${PASS_SCOPE}"

    # =================================================================
    # Execute pass — build prompt with guidance and invoke claude
    # =================================================================

    # Build the revision prompt (includes full pass config with guidance/targets)
    if [[ "$USE_CSV_PLAN" == true ]]; then
        # Build a YAML-like config block from CSV fields for prompt injection
        _csv_targets=$(read_csv_pass_field "$PASS_NUM" "targets")
        _csv_guidance=$(read_csv_pass_field "$PASS_NUM" "guidance")
        _csv_protection=$(read_csv_pass_field "$PASS_NUM" "protection")
        _csv_findings=$(read_csv_pass_field "$PASS_NUM" "findings")

        # "scene-level" and "targeted" scopes mean "use the targets column"
        # Convert semicolon-separated targets to comma-separated for resolve_scope
        EFFECTIVE_SCOPE="$PASS_SCOPE"
        if [[ "$PASS_SCOPE" == "scene-level" || "$PASS_SCOPE" == "targeted" ]]; then
            if [[ -n "$_csv_targets" ]]; then
                EFFECTIVE_SCOPE=$(echo "$_csv_targets" | tr ';' ',')
            else
                # No targets specified — fall back to full manuscript
                EFFECTIVE_SCOPE="full"
            fi
        fi

        PASS_BLOCK="- name: ${PASS_NAME}
    purpose: ${PASS_PURPOSE}
    scope: ${PASS_SCOPE}"
        [[ -n "$_csv_targets" ]] && PASS_BLOCK="${PASS_BLOCK}
    targets: ${_csv_targets}"
        [[ -n "$_csv_guidance" ]] && PASS_BLOCK="${PASS_BLOCK}
    guidance: ${_csv_guidance}"
        [[ -n "$_csv_protection" ]] && PASS_BLOCK="${PASS_BLOCK}
    protection: ${_csv_protection}"
        [[ -n "$_csv_findings" ]] && PASS_BLOCK="${PASS_BLOCK}
    findings: ${_csv_findings}"
    else
        PASS_BLOCK=$(_get_pass_block "$PASS_NUM")
    fi
    log "  Building revision prompt..."
    set +e
    # Skip API mode for dry-run — prompts should show claude -p format
    API_FLAG=""
    [[ "${DRY_RUN:-false}" != true && -n "${ANTHROPIC_API_KEY:-}" && ! -f "$INTERACTIVE_FILE" ]] && API_FLAG="--api-mode"

    PROMPT=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.revision build-prompt \
        "$PASS_NAME" "$PASS_PURPOSE" "${EFFECTIVE_SCOPE:-$PASS_SCOPE}" "$PROJECT_DIR" \
        --config "$PASS_BLOCK" --coaching "$EFFECTIVE_COACHING" $API_FLAG)
    PROMPT_EXIT=$?
    set -e

    if (( PROMPT_EXIT != 0 )); then
        log "ERROR: Failed to build prompt for pass '${PASS_NAME}'"
        log "Fix the issue and re-run: storyforge-revise ${PASS_NUM}"
        exit 1
    fi

    # --- Dry-run mode: print prompt and continue (no status update, no Claude) ---
    if [[ "$DRY_RUN" == true ]]; then
        echo "===== DRY RUN: ${PASS_NAME} (pass ${PASS_NUM}/${TOTAL_PASSES}) ====="
        echo "$PROMPT"
        echo "===== END DRY RUN: ${PASS_NAME} ====="
        echo ""
        continue
    fi

    # Mark as in_progress (only in live mode)
    unified_update_pass_field "$PASS_NUM" "status" "in_progress"

    # --- Check interactive mode ---
    # Offer mode switch if currently headless (including before first pass)
    if [[ ! -f "$INTERACTIVE_FILE" ]]; then
        offer_interactive "$PROJECT_DIR" "Pass: ${PASS_NAME} (${PASS_NUM}/${TOTAL_PASSES})" || true
    fi

    begin_healing_zone "revision pass ${PASS_NUM}: ${PASS_NAME}"

    # Record git HEAD before invocation
    HEAD_BEFORE=$(git -C "$PROJECT_DIR" rev-parse HEAD)

    STEP_LOG="${LOG_DIR}/revision-pass-${PASS_NUM}-${PASS_NAME}.log"

    START_TIME=$(date +%s)
    _SF_INVOCATION_START=$START_TIME
    export _SF_INVOCATION_START

    # Select model based on pass type (creative vs. mechanical)
    PASS_MODEL=$(select_revision_model "$PASS_NAME" "$PASS_PURPOSE")

    if [[ -f "$INTERACTIVE_FILE" ]]; then
        # --- Interactive mode ---
        show_interactive_banner "Pass ${PASS_NUM} of ${TOTAL_PASSES}: ${PASS_NAME}" "multi"

        INTERACTIVE_SYSTEM=$(build_interactive_system_prompt "$PROJECT_DIR" "pass")

        claude "$PROMPT" \
            --model "$PASS_MODEL" \
            --dangerously-skip-permissions \
            --append-system-prompt "$INTERACTIVE_SYSTEM"
        EXIT_CODE=$?
    else
        # --- Headless mode (direct API) ---
        log "  Invoking API for revision (model: ${PASS_MODEL})..."
        log "  Pass log: $(basename "$STEP_LOG")"

        # Start background monitor
        revision_monitor "$PASS_NAME" "$HEAD_BEFORE" "$START_TIME" &
        MONITOR_PID=$!
        register_child_pid $MONITOR_PID

        # Revision passes output full scene content — need high max_tokens
        invoke_anthropic_api "$PROMPT" "$PASS_MODEL" "$STEP_LOG" 32768
        EXIT_CODE=$?

        # Stop the monitor
        kill $MONITOR_PID 2>/dev/null || true
        wait $MONITOR_PID 2>/dev/null || true

        # Extract response and apply revision to scene files (Python parser)
        if (( EXIT_CODE == 0 )); then
            parse_output=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.parsing extract-scenes "$STEP_LOG" "${PROJECT_DIR}/scenes" 2>/dev/null || true)
            if [[ -n "$parse_output" ]]; then
                # Log each written scene
                while IFS= read -r parse_line; do
                    [[ -n "$parse_line" ]] && log "  ${parse_line}"
                done <<< "$parse_output"
            else
                log "  API response received (analytical pass, no scene markers)"
            fi

            # Register newly created scenes (NEW: targets) in metadata and intent CSVs
            if [[ -n "${_csv_targets:-}" ]]; then
                _register_new_scenes "$PROJECT_DIR" "$_csv_targets" "$PASS_NAME"
            fi
        fi
    fi

    END_TIME=$(date +%s)
    DURATION=$(( END_TIME - START_TIME ))
    MINUTES=$(( DURATION / 60 ))
    SECS=$(( DURATION % 60 ))

    # Log usage for cost tracking (API mode vs interactive)
    if [[ -f "$INTERACTIVE_FILE" ]]; then
        log_usage "$STEP_LOG" "revise" "$PASS_NAME" "$PASS_MODEL"
    else
        log_api_usage "$STEP_LOG" "revise" "$PASS_NAME" "$PASS_MODEL"
    fi

    if (( EXIT_CODE != 0 )); then
        log "ERROR: API call failed with code ${EXIT_CODE} for pass '${PASS_NAME}' after ${MINUTES}m${SECS}s"
        log "See full output: ${STEP_LOG}"
        log "Fix the issue and re-run: storyforge-revise ${PASS_NUM}"
        false
    fi

    # --- Verify changes ---
    if [[ "$EFFECTIVE_COACHING" == "coach" || "$EFFECTIVE_COACHING" == "strict" ]]; then
        # In coach/strict mode, check for coaching output files instead of scene changes
        if [[ "$EFFECTIVE_COACHING" == "coach" ]]; then
            COACHING_OUTPUT="${PROJECT_DIR}/working/coaching/${PASS_NAME}-notes.md"
        else
            COACHING_OUTPUT="${PROJECT_DIR}/working/coaching/${PASS_NAME}-checklist.md"
        fi

        if [[ ! -f "$COACHING_OUTPUT" ]]; then
            log "WARNING: Coaching output not created: ${COACHING_OUTPUT}"
        else
            log "  Coaching output: ${COACHING_OUTPUT}"
        fi
    else
        PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.revision verify-changes "$HEAD_BEFORE" "$PROJECT_DIR" || {
            log "WARNING: Pass '${PASS_NAME}' produced no detectable changes."
            log "This may be expected if the pass found nothing to fix."
            log "Marking as completed and continuing."
        }
    fi

    # --- Update word counts in metadata.csv after revision ---
    METADATA_CSV="${PROJECT_DIR}/reference/scene-metadata.csv"
    [[ ! -f "$METADATA_CSV" ]] && METADATA_CSV="${PROJECT_DIR}/scenes/metadata.csv"
    if [[ -f "$METADATA_CSV" && "$EFFECTIVE_COACHING" == "full" ]]; then
        while IFS= read -r scene_id; do
            [[ -z "$scene_id" ]] && continue
            scene_file="${PROJECT_DIR}/scenes/${scene_id}.md"
            if [[ -f "$scene_file" ]]; then
                new_wc=$(wc -w < "$scene_file" | tr -d ' ')
                update_csv_field "$METADATA_CSV" "$scene_id" "word_count" "$new_wc"
            fi
        done < <(list_csv_ids "$METADATA_CSV")
    fi

    # --- Git commit (if claude didn't already) ---
    HEAD_AFTER=$(git -C "$PROJECT_DIR" rev-parse HEAD)
    if [[ "$HEAD_BEFORE" == "$HEAD_AFTER" ]]; then
        log "  No commit from claude. Creating manual commit..."
        cd "$PROJECT_DIR"
        if [[ "$EFFECTIVE_COACHING" == "coach" || "$EFFECTIVE_COACHING" == "strict" ]]; then
            git add working/coaching/ 2>/dev/null || true
            git add working/logs/ 2>/dev/null || true
            git add working/costs/ 2>/dev/null || true
            git add working/pipeline.csv 2>/dev/null || true
            git commit -m "${EFFECTIVE_COACHING^}: ${PASS_NAME}" 2>/dev/null || true
        else
            git add -A
            git commit -m "Revision: ${PASS_NAME}" 2>/dev/null || true
        fi
        HEAD_AFTER=$(git -C "$PROJECT_DIR" rev-parse HEAD)
        if [[ "$HEAD_BEFORE" == "$HEAD_AFTER" ]]; then
            log "  No changes to commit for pass '${PASS_NAME}'."
        else
            log "  Manual commit created."
        fi
    fi

    COMMIT_SHORT=$(git -C "$PROJECT_DIR" rev-parse --short HEAD)

    # --- Push (warn on failure) ---
    if ! git -C "$PROJECT_DIR" push 2>/dev/null; then
        log "WARNING: git push failed for pass '${PASS_NAME}' (commit ${COMMIT_SHORT}). Continuing."
    fi

    end_healing_zone

    # --- Update plan status ---
    unified_update_pass_field "$PASS_NUM" "status" "completed"

    log "SUCCESS: Pass ${PASS_NUM}/${TOTAL_PASSES} (${PASS_NAME}) — ${MINUTES}m${SECS}s, commit ${COMMIT_SHORT}"
    update_pr_task "Pass: ${PASS_NAME}" "$PROJECT_DIR"

    # --- Pause between passes (headless only) ---
    if (( PASS_NUM < TOTAL_PASSES )) && [[ ! -f "$INTERACTIVE_FILE" ]]; then
        NEXT_STATUS=$(unified_read_pass_field "$((PASS_NUM + 1))" "status")
        if [[ "$NEXT_STATUS" != "completed" ]]; then
            log "Pausing 10s before next pass..."
            sleep 10
        fi
    fi
done

# Clean up interactive file
rm -f "$INTERACTIVE_FILE"

# ============================================================================
# Session summary
# ============================================================================

log ""
log "============================================"
# Count completed passes
COMPLETED=0
for (( i = 1; i <= TOTAL_PASSES; i++ )); do
    s=$(unified_read_pass_field "$i" "status")
    if [[ "$s" == "completed" ]]; then
        COMPLETED=$((COMPLETED + 1))
    fi
done
log "Revision session complete. ${COMPLETED}/${TOTAL_PASSES} passes finished."

# --- Cost summary ---
if [[ "$DRY_RUN" != true ]]; then
    print_cost_summary "revise"
fi

if (( COMPLETED == TOTAL_PASSES )); then
    log "All revision passes are done!"

    # Advance project phase to review
    sed -i '' "s/^[[:space:]]*phase:.*/phase: review/" "${PROJECT_DIR}/storyforge.yaml" 2>/dev/null || true
    log "Project phase advanced to: review"

    # Ensure reviews directory exists
    mkdir -p "${PROJECT_DIR}/working/reviews"

    # Update pipeline cycle status to reviewing
    if [[ "$CYCLE_ID" != "0" ]]; then
        update_cycle_field "$CYCLE_ID" "status" "reviewing"
    fi

    # Commit phase advancement + manifest
    (
        cd "$PROJECT_DIR"
        git add storyforge.yaml 2>/dev/null || true
        git add working/pipeline.csv 2>/dev/null || true
        git commit -m "Revision complete: advance phase to review" 2>/dev/null || true
        git push 2>/dev/null || true
    )

    log ""
    log "Next step: run /storyforge:review to assess revision results"
    log "  or /storyforge:forge to get a recommendation"

    # --- Review phase ---
    run_review_phase "revision" "$PROJECT_DIR"
fi
log "============================================"

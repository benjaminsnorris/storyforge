#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-revise — Execute revision passes from a revision plan
#
# Reads working/plans/revision-plan.yaml and executes each pass in order.
# All passes run autonomously via `claude -p`. Creative decisions are
# documented as guidance entries in the plan — the author steers by editing
# guidance before execution or by redirecting after reviewing output.
#
# Progress is tracked durably in the YAML — the script updates pass status
# after each step so it can resume cleanly after restarts.
#
# Usage:
#   storyforge-revise            # Start from first pending pass
#   storyforge-revise 3          # Start from pass number 3 (1-indexed)
#   storyforge-revise --dry-run  # Print prompts without invoking Claude
# ============================================================================

# --- Resolve script and library paths ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

# Source shared libraries
source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/revision-passes.sh"

# --- Detect project root ---
detect_project_root
# PROJECT_DIR is now set and exported

# --- Pipeline manifest: resolve plan file for current cycle ---
ensure_pipeline_manifest
CYCLE_ID=$(get_current_cycle)
PLAN_FILE=$(get_cycle_plan_file "$CYCLE_ID")

# Fallback: if manifest has no plan and legacy file exists, use it
if [[ ! -f "$PLAN_FILE" && -f "${PROJECT_DIR}/working/plans/revision-plan.yaml" ]]; then
    PLAN_FILE="${PROJECT_DIR}/working/plans/revision-plan.yaml"
fi

LOG_DIR="${PROJECT_DIR}/working/logs"
LOG_FILE="${LOG_DIR}/revision-log.txt"
export LOG_FILE

mkdir -p "$LOG_DIR"

# --- Arguments ---
DRY_RUN=false
INTERACTIVE=false
COACHING_LEVEL=""
START_PASS=0  # 0 means "find first pending"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --coaching)
            COACHING_LEVEL="${2:?ERROR: --coaching requires a value (full, coach, or strict)}"
            case "$COACHING_LEVEL" in
                full|coach|strict) ;;
                *) echo "ERROR: Invalid coaching level '${COACHING_LEVEL}'. Must be full, coach, or strict." >&2; exit 1 ;;
            esac
            shift 2
            ;;
        --interactive|-i)
            INTERACTIVE=true
            shift
            ;;
        -h|--help)
            echo "Usage: storyforge-revise [--dry-run] [--interactive] [--coaching LEVEL] [PASS_NUM]"
            echo ""
            echo "Options:"
            echo "  --dry-run       Build and print prompts without invoking Claude"
            echo "  --interactive   Supervise each pass — watch, give feedback, redirect"
            echo "  --coaching LVL  Set coaching level: full, coach, or strict"
            echo "  PASS_NUM        Start from this pass number (1-indexed; default: first pending)"
            echo ""
            echo "Environment:"
            echo "  STORYFORGE_MODEL            Override model (default: opus for creative, sonnet for mechanical)"
            echo "  STORYFORGE_COACHING         Override coaching level (default: from storyforge.yaml or full)"
            echo "  STORYFORGE_REJOIN_TIMEOUT   Seconds to wait for 'i' keypress in autopilot (default: 5)"
            exit 0
            ;;
        [0-9]*)
            START_PASS="$1"
            shift
            ;;
        *)
            echo "Error: Unknown argument '$1'" >&2
            exit 1
            ;;
    esac
done

# ============================================================================
# Coaching level
# ============================================================================

if [[ -n "$COACHING_LEVEL" ]]; then
    STORYFORGE_COACHING="$COACHING_LEVEL"
    export STORYFORGE_COACHING
fi

EFFECTIVE_COACHING=$(get_coaching_level)

# Ensure coaching directory exists
mkdir -p "${PROJECT_DIR}/working/coaching"

# ============================================================================
# YAML helpers for revision-plan.yaml
#
# The revision plan has nested YAML: top-level passes may contain subtasks
# with their own "- name:" entries. These helpers use indentation to
# distinguish top-level passes (shallow indent) from subtask entries.
# ============================================================================

# Extract the raw YAML block for the Nth top-level pass (1-indexed).
# Detects the indentation of the first pass entry and only treats entries
# at that same level as pass boundaries.
_get_pass_block() {
    local pass_num=$1
    awk -v target="$pass_num" '
        BEGIN { count = 0; found = 0; first_indent = -1 }
        /^passes:/ { in_passes = 1; next }
        !in_passes { next }
        /^[^ \t]/ { if (found) exit; in_passes = 0; next }
        /^[[:space:]]*-[[:space:]]+name:/ {
            match($0, /^[[:space:]]*/); indent = RLENGTH
            if (first_indent < 0) first_indent = indent
            if (indent == first_indent) {
                if (found) exit
                count++
                if (count == target) found = 1
            }
        }
        found { print }
    ' "$PLAN_FILE"
}

# Count the number of top-level passes in the plan.
count_passes() {
    awk '
        BEGIN { count = 0; first_indent = -1 }
        /^passes:/ { in_passes = 1; next }
        !in_passes { next }
        /^[^ \t]/ { exit }
        /^[[:space:]]*-[[:space:]]+name:/ {
            match($0, /^[[:space:]]*/); indent = RLENGTH
            if (first_indent < 0) first_indent = indent
            if (indent == first_indent) count++
        }
        END { print count + 0 }
    ' "$PLAN_FILE"
}

# Read a field from a specific pass (1-indexed).
# Usage: read_pass_field 2 "name"  =>  "voice-consistency"
# Handles both "field: value" and "- field: value" (list-start) formats.
read_pass_field() {
    local pass_num=$1
    local field="$2"

    local block
    block=$(_get_pass_block "$pass_num")

    # Extract the field value. The grep handles both:
    #   "    name: foo"     (regular mapping key)
    #   "  - name: foo"     (YAML list-start item)
    local value
    value=$(echo "$block" \
        | grep -E "^[[:space:]]+(- )?${field}:" \
        | head -1 \
        | sed "s/.*${field}:[[:space:]]*//" \
        | sed 's/^["'"'"']//' \
        | sed 's/["'"'"']$//' \
        | sed 's/[[:space:]]*$//'
    ) || true

    echo "$value"
}

# Read the scope for a specific pass, handling both string and YAML list formats.
# String format:  "scope: full"           => "full"
# List format:    "scope:\n  - a\n  - b"  => "a,b"
read_pass_scope() {
    local pass_num=$1

    local block
    block=$(_get_pass_block "$pass_num")

    # Try inline value first (e.g., "scope: full" or "scope: targeted")
    local inline
    inline=$(echo "$block" \
        | grep -E "^[[:space:]]+(- )?scope:" \
        | head -1 \
        | sed 's/.*scope:[[:space:]]*//' \
        | sed 's/^["'"'"']//' \
        | sed 's/["'"'"']$//' \
        | sed 's/[[:space:]]*$//'
    ) || true

    if [[ -n "$inline" ]]; then
        echo "$inline"
        return 0
    fi

    # Scope is a YAML list — collect items and return comma-separated
    local items="" in_scope=false
    while IFS= read -r line; do
        if [[ "$in_scope" == false ]]; then
            if echo "$line" | grep -qE "^[[:space:]]+scope:[[:space:]]*$"; then
                in_scope=true
            fi
            continue
        fi
        # Skip comment lines
        if echo "$line" | grep -qE "^[[:space:]]*#"; then
            continue
        fi
        # Collect list items
        if echo "$line" | grep -qE "^[[:space:]]+-[[:space:]]"; then
            local item
            item=$(echo "$line" \
                | sed 's/^[[:space:]]*-[[:space:]]*//' \
                | sed 's/^["'"'"']//' \
                | sed 's/["'"'"']$//' \
                | sed 's/[[:space:]]*$//')
            [[ -n "$item" ]] && items="${items:+${items},}${item}"
        else
            break
        fi
    done <<< "$block"

    echo "$items"
}

# Update a field for a specific pass (1-indexed) in revision-plan.yaml.
# Usage: update_pass_field 2 "status" "completed"
update_pass_field() {
    local pass_num=$1
    local field="$2"
    local new_value="$3"

    local tmp_file="${PLAN_FILE}.tmp"

    awk -v target="$pass_num" -v field="$field" -v newval="$new_value" '
    BEGIN { count = 0; in_passes = 0; found_block = 0; replaced = 0; first_indent = -1 }
    /^passes:/ { in_passes = 1; print; next }
    !in_passes { print; next }
    /^[^ \t]/ { in_passes = 0; found_block = 0; print; next }

    # Detect start of a new top-level pass entry (same indent as first)
    /^[[:space:]]*-[[:space:]]+name:/ {
        match($0, /^[[:space:]]*/); indent = RLENGTH
        if (first_indent < 0) first_indent = indent
        if (indent == first_indent) {
            count++
            found_block = (count == target) ? 1 : 0
            if (found_block) replaced = 0
        }
    }

    # If we are in the target block and find the field, replace it
    found_block && !replaced && $0 ~ "^[[:space:]]+" field ":" {
        match($0, /^[[:space:]]+/)
        indent_str = substr($0, RSTART, RLENGTH)
        print indent_str field ": " newval
        replaced = 1
        next
    }

    { print }
    ' "$PLAN_FILE" > "$tmp_file"

    mv "$tmp_file" "$PLAN_FILE"
}

# ============================================================================
# Background progress monitor (simplified)
# ============================================================================

# Poll every 30 seconds for heartbeat and commit detection.
# Usage: revision_monitor "pass-name" "$HEAD_BEFORE" "$START_TIME" &
revision_monitor() {
    local pass_name="$1"
    local head_before="$2"
    local start_time="$3"

    local commit_detected=false
    local ticks=0

    while true; do
        sleep 30
        ticks=$((ticks + 1))
        local elapsed=$(( $(date +%s) - start_time ))
        local mins=$(( elapsed / 60 ))

        # Git commit made?
        if [[ "$commit_detected" == false ]]; then
            local head_now
            head_now=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "")
            if [[ -n "$head_now" && "$head_now" != "$head_before" ]]; then
                commit_detected=true
                log "  [${pass_name}] Git commit detected [${mins}m]"
            fi
        fi

        # Check for scene file changes
        if (( ticks % 2 == 0 )); then
            local changed_count
            changed_count=$(git -C "$PROJECT_DIR" diff --name-only -- scenes/ 2>/dev/null | wc -l | tr -d ' ')
            if (( changed_count > 0 )); then
                log "  [${pass_name}] ${changed_count} scene file(s) modified [${mins}m]"
            fi
        fi

        # Heartbeat every 2 minutes (4 ticks x 30s)
        if (( ticks % 4 == 0 )); then
            log "  [${pass_name}] ${mins}m elapsed..."
        fi
    done
}

# ============================================================================
# Prerequisite checks
# ============================================================================

if [[ ! -f "$PLAN_FILE" ]]; then
    log "ERROR: Revision plan not found at ${PLAN_FILE}"
    log "Run the storyforge-plan-revision skill first to create a revision plan."
    exit 1
fi

TOTAL_PASSES=$(count_passes)

if (( TOTAL_PASSES == 0 )); then
    log "ERROR: No passes found in ${PLAN_FILE}"
    exit 1
fi

# ============================================================================
# Determine start point
# ============================================================================

if (( START_PASS == 0 )); then
    # Find the first pending or in_progress pass
    for (( i = 1; i <= TOTAL_PASSES; i++ )); do
        local_status=$(read_pass_field "$i" "status")
        if [[ "$local_status" == "pending" || "$local_status" == "in_progress" ]]; then
            START_PASS=$i
            break
        fi
    done

    if (( START_PASS == 0 )); then
        log "All passes are already completed. Nothing to do."
        exit 0
    fi
fi

if (( START_PASS < 1 || START_PASS > TOTAL_PASSES )); then
    log "ERROR: Pass number ${START_PASS} is out of range (1-${TOTAL_PASSES})"
    exit 1
fi

# ============================================================================
# Read project title for log messages
# ============================================================================

PROJECT_TITLE=$(read_yaml_field "project.title")
if [[ -z "$PROJECT_TITLE" ]]; then
    PROJECT_TITLE="(untitled project)"
fi

# Set up interactive mode file
INTERACTIVE_FILE="${PROJECT_DIR}/working/.interactive"
rm -f "$INTERACTIVE_FILE"
if [[ "$INTERACTIVE" == true ]]; then
    touch "$INTERACTIVE_FILE"
fi

# ============================================================================
# Main execution loop
# ============================================================================

# --- Branch + PR setup ---
if [[ "$DRY_RUN" != true ]]; then
    create_branch "revise" "$PROJECT_DIR"

    # Ensure phase is set to revision before pushing (gives the branch an initial commit)
    CURRENT_PHASE=$(read_yaml_field "phase" 2>/dev/null || echo "")
    if [[ "$CURRENT_PHASE" != "revision" ]]; then
        sed -i '' "s/^[[:space:]]*phase:.*/phase: revision/" "${PROJECT_DIR}/storyforge.yaml" 2>/dev/null || true
    fi

    ensure_branch_pushed "$PROJECT_DIR"

    PR_BODY="## Revision

**Project:** ${PROJECT_TITLE}
**Passes:** ${TOTAL_PASSES}

### Tasks
"
    for (( _i = 1; _i <= TOTAL_PASSES; _i++ )); do
        _pname=$(read_pass_field "$_i" "name")
        PR_BODY="${PR_BODY}- [ ] Pass: ${_pname}
"
    done
    PR_BODY="${PR_BODY}- [ ] Review"

    create_draft_pr "Revise: ${PROJECT_TITLE}" "$PR_BODY" "$PROJECT_DIR" "revision"
fi

# Update pipeline cycle status to revising
if [[ "$DRY_RUN" != true && "$CYCLE_ID" != "0" ]]; then
    update_cycle_field "$CYCLE_ID" "status" "revising"
fi

log "============================================"
log "Storyforge Revision — ${PROJECT_TITLE}"
log "Plan: ${PLAN_FILE}"
log "Cycle: ${CYCLE_ID}"
log "Coaching level: ${EFFECTIVE_COACHING}"
log "Starting from pass: ${START_PASS} of ${TOTAL_PASSES}"
log "============================================"

for (( PASS_NUM = START_PASS; PASS_NUM <= TOTAL_PASSES; PASS_NUM++ )); do
    # --- Read pass configuration ---
    PASS_NAME=$(read_pass_field "$PASS_NUM" "name")
    PASS_SCOPE=$(read_pass_scope "$PASS_NUM")
    PASS_PURPOSE=$(read_pass_field "$PASS_NUM" "purpose")
    PASS_STATUS=$(read_pass_field "$PASS_NUM" "status")

    # --- Skip completed passes ---
    if [[ "$PASS_STATUS" == "completed" ]]; then
        log "Pass ${PASS_NUM}/${TOTAL_PASSES}: ${PASS_NAME} — already completed, skipping."
        continue
    fi

    log "--- Pass ${PASS_NUM}/${TOTAL_PASSES}: ${PASS_NAME} ---"
    log "  Purpose: ${PASS_PURPOSE}"
    log "  Scope: ${PASS_SCOPE}"

    # =================================================================
    # Execute pass — build prompt with guidance and invoke claude
    # =================================================================

    # Build the revision prompt (includes full pass config with guidance/targets)
    PASS_BLOCK=$(_get_pass_block "$PASS_NUM")
    log "  Building revision prompt..."
    set +e
    PROMPT=$(build_revision_prompt "$PASS_NAME" "$PASS_PURPOSE" "$PASS_SCOPE" "$PROJECT_DIR" "$PASS_BLOCK")
    PROMPT_EXIT=$?
    set -e

    if (( PROMPT_EXIT != 0 )); then
        log "ERROR: Failed to build prompt for pass '${PASS_NAME}'"
        log "Fix the issue and re-run: storyforge-revise ${PASS_NUM}"
        exit 1
    fi

    # --- Dry-run mode: print prompt and continue (no status update, no Claude) ---
    if [[ "$DRY_RUN" == true ]]; then
        echo "===== DRY RUN: ${PASS_NAME} (pass ${PASS_NUM}/${TOTAL_PASSES}) ====="
        echo "$PROMPT"
        echo "===== END DRY RUN: ${PASS_NAME} ====="
        echo ""
        continue
    fi

    # Mark as in_progress (only in live mode)
    update_pass_field "$PASS_NUM" "status" "in_progress"

    # --- Check interactive mode ---
    # Offer mode switch if currently headless (including before first pass)
    if [[ ! -f "$INTERACTIVE_FILE" ]]; then
        offer_interactive "$PROJECT_DIR" "Pass: ${PASS_NAME} (${PASS_NUM}/${TOTAL_PASSES})" || true
    fi

    begin_healing_zone "revision pass ${PASS_NUM}: ${PASS_NAME}"

    # Record git HEAD before invocation
    HEAD_BEFORE=$(git -C "$PROJECT_DIR" rev-parse HEAD)

    STEP_LOG="${LOG_DIR}/revision-pass-${PASS_NUM}-${PASS_NAME}.log"

    START_TIME=$(date +%s)

    # Select model based on pass type (creative vs. mechanical)
    PASS_MODEL=$(select_revision_model "$PASS_NAME" "$PASS_PURPOSE")

    if [[ -f "$INTERACTIVE_FILE" ]]; then
        # --- Interactive mode ---
        show_interactive_banner "Pass ${PASS_NUM} of ${TOTAL_PASSES}: ${PASS_NAME}" "multi"

        INTERACTIVE_SYSTEM=$(build_interactive_system_prompt "$PROJECT_DIR" "pass")

        claude "$PROMPT" \
            --model "$PASS_MODEL" \
            --dangerously-skip-permissions \
            --append-system-prompt "$INTERACTIVE_SYSTEM"
        EXIT_CODE=$?
    else
        # --- Headless mode ---
        log "  Invoking claude for revision (model: ${PASS_MODEL})..."
        log "  Pass log: $(basename "$STEP_LOG") (tail -f for live output)"

        # Start background monitor
        revision_monitor "$PASS_NAME" "$HEAD_BEFORE" "$START_TIME" &
        MONITOR_PID=$!
        register_child_pid $MONITOR_PID

        claude -p "$PROMPT" \
            --model "$PASS_MODEL" \
            --dangerously-skip-permissions \
            --output-format stream-json \
            --verbose \
            > "$STEP_LOG" 2>&1
        EXIT_CODE=$?

        # Stop the monitor
        kill $MONITOR_PID 2>/dev/null || true
        wait $MONITOR_PID 2>/dev/null || true
    fi

    END_TIME=$(date +%s)
    DURATION=$(( END_TIME - START_TIME ))
    MINUTES=$(( DURATION / 60 ))
    SECS=$(( DURATION % 60 ))

    if (( EXIT_CODE != 0 )); then
        log "ERROR: claude exited with code ${EXIT_CODE} for pass '${PASS_NAME}' after ${MINUTES}m${SECS}s"
        log "See full output: ${STEP_LOG}"
        log "Fix the issue and re-run: storyforge-revise ${PASS_NUM}"
        false
    fi

    # --- Verify changes ---
    if [[ "$EFFECTIVE_COACHING" == "coach" || "$EFFECTIVE_COACHING" == "strict" ]]; then
        # In coach/strict mode, check for coaching output files instead of scene changes
        if [[ "$EFFECTIVE_COACHING" == "coach" ]]; then
            COACHING_OUTPUT="${PROJECT_DIR}/working/coaching/${PASS_NAME}-notes.md"
        else
            COACHING_OUTPUT="${PROJECT_DIR}/working/coaching/${PASS_NAME}-checklist.md"
        fi

        if [[ ! -f "$COACHING_OUTPUT" ]]; then
            log "WARNING: Coaching output not created: ${COACHING_OUTPUT}"
        else
            log "  Coaching output: ${COACHING_OUTPUT}"
        fi
    else
        verify_revision_changes "$HEAD_BEFORE" "$PROJECT_DIR" || {
            log "WARNING: Pass '${PASS_NAME}' produced no detectable changes."
            log "This may be expected if the pass found nothing to fix."
            log "Marking as completed and continuing."
        }
    fi

    # --- Git commit (if claude didn't already) ---
    HEAD_AFTER=$(git -C "$PROJECT_DIR" rev-parse HEAD)
    if [[ "$HEAD_BEFORE" == "$HEAD_AFTER" ]]; then
        log "  No commit from claude. Creating manual commit..."
        cd "$PROJECT_DIR"
        if [[ "$EFFECTIVE_COACHING" == "coach" || "$EFFECTIVE_COACHING" == "strict" ]]; then
            git add working/coaching/ 2>/dev/null || true
            git add working/logs/ 2>/dev/null || true
            git add working/pipeline.yaml 2>/dev/null || true
            git commit -m "${EFFECTIVE_COACHING^}: ${PASS_NAME}" 2>/dev/null || true
        else
            git add -A
            git commit -m "Revision: ${PASS_NAME}" 2>/dev/null || true
        fi
        HEAD_AFTER=$(git -C "$PROJECT_DIR" rev-parse HEAD)
        if [[ "$HEAD_BEFORE" == "$HEAD_AFTER" ]]; then
            log "  No changes to commit for pass '${PASS_NAME}'."
        else
            log "  Manual commit created."
        fi
    fi

    COMMIT_SHORT=$(git -C "$PROJECT_DIR" rev-parse --short HEAD)

    # --- Push (warn on failure) ---
    if ! git -C "$PROJECT_DIR" push 2>/dev/null; then
        log "WARNING: git push failed for pass '${PASS_NAME}' (commit ${COMMIT_SHORT}). Continuing."
    fi

    end_healing_zone

    # --- Update plan status ---
    update_pass_field "$PASS_NUM" "status" "completed"

    log "SUCCESS: Pass ${PASS_NUM}/${TOTAL_PASSES} (${PASS_NAME}) — ${MINUTES}m${SECS}s, commit ${COMMIT_SHORT}"
    update_pr_task "Pass: ${PASS_NAME}" "$PROJECT_DIR"

    # --- Pause between passes (headless only) ---
    if (( PASS_NUM < TOTAL_PASSES )) && [[ ! -f "$INTERACTIVE_FILE" ]]; then
        NEXT_STATUS=$(read_pass_field "$((PASS_NUM + 1))" "status")
        if [[ "$NEXT_STATUS" != "completed" ]]; then
            log "Pausing 10s before next pass..."
            sleep 10
        fi
    fi
done

# Clean up interactive file
rm -f "$INTERACTIVE_FILE"

# ============================================================================
# Session summary
# ============================================================================

log ""
log "============================================"
# Count completed passes
COMPLETED=0
for (( i = 1; i <= TOTAL_PASSES; i++ )); do
    s=$(read_pass_field "$i" "status")
    if [[ "$s" == "completed" ]]; then
        COMPLETED=$((COMPLETED + 1))
    fi
done
log "Revision session complete. ${COMPLETED}/${TOTAL_PASSES} passes finished."
if (( COMPLETED == TOTAL_PASSES )); then
    log "All revision passes are done!"

    # Advance project phase to review
    sed -i '' "s/^[[:space:]]*phase:.*/phase: review/" "${PROJECT_DIR}/storyforge.yaml" 2>/dev/null || true
    log "Project phase advanced to: review"

    # Ensure reviews directory exists
    mkdir -p "${PROJECT_DIR}/working/reviews"

    # Update pipeline cycle status to reviewing
    if [[ "$CYCLE_ID" != "0" ]]; then
        update_cycle_field "$CYCLE_ID" "status" "reviewing"
    fi

    # Commit phase advancement + manifest
    (
        cd "$PROJECT_DIR"
        git add storyforge.yaml 2>/dev/null || true
        git add working/pipeline.yaml 2>/dev/null || true
        git commit -m "Revision complete: advance phase to review" 2>/dev/null || true
        git push 2>/dev/null || true
    )

    log ""
    log "Next step: run /storyforge:review to assess revision results"
    log "  or /storyforge:forge to get a recommendation"

    # --- Review phase ---
    run_review_phase "revision" "$PROJECT_DIR"
fi
log "============================================"

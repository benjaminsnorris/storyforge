#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-evaluate — Multi-agent evaluation panel for Storyforge projects
#
# Runs 6 core evaluator agents in parallel (plus any custom evaluators from
# storyforge.yaml), each reading the manuscript and writing a report from
# their professional perspective. After all evaluators complete, runs a
# synthesis session that combines findings into prose + structured findings.yaml.
#
# Usage:
#   ./storyforge-evaluate                      # Full manuscript (scene files)
#   ./storyforge-evaluate --manuscript         # Full manuscript (assembled chapters)
#   ./storyforge-evaluate --chapter N          # Single assembled chapter
#   ./storyforge-evaluate --act N              # Scenes in act N
#   ./storyforge-evaluate --part N             # Scenes in part N
#   ./storyforge-evaluate --scenes ID..ID      # Specific scene range
#   ./storyforge-evaluate --scene ID           # Single scene
#   ./storyforge-evaluate --dry-run            # Print prompts without invoking Claude
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# --- Detect project root ---
detect_project_root
log "Project root: ${PROJECT_DIR}"

# --- API key check for non-interactive modes ---
# (Checked early so we fail fast before doing branch/PR setup work)
_sf_check_api_key() {
    if [[ "$DRY_RUN" == true ]]; then return 0; fi
    if [[ "$EVAL_MODE" != "interactive" && -z "${ANTHROPIC_API_KEY:-}" ]]; then
        echo "ERROR: ANTHROPIC_API_KEY is required for batch and direct modes." >&2
        echo "  Set it with: export ANTHROPIC_API_KEY=your-key" >&2
        echo "  Or use --interactive to run with claude -p instead." >&2
        exit 1
    fi
}
# Deferred — called after argument parsing completes (see below)

# --- Resolve plugin directory (where evaluator persona files live) ---
PLUGIN_DIR=$(get_plugin_dir)
PERSONA_DIR="${PLUGIN_DIR}/scripts/prompts/evaluators"

# --- Configuration ---
SCENES_DIR="${PROJECT_DIR}/scenes"
LOG_DIR="${PROJECT_DIR}/working/logs"
LOG_FILE="${LOG_DIR}/evaluation-log.txt"
export LOG_FILE

EVAL_TIMESTAMP=$(date '+%Y%m%d-%H%M%S')
EVAL_DIR="${PROJECT_DIR}/working/evaluations/eval-${EVAL_TIMESTAMP}"

# Optional budget flag — uncomment and set to cap per-evaluator spend
# BUDGET_FLAG="--max-budget-usd 20"
BUDGET_FLAG=""

# Core evaluators (order matters for reporting, not execution)
CORE_EVALUATORS=(
    "literary-agent"
    "developmental-editor"
    "line-editor"
    "genre-expert"
    "first-reader"
    "writing-coach"
)

# ============================================================================
# Argument parsing
# ============================================================================

DRY_RUN=false
INTERACTIVE=false
FINAL_EVAL=false
SINGLE_EVALUATOR=""
EVAL_MODE="batch"       # batch | direct | interactive
FILTER_MODE="all"       # all | act | range | single | scenes | from_seq | manuscript | chapter
FILTER_VALUE=""
FILTER_SCENES=""
FILTER_FROM_SEQ=""
RANGE_START=""
RANGE_END=""

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Run a multi-agent evaluation panel on your manuscript.

Scope:
  (no args)                     Evaluate full manuscript (scene files)
  --manuscript                  Evaluate assembled chapters (from manuscript/chapters/)
  --chapter N                   Evaluate a single assembled chapter
  --act N                       Evaluate scenes in act/part N
  --scenes ID,ID                Evaluate specific scenes (comma-separated slug IDs)
  --scenes ID..ID               Evaluate a range of scenes (inclusive, by position)
  --scene ID                    Evaluate a single scene
  --from-seq N                  Evaluate scenes from sequence number N onward
  --from-seq N-M                Evaluate scenes in sequence range N through M

Options:
  --evaluator NAME              Run a single evaluator (e.g., line-editor, first-reader)
  --final                       Final evaluation before beta readers (shifts evaluator lens)
  --interactive                 Supervise the synthesis step interactively
  --direct                      Use direct API calls instead of batch (default: batch)
  --dry-run                     Print prompts without invoking Claude
  -h, --help                    Show this help

Environment:
  ANTHROPIC_API_KEY             Required for batch and direct modes
  STORYFORGE_MODEL              Override model (default: sonnet for evaluators, opus for synthesis)

Examples:
  $(basename "$0")
  $(basename "$0") --manuscript
  $(basename "$0") --chapter 5
  $(basename "$0") --act 2
  $(basename "$0") --from-seq 32
  $(basename "$0") --from-seq 5-10
  $(basename "$0") --scenes claires-cold,pewter-town
  $(basename "$0") --evaluator line-editor
  $(basename "$0") --interactive
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --final)
            FINAL_EVAL=true
            shift
            ;;
        --evaluator)
            SINGLE_EVALUATOR="${2:?ERROR: --evaluator requires an evaluator name}"
            shift 2
            ;;
        --interactive|-i)
            INTERACTIVE=true
            EVAL_MODE="interactive"
            shift
            ;;
        --direct)
            EVAL_MODE="direct"
            shift
            ;;
        --manuscript)
            FILTER_MODE="manuscript"
            shift
            ;;
        --chapter)
            FILTER_MODE="chapter"
            FILTER_VALUE="${2:?ERROR: --chapter requires a chapter number}"
            shift 2
            ;;
        --act|--part)
            FILTER_MODE="act"
            FILTER_VALUE="${2:?ERROR: $1 requires a value}"
            shift 2
            ;;
        --scenes)
            local_arg="${2:?ERROR: --scenes requires scene IDs}"
            if [[ "$local_arg" == *".."* ]]; then
                # Range format: ID..ID (legacy support)
                FILTER_MODE="range"
                RANGE_START="${local_arg%%\.\.*}"
                RANGE_END="${local_arg##*\.\.}"
            else
                # Comma-separated list
                FILTER_MODE="scenes"
                FILTER_SCENES="$local_arg"
            fi
            shift 2
            ;;
        --from-seq)
            FILTER_MODE="from_seq"
            FILTER_FROM_SEQ="${2:?ERROR: --from-seq requires a sequence number}"
            shift 2
            ;;
        --scene)
            FILTER_MODE="single"
            RANGE_START="${2:?ERROR: --scene requires a scene ID}"
            shift 2
            ;;
        -*)
            echo "ERROR: Unknown option: $1" >&2
            usage
            ;;
        *)
            echo "ERROR: Unexpected argument: $1" >&2
            usage
            ;;
    esac
done

# --- Check API key (now that args are parsed) ---
_sf_check_api_key

# ============================================================================
# Prerequisites
# ============================================================================

# Manuscript mode reads from manuscript/chapters/ instead of scenes/
MANUSCRIPT_MODE=false
CHAPTERS_DIR="${PROJECT_DIR}/manuscript/chapters"

if [[ "$FILTER_MODE" == "manuscript" || "$FILTER_MODE" == "chapter" ]]; then
    MANUSCRIPT_MODE=true
    if [[ ! -d "$CHAPTERS_DIR" ]]; then
        echo "ERROR: No assembled chapters found at manuscript/chapters/" >&2
        echo "Run 'storyforge assemble' first to generate chapter files." >&2
        exit 1
    fi
fi

# Read project metadata from storyforge.yaml
PROJECT_TITLE=$(read_yaml_field "project.title" 2>/dev/null || read_yaml_field "title" 2>/dev/null || echo "Unknown")
PROJECT_GENRE=$(read_yaml_field "project.genre" 2>/dev/null || read_yaml_field "genre" 2>/dev/null || echo "")
PROJECT_SUBGENRE=$(read_yaml_field "project.subgenre" 2>/dev/null || echo "")
PROJECT_LOGLINE=$(read_yaml_field "project.logline" 2>/dev/null || read_yaml_field "logline" 2>/dev/null || echo "")

# Resolve voice guide path
VOICE_GUIDE_PATH=""
VOICE_GUIDE_CONTENT=""

# Check storyforge.yaml first
CUSTOM_VG=$(read_yaml_field "artifacts.voice_guide.path" 2>/dev/null || true)
if [[ -n "$CUSTOM_VG" && -f "${PROJECT_DIR}/${CUSTOM_VG}" ]]; then
    VOICE_GUIDE_PATH="${PROJECT_DIR}/${CUSTOM_VG}"
fi

# Fall back to common locations
if [[ -z "$VOICE_GUIDE_PATH" ]]; then
    for vg in "references/voice-guide.md" "reference/voice-guide.md" "reference/persistent-prompt.md"; do
        if [[ -f "${PROJECT_DIR}/${vg}" ]]; then
            VOICE_GUIDE_PATH="${PROJECT_DIR}/${vg}"
            break
        fi
    done
fi

if [[ -n "$VOICE_GUIDE_PATH" ]]; then
    VOICE_GUIDE_CONTENT=$(cat "$VOICE_GUIDE_PATH")
    log "Voice guide: ${VOICE_GUIDE_PATH}"
else
    log "WARNING: No voice guide found. Evaluators will proceed without voice reference."
fi

# Build genre string for display and injection
GENRE_DISPLAY="$PROJECT_GENRE"
if [[ -n "$PROJECT_SUBGENRE" ]]; then
    GENRE_DISPLAY="${PROJECT_GENRE} (${PROJECT_SUBGENRE})"
fi

# ============================================================================
# Build file list — manuscript chapters or individual scenes
# ============================================================================

# These variables are populated by either manuscript or scene mode:
SCENE_FILES=()         # Relative paths for prompt injection
SCENE_LIST_STR=""      # Formatted list string for prompt
SCOPE_DESCRIPTION=""   # Human-readable scope label
INPUT_TYPE="scenes"    # "scenes" or "chapters" — affects prompt language

if [[ "$MANUSCRIPT_MODE" == true ]]; then
    # --- Manuscript mode: read assembled chapter files ---
    INPUT_TYPE="chapters"

    CHAPTER_FILES=()
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        CHAPTER_FILES+=("$f")
    done < <(ls "${CHAPTERS_DIR}"/chapter-*.md 2>/dev/null | sort)

    if [[ ${#CHAPTER_FILES[@]} -eq 0 ]]; then
        log "ERROR: No chapter files found in ${CHAPTERS_DIR}"
        log "Run 'storyforge assemble' first to generate chapter files."
        exit 1
    fi

    case "$FILTER_MODE" in
        manuscript)
            # All chapters
            for f in "${CHAPTER_FILES[@]}"; do
                rel_path="manuscript/chapters/$(basename "$f")"
                SCENE_FILES+=("$rel_path")
            done
            SCOPE_DESCRIPTION="full manuscript (${#CHAPTER_FILES[@]} assembled chapters)"
            ;;
        chapter)
            # Single chapter
            ch_file="${CHAPTERS_DIR}/chapter-$(printf '%02d' "$FILTER_VALUE").md"
            if [[ ! -f "$ch_file" ]]; then
                log "ERROR: Chapter file not found: manuscript/chapters/chapter-$(printf '%02d' "$FILTER_VALUE").md"
                exit 1
            fi
            SCENE_FILES+=("manuscript/chapters/$(basename "$ch_file")")
            SCOPE_DESCRIPTION="chapter ${FILTER_VALUE}"
            ;;
    esac

    log "Manuscript mode: ${#SCENE_FILES[@]} chapter file(s)"

    # Build file list string for prompt injection
    for sf in "${SCENE_FILES[@]}"; do
        SCENE_LIST_STR="${SCENE_LIST_STR}   - ${sf}
"
    done
else
    # --- Scene mode: read from metadata.csv ---
    METADATA_CSV="${PROJECT_DIR}/reference/scene-metadata.csv"
    [[ ! -f "$METADATA_CSV" ]] && METADATA_CSV="${PROJECT_DIR}/scenes/metadata.csv"

    build_scene_list "$METADATA_CSV"

    case "$FILTER_MODE" in
        all)       apply_scene_filter "$METADATA_CSV" "all" ;;
        single)    apply_scene_filter "$METADATA_CSV" "single" "$RANGE_START" ;;
        range)     apply_scene_filter "$METADATA_CSV" "range" "$RANGE_START" "$RANGE_END" ;;
        scenes)    apply_scene_filter "$METADATA_CSV" "scenes" "$FILTER_SCENES" ;;
        act)       apply_scene_filter "$METADATA_CSV" "act" "$FILTER_VALUE" ;;
        from_seq)  apply_scene_filter "$METADATA_CSV" "from_seq" "$FILTER_FROM_SEQ" ;;
    esac

    # Build the scene file list (only scenes that have been drafted)
    MISSING_SCENES=()
    for id in "${FILTERED_IDS[@]}"; do
        scene_file="${SCENES_DIR}/${id}.md"
        if [[ -f "$scene_file" ]]; then
            SCENE_FILES+=("scenes/${id}.md")
        else
            MISSING_SCENES+=("$id")
        fi
    done

    if [[ ${#SCENE_FILES[@]} -eq 0 ]]; then
        log "ERROR: No drafted scene files found for the selected scope."
        log "Missing scenes: ${MISSING_SCENES[*]}"
        exit 1
    fi

    if [[ ${#MISSING_SCENES[@]} -gt 0 ]]; then
        log "WARNING: ${#MISSING_SCENES[@]} scenes not yet drafted (skipping): ${MISSING_SCENES[*]}"
    fi

    # Build scene list string for prompt injection
    for sf in "${SCENE_FILES[@]}"; do
        SCENE_LIST_STR="${SCENE_LIST_STR}   - ${sf}
"
    done

    SCOPE_DESCRIPTION="full manuscript (${#SCENE_FILES[@]} scenes)"
    case "$FILTER_MODE" in
        act)      SCOPE_DESCRIPTION="Act ${FILTER_VALUE} (${#SCENE_FILES[@]} scenes)" ;;
        range)    SCOPE_DESCRIPTION="scenes ${RANGE_START} through ${RANGE_END} (${#SCENE_FILES[@]} scenes)" ;;
        single)   SCOPE_DESCRIPTION="scene ${RANGE_START}" ;;
        from_seq) SCOPE_DESCRIPTION="seq ${FILTER_FROM_SEQ} (${#SCENE_FILES[@]} scenes)" ;;
        scenes)   SCOPE_DESCRIPTION="${#SCENE_FILES[@]} selected scenes" ;;
    esac
fi

# ============================================================================
# Collect custom evaluators from storyforge.yaml
# ============================================================================

CUSTOM_EVALUATOR_NAMES=()
CUSTOM_EVALUATOR_PATHS=()

# Parse custom_evaluators list from storyforge.yaml
# Format:   - name: my_evaluator
#             persona_file: evaluation/my-evaluator.md
while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    name=$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
    if [[ -n "$name" ]]; then
        CUSTOM_EVALUATOR_NAMES+=("$name")
    fi
done < <(sed -n '/^[[:space:]]*custom_evaluators:/,/^[[:space:]]*[^-[:space:]]/p' \
    "${PROJECT_DIR}/storyforge.yaml" 2>/dev/null \
    | grep -E '^\s*- name:' \
    | sed 's/^[[:space:]]*- name:[[:space:]]*//' \
    | sed 's/^["'"'"']//' \
    | sed 's/["'"'"']$//')

# Resolve persona_file paths for each custom evaluator
CUSTOM_EVAL_COUNT=0
if [[ ${#CUSTOM_EVALUATOR_NAMES[@]} -gt 0 ]]; then
    for cname in "${CUSTOM_EVALUATOR_NAMES[@]}"; do
        cpath=$(sed -n "/- name:[[:space:]]*${cname}/,/- name:/p" \
            "${PROJECT_DIR}/storyforge.yaml" 2>/dev/null \
            | grep -E 'persona_file:' \
            | head -1 \
            | sed 's/^[[:space:]]*persona_file:[[:space:]]*//' \
            | sed 's/^["'"'"']//' \
            | sed 's/["'"'"']$//' \
            | sed 's/[[:space:]]*$//')
        if [[ -n "$cpath" ]]; then
            CUSTOM_EVALUATOR_PATHS+=("${PROJECT_DIR}/${cpath}")
        else
            log "WARNING: No persona_file found for custom evaluator '${cname}', skipping"
        fi
    done
    CUSTOM_EVAL_COUNT=${#CUSTOM_EVALUATOR_NAMES[@]}
fi

ALL_EVALUATOR_COUNT=$(( ${#CORE_EVALUATORS[@]} + CUSTOM_EVAL_COUNT ))

# --- Single evaluator filtering ---
if [[ -n "$SINGLE_EVALUATOR" ]]; then
    # Validate the evaluator name exists
    _found=false
    for _e in "${CORE_EVALUATORS[@]}"; do
        [[ "$_e" == "$SINGLE_EVALUATOR" ]] && _found=true && break
    done
    if [[ "$_found" == false ]]; then
        for _e in "${CUSTOM_EVALUATOR_NAMES[@]}"; do
            [[ "$_e" == "$SINGLE_EVALUATOR" ]] && _found=true && break
        done
    fi
    if [[ "$_found" == false ]]; then
        echo "ERROR: Unknown evaluator '${SINGLE_EVALUATOR}'" >&2
        echo "Available evaluators: ${CORE_EVALUATORS[*]} ${CUSTOM_EVALUATOR_NAMES[*]}" >&2
        exit 1
    fi

    # Filter core evaluators to just the selected one
    _filtered=()
    for _e in "${CORE_EVALUATORS[@]}"; do
        [[ "$_e" == "$SINGLE_EVALUATOR" ]] && _filtered+=("$_e")
    done
    CORE_EVALUATORS=("${_filtered[@]}")

    # Filter custom evaluators to just the selected one (if it's custom)
    _filtered_custom_names=()
    _filtered_custom_paths=()
    for _i in "${!CUSTOM_EVALUATOR_NAMES[@]}"; do
        if [[ "${CUSTOM_EVALUATOR_NAMES[$_i]}" == "$SINGLE_EVALUATOR" ]]; then
            _filtered_custom_names+=("${CUSTOM_EVALUATOR_NAMES[$_i]}")
            _filtered_custom_paths+=("${CUSTOM_EVALUATOR_PATHS[$_i]}")
        fi
    done
    CUSTOM_EVALUATOR_NAMES=("${_filtered_custom_names[@]}")
    CUSTOM_EVALUATOR_PATHS=("${_filtered_custom_paths[@]}")
    CUSTOM_EVAL_COUNT=${#CUSTOM_EVALUATOR_NAMES[@]}

    ALL_EVALUATOR_COUNT=$(( ${#CORE_EVALUATORS[@]} + CUSTOM_EVAL_COUNT ))
    log "Single evaluator mode: ${SINGLE_EVALUATOR}"
fi

# ============================================================================
# Build evaluation prompt
# ============================================================================

build_eval_prompt() {
    local evaluator=$1
    local is_custom=${2:-false}
    local api_mode=${3:-false}  # true for batch/direct API (inline files, no save instructions)
    local persona_file

    if [[ "$is_custom" == true ]]; then
        # Custom evaluator: path was resolved above
        local idx=0
        for cname in "${CUSTOM_EVALUATOR_NAMES[@]}"; do
            if [[ "$cname" == "$evaluator" ]]; then
                persona_file="${CUSTOM_EVALUATOR_PATHS[$idx]}"
                break
            fi
            idx=$((idx + 1))
        done
    else
        persona_file="${PERSONA_DIR}/${evaluator}.md"
    fi

    if [[ ! -f "$persona_file" ]]; then
        log "ERROR: Persona file not found: $persona_file"
        return 1
    fi

    local persona
    persona=$(cat "$persona_file")

    # Replace {GENRE} placeholder in persona (used by genre-expert)
    if [[ -n "$PROJECT_GENRE" ]]; then
        persona="${persona//\{GENRE\}/$GENRE_DISPLAY}"
    else
        persona="${persona//\{GENRE\}/fiction}"
    fi

    # Build inline manuscript content for API mode
    local manuscript_inline=""
    if [[ "$api_mode" == true ]]; then
        for sf in "${SCENE_FILES[@]}"; do
            sf_path="${PROJECT_DIR}/${sf}"
            if [[ -f "$sf_path" ]]; then
                manuscript_inline="${manuscript_inline}
===== ${sf} =====

$(cat "$sf_path")

===== END ${sf} =====
"
            fi
        done
    fi

    # Build final evaluation context block (if --final flag is set)
    local final_eval_block=""
    if [[ "$FINAL_EVAL" == true ]]; then
        final_eval_block="===== EVALUATION CONTEXT =====

This is a final evaluation. The author plans to send this manuscript to beta
readers after this cycle. Evaluate with that lens:

- Focus on issues that outside readers would notice, stumble on, or be
  confused by.
- Minor craft refinements that wouldn't affect a reader's experience should
  be noted briefly but should not dominate your report or be prioritized
  highly.
- Assess whether this manuscript is ready for outside eyes. What would
  embarrass the book in front of readers who don't know the author?

"
        case "$evaluator" in
            first-reader)
                final_eval_block+="Your perspective is the closest proxy for these beta readers — be explicit about where you'd put the book down, where you'd lose trust, and where you'd text a friend to say they have to read this."
                ;;
            developmental-editor)
                final_eval_block+="Focus on structural issues that would leave a reader feeling the story didn't hold together — dropped threads, unearned turns, pacing dead zones. Save fine-grained scene function notes for a future pass."
                ;;
            line-editor)
                final_eval_block+="Focus on prose issues that would pull a non-specialist reader out of the story — confusing sentences, jarring tense shifts, dialogue that rings false. Pattern-level tics that only another writer would notice can be flagged briefly."
                ;;
            genre-expert)
                final_eval_block+="Focus on where genre readers' expectations would be violated in ways that feel like mistakes rather than deliberate subversions. Would a reader of this genre feel they got what they came for?"
                ;;
            literary-agent)
                final_eval_block+="Assess this as if the author is about to share it with a small group before querying. What would you want fixed before anyone outside the author's circle sees it."
                ;;
            writing-coach)
                final_eval_block+="This is the last evaluation before outside readers. Focus your guidance on what the author should protect during any final touch-ups, and flag only growth edges that are actively visible to readers — not long-term craft development."
                ;;
        esac
    fi

    cat <<EVAL_PROMPT
You are evaluating the manuscript of "${PROJECT_TITLE}."

===== PROJECT CONTEXT =====

Title: ${PROJECT_TITLE}
Genre: ${GENRE_DISPLAY:-Not specified}
Logline: ${PROJECT_LOGLINE:-Not provided}
Evaluation scope: ${SCOPE_DESCRIPTION}

===== YOUR ROLE =====

${persona}

${final_eval_block}

$(if [[ "$api_mode" == true ]]; then
    cat <<APIFILES
===== MANUSCRIPT =====

${manuscript_inline}

===== INSTRUCTIONS =====

The manuscript is provided above. Evaluate it following the structure defined in your role description.

APIFILES
else
    cat <<CLIFILES
===== INSTRUCTIONS =====

$(if [[ "$INPUT_TYPE" == "chapters" ]]; then
    echo "1. Read the assembled chapter files that comprise the evaluation scope. These are the final manuscript chapters with scenes already combined, scene breaks in place, and chapter headings applied. Read them in order:"
else
    echo "1. Read the scene files that comprise the evaluation scope. Read them in order:"
fi)
${SCENE_LIST_STR}
CLIFILES
fi)

$(if [[ "$api_mode" != true ]]; then
    echo "2. Write your evaluation report following the structure defined in your role description above."
    echo ""
    echo "3. Save your report to: working/evaluations/eval-${EVAL_TIMESTAMP}/${evaluator}.md"
    echo ""
fi)
$(if [[ "$INPUT_TYPE" == "chapters" ]]; then
    cat <<'CHAPTER_CITE'
Be specific. Cite chapter numbers, character names, and quote brief passages when making points. Pay particular attention to:
   - Chapter-level pacing: Does each chapter have a satisfying arc? Does it open with momentum and close with a reason to turn the page?
   - Chapter transitions: How does the end of one chapter flow into the beginning of the next? Are cliffhangers, hooks, and tonal shifts effective?
   - Chapter length variation: Are chapters appropriately varied in length, or do they feel monotonous? Do short chapters create urgency where needed?
   - Scene breaks within chapters: Do the scene breaks within each chapter feel natural? Does the ordering of scenes within a chapter create the right rhythm?
   - Overall reading momentum: Evaluate pacing as a reader would experience it — chapter by chapter, not scene by scene.
CHAPTER_CITE
else
    cat <<'SCENE_CITE'
Be specific. Cite scene IDs, character names, and quote brief passages when making points. Vague praise or criticism is unhelpful. The author wants to know exactly what works, what does not, and why.
SCENE_CITE
fi)

Be honest. The author is looking for professional-grade feedback, not encouragement. If something is broken, say so clearly. If something is excellent, say that too — protecting strengths is as important as fixing weaknesses.

$(if [[ "$api_mode" == true ]]; then
    echo "===== OUTPUT ====="
    echo ""
    echo "Output your complete evaluation report directly. Do not include any preamble or explanation — just the evaluation report content."
else
    cat <<CLIOUTPUT
===== OUTPUT =====

Save your complete evaluation to: working/evaluations/eval-${EVAL_TIMESTAMP}/${evaluator}.md

===== COMMIT AND PUSH =====

After saving your report, stage and commit:

  git add "working/evaluations/eval-${EVAL_TIMESTAMP}/${evaluator}.md"
  git commit -m "Evaluate: ${evaluator} report (${SCOPE_DESCRIPTION})"
  git push

This is required — the author follows progress by pulling commits as you work.
CLIOUTPUT
fi)
EVAL_PROMPT
}

# ============================================================================
# Progress monitors (background processes for user feedback)
# ============================================================================

evaluation_monitor() {
    local eval_dir="$1"
    local eval_names_str="$2"
    local total_count="$3"
    local start_time="$4"

    # Split names into array
    local names=()
    read -ra names <<< "$eval_names_str"

    # Track which evaluators we've already reported on (space-delimited strings for bash 3.2 compat)
    local reported_complete=" "
    local reported_active=" "
    local completed=0
    local ticks=0

    while true; do
        sleep 30
        ticks=$((ticks + 1))
        local elapsed=$(( $(date +%s) - start_time ))
        local mins=$(( elapsed / 60 ))

        # Check for new report files
        for name in "${names[@]}"; do
            if [[ "$reported_complete" != *" ${name} "* && -f "${eval_dir}/${name}.md" ]]; then
                local wc
                wc=$(wc -w < "${eval_dir}/${name}.md" 2>/dev/null | tr -d ' ')
                log "  [${name}] Report created (~${wc} words) [${mins}m]"
                reported_complete="${reported_complete}${name} "
                completed=$((completed + 1))
            fi
        done

        # Check log file activity for in-progress evaluators (report once per evaluator)
        for name in "${names[@]}"; do
            if [[ "$reported_complete" != *" ${name} "* && "$reported_active" != *" ${name} "* ]]; then
                local log_file="${LOG_DIR}/eval-${name}.log"
                if [[ -f "$log_file" ]]; then
                    local log_size
                    log_size=$(wc -c < "$log_file" 2>/dev/null | tr -d ' ')
                    if (( log_size > 1000 )); then
                        log "  [${name}] Log active (growing) [${mins}m]"
                        reported_active="${reported_active}${name} "
                    fi
                fi
            fi
        done

        # Heartbeat every 2 minutes (4 ticks x 30s)
        if (( ticks % 4 == 0 )); then
            log "  Evaluator progress: ${completed}/${total_count} complete, ${mins}m elapsed..."
        fi
    done
}

synthesis_monitor() {
    local eval_dir="$1"
    local start_time="$2"

    local synthesis_detected=false
    local findings_detected=false
    local ticks=0

    while true; do
        sleep 30
        ticks=$((ticks + 1))
        local elapsed=$(( $(date +%s) - start_time ))
        local mins=$(( elapsed / 60 ))

        # Check for synthesis.md creation
        if [[ "$synthesis_detected" == false && -f "${eval_dir}/synthesis.md" ]]; then
            synthesis_detected=true
            local wc
            wc=$(wc -w < "${eval_dir}/synthesis.md" 2>/dev/null | tr -d ' ')
            log "  [synthesis] synthesis.md created (~${wc} words) [${mins}m]"
        fi

        # Check for findings.yaml creation
        if [[ "$findings_detected" == false && -f "${eval_dir}/findings.yaml" ]]; then
            findings_detected=true
            log "  [synthesis] findings.yaml created [${mins}m]"
        fi

        # Heartbeat every 2 minutes (4 ticks x 30s)
        if (( ticks % 4 == 0 )); then
            log "  Synthesis: ${mins}m elapsed..."
        fi
    done
}

# ============================================================================
# Main execution
# ============================================================================

# --- Dry-run mode: print all prompts and exit ---
if [[ "$DRY_RUN" == true ]]; then
    DRY_RUN_API=false
    [[ "$EVAL_MODE" == "batch" || "$EVAL_MODE" == "direct" ]] && DRY_RUN_API=true
    echo "# Mode: ${EVAL_MODE} (api_prompts: ${DRY_RUN_API})"
    echo ""
    for EVAL in "${CORE_EVALUATORS[@]}"; do
        echo "===== DRY RUN: ${EVAL} ====="
        build_eval_prompt "$EVAL" false "$DRY_RUN_API"
        echo "===== END DRY RUN: ${EVAL} ====="
        echo ""
    done
    if [[ ${#CUSTOM_EVALUATOR_NAMES[@]} -gt 0 ]]; then
        for EVAL in "${CUSTOM_EVALUATOR_NAMES[@]}"; do
            [[ -z "$EVAL" ]] && continue
            echo "===== DRY RUN: ${EVAL} (custom) ====="
            build_eval_prompt "$EVAL" true "$DRY_RUN_API"
            echo "===== END DRY RUN: ${EVAL} ====="
            echo ""
        done
    fi

    # Synthesis prompt (placeholder — full synthesis depends on evaluator output)
    echo "===== DRY RUN: synthesis (Pass 1 — reconciliation) ====="
    echo "# Reconciliation prompt would read reports from: working/evaluations/eval-${EVAL_TIMESTAMP}/"
    echo "# Evaluators: ${CORE_EVALUATORS[*]}"
    echo "# No reference files — pure panel feedback synthesis"
    if [[ "$DRY_RUN_API" == true ]]; then
        echo "# Mode: direct API (reports will be inlined in prompt)"
    fi
    echo "===== END DRY RUN: synthesis ====="
    echo ""

    # Assessment prompt (placeholder — depends on synthesis output + reference files)
    echo "===== DRY RUN: assessment (Pass 2 — execution vs. intent) ====="
    echo "# Assessment reads: synthesis.md + reference files"
    echo "# Reference files checked: key-decisions.md, voice-guide.md, story-architecture.md"
    echo "# Sections: Voice Guide Alignment, Story Architecture Alignment, Key Decisions Audit, Revised Priorities"
    if [[ "$FINAL_EVAL" == true ]]; then
        echo "# --final: includes Beta Reader Readiness section"
    fi
    echo "# Skipped if no reference files exist"
    echo "===== END DRY RUN: assessment ====="
    exit 0
fi

# --- Pipeline manifest: start a new cycle (after dry-run guard) ---
if [[ -z "$SINGLE_EVALUATOR" ]]; then
    ensure_pipeline_manifest
    CYCLE_ID=$(start_new_cycle)
    update_cycle_field "$CYCLE_ID" "evaluation" "eval-${EVAL_TIMESTAMP}"
    update_cycle_field "$CYCLE_ID" "status" "evaluating"
else
    CYCLE_ID="0"
fi

mkdir -p "$EVAL_DIR" "$LOG_DIR"

SESSION_START=$(date +%s)

# --- Branch + PR setup (skip for single evaluator) ---
if [[ -z "$SINGLE_EVALUATOR" ]]; then
create_branch "evaluate" "$PROJECT_DIR"

ensure_branch_pushed "$PROJECT_DIR"

PR_BODY="## Evaluation Panel

**Project:** ${PROJECT_TITLE}
**Scope:** ${SCOPE_DESCRIPTION}
**Evaluators:** ${ALL_EVALUATOR_COUNT}

### Tasks
"
# Build task labels (track for consistent checkbox updates later)
EVAL_TASK_LABELS=()
for EVAL in "${CORE_EVALUATORS[@]}"; do
    label="Evaluator: ${EVAL}"
    EVAL_TASK_LABELS+=("$label")
    PR_BODY="${PR_BODY}- [ ] ${label}
"
done
for EVAL in "${CUSTOM_EVALUATOR_NAMES[@]}"; do
    [[ -z "$EVAL" ]] && continue
    label="Evaluator: ${EVAL} (custom)"
    EVAL_TASK_LABELS+=("$label")
    PR_BODY="${PR_BODY}- [ ] ${label}
"
done
PR_BODY="${PR_BODY}- [ ] Synthesis
- [ ] Assessment"

create_draft_pr "Evaluate: ${PROJECT_TITLE} (${SCOPE_DESCRIPTION})" "$PR_BODY" "$PROJECT_DIR" "evaluation"
fi  # end of branch/PR setup (skipped for single evaluator)

log "============================================"
log "Starting Storyforge evaluation panel"
log "Project: ${PROJECT_TITLE}"
log "Genre: ${GENRE_DISPLAY:-Not specified}"
log "Scope: ${SCOPE_DESCRIPTION}"
log "Core evaluators: ${CORE_EVALUATORS[*]}"
if [[ ${#CUSTOM_EVALUATOR_NAMES[@]} -gt 0 ]]; then
    log "Custom evaluators: ${CUSTOM_EVALUATOR_NAMES[*]}"
fi
log "Output directory: ${EVAL_DIR}"
log "============================================"

# --- Cost forecast ---
EVAL_MODEL_FORECAST=$(select_model "evaluation")
SYNTH_MODEL_FORECAST=$(select_model "synthesis")

# Estimate average word count from metadata.csv or scene files
METADATA_CSV="${PROJECT_DIR}/reference/scene-metadata.csv"
# Fallback to old location
[[ ! -f "$METADATA_CSV" ]] && METADATA_CSV="${PROJECT_DIR}/scenes/metadata.csv"
AVG_WORDS=0
if [[ -f "$METADATA_CSV" ]]; then
    TOTAL_WC=0
    WC_COUNT=0
    while IFS= read -r wc; do
        [[ -z "$wc" || "$wc" == "0" ]] && continue
        TOTAL_WC=$((TOTAL_WC + wc))
        WC_COUNT=$((WC_COUNT + 1))
    done < <(get_csv_column "$METADATA_CSV" "word_count")
    if (( WC_COUNT > 0 )); then
        AVG_WORDS=$((TOTAL_WC / WC_COUNT))
    fi
fi
if (( AVG_WORDS == 0 )); then
    # Estimate from scene files
    TOTAL_WC=0
    WC_COUNT=0
    for sf in "${SCENE_FILES[@]}"; do
        sf_path="${PROJECT_DIR}/${sf}"
        if [[ -f "$sf_path" ]]; then
            wc_val=$(wc -w < "$sf_path" | tr -d ' ')
            TOTAL_WC=$((TOTAL_WC + wc_val))
            WC_COUNT=$((WC_COUNT + 1))
        fi
    done
    if (( WC_COUNT > 0 )); then
        AVG_WORDS=$((TOTAL_WC / WC_COUNT))
    else
        AVG_WORDS=3000
    fi
fi

# Each evaluator reads all scenes; synthesis reads reports
EVALUATOR_COST=$(estimate_cost "evaluate" "${#SCENE_FILES[@]}" "$AVG_WORDS" "$EVAL_MODEL_FORECAST")
SYNTH_COST=$(estimate_cost "evaluate" "1" "$((AVG_WORDS * ${#SCENE_FILES[@]}))" "$SYNTH_MODEL_FORECAST")
if [[ "$EVAL_MODE" == "batch" ]]; then
    # Batch API gets 50% discount on input tokens — approximate as 25% total discount
    TOTAL_FORECAST=$(awk "BEGIN { printf \"%.2f\", (${EVALUATOR_COST} * ${ALL_EVALUATOR_COUNT}) * 0.75 + ${SYNTH_COST} }")
    COST_MODE_LABEL="batch, ~25% discount"
else
    TOTAL_FORECAST=$(awk "BEGIN { printf \"%.2f\", ${EVALUATOR_COST} * ${ALL_EVALUATOR_COUNT} + ${SYNTH_COST} }")
    COST_MODE_LABEL="${EVAL_MODE}"
fi

log "Cost forecast: ~\$${TOTAL_FORECAST} (${ALL_EVALUATOR_COUNT} evaluators @ ~\$${EVALUATOR_COST} + synthesis ~\$${SYNTH_COST}, mode: ${COST_MODE_LABEL})"
check_cost_threshold "$TOTAL_FORECAST" || { log "Cost threshold check declined. Aborting."; exit 1; }

# --- Offer interactive mode before starting ---
if [[ ! -f "$INTERACTIVE_FILE" ]]; then
    offer_interactive "$PROJECT_DIR" "Evaluation panel (${ALL_EVALUATOR_COUNT} evaluators)" || true
fi

# --- Launch all evaluators ---
EVAL_NAMES=()
EVAL_MODELS=()
_SF_INVOCATION_START=$(date +%s)
export _SF_INVOCATION_START

# Collect all evaluator names + models + prompts
ALL_EVAL_PROMPTS=()
ALL_EVAL_IS_CUSTOM=()

# Determine if prompts need inline file content (API modes can't read files)
USE_API_PROMPTS=false
if [[ "$EVAL_MODE" == "batch" || "$EVAL_MODE" == "direct" ]]; then
    USE_API_PROMPTS=true
fi

for EVAL in "${CORE_EVALUATORS[@]}"; do
    EVAL_MODEL=$(select_model "evaluation")
    EVAL_NAMES+=("$EVAL")
    EVAL_MODELS+=("$EVAL_MODEL")
    ALL_EVAL_PROMPTS+=("$(build_eval_prompt "$EVAL" false "$USE_API_PROMPTS")")
    ALL_EVAL_IS_CUSTOM+=(false)
done

for EVAL in "${CUSTOM_EVALUATOR_NAMES[@]}"; do
    [[ -z "$EVAL" ]] && continue
    EVAL_MODEL=$(select_model "evaluation")
    EVAL_NAMES+=("$EVAL")
    EVAL_MODELS+=("$EVAL_MODEL")
    ALL_EVAL_PROMPTS+=("$(build_eval_prompt "$EVAL" true "$USE_API_PROMPTS")")
    ALL_EVAL_IS_CUSTOM+=(true)
done

FAILED=()
SUCCEEDED=()

if [[ "$EVAL_MODE" == "batch" ]]; then
    # ---- BATCH MODE: submit all evaluators as a single batch ----
    log "Building batch request for ${#EVAL_NAMES[@]} evaluators..."
    BATCH_FILE="${LOG_DIR}/eval-batch-${EVAL_TIMESTAMP}.jsonl"
    > "$BATCH_FILE"

    for i in "${!EVAL_NAMES[@]}"; do
        EVAL_NAME="${EVAL_NAMES[$i]}"
        EVAL_MODEL="${EVAL_MODELS[$i]}"
        PROMPT="${ALL_EVAL_PROMPTS[$i]}"

        # Build JSONL line — escape prompt for JSON
        json_prompt=$(jq -Rs '.' <<< "$PROMPT")
        cat <<BATCHLINE >> "$BATCH_FILE"
{"custom_id": "${EVAL_NAME}", "params": {"model": "${EVAL_MODEL}", "max_tokens": 8192, "messages": [{"role": "user", "content": ${json_prompt}}]}}
BATCHLINE
        log "  Added to batch: ${EVAL_NAME} (model: ${EVAL_MODEL})"
    done

    log "Submitting batch (${#EVAL_NAMES[@]} requests)..."
    BATCH_ID=$(submit_batch "$BATCH_FILE")
    log "Batch submitted: ${BATCH_ID}"

    log "Polling batch for completion..."
    poll_batch "$BATCH_ID"
    log "Batch complete. Downloading results..."

    download_batch_results "$BATCH_ID" "$EVAL_DIR" "$LOG_DIR"

    # Process results for each evaluator
    for i in "${!EVAL_NAMES[@]}"; do
        EVAL_NAME="${EVAL_NAMES[$i]}"
        EVAL_MODEL="${EVAL_MODELS[$i]}"
        STATUS_FILE="${EVAL_DIR}/.status-${EVAL_NAME}"
        EVAL_JSON="${LOG_DIR}/${EVAL_NAME}.json"
        EVAL_TXT="${LOG_DIR}/${EVAL_NAME}.txt"

        # Log usage from the per-evaluator JSON response
        if [[ -f "$EVAL_JSON" ]]; then
            log_api_usage "$EVAL_JSON" "evaluate" "$EVAL_NAME" "$EVAL_MODEL"
        fi

        if [[ -f "$STATUS_FILE" ]] && [[ "$(cat "$STATUS_FILE")" == "ok" ]]; then
            # Batch responses are text — the evaluator prompt asked Claude to save a file,
            # but in API mode Claude can't write files. Save the response as the report.
            if [[ -f "$EVAL_TXT" ]]; then
                mkdir -p "$EVAL_DIR"
                cp "$EVAL_TXT" "${EVAL_DIR}/${EVAL_NAME}.md"
            fi

            if [[ -f "${EVAL_DIR}/${EVAL_NAME}.md" ]]; then
                WORD_COUNT=$(wc -w < "${EVAL_DIR}/${EVAL_NAME}.md" | tr -d ' ')
                log "SUCCESS: ${EVAL_NAME} (${WORD_COUNT} words)"
                SUCCEEDED+=("$EVAL_NAME")
                update_pr_task "${EVAL_TASK_LABELS[$i]}" "$PROJECT_DIR"
            else
                log "FAILED: ${EVAL_NAME} (no output file created)"
                FAILED+=("$EVAL_NAME")
            fi
        else
            log "FAILED: ${EVAL_NAME} (batch request failed)"
            FAILED+=("$EVAL_NAME")
        fi
    done

    # Clean up batch artifacts
    rm -f "$BATCH_FILE"

elif [[ "$EVAL_MODE" == "direct" ]]; then
    # ---- DIRECT MODE: parallel invoke_anthropic_api calls ----
    PIDS=()

    for i in "${!EVAL_NAMES[@]}"; do
        EVAL_NAME="${EVAL_NAMES[$i]}"
        EVAL_MODEL="${EVAL_MODELS[$i]}"
        EVAL_LOG="${LOG_DIR}/eval-${EVAL_NAME}.log"
        PROMPT="${ALL_EVAL_PROMPTS[$i]}"

        IS_CUSTOM="${ALL_EVAL_IS_CUSTOM[$i]}"
        if [[ "$IS_CUSTOM" == true ]]; then
            log "Launching custom evaluator (direct API): ${EVAL_NAME} (model: ${EVAL_MODEL})"
        else
            log "Launching evaluator (direct API): ${EVAL_NAME} (model: ${EVAL_MODEL})"
        fi

        (
            invoke_anthropic_api "$PROMPT" "$EVAL_MODEL" "$EVAL_LOG" 8192 || true

            # Save response as the evaluator report
            if [[ -f "$EVAL_LOG" ]]; then
                response=$(extract_api_response "$EVAL_LOG" || true)
                if [[ -n "$response" ]]; then
                    mkdir -p "$EVAL_DIR"
                    echo "$response" > "${EVAL_DIR}/${EVAL_NAME}.md"
                    echo "ok" > "${EVAL_DIR}/.status-${EVAL_NAME}"
                else
                    echo "fail" > "${EVAL_DIR}/.status-${EVAL_NAME}"
                fi
            else
                echo "fail" > "${EVAL_DIR}/.status-${EVAL_NAME}"
            fi
        ) &

        PIDS+=($!)
        register_child_pid $!
    done

    log "All ${#PIDS[@]} evaluators launched (direct API). Waiting for completion..."

    # Launch background progress monitor
    evaluation_monitor "$EVAL_DIR" "${EVAL_NAMES[*]}" "${#PIDS[@]}" "$(date +%s)" &
    EVAL_MONITOR_PID=$!
    register_child_pid $EVAL_MONITOR_PID

    for i in "${!PIDS[@]}"; do
        PID=${PIDS[$i]}
        EVAL_NAME=${EVAL_NAMES[$i]}

        set +e
        wait "$PID"
        EXIT_CODE=$?
        set -e

        EVAL_LOG_FILE="${LOG_DIR}/eval-${EVAL_NAME}.log"
        EVAL_MODEL_USED="${EVAL_MODELS[$i]:-unknown}"
        log_api_usage "$EVAL_LOG_FILE" "evaluate" "$EVAL_NAME" "$EVAL_MODEL_USED"

        STATUS_FILE="${EVAL_DIR}/.status-${EVAL_NAME}"
        if [[ -f "$STATUS_FILE" ]] && [[ "$(cat "$STATUS_FILE")" == "ok" ]]; then
            if [[ -f "${EVAL_DIR}/${EVAL_NAME}.md" ]]; then
                WORD_COUNT=$(wc -w < "${EVAL_DIR}/${EVAL_NAME}.md" | tr -d ' ')
                log "SUCCESS: ${EVAL_NAME} (${WORD_COUNT} words)"
                SUCCEEDED+=("$EVAL_NAME")
                update_pr_task "${EVAL_TASK_LABELS[$i]}" "$PROJECT_DIR"
            else
                log "FAILED: ${EVAL_NAME} (no output file created)"
                FAILED+=("$EVAL_NAME")
            fi
        else
            log "FAILED: ${EVAL_NAME} (exit code ${EXIT_CODE})"
            FAILED+=("$EVAL_NAME")
        fi
    done

    # Stop the evaluation progress monitor
    kill "$EVAL_MONITOR_PID" 2>/dev/null || true
    wait "$EVAL_MONITOR_PID" 2>/dev/null || true

else
    # ---- INTERACTIVE MODE: keep claude -p unchanged ----
    PIDS=()

    for i in "${!EVAL_NAMES[@]}"; do
        EVAL_NAME="${EVAL_NAMES[$i]}"
        EVAL_MODEL="${EVAL_MODELS[$i]}"
        EVAL_LOG="${LOG_DIR}/eval-${EVAL_NAME}.log"
        PROMPT="${ALL_EVAL_PROMPTS[$i]}"

        IS_CUSTOM="${ALL_EVAL_IS_CUSTOM[$i]}"
        if [[ "$IS_CUSTOM" == true ]]; then
            log "Launching custom evaluator: ${EVAL_NAME} (model: ${EVAL_MODEL})"
        else
            log "Launching evaluator: ${EVAL_NAME} (model: ${EVAL_MODEL})"
        fi

        claude -p "$PROMPT" \
            --model "$EVAL_MODEL" \
            --dangerously-skip-permissions \
            --output-format stream-json \
            --verbose \
            $BUDGET_FLAG \
            > "$EVAL_LOG" 2>&1 &

        PIDS+=($!)
        register_child_pid $!
    done

    log "All ${#PIDS[@]} evaluators launched. Waiting for completion..."

    # Launch background progress monitor
    evaluation_monitor "$EVAL_DIR" "${EVAL_NAMES[*]}" "${#PIDS[@]}" "$(date +%s)" &
    EVAL_MONITOR_PID=$!
    register_child_pid $EVAL_MONITOR_PID

    for i in "${!PIDS[@]}"; do
        PID=${PIDS[$i]}
        EVAL_NAME=${EVAL_NAMES[$i]}

        set +e
        wait "$PID"
        EXIT_CODE=$?
        set -e

        EVAL_LOG_FILE="${LOG_DIR}/eval-${EVAL_NAME}.log"
        EVAL_MODEL_USED="${EVAL_MODELS[$i]:-unknown}"
        log_usage "$EVAL_LOG_FILE" "evaluate" "$EVAL_NAME" "$EVAL_MODEL_USED"

        if (( EXIT_CODE != 0 )); then
            log "FAILED: ${EVAL_NAME} (exit code $EXIT_CODE)"
            FAILED+=("$EVAL_NAME")
        elif [[ ! -f "${EVAL_DIR}/${EVAL_NAME}.md" ]]; then
            log "FAILED: ${EVAL_NAME} (no output file created)"
            FAILED+=("$EVAL_NAME")
        else
            WORD_COUNT=$(wc -w < "${EVAL_DIR}/${EVAL_NAME}.md" | tr -d ' ')
            log "SUCCESS: ${EVAL_NAME} (${WORD_COUNT} words)"
            SUCCEEDED+=("$EVAL_NAME")
            update_pr_task "${EVAL_TASK_LABELS[$i]}" "$PROJECT_DIR"
        fi
    done

    # Stop the evaluation progress monitor
    kill "$EVAL_MONITOR_PID" 2>/dev/null || true
    wait "$EVAL_MONITOR_PID" 2>/dev/null || true
fi

log "Evaluator results: ${#SUCCEEDED[@]} succeeded, ${#FAILED[@]} failed"

if (( ${#FAILED[@]} > 0 )); then
    log "Failed evaluators: ${FAILED[*]}"
fi

# --- Run synthesis (needs at least 3 evaluators to be useful) ---
if [[ -n "$SINGLE_EVALUATOR" ]]; then
    log "Single evaluator mode — skipping synthesis and assessment"
elif (( ${#SUCCEEDED[@]} < 3 )); then
    log "ERROR: Too few evaluators succeeded (${#SUCCEEDED[@]}/${ALL_EVALUATOR_COUNT}). Skipping synthesis."
    exit 1
fi

if [[ -z "$SINGLE_EVALUATOR" ]] && (( ${#SUCCEEDED[@]} >= 3 )); then
log "Running synthesis session..."
SYNTHESIS_LOG="${LOG_DIR}/eval-synthesis.log"

SYNTH_START=$(date +%s)
SYNTH_MODEL=$(select_model "synthesis")

INTERACTIVE_FILE="${PROJECT_DIR}/working/.interactive"
if [[ "$INTERACTIVE" == true ]]; then
    touch "$INTERACTIVE_FILE"
fi

_SF_INVOCATION_START=$(date +%s)
export _SF_INVOCATION_START

begin_healing_zone "evaluation synthesis"

# Build beta reader readiness section for synthesis (if --final)
SYNTH_READINESS=""
if [[ "$FINAL_EVAL" == true ]]; then
    SYNTH_READINESS="
## Beta Reader Readiness

Assess whether this manuscript is ready for beta readers. Use one of these three ratings:

**Ready with high confidence** — The manuscript is solid. Beta readers will engage with the story on its own terms. Any remaining issues are minor and won't undermine the reading experience.

**Ready with reservations** — The manuscript can go to beta readers, but certain issues may surface in their feedback. List what those issues are and what the author should expect to hear.

**Not ready** — There are issues that should be addressed before outside readers see this. List the specific blockers and why they matter.

Whichever rating you choose, explain your reasoning in 2-3 paragraphs. Ground it in the evaluator reports — this should feel like a synthesis judgment, not a new opinion.
"
fi

# Build list of available reports for the synthesis prompt
REPORT_LIST=""
for EVAL_NAME in "${SUCCEEDED[@]}"; do
    REPORT_LIST="${REPORT_LIST}   - working/evaluations/eval-${EVAL_TIMESTAMP}/${EVAL_NAME}.md
"
done

read -r -d '' SYNTHESIS_PROMPT <<SYNTH_EOF || true
You are reconciling the evaluation reports from a multi-agent review panel for "${PROJECT_TITLE}."

Your job is to synthesize what the panel said — consensus, disagreements, and priorities. Do not filter or reinterpret findings based on the author's intentions. Report what the evaluators experienced.

===== PROJECT CONTEXT =====

Title: ${PROJECT_TITLE}
Genre: ${GENRE_DISPLAY:-Not specified}
Logline: ${PROJECT_LOGLINE:-Not provided}
Evaluation scope: ${SCOPE_DESCRIPTION}

===== INSTRUCTIONS =====

1. Read ALL of the following evaluation reports:
${REPORT_LIST}
2. Produce TWO output files:

--- FILE 1: synthesis.md ---

Save to: working/evaluations/eval-${EVAL_TIMESTAMP}/synthesis.md

A prose synthesis report with these sections:

## Consensus Findings
Issues or strengths identified by 3+ evaluators. These are high-confidence findings.

## Contested Points
Areas where evaluators disagree. Present both sides fairly and note why the disagreement exists.

## Prioritized Action Items
A numbered list of the most impactful changes, ordered by priority. For each:
- What the issue is
- Which evaluators flagged it
- Suggested approach
- Estimated effort (minor/moderate/major)

## Strengths to Protect
Elements that evaluators praised and that must be preserved in any further revision.

## Overall Assessment
A brief (2-3 paragraph) synthesis of where the manuscript stands. Be direct.

--- FILE 2: findings.yaml ---

Save to: working/evaluations/eval-${EVAL_TIMESTAMP}/findings.yaml

A structured YAML file containing all findings categorized for machine consumption. Use this exact format:

\`\`\`yaml
# Evaluation Findings — ${PROJECT_TITLE}
# Generated: ${EVAL_TIMESTAMP}
# Scope: ${SCOPE_DESCRIPTION}

metadata:
  title: "${PROJECT_TITLE}"
  genre: "${GENRE_DISPLAY:-Not specified}"
  scope: "${SCOPE_DESCRIPTION}"
  evaluators_succeeded:
    - evaluator-name
  evaluators_failed:
    - evaluator-name
  timestamp: "${EVAL_TIMESTAMP}"

findings:
  - id: F001
    category: structure|character|pacing|prose|worldbuilding|theme|market|genre|continuity
    severity: critical|major|minor|suggestion
    summary: "One-line description of the finding"
    detail: "Full explanation with context"
    affected_locations:
      - $(if [[ "$INPUT_TYPE" == "chapters" ]]; then echo "chapter-number-or-range"; else echo "scene-id"; fi)
    flagged_by:
      - evaluator-name
    recommendation: "Specific, actionable suggestion"
    fix_location: brief|intent|structural|craft
    # Where to fix this finding:
    #   brief — fix in scene-briefs.csv (knowledge, goal/conflict/outcome, key_actions)
    #   intent — fix in scene-intent.csv (value_shift, threads, scene_type, emotional_arc)
    #   structural — fix in scenes.csv (pov, timeline, part structure)
    #   craft — fix in prose only (voice, rhythm, word choice — no upstream changes needed)

  # ... more findings ...

strengths:
  - id: S001
    category: structure|character|pacing|prose|worldbuilding|theme|voice|craft
    summary: "One-line description of the strength"
    detail: "Why this works and why it must be protected"
    examples:
      - $(if [[ "$INPUT_TYPE" == "chapters" ]]; then echo "chapter-number-or-range"; else echo "scene-id"; fi)
    flagged_by:
      - evaluator-name

  # ... more strengths ...
\`\`\`

IMPORTANT: The findings.yaml must be valid YAML. Use quoted strings for values that contain colons, special characters, or newlines. Categorize every substantive point from every evaluator report. Severity levels:
- critical: Structural or fundamental issue that must be addressed
- major: Significant issue that weakens the manuscript
- minor: Worth fixing but not urgent
- suggestion: Nice-to-have improvement

After saving both files, stage and commit:

  git add "working/evaluations/eval-${EVAL_TIMESTAMP}/synthesis.md" "working/evaluations/eval-${EVAL_TIMESTAMP}/findings.yaml"
  git commit -m "Evaluate: synthesis (${SCOPE_DESCRIPTION})"
  git push

This is required — the author follows progress by pulling commits as you work.
SYNTH_EOF

if [[ "$EVAL_MODE" == "interactive" ]]; then
    # Interactive synthesis — user can guide how findings are interpreted
    show_interactive_banner "Evaluation Synthesis"

    SYNTH_SYSTEM=$(build_interactive_system_prompt "$PROJECT_DIR" "synthesis")

    claude "$SYNTHESIS_PROMPT" \
        --model "$SYNTH_MODEL" \
        --dangerously-skip-permissions \
        --append-system-prompt "$SYNTH_SYSTEM" || false
else
    # Non-interactive (batch or direct): use direct API for synthesis
    # Build an augmented prompt that includes report contents inline
    # (API mode can't read files from disk)
    SYNTH_INLINE_REPORTS=""
    for EVAL_NAME in "${SUCCEEDED[@]}"; do
        REPORT_FILE="${EVAL_DIR}/${EVAL_NAME}.md"
        if [[ -f "$REPORT_FILE" ]]; then
            SYNTH_INLINE_REPORTS="${SYNTH_INLINE_REPORTS}
===== REPORT: ${EVAL_NAME} =====

$(cat "$REPORT_FILE")

===== END REPORT: ${EVAL_NAME} =====
"
        fi
    done

    # Build API-mode synthesis prompt (replaces file-reading instructions with inline content)
    read -r -d '' SYNTH_API_PROMPT <<SYNTH_API_EOF || true
You are reconciling the evaluation reports from a multi-agent review panel for "${PROJECT_TITLE}."

Your job is to synthesize what the panel said — consensus, disagreements, and priorities. Do not filter or reinterpret findings based on the author's intentions. Report what the evaluators experienced.

===== PROJECT CONTEXT =====

Title: ${PROJECT_TITLE}
Genre: ${GENRE_DISPLAY:-Not specified}
Logline: ${PROJECT_LOGLINE:-Not provided}
Evaluation scope: ${SCOPE_DESCRIPTION}

===== EVALUATION REPORTS =====

${SYNTH_INLINE_REPORTS}

===== INSTRUCTIONS =====

Produce TWO sections in your response, clearly delimited:

--- BEGIN synthesis.md ---

A prose synthesis report with these sections:

## Consensus Findings
Issues or strengths identified by 3+ evaluators. These are high-confidence findings.

## Contested Points
Areas where evaluators disagree. Present both sides fairly and note why the disagreement exists.

## Prioritized Action Items
A numbered list of the most impactful changes, ordered by priority. For each:
- What the issue is
- Which evaluators flagged it
- Suggested approach
- Estimated effort (minor/moderate/major)

## Strengths to Protect
Elements that evaluators praised and that must be preserved in any further revision.

## Overall Assessment
A brief (2-3 paragraph) synthesis of where the manuscript stands. Be direct.

--- END synthesis.md ---

--- BEGIN findings.yaml ---

A structured YAML file containing all findings. Use this exact format:

\`\`\`yaml
# Evaluation Findings — ${PROJECT_TITLE}
# Generated: ${EVAL_TIMESTAMP}
# Scope: ${SCOPE_DESCRIPTION}

metadata:
  title: "${PROJECT_TITLE}"
  genre: "${GENRE_DISPLAY:-Not specified}"
  scope: "${SCOPE_DESCRIPTION}"
  evaluators_succeeded:
    - evaluator-name
  evaluators_failed:
    - evaluator-name
  timestamp: "${EVAL_TIMESTAMP}"

findings:
  - id: F001
    category: structure|character|pacing|prose|worldbuilding|theme|market|genre|continuity
    severity: critical|major|minor|suggestion
    summary: "One-line description of the finding"
    detail: "Full explanation with context"
    affected_locations:
      - $(if [[ "$INPUT_TYPE" == "chapters" ]]; then echo "chapter-number-or-range"; else echo "scene-id"; fi)
    flagged_by:
      - evaluator-name
    recommendation: "Specific, actionable suggestion"

strengths:
  - id: S001
    category: structure|character|pacing|prose|worldbuilding|theme|voice|craft
    summary: "One-line description of the strength"
    detail: "Why this works and why it must be protected"
    examples:
      - $(if [[ "$INPUT_TYPE" == "chapters" ]]; then echo "chapter-number-or-range"; else echo "scene-id"; fi)
    flagged_by:
      - evaluator-name
\`\`\`

IMPORTANT: The findings.yaml must be valid YAML. Use quoted strings for values that contain colons, special characters, or newlines. Categorize every substantive point from every evaluator report. Severity levels:
- critical: Structural or fundamental issue that must be addressed
- major: Significant issue that weakens the manuscript
- minor: Worth fixing but not urgent
- suggestion: Nice-to-have improvement

--- END findings.yaml ---
SYNTH_API_EOF

    log "Running synthesis via direct API (model: ${SYNTH_MODEL})..."

    # Launch synthesis progress monitor (headless only)
    synthesis_monitor "$EVAL_DIR" "$(date +%s)" &
    SYNTH_MONITOR_PID=$!
    register_child_pid $SYNTH_MONITOR_PID

    invoke_anthropic_api "$SYNTH_API_PROMPT" "$SYNTH_MODEL" "$SYNTHESIS_LOG" 8192 || false

    # Stop the synthesis progress monitor
    kill "$SYNTH_MONITOR_PID" 2>/dev/null || true
    wait "$SYNTH_MONITOR_PID" 2>/dev/null || true

    # Parse the API response into the two output files
    SYNTH_RESPONSE=$(extract_api_response "$SYNTHESIS_LOG" || true)

    if [[ -n "$SYNTH_RESPONSE" ]]; then
        # Extract synthesis.md content (between the delimiters)
        SYNTH_MD=$(echo "$SYNTH_RESPONSE" | sed -n '/^--- BEGIN synthesis\.md ---$/,/^--- END synthesis\.md ---$/p' | sed '1d;$d')
        if [[ -z "$SYNTH_MD" ]]; then
            # Fallback: save the entire response as synthesis.md
            SYNTH_MD="$SYNTH_RESPONSE"
        fi
        echo "$SYNTH_MD" > "${EVAL_DIR}/synthesis.md"

        # Extract findings.yaml content (between the delimiters, strip yaml code fences)
        FINDINGS_YAML=$(echo "$SYNTH_RESPONSE" | sed -n '/^--- BEGIN findings\.yaml ---$/,/^--- END findings\.yaml ---$/p' | sed '1d;$d')
        if [[ -n "$FINDINGS_YAML" ]]; then
            # Strip ```yaml and ``` fences if present
            echo "$FINDINGS_YAML" | sed '/^```yaml$/d' | sed '/^```$/d' > "${EVAL_DIR}/findings.yaml"
        fi
    fi
fi

SYNTH_END=$(date +%s)
SYNTH_DURATION=$(( SYNTH_END - SYNTH_START ))
SYNTH_MINS=$(( SYNTH_DURATION / 60 ))
SYNTH_SECS=$(( SYNTH_DURATION % 60 ))

# Verify synthesis outputs
if [[ ! -f "${EVAL_DIR}/synthesis.md" ]]; then
    log "ERROR: synthesis.md not created"
    log "See: $SYNTHESIS_LOG"
    false
fi

if [[ ! -f "${EVAL_DIR}/findings.yaml" ]]; then
    log "WARNING: findings.yaml not created — synthesis may be incomplete"
    # Not fatal: the prose synthesis is the primary output
fi

end_healing_zone

# Log synthesis usage
if [[ "$EVAL_MODE" == "interactive" ]]; then
    log_usage "$SYNTHESIS_LOG" "synthesize" "synthesis" "$SYNTH_MODEL"
else
    log_api_usage "$SYNTHESIS_LOG" "synthesize" "synthesis" "$SYNTH_MODEL"
fi

SYNTH_WORDS=$(wc -w < "${EVAL_DIR}/synthesis.md" | tr -d ' ')
log "SUCCESS: Synthesis complete (${SYNTH_WORDS} words, ${SYNTH_MINS}m${SYNTH_SECS}s)"

# Advance pipeline cycle to planning phase
update_cycle_field "$CYCLE_ID" "status" "planning"
update_pr_task "Synthesis" "$PROJECT_DIR"

if [[ -f "${EVAL_DIR}/findings.yaml" ]]; then
    FINDING_COUNT=$(grep -c '^\s*- id: F' "${EVAL_DIR}/findings.yaml" 2>/dev/null || echo "0")
    STRENGTH_COUNT=$(grep -c '^\s*- id: S' "${EVAL_DIR}/findings.yaml" 2>/dev/null || echo "0")
    log "Findings: ${FINDING_COUNT} issues, ${STRENGTH_COUNT} strengths cataloged"
fi

# ============================================================================
# Pass 2: Assessment — execution vs. intent (only if reference files exist)
# ============================================================================

# Collect available reference files for assessment
ASSESS_REF_LIST=()
for ref in "reference/key-decisions.md" \
           "reference/voice-guide.md" "references/voice-guide.md" \
           "reference/story-architecture.md" "references/story-architecture.md"; do
    if [[ -f "${PROJECT_DIR}/${ref}" ]]; then
        ASSESS_REF_LIST+=("$ref")
    fi
done

if (( ${#ASSESS_REF_LIST[@]} > 0 )); then
    log "Running assessment pass (${#ASSESS_REF_LIST[@]} reference files)..."
    ASSESS_LOG="${LOG_DIR}/eval-assessment.log"
    ASSESS_START=$(date +%s)
    ASSESS_MODEL=$(select_model "synthesis")

    _SF_INVOCATION_START=$(date +%s)
    export _SF_INVOCATION_START

    begin_healing_zone "evaluation assessment"

    # Build reference file content for assessment
    ASSESS_REF_FILE_LIST=""
    ASSESS_REF_INLINE=""
    for ref in "${ASSESS_REF_LIST[@]}"; do
        ASSESS_REF_FILE_LIST="${ASSESS_REF_FILE_LIST}   - ${ref}
"
        ASSESS_REF_INLINE="${ASSESS_REF_INLINE}
===== REFERENCE: ${ref} =====

$(cat "${PROJECT_DIR}/${ref}")

===== END REFERENCE: ${ref} =====
"
    done

    # Determine which assessment sections to include based on available files
    ASSESS_VOICE_SECTION=""
    ASSESS_ARCH_SECTION=""
    ASSESS_DECISIONS_SECTION=""
    for ref in "${ASSESS_REF_LIST[@]}"; do
        case "$ref" in
            *voice-guide*)
                ASSESS_VOICE_SECTION="## Voice Guide Alignment
Did the prose deliver the voice described in the voice guide? Where did evaluators feel it working, where did they feel it breaking?"
                ;;
            *story-architecture*)
                ASSESS_ARCH_SECTION="## Story Architecture Alignment
Did the structural intentions land? Did the arcs, turning points, and thematic throughlines that the architecture describes actually register with the panel?"
                ;;
            *key-decisions*)
                ASSESS_DECISIONS_SECTION="## Key Decisions Audit
Which deliberate choices read as intentional to the panel? Which read as mistakes? For the ones that read as mistakes — is it an execution problem or just the inherent friction of a subversion?"
                ;;
        esac
    done

    ASSESS_SECTIONS="${ASSESS_VOICE_SECTION}

${ASSESS_ARCH_SECTION}

${ASSESS_DECISIONS_SECTION}

## Revised Priorities
In light of the author's intentions, which findings from the reconciliation are the most important to address? Which can be set aside because they conflict with deliberate choices that are landing well enough?"

    if [[ "$EVAL_MODE" == "interactive" ]]; then
        # Interactive assessment
        read -r -d '' ASSESS_PROMPT <<ASSESS_EOF || true
You are assessing the manuscript's execution against the author's stated intentions for "${PROJECT_TITLE}."

The evaluation panel has already read the manuscript cold and provided their reports. A reconciliation of their feedback has been produced. Now you will compare what the panel experienced against what the author intended.

===== PROJECT CONTEXT =====

Title: ${PROJECT_TITLE}
Genre: ${GENRE_DISPLAY:-Not specified}
Evaluation scope: ${SCOPE_DESCRIPTION}

===== INSTRUCTIONS =====

1. Read the reconciliation report:
   - working/evaluations/eval-${EVAL_TIMESTAMP}/synthesis.md
2. Read the author's reference files:
${ASSESS_REF_FILE_LIST}
3. Produce an assessment report with these sections:

${ASSESS_SECTIONS}

${SYNTH_READINESS}

4. Save your report to: working/evaluations/eval-${EVAL_TIMESTAMP}/assessment.md

After saving, stage and commit:

  git add "working/evaluations/eval-${EVAL_TIMESTAMP}/assessment.md"
  git commit -m "Evaluate: assessment (${SCOPE_DESCRIPTION})"
  git push
ASSESS_EOF

        show_interactive_banner "Evaluation Assessment"
        ASSESS_SYSTEM=$(build_interactive_system_prompt "$PROJECT_DIR" "assessment")

        claude "$ASSESS_PROMPT" \
            --model "$ASSESS_MODEL" \
            --dangerously-skip-permissions \
            --append-system-prompt "$ASSESS_SYSTEM" || false
    else
        # API-mode assessment — inline synthesis.md and reference files
        SYNTH_CONTENT=""
        if [[ -f "${EVAL_DIR}/synthesis.md" ]]; then
            SYNTH_CONTENT=$(cat "${EVAL_DIR}/synthesis.md")
        fi

        read -r -d '' ASSESS_API_PROMPT <<ASSESS_API_EOF || true
You are assessing the manuscript's execution against the author's stated intentions for "${PROJECT_TITLE}."

The evaluation panel has already read the manuscript cold and provided their reports. A reconciliation of their feedback has been produced. Now you will compare what the panel experienced against what the author intended.

===== PROJECT CONTEXT =====

Title: ${PROJECT_TITLE}
Genre: ${GENRE_DISPLAY:-Not specified}
Evaluation scope: ${SCOPE_DESCRIPTION}

===== RECONCILIATION =====

${SYNTH_CONTENT}

===== AUTHOR'S REFERENCE FILES =====

${ASSESS_REF_INLINE}

===== INSTRUCTIONS =====

Produce a single assessment report with these sections:

${ASSESS_SECTIONS}

${SYNTH_READINESS}

===== OUTPUT =====

Output your complete assessment report directly. Do not include any preamble or explanation — just the assessment report content.
ASSESS_API_EOF

        log "Running assessment via direct API (model: ${ASSESS_MODEL})..."

        invoke_anthropic_api "$ASSESS_API_PROMPT" "$ASSESS_MODEL" "$ASSESS_LOG" 8192 || false

        # Parse the API response and save assessment.md
        ASSESS_RESPONSE=$(extract_api_response "$ASSESS_LOG" || true)
        if [[ -n "$ASSESS_RESPONSE" ]]; then
            echo "$ASSESS_RESPONSE" > "${EVAL_DIR}/assessment.md"
        fi
    fi

    ASSESS_END=$(date +%s)
    ASSESS_DURATION=$(( ASSESS_END - ASSESS_START ))
    ASSESS_MINS=$(( ASSESS_DURATION / 60 ))
    ASSESS_SECS=$(( ASSESS_DURATION % 60 ))

    # Verify assessment output
    if [[ -f "${EVAL_DIR}/assessment.md" ]]; then
        ASSESS_WORDS=$(wc -w < "${EVAL_DIR}/assessment.md" | tr -d ' ')
        log "SUCCESS: Assessment complete (${ASSESS_WORDS} words, ${ASSESS_MINS}m${ASSESS_SECS}s)"
    else
        log "WARNING: assessment.md not created"
    fi

    end_healing_zone

    # Log assessment usage
    if [[ "$EVAL_MODE" == "interactive" ]]; then
        log_usage "$ASSESS_LOG" "assess" "assessment" "$ASSESS_MODEL"
    else
        log_api_usage "$ASSESS_LOG" "assess" "assessment" "$ASSESS_MODEL"
    fi

    update_pr_task "Assessment" "$PROJECT_DIR"
else
    log "No reference files found — skipping assessment pass"
fi

fi  # end of synthesis/assessment block (skipped for single evaluator)

# ============================================================================
# Git commit all evaluation files
# ============================================================================

log "Committing evaluation files..."

HEAD_BEFORE=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")

(
    cd "$PROJECT_DIR"
    git add "working/evaluations/eval-${EVAL_TIMESTAMP}/" 2>/dev/null || true
    git add working/logs/ 2>/dev/null || true
    git add working/costs/ 2>/dev/null || true
    git add working/pipeline.csv 2>/dev/null || true
    git commit -m "Evaluation: ${SCOPE_DESCRIPTION} (${#SUCCEEDED[@]}/${ALL_EVALUATOR_COUNT} evaluators)" 2>/dev/null || true
)

HEAD_AFTER=$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "none")

if [[ "$HEAD_BEFORE" != "$HEAD_AFTER" ]]; then
    COMMIT_SHORT=$(git -C "$PROJECT_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    log "Committed evaluation: ${COMMIT_SHORT}"

    # Push to remote (warn on failure, don't stop)
    if ! git -C "$PROJECT_DIR" push 2>/dev/null; then
        log "WARNING: git push failed for evaluation commit ${COMMIT_SHORT}. Continuing."
    else
        log "Pushed evaluation to remote."
    fi
else
    log "WARNING: No git commit created (nothing to commit or git error)"
fi

# ============================================================================
# Session complete
# ============================================================================

SESSION_END=$(date +%s)
SESSION_DURATION=$(( SESSION_END - SESSION_START ))
SESSION_MINS=$(( SESSION_DURATION / 60 ))
SESSION_SECS=$(( SESSION_DURATION % 60 ))

log "============================================"
log "Evaluation panel complete!"
log "  Project: ${PROJECT_TITLE}"
log "  Scope: ${SCOPE_DESCRIPTION}"
log "  Reports: ${EVAL_DIR}/"
if [[ -n "$SINGLE_EVALUATOR" ]]; then
    log "  Evaluator: ${SINGLE_EVALUATOR}"
else
    log "  Succeeded: ${#SUCCEEDED[@]}/${ALL_EVALUATOR_COUNT} evaluators + synthesis"
fi
if [[ -f "${EVAL_DIR}/assessment.md" ]]; then
    log "  Assessment: yes (execution vs. intent)"
fi
if [[ ${#FAILED[@]} -gt 0 ]]; then
    log "  Failed: ${FAILED[*]}"
fi
log "  Time: ${SESSION_MINS}m${SESSION_SECS}s"
log "============================================"
log ""
log "Next steps:"
log "  Read the synthesis:  cat ${EVAL_DIR}/synthesis.md"
if [[ -f "${EVAL_DIR}/assessment.md" ]]; then
    log "  Read the assessment: cat ${EVAL_DIR}/assessment.md"
fi
if [[ -f "${EVAL_DIR}/findings.yaml" ]]; then
    log "  Browse findings:    cat ${EVAL_DIR}/findings.yaml"
fi
log "  Read individual:    ls ${EVAL_DIR}/"

# --- Cost summary ---
print_cost_summary "evaluate"
print_cost_summary "synthesize"
print_cost_summary "assess"

# Skip review phase — evaluation is self-contained (synthesis + assessment)

# Mark cycle complete
CYCLE_ID_CHECK=$(get_current_cycle)
if [[ "$CYCLE_ID_CHECK" != "0" ]]; then
    update_cycle_field "$CYCLE_ID_CHECK" "status" "complete"
fi

# Clean up interactive file
rm -f "${PROJECT_DIR}/working/.interactive"

# Exit with failure if any evaluator failed
if (( ${#FAILED[@]} > 0 )); then
    exit 1
fi

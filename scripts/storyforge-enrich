#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-enrich — Metadata enrichment for Storyforge projects
#
# Reads scene prose files and uses Claude to extract missing metadata,
# populating the CSV files that power the manuscript dashboard.
#
# Enriches metadata.csv fields: type, time_of_day
# (timeline_day is handled by storyforge-timeline, called as Step 8)
# Enriches intent.csv fields: emotional_arc, characters, threads, motifs
#
# Usage:
#   ./storyforge-enrich                        # All scenes, all fields
#   ./storyforge-enrich --scenes 001,002       # Specific scenes only
#   ./storyforge-enrich --act 2                # Scenes in act 2 only
#   ./storyforge-enrich --fields type,threads  # Enrich specific fields only
#   ./storyforge-enrich --force                # Re-enrich even populated fields
#   ./storyforge-enrich --dry-run              # Show what would be enriched
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# --- Default options ---
DRY_RUN=false
FORCE=false
SKIP_TIMELINE=false
FILTER_MODE="all"
FILTER_SCENES=""
FILTER_ACT=""
FILTER_FROM_SEQ=""
PARALLEL=${STORYFORGE_ENRICH_PARALLEL:-6}
ENRICH_FIELDS="type,location,time_of_day,characters,emotional_arc,threads,motifs"

# All valid enrichment fields
VALID_FIELDS="type,location,time_of_day,characters,emotional_arc,threads,motifs"

# Minimum word count for enrichment
MIN_WORDS=50

# --- Argument parsing ---
usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Enrich scene metadata by analyzing prose with Claude. Runs in two
phases: free heuristics first (word count, time of day, thread
recovery), then Claude for remaining gaps (type, location, characters,
emotional arc, threads, motifs).

Scope:
  --scenes ID,ID    Enrich specific scenes only (comma-separated slug IDs)
  --act N           Enrich scenes in act/part N only
  --from-seq N      Enrich scenes from sequence number N onward
  --from-seq N-M    Enrich scenes in sequence range N through M

Options:
  --parallel N      Concurrent workers (default: 6, env: STORYFORGE_ENRICH_PARALLEL)
  --fields FIELDS   Comma-separated fields to enrich (default: all)
                    Valid: type,location,time_of_day,characters,emotional_arc,threads,motifs
  --force           Re-enrich scenes that already have data (overwrite)
  --skip-timeline   Skip the timeline_day analysis pass (Step 8)
  --dry-run         Show what would be enriched without invoking Claude
  -h, --help        Show this help

Examples:
  $(basename "$0")                          # Enrich all scenes (includes timeline)
  $(basename "$0") --skip-timeline          # Enrich without timeline pass
  $(basename "$0") --from-seq 32            # Enrich from scene 32 onward
  $(basename "$0") --from-seq 5-10          # Enrich scenes 5 through 10
  $(basename "$0") --act 3                  # Enrich part 3 only
  $(basename "$0") --fields type,characters # Only extract type and characters
  $(basename "$0") --scenes claires-cold,pewter-town  # Specific scenes
  $(basename "$0") --dry-run               # Preview without invoking Claude
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --skip-timeline)
            SKIP_TIMELINE=true
            shift
            ;;
        --force)
            FORCE=true
            shift
            ;;
        --scenes)
            FILTER_MODE="scenes"
            FILTER_SCENES="${2:?ERROR: --scenes requires comma-separated scene IDs}"
            shift 2
            ;;
        --act)
            FILTER_MODE="act"
            FILTER_ACT="${2:?ERROR: --act requires an act number}"
            shift 2
            ;;
        --from-seq)
            FILTER_MODE="from_seq"
            FILTER_FROM_SEQ="${2:?ERROR: --from-seq requires a sequence number}"
            shift 2
            ;;
        --parallel)
            PARALLEL="${2:?ERROR: --parallel requires a number}"
            shift 2
            ;;
        --fields)
            ENRICH_FIELDS="${2:?ERROR: --fields requires comma-separated field names}"
            # Validate fields
            IFS=',' read -ra _check_fields <<< "$ENRICH_FIELDS"
            for _f in "${_check_fields[@]}"; do
                case "$_f" in
                    type|location|time_of_day|characters|emotional_arc|threads|motifs) ;;
                    *)
                        echo "ERROR: Invalid field '$_f'. Valid fields: ${VALID_FIELDS}" >&2
                        exit 1
                        ;;
                esac
            done
            shift 2
            ;;
        -*)
            echo "ERROR: Unknown option: $1" >&2
            usage
            ;;
        *)
            echo "ERROR: Unexpected argument: $1" >&2
            usage
            ;;
    esac
done

# --- Detect project root ---
detect_project_root
log "Project root: ${PROJECT_DIR}"

# --- Project info ---
PROJECT_TITLE=$(read_yaml_field "project.title" 2>/dev/null || read_yaml_field "title" 2>/dev/null || echo "Unknown")

# --- Resolve paths ---
METADATA_CSV="${PROJECT_DIR}/reference/scene-metadata.csv"
INTENT_CSV="${PROJECT_DIR}/reference/scene-intent.csv"
# Fallback to old locations
[[ ! -f "$METADATA_CSV" ]] && METADATA_CSV="${PROJECT_DIR}/scenes/metadata.csv"
[[ ! -f "$INTENT_CSV" ]] && INTENT_CSV="${PROJECT_DIR}/scenes/intent.csv"
SCENES_DIR="${PROJECT_DIR}/scenes"
SCENE_INDEX="${PROJECT_DIR}/scenes/scene-index.yaml"
LOG_DIR="${PROJECT_DIR}/working/logs"
ENRICH_DIR="${PROJECT_DIR}/working/enrich"

mkdir -p "$LOG_DIR"
mkdir -p "$ENRICH_DIR"

if [[ ! -f "$METADATA_CSV" ]]; then
    log "ERROR: reference/scene-metadata.csv not found. Run 'storyforge scenes' to create scene metadata."
    exit 1
fi

if [[ ! -f "$INTENT_CSV" ]]; then
    log "ERROR: reference/scene-intent.csv not found. Run 'storyforge scenes' to create scene metadata."
    exit 1
fi

# --- Select model (analytical task -> Sonnet) ---
MODEL=$(select_model "evaluation")
log "Enrichment model: ${MODEL}"

# ============================================================================
# Step 1: Discover scenes — ensure all scene files have metadata rows
# ============================================================================

log "Discovering scenes..."

# Get existing IDs from metadata.csv
EXISTING_META_IDS=()
while IFS= read -r eid; do
    [[ -z "$eid" ]] && continue
    EXISTING_META_IDS+=("$eid")
done < <(list_csv_ids "$METADATA_CSV")

EXISTING_INTENT_IDS=()
while IFS= read -r eid; do
    [[ -z "$eid" ]] && continue
    EXISTING_INTENT_IDS+=("$eid")
done < <(list_csv_ids "$INTENT_CSV")

# Find the next available seq number
MAX_SEQ=0
while IFS= read -r seq_val; do
    [[ -z "$seq_val" ]] && continue
    if [[ "$seq_val" =~ ^[0-9]+$ ]] && (( seq_val > MAX_SEQ )); then
        MAX_SEQ="$seq_val"
    fi
done < <(get_csv_column "$METADATA_CSV" "seq")

# Scan for scene files not yet in CSVs
ADDED_ROWS=0
for scene_file in "${SCENES_DIR}"/*.md; do
    [[ -f "$scene_file" ]] || continue
    fname=$(basename "$scene_file" .md)
    # Skip non-scene files (like README, etc.)
    [[ "$fname" =~ ^[0-9] ]] || continue

    # Check if already in metadata.csv
    in_meta=false
    for eid in "${EXISTING_META_IDS[@]+"${EXISTING_META_IDS[@]}"}"; do
        if [[ "$eid" == "$fname" ]]; then
            in_meta=true
            break
        fi
    done

    if [[ "$in_meta" == false ]]; then
        MAX_SEQ=$((MAX_SEQ + 1))
        # Extract title from first heading or use filename
        title=$(grep -m1 '^#' "$scene_file" 2>/dev/null | sed 's/^#\+[[:space:]]*//' || echo "$fname")
        [[ -z "$title" ]] && title="$fname"
        # metadata.csv header: id|seq|title|pov|location|part|type|timeline_day|time_of_day|status|word_count|target_words
        append_csv_row "$METADATA_CSV" "${fname}|${MAX_SEQ}|${title}||||||||"
        ADDED_ROWS=$((ADDED_ROWS + 1))
        log "  Added metadata row for ${fname}"
    fi

    # Check if already in intent.csv
    in_intent=false
    for eid in "${EXISTING_INTENT_IDS[@]+"${EXISTING_INTENT_IDS[@]}"}"; do
        if [[ "$eid" == "$fname" ]]; then
            in_intent=true
            break
        fi
    done

    if [[ "$in_intent" == false ]]; then
        # intent.csv header: id|function|emotional_arc|characters|threads|motifs|notes
        append_csv_row "$INTENT_CSV" "${fname}||||||"
        log "  Added intent row for ${fname}"
    fi
done

if (( ADDED_ROWS > 0 )); then
    log "Added ${ADDED_ROWS} new rows to CSVs"
fi

# ============================================================================
# Step 1.5: Recover threads from scene-index.yaml (if present)
# ============================================================================

if [[ -f "$SCENE_INDEX" ]]; then
    log "Found scene-index.yaml — recovering thread data..."
    THREADS_RECOVERED=0

    # Parse scene-index.yaml for threads_planted, threads_advanced, threads_resolved
    # Format in YAML:
    #   - id: 1
    #     threads_planted: ["dream_mechanic", "victim_perspective"]
    #     threads_advanced: ["dream_mechanic"]
    #     threads_resolved: []

    current_id=""
    current_threads_planted=""
    current_threads_advanced=""
    current_threads_resolved=""

    while IFS= read -r line; do
        # Detect scene id
        if echo "$line" | grep -qE '^\s*-\s*id:'; then
            # Process previous scene if we had one
            if [[ -n "$current_id" ]]; then
                # Merge all threads into a single semicolon-separated list
                all_threads=""
                for t in $current_threads_planted $current_threads_advanced $current_threads_resolved; do
                    t=$(echo "$t" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                    [[ -z "$t" ]] && continue
                    if [[ -z "$all_threads" ]]; then
                        all_threads="$t"
                    else
                        # Avoid duplicates
                        if ! echo ";${all_threads};" | grep -q ";${t};"; then
                            all_threads="${all_threads};${t}"
                        fi
                    fi
                done

                if [[ -n "$all_threads" ]]; then
                    # Zero-pad the id to match CSV format (e.g., 1 -> 001)
                    padded_id=$(printf "%03d" "$current_id" 2>/dev/null || echo "$current_id")
                    existing_threads=$(get_csv_field "$INTENT_CSV" "$padded_id" "threads")
                    if [[ -z "$existing_threads" ]] || [[ "$FORCE" == true ]]; then
                        update_csv_field "$INTENT_CSV" "$padded_id" "threads" "$all_threads"
                        THREADS_RECOVERED=$((THREADS_RECOVERED + 1))
                    fi
                fi
            fi

            current_id=$(echo "$line" | sed 's/.*id:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            current_threads_planted=""
            current_threads_advanced=""
            current_threads_resolved=""
        fi

        # Extract thread arrays — format: threads_planted: ["a", "b"]
        if echo "$line" | grep -qE 'threads_planted:'; then
            raw=$(echo "$line" | sed 's/.*threads_planted:[[:space:]]*//')
            # Parse ["a", "b"] -> a b
            current_threads_planted=$(echo "$raw" | sed 's/\[//g;s/\]//g;s/"//g;s/,/ /g' | tr -s ' ')
        fi
        if echo "$line" | grep -qE 'threads_advanced:'; then
            raw=$(echo "$line" | sed 's/.*threads_advanced:[[:space:]]*//')
            current_threads_advanced=$(echo "$raw" | sed 's/\[//g;s/\]//g;s/"//g;s/,/ /g' | tr -s ' ')
        fi
        if echo "$line" | grep -qE 'threads_resolved:'; then
            raw=$(echo "$line" | sed 's/.*threads_resolved:[[:space:]]*//')
            current_threads_resolved=$(echo "$raw" | sed 's/\[//g;s/\]//g;s/"//g;s/,/ /g' | tr -s ' ')
        fi
    done < "$SCENE_INDEX"

    # Process the last scene
    if [[ -n "$current_id" ]]; then
        all_threads=""
        for t in $current_threads_planted $current_threads_advanced $current_threads_resolved; do
            t=$(echo "$t" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            [[ -z "$t" ]] && continue
            if [[ -z "$all_threads" ]]; then
                all_threads="$t"
            else
                if ! echo ";${all_threads};" | grep -q ";${t};"; then
                    all_threads="${all_threads};${t}"
                fi
            fi
        done
        if [[ -n "$all_threads" ]]; then
            padded_id=$(printf "%03d" "$current_id" 2>/dev/null || echo "$current_id")
            existing_threads=$(get_csv_field "$INTENT_CSV" "$padded_id" "threads")
            if [[ -z "$existing_threads" ]] || [[ "$FORCE" == true ]]; then
                update_csv_field "$INTENT_CSV" "$padded_id" "threads" "$all_threads"
                THREADS_RECOVERED=$((THREADS_RECOVERED + 1))
            fi
        fi
    fi

    log "Recovered threads for ${THREADS_RECOVERED} scenes from scene-index.yaml"
fi

# ============================================================================
# Step 2: Build scene list and apply filters
# ============================================================================

build_scene_list "$METADATA_CSV"

case "$FILTER_MODE" in
    all)       apply_scene_filter "$METADATA_CSV" "all" ;;
    scenes)    apply_scene_filter "$METADATA_CSV" "scenes" "$FILTER_SCENES" ;;
    act)       apply_scene_filter "$METADATA_CSV" "act" "$FILTER_ACT" ;;
    from_seq)  apply_scene_filter "$METADATA_CSV" "from_seq" "$FILTER_FROM_SEQ" ;;
esac

# ============================================================================
# Identify which scenes need enrichment
# ============================================================================

# Parse requested fields into an array
IFS=',' read -ra FIELDS_ARRAY <<< "$ENRICH_FIELDS"

# Metadata fields vs intent fields
is_metadata_field() {
    case "$1" in
        type|location|time_of_day) return 0 ;;
        *) return 1 ;;
    esac
}

is_intent_field() {
    case "$1" in
        emotional_arc|characters|threads|motifs) return 0 ;;
        *) return 1 ;;
    esac
}

# Build list of scenes that need enrichment, tracking which fields are needed
SCENE_IDS=()
MISSING_SCENES=()
SKIPPED_SHORT=()

for id in "${FILTERED_IDS[@]}"; do
    scene_file="${SCENES_DIR}/${id}.md"

    # Check scene file exists
    if [[ ! -f "$scene_file" ]]; then
        MISSING_SCENES+=("$id")
        continue
    fi

    # Check word count
    wc_val=$(wc -w < "$scene_file" | tr -d ' ')
    if (( wc_val < MIN_WORDS )); then
        SKIPPED_SHORT+=("$id")
        continue
    fi

    # Check if any requested fields are empty
    needs_enrichment=false
    for field in "${FIELDS_ARRAY[@]}"; do
        current_val=""
        if is_metadata_field "$field"; then
            current_val=$(get_csv_field "$METADATA_CSV" "$id" "$field")
        elif is_intent_field "$field"; then
            current_val=$(get_csv_field "$INTENT_CSV" "$id" "$field")
        fi

        if [[ -z "$current_val" ]] || [[ "$FORCE" == true ]]; then
            needs_enrichment=true
            break
        fi
    done

    if [[ "$needs_enrichment" == true ]]; then
        SCENE_IDS+=("$id")
    fi
done

if [[ ${#MISSING_SCENES[@]} -gt 0 ]]; then
    log "WARNING: ${#MISSING_SCENES[@]} scenes have metadata rows but no prose file (skipping): ${MISSING_SCENES[*]}"
fi

if [[ ${#SKIPPED_SHORT[@]} -gt 0 ]]; then
    log "WARNING: ${#SKIPPED_SHORT[@]} scenes are too short (<${MIN_WORDS} words) for enrichment: ${SKIPPED_SHORT[*]}"
fi

if [[ ${#SCENE_IDS[@]} -eq 0 ]]; then
    log "No scenes need enrichment. All requested fields are already populated."
    log "Use --force to re-enrich existing data."
    exit 0
fi

SCENE_COUNT=${#SCENE_IDS[@]}
log "${SCENE_COUNT} scenes need enrichment"

# ============================================================================
# Step 3: Dry-run (exit early before any changes)
# ============================================================================

if [[ "$DRY_RUN" == true ]]; then
    AVG_WORDS=800
    for id in "${SCENE_IDS[@]}"; do
        sf="${SCENES_DIR}/${id}.md"
        [[ -f "$sf" ]] && { wc_val=$(wc -w < "$sf" | tr -d ' '); AVG_WORDS=$((AVG_WORDS + wc_val)); }
    done
    (( SCENE_COUNT > 0 )) && AVG_WORDS=$((AVG_WORDS / SCENE_COUNT))
    ENRICH_COST=$(estimate_cost "evaluate" "$SCENE_COUNT" "$AVG_WORDS" "$MODEL")

    log "============================================"
    log "DRY RUN — Enrichment Plan"
    log "============================================"
    log "Scenes needing enrichment: ${SCENE_COUNT}"
    log "Fields:   ${ENRICH_FIELDS}"
    log "Parallel: ${PARALLEL}"
    log "Force:    ${FORCE}"
    log "Model:    ${MODEL}"
    log "Max cost: ~\$${ENRICH_COST} (actual will be lower — free heuristics run first)"
    log ""
    log "Phase 1 (free): word_count updates, time_of_day inference from keywords"
    log "Phase 2 (Claude): only fields that can't be inferred — type, characters, emotional_arc, threads, motifs"
    log ""
    log "Scenes to enrich:"
    for id in "${SCENE_IDS[@]}"; do
        local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
        missing_fields=""
        for field in "${FIELDS_ARRAY[@]}"; do
            current_val=""
            if is_metadata_field "$field"; then
                current_val=$(get_csv_field "$METADATA_CSV" "$id" "$field")
            elif is_intent_field "$field"; then
                current_val=$(get_csv_field "$INTENT_CSV" "$id" "$field")
            fi
            if [[ -z "$current_val" ]] || [[ "$FORCE" == true ]]; then
                [[ -z "$missing_fields" ]] && missing_fields="$field" || missing_fields="${missing_fields}, ${field}"
            fi
        done
        log "  - ${id} (${local_title:-untitled}) — missing: ${missing_fields}"
    done
    log ""
    log "============================================"
    exit 0
fi

# ============================================================================
# Step 4: Create branch and PR
# ============================================================================

create_branch "enrich" "$PROJECT_DIR"

# Commit any files already changed by discovery and thread recovery
(
    cd "$PROJECT_DIR"
    git add reference/scene-metadata.csv reference/scene-intent.csv 2>/dev/null || true
    git add -A 2>/dev/null || true
    git commit -m "Enrich: discover scenes and recover threads" 2>/dev/null || true
)

ensure_branch_pushed "$PROJECT_DIR"

# ============================================================================
# Step 5: Free enrichment (no Claude needed)
# ============================================================================

log "============================================"
log "Phase 1: Free enrichment (no API calls)"
log "============================================"

FREE_ENRICHED=0

# --- Update word_count from actual files ---
for id in "${SCENE_IDS[@]}"; do
    scene_file="${SCENES_DIR}/${id}.md"
    [[ -f "$scene_file" ]] || continue
    current_wc=$(get_csv_field "$METADATA_CSV" "$id" "word_count")
    actual_wc=$(wc -w < "$scene_file" | tr -d ' ')
    if [[ -z "$current_wc" ]] || [[ "$current_wc" == "0" ]]; then
        update_csv_field "$METADATA_CSV" "$id" "word_count" "$actual_wc"
    fi
done

# --- Infer time_of_day from keywords in prose and setting ---
infer_time_of_day() {
    local text="$1"
    local lower
    lower=$(echo "$text" | tr '[:upper:]' '[:lower:]')
    # Check for explicit time references
    if echo "$lower" | grep -qiE 'dawn|sunrise|first light'; then echo "dawn"; return; fi
    if echo "$lower" | grep -qiE 'morning|breakfast|coffee.*woke|alarm clock|a\.m\b'; then echo "morning"; return; fi
    if echo "$lower" | grep -qiE 'afternoon|lunch|midday|noon'; then echo "afternoon"; return; fi
    if echo "$lower" | grep -qiE 'dusk|sunset|twilight|golden hour'; then echo "dusk"; return; fi
    if echo "$lower" | grep -qiE 'evening|dinner|supper|sundown'; then echo "evening"; return; fi
    if echo "$lower" | grep -qiE 'night|midnight|dark.*outside|moonlight|2:[0-9][0-9]\s*a|3:[0-9][0-9]\s*a|lamp.*lit|streetlight'; then echo "night"; return; fi
    echo ""
}

for id in "${SCENE_IDS[@]}"; do
    current_tod=$(get_csv_field "$METADATA_CSV" "$id" "time_of_day")
    if [[ -z "$current_tod" ]] || [[ "$FORCE" == true ]]; then
        # Check setting field first
        setting_val=$(get_csv_field "$METADATA_CSV" "$id" "location")
        inferred=$(infer_time_of_day "$setting_val")
        # If not found in setting, check first 500 chars of scene prose
        if [[ -z "$inferred" ]]; then
            scene_file="${SCENES_DIR}/${id}.md"
            if [[ -f "$scene_file" ]]; then
                head_text=$(head -c 1000 "$scene_file")
                inferred=$(infer_time_of_day "$head_text")
            fi
        fi
        if [[ -n "$inferred" ]]; then
            update_csv_field "$METADATA_CSV" "$id" "time_of_day" "$inferred"
            FREE_ENRICHED=$((FREE_ENRICHED + 1))
        fi
    fi
done

log "Free enrichment: ${FREE_ENRICHED} fields updated (word count + time_of_day)"

# ============================================================================
# Step 6: Re-check which scenes still need Claude enrichment
# ============================================================================

CLAUDE_IDS=()
for id in "${SCENE_IDS[@]}"; do
    still_needs=false
    for field in "${FIELDS_ARRAY[@]}"; do
        # Skip fields that aren't Claude-dependent
        case "$field" in
            time_of_day)
                # Already handled by heuristic — only ask Claude if still empty
                current_val=$(get_csv_field "$METADATA_CSV" "$id" "$field")
                [[ -z "$current_val" ]] && still_needs=true
                ;;
            location)
                current_val=$(get_csv_field "$METADATA_CSV" "$id" "location")
                [[ -z "$current_val" || "$FORCE" == true ]] && still_needs=true
                ;;
            type)
                current_val=$(get_csv_field "$METADATA_CSV" "$id" "$field")
                [[ -z "$current_val" || "$FORCE" == true ]] && still_needs=true
                ;;
            emotional_arc|characters|threads|motifs)
                current_val=$(get_csv_field "$INTENT_CSV" "$id" "$field")
                [[ -z "$current_val" || "$FORCE" == true ]] && still_needs=true
                ;;
        esac
        [[ "$still_needs" == true ]] && break
    done
    [[ "$still_needs" == true ]] && CLAUDE_IDS+=("$id")
done

CLAUDE_COUNT=${#CLAUDE_IDS[@]}
if (( CLAUDE_COUNT == 0 )); then
    log "All remaining fields populated by free enrichment. No Claude calls needed."
    # Skip to commit
else
    log "${CLAUDE_COUNT} scenes still need Claude enrichment (reduced from ${SCENE_COUNT})"
fi

# ============================================================================
# Step 6.5: Load alias maps for normalization (if registry files exist)
# ============================================================================

CHAR_MAP=""
MOTIF_MAP=""
LOCATION_MAP=""

CHARACTERS_CSV="${PROJECT_DIR}/reference/characters.csv"
if [[ -f "$CHARACTERS_CSV" ]]; then
    CHAR_MAP=$(load_alias_map "$CHARACTERS_CSV")
    log "Loaded character aliases from characters.csv"
fi

MOTIF_TAXONOMY="${PROJECT_DIR}/reference/motif-taxonomy.csv"
if [[ -f "$MOTIF_TAXONOMY" ]]; then
    MOTIF_MAP=$(load_alias_map "$MOTIF_TAXONOMY")
    log "Loaded motif taxonomy from motif-taxonomy.csv"
fi

LOCATIONS_CSV="${PROJECT_DIR}/reference/locations.csv"
if [[ -f "$LOCATIONS_CSV" ]]; then
    LOCATION_MAP=$(load_alias_map "$LOCATIONS_CSV")
    log "Loaded location aliases from locations.csv"
fi

# ============================================================================
# Step 7: Claude enrichment for remaining gaps
# ============================================================================

ENRICHED=0
FAILED=0

if (( CLAUDE_COUNT > 0 )); then

# Cost forecast (now accurate — only counts scenes that still need Claude)
AVG_WORDS=0
TOTAL_WC=0
WC_COUNT=0
for id in "${CLAUDE_IDS[@]}"; do
    sf="${SCENES_DIR}/${id}.md"
    if [[ -f "$sf" ]]; then
        wc_val=$(wc -w < "$sf" | tr -d ' ')
        TOTAL_WC=$((TOTAL_WC + wc_val))
        WC_COUNT=$((WC_COUNT + 1))
    fi
done
(( WC_COUNT > 0 )) && AVG_WORDS=$((TOTAL_WC / WC_COUNT)) || AVG_WORDS=800

ENRICH_COST=$(estimate_cost "evaluate" "$CLAUDE_COUNT" "$AVG_WORDS" "$MODEL")
log "Cost forecast: ~\$${ENRICH_COST} (${CLAUDE_COUNT} scenes needing Claude, avg ${AVG_WORDS} words/scene)"

check_cost_threshold "$ENRICH_COST" || { log "Cost threshold check declined. Aborting."; exit 1; }

# Create draft PR
PR_BODY="## Metadata Enrichment

**Project:** ${PROJECT_TITLE}
**Phase 1 (free):** ${FREE_ENRICHED} fields updated (word count, time_of_day)
**Phase 2 (Claude):** ${CLAUDE_COUNT} scenes (of ${SCENE_COUNT} total)
**Fields:** ${ENRICH_FIELDS}
**Estimated cost:** ~\$${ENRICH_COST}

### Tasks
- [x] Free enrichment (word count, time_of_day keywords)
- [x] Thread recovery from scene-index.yaml
- [ ] Claude enrichment (${CLAUDE_COUNT} scenes)
- [ ] Commit and push results
- [ ] Review"

create_draft_pr "Enrich: ${PROJECT_TITLE} (${CLAUDE_COUNT} scenes)" "$PR_BODY" "$PROJECT_DIR" "enrichment" 2>/dev/null || true

log "============================================"
log "Phase 2: Claude enrichment (${CLAUDE_COUNT} scenes)"
log "============================================"
log "Parallel workers: ${PARALLEL}"

# Helper: build a TARGETED enrichment prompt (only asks for missing fields)
build_enrich_prompt() {
    local scene_id="$1"
    local scene_file="${SCENES_DIR}/${scene_id}.md"
    local scene_text=""
    [[ -f "$scene_file" ]] && scene_text=$(cat "$scene_file")

    local title pov setting part function_val
    title=$(get_csv_field "$METADATA_CSV" "$scene_id" "title")
    pov=$(get_csv_field "$METADATA_CSV" "$scene_id" "pov")
    setting=$(get_csv_field "$METADATA_CSV" "$scene_id" "location")
    part=$(get_csv_field "$METADATA_CSV" "$scene_id" "part")
    function_val=""
    [[ -f "$INTENT_CSV" ]] && function_val=$(get_csv_field "$INTENT_CSV" "$scene_id" "function")

    # Build field instructions only for fields that are actually missing
    local field_instructions=""
    for field in "${FIELDS_ARRAY[@]}"; do
        current_val=""
        if is_metadata_field "$field"; then
            current_val=$(get_csv_field "$METADATA_CSV" "$scene_id" "$field")
        elif is_intent_field "$field"; then
            current_val=$(get_csv_field "$INTENT_CSV" "$scene_id" "$field")
        fi
        [[ -n "$current_val" && "$FORCE" != true ]] && continue

        case "$field" in
            type) field_instructions="${field_instructions}
TYPE: <one of: character, plot, world, action, transition, confrontation>" ;;
            location) field_instructions="${field_instructions}
LOCATION: <the physical location where this scene takes place — use a short, reusable label (the name of the place, not a description of the scene). If two scenes happen in the same place, use the same location string. Do not include time of day, room-level detail, or character actions.>" ;;
            time_of_day) field_instructions="${field_instructions}
TIME_OF_DAY: <one of: morning, afternoon, evening, night, dawn, dusk>" ;;
            characters) field_instructions="${field_instructions}
CHARACTERS: <semicolon-separated list of ALL character names who appear or are mentioned by name>" ;;
            emotional_arc) field_instructions="${field_instructions}
EMOTIONAL_ARC: <one sentence: \"[starting emotion] giving way to [ending emotion]\">" ;;
            threads) field_instructions="${field_instructions}
THREADS: <semicolon-separated list of story threads, e.g. \"investigation;family_secret\">" ;;
            motifs) field_instructions="${field_instructions}
MOTIFS: <semicolon-separated list of recurring images/symbols, e.g. \"hands;darkness;water\">" ;;
        esac
    done

    cat <<PROMPT_EOF
Analyze this scene and extract the requested metadata. Respond with ONLY the labeled lines below, nothing else.

Title: ${title:-Unknown} | POV: ${pov:-Unknown} | Setting: ${setting:-Unknown}

${scene_text}
${field_instructions}
PROMPT_EOF
}

# Helper: validate a type value
validate_type() {
    case "$1" in
        character|plot|world|action|transition|confrontation) echo "$1" ;;
        *) echo "" ;;
    esac
}

# Helper: validate a time_of_day value
validate_time_of_day() {
    case "$1" in
        morning|afternoon|evening|night|dawn|dusk) echo "$1" ;;
        *) echo "" ;;
    esac
}

batch_start=0
while (( batch_start < CLAUDE_COUNT )); do
    batch_pids=()
    batch_ids=()
    batch_end=$(( batch_start + PARALLEL ))
    (( batch_end > CLAUDE_COUNT )) && batch_end=$CLAUDE_COUNT

    # Launch batch
    for (( i=batch_start; i<batch_end; i++ )); do
        id="${CLAUDE_IDS[$i]}"
        batch_ids+=("$id")
        local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
        log "  Launching enrichment for ${local_title:-$id} ($((i+1))/${CLAUDE_COUNT})..."

        (
            # Worker subshell
            prompt=$(build_enrich_prompt "$id")
            log_file="${LOG_DIR}/enrich-${id}.log"
            result_file="${ENRICH_DIR}/.enrich-${id}.txt"

            _SF_INVOCATION_START=$(date +%s)
            export _SF_INVOCATION_START

            begin_healing_zone "enrich invocation"

            claude -p "$prompt" \
                --model "$MODEL" \
                --dangerously-skip-permissions \
                --output-format stream-json \
                --verbose \
                > "$log_file" 2>&1 || true

            end_healing_zone

            # Extract text content using shared extraction function
            response=$(extract_claude_response "$log_file" 2>/dev/null || true)

            # Log usage
            log_usage "$log_file" "enrich" "$id" "$MODEL"

            # Parse response into result file
            if [[ -n "$response" ]]; then
                type_val=$(echo "$response" | grep "^TYPE:" | sed 's/^TYPE:[[:space:]]*//' | sed 's/[[:space:]]*$//' | head -1 || true)
                location_val=$(echo "$response" | grep "^LOCATION:" | sed 's/^LOCATION:[[:space:]]*//' | sed 's/[[:space:]]*$//' | head -1 || true)
                time_of_day_val=$(echo "$response" | grep "^TIME_OF_DAY:" | sed 's/^TIME_OF_DAY:[[:space:]]*//' | sed 's/[[:space:]]*$//' | head -1 || true)
                characters_val=$(echo "$response" | grep "^CHARACTERS:" | sed 's/^CHARACTERS:[[:space:]]*//' | sed 's/[[:space:]]*$//' | head -1 || true)
                emotional_arc_val=$(echo "$response" | grep "^EMOTIONAL_ARC:" | sed 's/^EMOTIONAL_ARC:[[:space:]]*//' | sed 's/[[:space:]]*$//' | head -1 || true)
                threads_val=$(echo "$response" | grep "^THREADS:" | sed 's/^THREADS:[[:space:]]*//' | sed 's/[[:space:]]*$//' | head -1 || true)
                motifs_val=$(echo "$response" | grep "^MOTIFS:" | sed 's/^MOTIFS:[[:space:]]*//' | sed 's/[[:space:]]*$//' | head -1 || true)

                # Normalize against alias maps
                if [[ -n "$CHAR_MAP" ]]; then
                    characters_val=$(normalize_aliases "$CHAR_MAP" "$characters_val")
                fi
                if [[ -n "$MOTIF_MAP" ]]; then
                    motifs_val=$(normalize_aliases "$MOTIF_MAP" "$motifs_val")
                fi
                if [[ -n "$LOCATION_MAP" && -n "$location_val" ]]; then
                    location_val=$(normalize_aliases "$LOCATION_MAP" "$location_val")
                fi

                # Validate
                type_val=$(validate_type "$type_val")
                time_of_day_val=$(validate_time_of_day "$time_of_day_val")

                # Write results to temp file (pipe-delimited key|value pairs)
                {
                    echo "TYPE|${type_val}"
                    echo "LOCATION|${location_val}"
                    echo "TIME_OF_DAY|${time_of_day_val}"
                    echo "CHARACTERS|${characters_val}"
                    echo "EMOTIONAL_ARC|${emotional_arc_val}"
                    echo "THREADS|${threads_val}"
                    echo "MOTIFS|${motifs_val}"
                    echo "STATUS|ok"
                } > "$result_file"
            else
                echo "STATUS|fail" > "$result_file"
            fi
        ) &
        batch_pids+=($!)
        register_child_pid $!
    done

    # Wait for batch to complete
    for pid in "${batch_pids[@]}"; do
        wait "$pid" 2>/dev/null || true
        unregister_child_pid "$pid" 2>/dev/null || true
    done

    # Apply results from temp files to CSVs
    for id in "${batch_ids[@]}"; do
        local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
        result_file="${ENRICH_DIR}/.enrich-${id}.txt"

        if [[ ! -f "$result_file" ]]; then
            FAILED=$((FAILED + 1))
            log "  WARNING: No results for ${id}"
            continue
        fi

        status_val=$(grep "^STATUS|" "$result_file" | cut -d'|' -f2)
        if [[ "$status_val" != "ok" ]]; then
            FAILED=$((FAILED + 1))
            log "  WARNING: Failed to enrich ${id}"
            rm -f "$result_file"
            continue
        fi

        # Apply each field if it was requested and is currently empty (or force)
        for field in "${FIELDS_ARRAY[@]}"; do
            # Map field name to result file key
            result_key=""
            case "$field" in
                type)           result_key="TYPE" ;;
                location)       result_key="LOCATION" ;;
                time_of_day)    result_key="TIME_OF_DAY" ;;
                characters)     result_key="CHARACTERS" ;;
                emotional_arc)  result_key="EMOTIONAL_ARC" ;;
                threads)        result_key="THREADS" ;;
                motifs)         result_key="MOTIFS" ;;
            esac

            [[ -z "$result_key" ]] && continue

            new_val=$(grep "^${result_key}|" "$result_file" | cut -d'|' -f2-)
            [[ -z "$new_val" ]] && continue

            # Check if field already has data (skip unless force)
            current_val=""
            if is_metadata_field "$field"; then
                current_val=$(get_csv_field "$METADATA_CSV" "$id" "$field")
            elif is_intent_field "$field"; then
                current_val=$(get_csv_field "$INTENT_CSV" "$id" "$field")
            fi

            if [[ -n "$current_val" ]] && [[ "$FORCE" != true ]]; then
                continue
            fi

            # Update the appropriate CSV
            if is_metadata_field "$field"; then
                update_csv_field "$METADATA_CSV" "$id" "$field" "$new_val"
            elif is_intent_field "$field"; then
                update_csv_field "$INTENT_CSV" "$id" "$field" "$new_val"
            fi
        done

        ENRICHED=$((ENRICHED + 1))
        log "  Enriched ${local_title:-$id} (${ENRICHED}/${SCENE_COUNT})"
        rm -f "$result_file"
    done

    batch_start=$batch_end
done

log ""
log "Enrichment complete: ${ENRICHED} scenes enriched, ${FAILED} failures"

fi  # end if CLAUDE_COUNT > 0

# Clean up alias map temp files
[[ -n "$CHAR_MAP" ]] && rm -f "$CHAR_MAP"
[[ -n "$MOTIF_MAP" ]] && rm -f "$MOTIF_MAP"
[[ -n "$LOCATION_MAP" ]] && rm -f "$LOCATION_MAP"

# ============================================================================
# Step 8: Timeline pass (delegated to storyforge-timeline)
# ============================================================================

if [[ "$SKIP_TIMELINE" != true && "$DRY_RUN" != true ]]; then
    log ""
    log "Step 8: Timeline analysis (delegating to storyforge-timeline)..."
    TIMELINE_SCRIPT="${SCRIPT_DIR}/storyforge-timeline"

    if [[ -x "$TIMELINE_SCRIPT" ]]; then
        TIMELINE_ARGS=(--embedded)
        [[ "$FORCE" == true ]] && TIMELINE_ARGS+=(--force)

        # Pass through scene filter
        case "$FILTER_MODE" in
            scenes)   TIMELINE_ARGS+=(--scenes "$FILTER_SCENES") ;;
            act)      TIMELINE_ARGS+=(--act "$FILTER_ACT") ;;
            from_seq) TIMELINE_ARGS+=(--from-seq "$FILTER_FROM_SEQ") ;;
        esac

        "$TIMELINE_SCRIPT" "${TIMELINE_ARGS[@]}" || {
            log "WARNING: Timeline analysis failed (non-fatal, continuing)"
        }
    else
        log "WARNING: storyforge-timeline not found at ${TIMELINE_SCRIPT}, skipping timeline"
    fi
elif [[ "$SKIP_TIMELINE" == true ]]; then
    log ""
    log "Step 8: Timeline analysis (skipped via --skip-timeline)"
fi

# ============================================================================
# Update PR tasks
# ============================================================================

update_pr_task "Recover threads from scene-index.yaml" "$PROJECT_DIR" 2>/dev/null || true
update_pr_task "Enrich metadata (${SCENE_COUNT} scenes)" "$PROJECT_DIR" 2>/dev/null || true

# ============================================================================
# Cost summary
# ============================================================================

echo ""
print_cost_summary "enrich"

# ============================================================================
# Commit and push
# ============================================================================

log "Committing enrichment results..."

(
    cd "$PROJECT_DIR"
    git add "reference/scene-metadata.csv" 2>/dev/null || true
    git add "reference/scene-intent.csv" 2>/dev/null || true
    git add "working/costs/" 2>/dev/null || true
    git add "working/logs/" 2>/dev/null || true
    git add "working/enrich/" 2>/dev/null || true
    git commit -m "Enrich: metadata for ${ENRICHED} scenes (${ENRICH_FIELDS})" 2>/dev/null || true
    git push 2>/dev/null || true
)

update_pr_task "Commit and push results" "$PROJECT_DIR" 2>/dev/null || true
update_pr_task "Review" "$PROJECT_DIR" 2>/dev/null || true

log "============================================"
log "Enrichment complete"
log "  Scenes enriched: ${ENRICHED}"
log "  Failures: ${FAILED}"
log "  Fields: ${ENRICH_FIELDS}"
log "============================================"

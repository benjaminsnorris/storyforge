            fill: color, rx: 1
        });
        attachSceneHandlers(rect, s.id);
        svg.appendChild(rect);
    });
})();

// ============================================================================
// 7. SETTING MAP
// ============================================================================

(function renderSettingMap() {
    const container = document.getElementById('setting-map');
    const settingFreq = {};
    const settingFirst = {};
    const settingScenes = {};

    sortedScenes.forEach(s => {
        const raw = (s.location || '').trim();
        if (!raw) return;
        const setting = normalizeLocation(raw);
        const key = setting.toLowerCase();
        settingFreq[key] = (settingFreq[key] || 0) + 1;
        if (!(key in settingFirst)) settingFirst[key] = +s.seq;
        if (!settingScenes[key]) settingScenes[key] = { label: setting, scenes: [] };
        settingScenes[key].scenes.push({ id: s.id, seq: +s.seq });
    });

    const topSettings = Object.keys(settingFreq)
        .sort((a, b) => settingFreq[b] - settingFreq[a])
        .slice(0, 15);

    const ROW_H = 22;
    const W = container.clientWidth - 24 || 1100;
    const CHART_W = W - GRID_LABEL_W - GRID_RIGHT_PAD;
    const H = topSettings.length * ROW_H + 20;
    const svg = makeSvg(container, W, H);

    topSettings.forEach((key, ri) => {
        const y = ri * ROW_H + 10;
        const displayLabel = settingScenes[key].label.substring(0, GRID_LABEL_TRUNC) + (settingScenes[key].label.length > GRID_LABEL_TRUNC ? '..' : '');
        const label = svgEl('text', {
            x: GRID_LABEL_W - 8, y: y + 4,
            'text-anchor': 'end', 'font-family': 'var(--font-mono)',
            'font-size': 10, fill: 'var(--text-dim)'
        });
        label.textContent = displayLabel;
        if (settingScenes[key].label.length > GRID_LABEL_TRUNC) { const t = document.createElementNS(SVG_NS, 'title'); t.textContent = settingScenes[key].label; label.appendChild(t); }
        svg.appendChild(label);

        const scenes = settingScenes[key].scenes.sort((a, b) => a.seq - b.seq);

        // Check for runs of 3+
        let runStart = 0;
        for (let i = 1; i <= scenes.length; i++) {
            if (i < scenes.length && scenes[i].seq === scenes[i-1].seq + 1) continue;
            const runLen = i - runStart;
            if (runLen >= 3) {
                const x1 = sceneX(scenes[runStart].seq - 1, CHART_W) - 4;
                const x2 = sceneX(scenes[i-1].seq - 1, CHART_W) + 4;
                svg.appendChild(svgEl('rect', {
                    x: x1, y: y - 8, width: x2 - x1, height: 16,
                    fill: 'var(--teal-bg)', rx: 3
                }));
            }
            runStart = i;
        }

        scenes.forEach(sc => {
            const cx = sceneX(sc.seq - 1, CHART_W);
            const dot = svgEl('circle', {
                cx, cy: y, r: 3,
                fill: 'var(--teal)', opacity: 0.7
            });
            attachSceneHandlers(dot, sc.id);
            svg.appendChild(dot);
        });
    });
})();

// ============================================================================
// 8. CRAFT SCORE HEATMAP
// ============================================================================

(function renderScoreHeatmap() {
    if (SCORES.length === 0) return;
    document.getElementById('heatmap-section').style.display = '';

    const container = document.getElementById('score-heatmap');

    // Get principle names from first score object
    const principles = Object.keys(SCORES[0]).filter(k => k !== 'id');

    // Group by section using weights data
    const sectionMap = {};
    WEIGHTS.forEach(w => {
        if (w.section && w.principle) {
            sectionMap[w.principle] = w.section;
        }
    });

    // Sort by section groups
    const sections = {};
    principles.forEach(p => {
        const sec = sectionMap[p] || 'other';
        if (!sections[sec]) sections[sec] = [];
        sections[sec].push(p);
    });

    const orderedPrinciples = [];
    const sectionLabels = [];
    for (const [sec, prns] of Object.entries(sections)) {
        sectionLabels.push({ name: sec, startIdx: orderedPrinciples.length });
        orderedPrinciples.push(...prns);
    }

    const W = container.clientWidth - 24 || 1100;
    const heatmapNarrow = window.innerWidth < 768;
    const HEATMAP_LABEL_W = heatmapNarrow ? 0 : GRID_LABEL_W;
    const CHART_W = W - HEATMAP_LABEL_W - GRID_RIGHT_PAD;
    const CELL = Math.max(2, Math.floor(CHART_W / sceneCount) - 1);
    const GAP = Math.max(1, Math.floor(CHART_W / sceneCount) - CELL);
    const SEC_GAP = heatmapNarrow ? 2 : 8;

    // Calculate height with section gaps
    let totalRows = orderedPrinciples.length;
    let totalSectionGaps = (Object.keys(sections).length - 1) * SEC_GAP;
    const H = totalRows * (CELL + GAP) + totalSectionGaps + 30;
    const svg = makeSvg(container, W, H);

    function scoreColor(val) {
        const n = parseInt(val);
        if (isNaN(n)) return 'var(--border)';
        if (n <= 1) return 'var(--score-low)';
        if (n <= 2) return 'var(--score-mid-low)';
        if (n <= 3) return 'var(--score-mid)';
        if (n <= 4) return 'var(--score-mid-high)';
        return 'var(--score-high)';
    }

    let yOffset = 8;
    let currentSection = '';

    orderedPrinciples.forEach((principle, ri) => {
        const sec = sectionMap[principle] || 'other';
        if (sec !== currentSection) {
            if (currentSection !== '') yOffset += SEC_GAP;
            if (!heatmapNarrow) {
                // Section label
                const secLabel = svgEl('text', {
                    x: 4, y: yOffset + 3,
                    'font-family': 'var(--font-mono)', 'font-size': 9,
                    'font-weight': 600, fill: 'var(--teal)',
                    'text-transform': 'uppercase'
                });
                secLabel.textContent = sec.replace(/_/g, ' ');
                svg.appendChild(secLabel);
            }
            currentSection = sec;
        }

        const y = yOffset;

        if (!heatmapNarrow) {
            const label = svgEl('text', {
                x: GRID_LABEL_W - 6, y: y + CELL / 2 + 3,
                'text-anchor': 'end', 'font-family': 'var(--font-mono)',
                'font-size': 9, fill: 'var(--text-dim)'
            });
            label.textContent = principle.replace(/_/g, ' ');
            svg.appendChild(label);
        }

        // Build a lookup for this principle across scenes
        sortedScenes.forEach((s, ci) => {
            const score = scoreById[s.id];
            const val = score ? score[principle] : '';
            const rect = svgEl('rect', {
                x: HEATMAP_LABEL_W + ci * (CELL + GAP),
                y,
                width: CELL, height: CELL,
                fill: scoreColor(val),
                rx: 1,
                opacity: val ? 0.85 : 0.15,
                style: val ? 'cursor:pointer' : ''
            });
            attachSceneHandlers(rect, s.id);
            svg.appendChild(rect);
        });

        yOffset += CELL + GAP;
    });
})();

// ============================================================================
// GENRE SCORES
// ============================================================================

(function renderGenreScores() {
    if (!GENRE_SCORES || GENRE_SCORES.length === 0) return;
    document.getElementById('genre-section').style.display = '';
    var container = document.getElementById('genre-scores');

    var genreData = GENRE_SCORES[0];
    var genreRat = GENRE_RATIONALES.length > 0 ? GENRE_RATIONALES[0] : {};
    var principles = Object.keys(genreData);

    var barNarrow = window.innerWidth < 768;
    var LABEL_W = barNarrow ? 100 : 180;
    var BAR_H = 24;
    var BAR_GAP = 6;
    var MAX_BAR_W = barNarrow ? 140 : 300;
    var H = principles.length * (BAR_H + BAR_GAP) + 8;
    var W = LABEL_W + MAX_BAR_W + 60;
    var svg = makeSvg(container, W, H);

    principles.forEach(function(p, i) {
        var y = i * (BAR_H + BAR_GAP) + 4;
        var score = parseInt(genreData[p]) || 0;
        var barW = (score / 5) * MAX_BAR_W;
        var color = scoreColorClass(score);

        // Label
        var label = svgEl('text', {
            x: LABEL_W - 8, y: y + BAR_H / 2 + 4,
            'text-anchor': 'end', 'font-family': 'var(--font-mono)',
            'font-size': 11, fill: 'var(--text-dim)'
        });
        label.textContent = formatPrincipleLabel(p);
        svg.appendChild(label);

        // Bar
        var rect = svgEl('rect', {
            x: LABEL_W, y: y,
            width: barW, height: BAR_H,
            fill: color, rx: 3, opacity: 0.85,
            style: 'cursor:pointer'
        });
        rect.addEventListener('click', function(e) {
            e.stopPropagation();
            var ratText = genreRat[p];
            if (!ratText) return;
            var html = '<div class="rationale-principle">' + formatPrincipleLabel(p) +
                '<span class="rationale-score" style="color:' + color + '">' + score + '/5</span></div>' +
                '<p>' + ratText + '</p>';
            openRationaleDrawer('genre-drawer', 'Genre Rationale', html);
        });
        svg.appendChild(rect);

        // Score label
        var scoreLabel = svgEl('text', {
            x: LABEL_W + barW + 8, y: y + BAR_H / 2 + 4,
            'font-family': 'var(--font-mono)', 'font-size': 12,
            'font-weight': 700, fill: color
        });
        scoreLabel.textContent = score;
        svg.appendChild(scoreLabel);
    });
})();


(function renderActScores() {
    if (!ACT_SCORES || ACT_SCORES.length === 0) return;
    document.getElementById('act-section').style.display = '';
    var container = document.getElementById('act-scores-vis');

    var principles = Object.keys(ACT_SCORES[0]).filter(function(k) { return k !== 'id'; });
    var acts = ACT_SCORES;

    var barNarrow = window.innerWidth < 768;
    var LABEL_W = barNarrow ? 100 : 200;
    var BAR_H = 18;
    var BAR_GAP = 3;
    var GROUP_GAP = 16;
    var MAX_BAR_W = barNarrow ? 140 : 280;
    var groupH = principles.length * (BAR_H + BAR_GAP);
    var H = acts.length * (groupH + GROUP_GAP + 16) + 8;
    var W = LABEL_W + MAX_BAR_W + 60;
    var svg = makeSvg(container, W, H);

    var FRAMEWORK_LABELS = {
        campbells_monomyth: "Campbell's Monomyth",
        three_act: 'Three Act',
        save_the_cat: 'Save the Cat',
        truby_22: 'Truby 22',
        harmon_circle: 'Harmon Circle',
        kishotenketsu: 'Kishotenketsu',
        freytag: "Freytag's Pyramid",
        character_web: 'Character Web',
        character_as_theme: 'Character as Theme'
    };

    var yOffset = 4;
    acts.forEach(function(act) {
        var rat = actRationaleById[act.id] || {};

        // Act name header
        var nameLabel = svgEl('text', {
            x: 4, y: yOffset + 3,
            'font-family': 'var(--font-mono)', 'font-size': 11,
            'font-weight': 600, fill: 'var(--teal)',
            'data-act-group': act.id
        });
        nameLabel.textContent = act.id.replace(/-/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
        svg.appendChild(nameLabel);
        yOffset += 16;

        principles.forEach(function(p) {
            var score = parseInt(act[p]) || 0;
            var barW = (score / 5) * MAX_BAR_W;
            var color = scoreColorClass(score);

            // Label
            var label = svgEl('text', {
                x: LABEL_W - 8, y: yOffset + BAR_H / 2 + 4,
                'text-anchor': 'end', 'font-family': 'var(--font-mono)',
                'font-size': 10, fill: 'var(--text-dim)',
                'data-act-group': act.id
            });
            label.textContent = FRAMEWORK_LABELS[p] || formatPrincipleLabel(p);
            svg.appendChild(label);

            // Bar
            var rect = svgEl('rect', {
                x: LABEL_W, y: yOffset,
                width: barW, height: BAR_H,
                fill: color, rx: 3, opacity: 0.85,
                style: 'cursor:pointer',
                'data-act-group': act.id
            });
            rect.addEventListener('click', function(e) {
                e.stopPropagation();
                showAllActRationales(act.id);
            });
            svg.appendChild(rect);

            // Score label
            var scoreLabel = svgEl('text', {
                x: LABEL_W + barW + 8, y: yOffset + BAR_H / 2 + 4,
                'font-family': 'var(--font-mono)', 'font-size': 11,
                'font-weight': 700, fill: color,
                'data-act-group': act.id
            });
            scoreLabel.textContent = score;
            svg.appendChild(scoreLabel);

            yOffset += BAR_H + BAR_GAP;
        });

        yOffset += GROUP_GAP;
    });
})();

// ============================================================================
// 9. NARRATIVE FRAMEWORK RADAR
// ============================================================================

(function renderNarrativeRadar() {
    if (!NARRATIVE_SCORES || NARRATIVE_SCORES.length === 0) return;
    document.getElementById('narrative-radar-section').style.display = '';
    var container = document.getElementById('narrative-radar');

    var PAD_X = 120;
    var PAD_Y = 40;
    var R = 180;
    var W = R * 2 + PAD_X * 2;
    var H = R * 2 + PAD_Y * 2;
    var CX = W / 2;
    var CY = H / 2;
    var RINGS = 5;
    var principles = NARRATIVE_SCORES;
    var N = principles.length;
    var angleStep = (2 * Math.PI) / N;
    var startAngle = -Math.PI / 2;

    var LABELS = {
        three_act: 'Three Act',
        campbells_monomyth: "Campbell's Monomyth",
        save_the_cat: 'Save the Cat',
        truby_22: 'Truby 22',
        harmon_circle: 'Harmon Circle',
        kishotenketsu: 'Kishotenketsu',
        freytag: "Freytag's Pyramid"
    };

    var svg = makeSvg(container, W, H);

    // Draw concentric rings
    for (var ring = 1; ring <= RINGS; ring++) {
        var r = (ring / RINGS) * R;
        svg.appendChild(svgEl('circle', {
            cx: CX, cy: CY, r: r,
            fill: 'none', stroke: 'var(--border)', 'stroke-width': 0.5,
            'stroke-dasharray': ring < RINGS ? '2,3' : 'none'
        }));
        svg.appendChild(svgEl('text', {
            x: CX + 4, y: CY - r + 12,
            'font-family': 'var(--font-mono)', 'font-size': 9,
            fill: 'var(--text-dim)', opacity: 0.6
        })).textContent = ring;
    }

    // Draw spokes, data polygon, and labels
    var points = [];
    principles.forEach(function(p, i) {
        var angle = startAngle + i * angleStep;
        var score = parseInt(p.score) || 0;
        var sr = (score / RINGS) * R;

        // Spoke line
        var spokeX = CX + Math.cos(angle) * R;
        var spokeY = CY + Math.sin(angle) * R;
        svg.appendChild(svgEl('line', {
            x1: CX, y1: CY, x2: spokeX, y2: spokeY,
            stroke: 'var(--border)', 'stroke-width': 0.5
        }));

        // Data point
        var px = CX + Math.cos(angle) * sr;
        var py = CY + Math.sin(angle) * sr;
        points.push({ x: px, y: py, score: score, principle: p.principle });

        // Framework label around perimeter
        var labelR = R + 24;
        var lx = CX + Math.cos(angle) * labelR;
        var ly = CY + Math.sin(angle) * labelR;
        var anchor = Math.abs(Math.cos(angle)) < 0.05 ? 'middle' : (lx > CX ? 'start' : 'end');
        var label = LABELS[p.principle] || p.principle.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
        svg.appendChild(svgEl('text', {
            x: lx, y: ly + 4, 'text-anchor': anchor,
            'font-family': 'var(--font)', 'font-size': 11,
            fill: 'var(--text)', 'font-weight': 500
        })).textContent = label;

        // Score value near dot
        svg.appendChild(svgEl('text', {
            x: px, y: py - 8, 'text-anchor': 'middle',
            'font-family': 'var(--font-mono)', 'font-size': 10,
            fill: 'var(--text)', 'font-weight': 700
        })).textContent = score;
    });

    // Draw filled polygon
    if (points.length > 0) {
        var polyPoints = points.map(function(p) { return p.x + ',' + p.y; }).join(' ');
        svg.appendChild(svgEl('polygon', {
            points: polyPoints,
            fill: 'var(--score-high)', 'fill-opacity': 0.15,
            stroke: 'var(--score-high)', 'stroke-width': 2
        }));

        // Draw clickable score dots
        points.forEach(function(p) {
            var color = p.score <= 1 ? 'var(--score-low)' :
                        p.score <= 2 ? 'var(--score-mid-low)' :
                        p.score <= 3 ? 'var(--score-mid)' :
                        p.score <= 4 ? 'var(--score-mid-high)' :
                        'var(--score-high)';
            var dot = svgEl('circle', {
                cx: p.x, cy: p.y, r: 5,
                fill: color, stroke: 'var(--surface)', 'stroke-width': 2,
                style: 'cursor:pointer'
            });
            dot.addEventListener('click', function(e) {
                e.stopPropagation();
                var rat = narrativeRationaleByPrinciple[p.principle];
                if (!rat || !rat.rationale) return;
                var label = LABELS[p.principle] || formatPrincipleLabel(p.principle);
                var html = '<div class="rationale-principle">' + label +
                    '<span class="rationale-score" style="color:' + color + '">' + p.score + '/5</span></div>' +
                    '<p>' + rat.rationale + '</p>';
                openRationaleDrawer('narrative-radar-drawer', 'Narrative Rationale', html);
            });
            svg.appendChild(dot);
        });
    }
})();

// ============================================================================
// 10. MOTIF CONSTELLATION
// ============================================================================

(function renderMotifConstellation() {
    const container = document.getElementById('motif-constellation');
    const motifFirst = {};
    const motifScenes = {};

    INTENTS.forEach(intent => {
        const motifs = (intent.motifs || '').split(';').map(m => m.trim()).filter(Boolean);
        const s = sceneById[intent.id];
        if (!s) return;
        const seq = +s.seq;
        // Normalize and deduplicate within this scene
        const seen = new Set();
        motifs.forEach(raw => {
            const m = normalizeMotif(raw);
            if (seen.has(m.toLowerCase())) return;
            seen.add(m.toLowerCase());
            if (!motifFirst[m]) motifFirst[m] = seq;
            if (!motifScenes[m]) motifScenes[m] = [];
            motifScenes[m].push({ id: intent.id, seq });
        });
    });

    // Suppress motifs appearing in only 1 scene (noise) or >90% of scenes (universal)
    const upperThreshold = sceneCount * 0.9;
    const minOccurrences = 2;
    const universalMotifs = [];
    Object.keys(motifScenes).forEach(m => {
        if (motifScenes[m].length > upperThreshold) {
            universalMotifs.push(m + ' (' + motifScenes[m].length + '/' + sceneCount + ')');
            delete motifFirst[m];
            delete motifScenes[m];
        } else if (motifScenes[m].length < minOccurrences) {
            delete motifFirst[m];
            delete motifScenes[m];
        }
    });

    // Sort by tier (primary first), then by first appearance
    const tierOrder = { primary: 0, secondary: 1, tertiary: 2 };
    const motifList = Object.keys(motifFirst).sort((a, b) => {
        const ta = tierOrder[motifTierMap[a]] ?? 3;
        const tb = tierOrder[motifTierMap[b]] ?? 3;
        if (ta !== tb) return ta - tb;
        return motifFirst[a] - motifFirst[b];
    });

    if (motifList.length === 0) {
        let msg = '<div style="padding:16px;color:var(--text-dim);font-size:13px">No motif data found in intent.csv</div>';
        if (universalMotifs.length > 0) {
            msg = '<div style="padding:16px;color:var(--text-dim);font-size:13px">All motifs appear in >90% of scenes (universal): ' + universalMotifs.join(', ') + '</div>';
        }
        container.innerHTML = msg;
        return;
    }

    const ROW_H = 22;
    const DENSITY_H = 24;
    const W = container.clientWidth - 24 || 1100;
    const CHART_W = W - GRID_LABEL_W - GRID_RIGHT_PAD;
    const H = motifList.length * ROW_H + DENSITY_H + 30;
    const svg = makeSvg(container, W, H);

    motifList.forEach((motif, ri) => {
        const y = ri * ROW_H + 10;
        const label = svgEl('text', {
            x: GRID_LABEL_W - 8, y: y + 4,
            'text-anchor': 'end', 'font-family': 'var(--font-mono)',
            'font-size': 10, fill: 'var(--text-dim)'
        });
        label.textContent = motif.length > GRID_LABEL_TRUNC ? motif.substring(0, GRID_LABEL_TRUNC - 2) + '..' : motif;
        if (motif.length > GRID_LABEL_TRUNC) { var t = document.createElementNS(SVG_NS, 'title'); t.textContent = motif; label.appendChild(t); }
        svg.appendChild(label);

        const scenes = (motifScenes[motif] || []).sort((a, b) => a.seq - b.seq);

        // Lines
        for (let i = 1; i < scenes.length; i++) {
            const x1 = sceneX(scenes[i-1].seq - 1, CHART_W);
            const x2 = sceneX(scenes[i].seq - 1, CHART_W);
            const gap = scenes[i].seq - scenes[i-1].seq;
            svg.appendChild(svgEl('line', {
                x1, y1: y, x2, y2: y,
                stroke: 'var(--type-confrontation)', 'stroke-width': 1,
                opacity: 0.3,
                'stroke-dasharray': gap > 2 ? '2,2' : 'none'
            }));
        }

        // Dots
        scenes.forEach(sc => {
            const cx = sceneX(sc.seq - 1, CHART_W);
            const dot = svgEl('circle', {
                cx, cy: y, r: 3,
                fill: 'var(--type-confrontation)', opacity: 0.7
            });
            attachSceneHandlers(dot, sc.id);
            svg.appendChild(dot);
        });
    });

    // Density bar
    const densityY = motifList.length * ROW_H + 20;
    const density = new Array(sceneCount).fill(0);
    sortedScenes.forEach((s, i) => {
        const intent = intentById[s.id];
        if (intent) {
            density[i] = (intent.motifs || '').split(';').filter(m => m.trim()).length;
        }
    });
    const maxDensity = Math.max(...density, 1);

    // Density label
    svg.appendChild(svgEl('text', {
        x: GRID_LABEL_W - 8, y: densityY + DENSITY_H / 2 + 3,
        'text-anchor': 'end', 'font-family': 'var(--font-mono)',
        'font-size': 9, fill: 'var(--text-dim)'
    })).textContent = 'density';

    sortedScenes.forEach((s, i) => {
        const h = (density[i] / maxDensity) * DENSITY_H;
        const rect = svgEl('rect', {
            x: GRID_LABEL_W + (i / sceneCount) * CHART_W,
            y: densityY + DENSITY_H - h,
            width: Math.max(CHART_W / sceneCount - 1, 2),
            height: h,
            fill: 'var(--type-confrontation)',
            opacity: 0.4,
            rx: 1
        });
        attachSceneHandlers(rect, s.id);
        svg.appendChild(rect);
    });

    // Note universal motifs that were suppressed
    if (universalMotifs.length > 0) {
        const note = document.createElement('div');
        note.style.cssText = 'padding:4px 0 0 ' + GRID_LABEL_W + 'px;color:var(--text-dim);font-size:11px;font-family:var(--font-mono)';
        note.textContent = 'Universal (>90%): ' + universalMotifs.join(', ');
        container.appendChild(note);
    }
})();

// ============================================================================
// 11. TIMELINE VS READING ORDER
// ============================================================================

(function renderTimelineScatter() {
    const withTimeline = sortedScenes.filter(s => s.timeline_day && s.timeline_day.trim() !== '');
    if (withTimeline.length < 3) return;

    document.getElementById('timeline-section').style.display = '';
    const container = document.getElementById('timeline-scatter');
    const W = container.clientWidth - 24 || 1100;
    const timeNarrow = window.innerWidth < 768;
    const H = 260;
    const PAD_L = timeNarrow ? 20 : 60, PAD_R = 20, PAD_T = 16, PAD_B = timeNarrow ? 16 : 32;
    const svg = makeSvg(container, W, H);

    const days = sortedScenes.map(s => parseFloat(s.timeline_day) || 0);
    const minDay = Math.min(...days.filter(d => d > 0));
    const maxDay = Math.max(...days);
    const dayRange = maxDay - minDay || 1;

    const points = [];
    sortedScenes.forEach((s, i) => {
        const day = parseFloat(s.timeline_day);
        if (isNaN(day) || day <= 0) return;
        points.push({
            x: PAD_L + (i / (sceneCount - 1 || 1)) * (W - PAD_L - PAD_R),
            y: PAD_T + (1 - (day - minDay) / dayRange) * (H - PAD_T - PAD_B),
            id: s.id,
            day
        });
    });

    // Axes
    if (!timeNarrow) {
        svg.appendChild(svgEl('text', {
            x: W / 2, y: H - 4, 'text-anchor': 'middle',
            'font-family': 'var(--font-mono)', 'font-size': 10, fill: 'var(--text-dim)'
        })).textContent = 'Reading Order →';

        svg.appendChild(svgEl('text', {
            x: 12, y: H / 2, 'text-anchor': 'middle',
            'font-family': 'var(--font-mono)', 'font-size': 10, fill: 'var(--text-dim)',
            transform: `rotate(-90, 12, ${H/2})`
        })).textContent = 'Timeline Day →';
    }

    // Grid lines
    for (let i = 0; i <= 4; i++) {
        const y = PAD_T + (i / 4) * (H - PAD_T - PAD_B);
        svg.appendChild(svgEl('line', {
            x1: PAD_L, y1: y, x2: W - PAD_R, y2: y,
            stroke: 'var(--border)', 'stroke-width': 0.5
        }));
    }

    // Connecting lines
    for (let i = 1; i < points.length; i++) {
        svg.appendChild(svgEl('line', {
            x1: points[i-1].x, y1: points[i-1].y,
            x2: points[i].x, y2: points[i].y,
            stroke: 'var(--teal)', 'stroke-width': 1, opacity: 0.3
        }));
    }

    // Dots
    points.forEach(p => {
        const dot = svgEl('circle', {
            cx: p.x, cy: p.y, r: 4,
            fill: 'var(--teal)', opacity: 0.8
        });
        attachSceneHandlers(dot, p.id);
        svg.appendChild(dot);
    });
})();

// ============================================================================
// VALUE SHIFT ARC — McKee polarity tracking
// ============================================================================

(function renderValueShiftArc() {
    const container = document.getElementById('value-shift-arc');
    const section = document.getElementById('value-shift-section');
    if (!container || !INTENTS.length) return;

    // Parse value shifts: "+/- — explanation..." → extract just the +/- part
    const shifts = [];
    INTENTS.forEach((intent, i) => {
        const vsRaw = (intent.value_shift || '').trim();
        if (!vsRaw) return;
        // Extract the polarity notation before any explanation
        const match = vsRaw.match(/^([+\-]+)\s*\/\s*([+\-]+)/);
        if (!match) return;
        const fromVal = match[1].trim();
        const toVal = match[2].trim();

        // Convert to numeric: + = 1, ++ = 2, - = -1, -- = -2
        function toNum(s) {
            if (s === '++') return 2;
            if (s === '+') return 1;
            if (s === '-') return -1;
            if (s === '--') return -2;
            return 0;
        }
        shifts.push({
            id: intent.id,
            index: i,
            from: toNum(fromVal),
            to: toNum(toVal),
            raw: fromVal + '/' + toVal,
            valueAtStake: intent.value_at_stake || ''
        });
    });

    if (shifts.length < 3) return;
    if (section) section.style.display = '';

    const mobile = window.innerWidth < 768;
    const W = container.clientWidth - 24 || 1100;
    const H = 200;
    const labelW = mobile ? 60 : 100;
    const chartW = W - labelW - 20;
    const midY = H / 2;
    const scaleY = 40;

    const svg = svgEl('svg', { width: W, height: H, class: 'chart' });

    // Y-axis labels
    [2, 1, 0, -1, -2].forEach(v => {
        const y = midY - v * scaleY;
        svg.appendChild(svgEl('line', {
            x1: labelW, y1: y, x2: W - 20, y2: y,
            stroke: 'var(--border)', 'stroke-width': 0.5, 'stroke-dasharray': v === 0 ? 'none' : '2,4'
        }));
        const labels = { 2: '++', 1: '+', 0: '0', '-1': '-', '-2': '--' };
        const lbl = svgEl('text', {
            x: labelW - 8, y: y + 4, 'text-anchor': 'end',
            fill: 'var(--text-dim)', 'font-family': 'var(--font-mono)', 'font-size': 11
        });
        lbl.textContent = labels[v] || '';
        svg.appendChild(lbl);
    });

    // Plot value shifts as arrows
    shifts.forEach((s, i) => {
        const x = labelW + (i / (shifts.length - 1)) * chartW;
        const y1 = midY - s.from * scaleY;
        const y2 = midY - s.to * scaleY;

        // Arrow line
        const color = s.to > s.from ? 'var(--green, #22c55e)' : s.to < s.from ? 'var(--red, #ef4444)' : 'var(--muted)';
        svg.appendChild(svgEl('line', {
            x1: x, y1: y1, x2: x, y2: y2,
            stroke: color, 'stroke-width': 2
        }));

        // Endpoint dot
        const dot = svgEl('circle', {
            cx: x, cy: y2, r: 3, fill: color
        });
        attachSceneHandlers(dot, s.id);
        svg.appendChild(dot);
    });

    container.appendChild(svg);
})();

// ============================================================================
// SCENE RHYTHM — action/sequel + turning point variety
// ============================================================================

(function renderSceneRhythm() {
    const container = document.getElementById('scene-rhythm');
    const section = document.getElementById('scene-rhythm-section');
    if (!container || !INTENTS.length) return;

    const types = [];
    INTENTS.forEach(intent => {
        // action_sequel may be "action" or "sequel — explanation..."; extract first word
        const stRaw = (intent.action_sequel || '').trim().toLowerCase();
        const st = stRaw.split(/[\s—–-]/)[0].trim();
        // turning_point may also have explanation
        const tpRaw = (intent.turning_point || '').trim().toLowerCase();
        const tp = tpRaw.split(/[\s—–-]/)[0].trim();
        if (st) types.push({ id: intent.id, sceneType: st, turningPoint: tp });
    });

    if (types.length < 3) return;
    if (section) section.style.display = '';

    const mobile = window.innerWidth < 768;
    const W = container.clientWidth - 24 || 1100;
    const labelW = mobile ? 100 : 140;
    const chartW = W - labelW - 20;
    const rowH = 18;
    const gap = 6;
    const legendH = 20;
    const H = rowH * 2 + gap + legendH + 12;

    const svg = svgEl('svg', { width: W, height: H, class: 'chart' });

    // Row 1: Scene type (action vs sequel)
    const label1 = svgEl('text', {
        x: labelW - 8, y: rowH - 4, 'text-anchor': 'end',
        fill: 'var(--text-dim)', 'font-family': 'var(--font-mono)', 'font-size': 11
    });
    label1.textContent = 'Scene Type';
    svg.appendChild(label1);

    types.forEach((t, i) => {
        const x = labelW + (i / types.length) * chartW;
        const w = Math.max(chartW / types.length - 1, 2);
        const color = t.sceneType === 'action' ? '#ef4444' : '#3b82f6';
        const rect = svgEl('rect', {
            x: x, y: 0, width: w, height: rowH,
            fill: color, opacity: 0.75, rx: 2
        });
        attachSceneHandlers(rect, t.id);
        svg.appendChild(rect);
    });

    // Row 2: Turning point type (action vs revelation)
    const row2Y = rowH + gap;
    const label2 = svgEl('text', {
        x: labelW - 8, y: row2Y + rowH - 4, 'text-anchor': 'end',
        fill: 'var(--text-dim)', 'font-family': 'var(--font-mono)', 'font-size': 11
    });
    label2.textContent = 'Turning Point';
    svg.appendChild(label2);

    types.forEach((t, i) => {
        const x = labelW + (i / types.length) * chartW;
        const w = Math.max(chartW / types.length - 1, 2);
        const color = t.turningPoint === 'action' ? '#f59e0b' : '#8b5cf6';
        const rect = svgEl('rect', {
            x: x, y: row2Y, width: w, height: rowH,
            fill: color, opacity: 0.75, rx: 2
        });
        attachSceneHandlers(rect, t.id);
        svg.appendChild(rect);
    });

    // Legend
    const legendY = row2Y + rowH + 8;
    const legends = [
        { label: 'Action', color: '#ef4444' },
        { label: 'Sequel', color: '#3b82f6' },
        { label: 'Action TP', color: '#f59e0b' },
        { label: 'Revelation TP', color: '#8b5cf6' },
    ];
    let legendX = labelW;
    legends.forEach(l => {
        svg.appendChild(svgEl('rect', { x: legendX, y: legendY, width: 10, height: 10, fill: l.color, rx: 2, opacity: 0.8 }));
        const txt = svgEl('text', { x: legendX + 14, y: legendY + 9, fill: 'var(--text-dim)', 'font-family': 'var(--font-mono)', 'font-size': 10 });
        txt.textContent = l.label;
        svg.appendChild(txt);
        legendX += l.label.length * 7 + 26;
    });

    container.appendChild(svg);
})();

// ============================================================================
// BRIEF FIDELITY — did prose deliver what brief promised?
// ============================================================================

(function renderFidelity() {
    const container = document.getElementById('fidelity-chart');
    const section = document.getElementById('fidelity-section');
    if (!container || !FIDELITY_SCORES.length) return;
    if (section) section.style.display = '';

    const mobile = window.innerWidth < 768;
    const W = container.clientWidth - 24 || 1100;
    const elements = ['goal', 'conflict', 'outcome', 'crisis', 'decision', 'key_actions', 'key_dialogue', 'emotions', 'knowledge'];
    const H = elements.length * 28 + 40;
    const labelW = mobile ? 80 : 120;
    const chartW = W - labelW - 40;

    const svg = svgEl('svg', { width: W, height: H, class: 'chart' });

    // Calculate average per element across all scenes
    elements.forEach((el, i) => {
        const scores = FIDELITY_SCORES.map(s => parseInt(s[el] || '0')).filter(v => v > 0);
        if (!scores.length) return;

        const avg = scores.reduce((a, b) => a + b, 0) / scores.length;
        const y = i * 28 + 20;
        const barW = (avg / 5) * chartW;

        // Label
        const lbl = svgEl('text', {
            x: labelW - 8, y: y + 14, 'text-anchor': 'end',
            fill: 'var(--text)', 'font-family': 'var(--font-mono)', 'font-size': 11
        });
        lbl.textContent = el.replace(/_/g, ' ');
        svg.appendChild(lbl);

        // Background
        svg.appendChild(svgEl('rect', {
            x: labelW, y: y, width: chartW, height: 20,
            fill: 'var(--border)', opacity: 0.2, rx: 3
        }));

        // Bar
        const color = avg >= 4 ? 'var(--green, #22c55e)' : avg >= 3 ? 'var(--teal)' : avg >= 2 ? 'var(--orange, #f59e0b)' : 'var(--red, #ef4444)';
        svg.appendChild(svgEl('rect', {
            x: labelW, y: y, width: barW, height: 20,
            fill: color, opacity: 0.8, rx: 3
        }));

        // Score text
        const scoreTxt = svgEl('text', {
            x: labelW + barW + 6, y: y + 14,
            fill: 'var(--text-dim)', 'font-family': 'var(--font-mono)', 'font-size': 11
        });
        scoreTxt.textContent = avg.toFixed(1);
        svg.appendChild(scoreTxt);
    });

    container.appendChild(svg);
})();

// All charts rendered — now activate the page router to hide inactive pages
_initRouter();

</script>
</body>
</html>

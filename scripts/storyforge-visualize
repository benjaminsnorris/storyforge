document.getElementById('meta-genre').textContent = PROJECT.genre || '';
document.getElementById('meta-scenes').textContent = PROJECT.scene_count + ' scenes';
document.getElementById('meta-words').textContent = totalWords.toLocaleString() + ' words';
document.getElementById('meta-date').textContent = PROJECT.generated;

// ============================================================================
// 1. MANUSCRIPT SPINE
// ============================================================================

(function renderSpine() {
    const container = document.getElementById('spine');
    const W = container.clientWidth - 24 || 1100;
    const H = 40;
    const svg = makeSvg(container, W, H);

    // Scale widths
    const totalWC = sortedScenes.reduce((s, sc) => s + getWordCount(sc), 0) || 1;
    let x = 0;
    let lastPart = '';

    sortedScenes.forEach(s => {
        const wc = getWordCount(s);
        const w = Math.min(Math.max(2, (wc / totalWC) * W), W - x);
        const color = TYPE_COLORS[s.type] || 'var(--text-dim)';

        // Part divider
        if (s.part && s.part !== lastPart && lastPart !== '') {
            svg.appendChild(svgEl('line', {
                x1: x, y1: 0, x2: x, y2: H,
                stroke: 'var(--text)', 'stroke-width': 1.5, opacity: 0.3
            }));
        }
        lastPart = s.part;

        const rect = svgEl('rect', {
            x, y: 0, width: w, height: H,
            fill: color, rx: 1
        });
        attachSceneHandlers(rect, s.id);
        svg.appendChild(rect);
        x += w;
    });

    // Subtitle
    document.getElementById('spine-subtitle').textContent =
        `${sceneCount} scenes · ${totalWords.toLocaleString()} words`;

    // Legend
    const legendEl = document.getElementById('spine-legend');
    for (const [type, color] of Object.entries(TYPE_COLORS_RAW)) {
        const item = document.createElement('div');
        item.className = 'legend-item';
        item.innerHTML = `<span class="legend-swatch" style="background:${color}"></span>${type}`;
        legendEl.appendChild(item);
    }
})();

// ============================================================================
// 2. POV RIVER
// ============================================================================

(function renderPovRiver() {
    const container = document.getElementById('pov-river');
    const povs = {};
    sortedScenes.forEach(s => {
        const p = (s.pov || 'unknown').toLowerCase();
        if (!povs[p]) povs[p] = { total: 0, scenes: [] };
        povs[p].total += getWordCount(s);
        povs[p].scenes.push(s);
    });

    const povList = Object.keys(povs).sort((a, b) => povs[b].total - povs[a].total);
    const LABEL_GAP = 4;
    const LANE_H = 32;
    const ROW_GAP = 16;
    const W = container.clientWidth - 24 || 1100;
    const ROW_H = 14 + LABEL_GAP + LANE_H + ROW_GAP;
    const H = povList.length * ROW_H + 8;
    const svg = makeSvg(container, W, H);

    const totalWC = sortedScenes.reduce((s, sc) => s + getWordCount(sc), 0) || 1;

    // Precompute spine layout so POV bars align exactly with the manuscript spine
    const spineLayout = {};
    let sx = 0;
    sortedScenes.forEach(s => {
        const wc = getWordCount(s);
        const sw = Math.min(Math.max(2, (wc / totalWC) * W), W - sx);
        spineLayout[s.id] = { x: sx, w: sw };
        sx += sw;
    });

    povList.forEach((pov, i) => {
        const labelY = i * ROW_H + 12;
        const laneY = labelY + LABEL_GAP + 2;

        // Name on the left above the bar
        const label = svgEl('text', {
            x: 0, y: labelY,
            'font-family': 'var(--font-mono)',
            'font-size': 11, fill: 'var(--text-secondary)'
        });
        label.textContent = pov;
        svg.appendChild(label);

        // Stats on the right above the bar
        const pct = ((povs[pov].total / totalWC) * 100).toFixed(0);
        const stat = svgEl('text', {
            x: W, y: labelY,
            'text-anchor': 'end', 'font-family': 'var(--font-mono)',
            'font-size': 10, fill: 'var(--text-dim)'
        });
        stat.textContent = povs[pov].total.toLocaleString() + ' (' + pct + '%)';
        svg.appendChild(stat);

        // Lane background — full width
        svg.appendChild(svgEl('rect', {
            x: 0, y: laneY, width: W, height: LANE_H,
            fill: 'var(--border-light)', rx: 3
        }));

        // Scene blocks — positioned exactly as in spine
        sortedScenes.forEach(s => {
            if ((s.pov || '').toLowerCase() !== pov) return;
            const layout = spineLayout[s.id];
            if (!layout) return;
            const color = TYPE_COLORS[s.type] || 'var(--teal)';
            const rect = svgEl('rect', {
                x: layout.x, y: laneY + 2, width: layout.w, height: LANE_H - 4,
                fill: color, rx: 2, opacity: 0.85
            });
            attachSceneHandlers(rect, s.id);
            svg.appendChild(rect);
        });
    });
})();

// ============================================================================
// 3. CHARACTER PRESENCE GRID
// ============================================================================

(function renderCharGrid() {
    const container = document.getElementById('char-grid');
    const charFreq = {};

    INTENTS.forEach(intent => {
        const chars = (intent.characters || '').split(';').map(c => c.trim()).filter(Boolean);
        chars.forEach(c => {
            const normalized = normalizeChar(c);
            charFreq[normalized] = (charFreq[normalized] || 0) + 1;
        });
    });

    // Also add POV characters (normalized to match intent characters)
    sortedScenes.forEach(s => {
        const p = normalizeChar(s.pov || '');
        if (p) charFreq[p] = (charFreq[p] || 0) + 1;
    });

    const topChars = Object.entries(charFreq)
        .sort((a, b) => b[1] - a[1])
        .slice(0, 15)
        .map(e => e[0]);

    const ROW_H = 18;
    const W = container.clientWidth - 24 || 1100;
    const CHART_W = W - GRID_LABEL_W - GRID_RIGHT_PAD;
    const H = topChars.length * ROW_H + 20;
    const svg = makeSvg(container, W, H);

    topChars.forEach((char, ri) => {
        const y = ri * ROW_H + 10;
        const label = svgEl('text', {
            x: GRID_LABEL_W - 6, y: y + ROW_H / 2 + 3,
            'text-anchor': 'end', 'font-family': 'var(--font-mono)',
            'font-size': 10, fill: 'var(--text-dim)'
        });
        label.textContent = char.length > GRID_LABEL_TRUNC ? char.substring(0, GRID_LABEL_TRUNC - 2) + '..' : char;
        if (char.length > GRID_LABEL_TRUNC) { var t = document.createElementNS(SVG_NS, 'title'); t.textContent = char; label.appendChild(t); }
        svg.appendChild(label);

        sortedScenes.forEach((s, ci) => {
            const intent = intentById[s.id];
            const chars = intent ? (intent.characters || '').split(';').map(c => normalizeChar(c)) : [];
            const isPov = normalizeChar(s.pov || '') === char;
            const isPresent = chars.includes(char);

            if (isPov || isPresent) {
                const cx = sceneX(ci, CHART_W);
                const cy = y + ROW_H / 2;
                const r = isPov ? 3 : 1.5;
                const circle = svgEl('circle', {
                    cx, cy, r,
                    fill: isPov ? 'var(--teal)' : 'var(--text-dim)',
                    opacity: isPov ? 1 : 0.5
                });
                attachSceneHandlers(circle, s.id);
                svg.appendChild(circle);
            }
        });
    });
})();

// ============================================================================
// 4. THREAD WEAVE
// ============================================================================

(function renderThreadWeave() {
    const container = document.getElementById('thread-weave');
    const threadFirst = {};
    const threadScenes = {};

    INTENTS.forEach(intent => {
        const threads = (intent.threads || '').split(';').map(t => t.trim()).filter(Boolean);
        const s = sceneById[intent.id];
        if (!s) return;
        const seq = +s.seq;
        threads.forEach(t => {
            if (!threadFirst[t]) threadFirst[t] = seq;
            if (!threadScenes[t]) threadScenes[t] = [];
            threadScenes[t].push({ id: intent.id, seq });
        });
    });

    const threadList = Object.keys(threadFirst).sort((a, b) => threadFirst[a] - threadFirst[b]);

    const ROW_H = 24;
    const W = container.clientWidth - 24 || 1100;
    const CHART_W = W - GRID_LABEL_W - GRID_RIGHT_PAD;
    const H = threadList.length * ROW_H + 20;
    const svg = makeSvg(container, W, H);

    threadList.forEach((thread, ri) => {
        const y = ri * ROW_H + 12;
        const label = svgEl('text', {
            x: GRID_LABEL_W - 8, y: y + 4,
            'text-anchor': 'end', 'font-family': 'var(--font-mono)',
            'font-size': 10, fill: 'var(--text-dim)'
        });
        label.textContent = thread.length > GRID_LABEL_TRUNC ? thread.substring(0, GRID_LABEL_TRUNC - 2) + '..' : thread;
        if (thread.length > GRID_LABEL_TRUNC) { var t = document.createElementNS(SVG_NS, 'title'); t.textContent = thread; label.appendChild(t); }
        svg.appendChild(label);

        // Sort scenes for this thread
        const scenes = (threadScenes[thread] || []).sort((a, b) => a.seq - b.seq);

        // Draw connecting lines
        for (let i = 1; i < scenes.length; i++) {
            const x1 = sceneX(scenes[i-1].seq - 1, CHART_W);
            const x2 = sceneX(scenes[i].seq - 1, CHART_W);
            const gap = scenes[i].seq - scenes[i-1].seq;
            svg.appendChild(svgEl('line', {
                x1, y1: y, x2, y2: y,
                stroke: 'var(--teal)', 'stroke-width': 1.5,
                opacity: 0.4,
                'stroke-dasharray': gap > 2 ? '3,3' : 'none'
            }));
        }

        // Draw dots
        scenes.forEach(sc => {
            const cx = sceneX(sc.seq - 1, CHART_W);
            const dot = svgEl('circle', {
                cx, cy: y, r: 3.5,
                fill: 'var(--teal)', opacity: 0.8
            });
            attachSceneHandlers(dot, sc.id);
            svg.appendChild(dot);
        });
    });
})();

// ============================================================================
// 5. EMOTIONAL TERRAIN
// ============================================================================

(function renderEmotionalTerrain() {
    const container = document.getElementById('emotional-terrain');
    const W = container.clientWidth - 24 || 1100;
    const H = 200;
    const PAD_L = 40, PAD_R = 20, PAD_T = 16, PAD_B = 28;
    const svg = makeSvg(container, W, H);

    const highWords = /dread|fury|revelation|confrontation|crisis|terror|ecstasy|devastation|climax|breaking|scream|rage|flashover|detonation|worst/i;
    const medHighWords = /tension|unease|urgency|alarm|determination|defiance|passion|danger|electric|fear|desperate|raw|charged|intense/i;
    const medWords = /uncertainty|hope|curiosity|resolve|longing|melancholy|vulnerability|trust|recognition|understanding/i;
    const lowWords = /calm|quiet|routine|gentle|peace|reflection|contentment|stillness|normalcy|silence|steady|soft/i;

    function emotionScore(text) {
        if (!text) return 5;
        const words = text.toLowerCase().split(/\W+/);
        let total = 0, count = 0;
        words.forEach(w => {
            if (highWords.test(w)) { total += 9; count++; }
            else if (medHighWords.test(w)) { total += 6.5; count++; }
            else if (medWords.test(w)) { total += 4.5; count++; }
            else if (lowWords.test(w)) { total += 2.5; count++; }
        });
        return count > 0 ? total / count : 5;
    }

    const points = sortedScenes.map((s, i) => {
        const intent = intentById[s.id];
        const score = emotionScore(intent ? intent.emotional_arc : '');
        return {
            x: PAD_L + (i / (sceneCount - 1 || 1)) * (W - PAD_L - PAD_R),
            y: PAD_T + (1 - score / 10) * (H - PAD_T - PAD_B),
            score,
            id: s.id
        };
    });

    // Y-axis labels
    [0, 2, 4, 6, 8, 10].forEach(v => {
        const y = PAD_T + (1 - v / 10) * (H - PAD_T - PAD_B);
        svg.appendChild(svgEl('text', {
            x: PAD_L - 8, y: y + 3, 'text-anchor': 'end',
            'font-family': 'var(--font-mono)', 'font-size': 9, fill: 'var(--text-dim)'
        })).textContent = v;
        svg.appendChild(svgEl('line', {
            x1: PAD_L, y1: y, x2: W - PAD_R, y2: y,
            stroke: 'var(--border)', 'stroke-width': 0.5
        }));
    });

    // Smooth path using cubic bezier
    if (points.length > 1) {
        let pathD = `M${points[0].x},${points[0].y}`;
        for (let i = 1; i < points.length; i++) {
            const p0 = points[i - 1];
            const p1 = points[i];
            const tension = 0.3;
            const dx = p1.x - p0.x;
            const cp1x = p0.x + dx * tension;
            const cp2x = p1.x - dx * tension;
            pathD += ` C${cp1x},${p0.y} ${cp2x},${p1.y} ${p1.x},${p1.y}`;
        }

        // Gradient fill
        const gradId = 'emo-grad';
        const defs = svgEl('defs', {});
        const grad = svgEl('linearGradient', { id: gradId, x1: 0, y1: 0, x2: 0, y2: 1 });
        grad.appendChild(svgEl('stop', { offset: '0%', 'stop-color': 'var(--teal)', 'stop-opacity': 0.3 }));
        grad.appendChild(svgEl('stop', { offset: '100%', 'stop-color': 'var(--teal)', 'stop-opacity': 0.02 }));
        defs.appendChild(grad);
        svg.appendChild(defs);

        // Fill area
        const fillPath = pathD + ` L${points[points.length-1].x},${H - PAD_B} L${points[0].x},${H - PAD_B} Z`;
        svg.appendChild(svgEl('path', {
            d: fillPath, fill: `url(#${gradId})`
        }));

        // Line
        svg.appendChild(svgEl('path', {
            d: pathD, fill: 'none',
            stroke: 'var(--teal)', 'stroke-width': 2
        }));
    }

    // Dots
    points.forEach(p => {
        const dot = svgEl('circle', {
            cx: p.x, cy: p.y, r: 4,
            fill: 'var(--surface)', stroke: 'var(--teal)', 'stroke-width': 1.5
        });
        attachSceneHandlers(dot, p.id);
        svg.appendChild(dot);
    });
})();


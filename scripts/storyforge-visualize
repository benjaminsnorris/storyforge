#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-visualize — Manuscript visualization dashboard
#
# Reads scene metadata, intent, and score CSVs to generate an interactive
# self-contained HTML dashboard showing 10 visualizations of the manuscript.
#
# Usage:
#   ./storyforge-visualize              # Generate dashboard
#   ./storyforge-visualize --open       # Generate and open in browser
#   ./storyforge-visualize --dry-run    # Show what would be generated
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"
PYTHON_LIB="${SCRIPT_DIR}/lib/python"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# --- Default options ---
DRY_RUN=false
OPEN_BROWSER=false

# --- Parse arguments ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)  DRY_RUN=true; shift ;;
        --open)     OPEN_BROWSER=true; shift ;;
        -h|--help)
            echo "Usage: storyforge-visualize [OPTIONS]"
            echo ""
            echo "Generate an interactive HTML dashboard from manuscript data."
            echo ""
            echo "Options:"
            echo "  --open       Open the dashboard in the default browser"
            echo "  --dry-run    Show what would be generated without writing"
            echo "  -h, --help   Show this help message"
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

# --- Detect project ---
detect_project_root

METADATA_CSV="${PROJECT_DIR}/reference/scenes.csv"
INTENT_CSV="${PROJECT_DIR}/reference/scene-intent.csv"
SCORES_CSV="${PROJECT_DIR}/working/scores/latest/scene-scores.csv"
WEIGHTS_CSV="${PROJECT_DIR}/working/craft-weights.csv"
CHAPTER_MAP_CSV="${PROJECT_DIR}/reference/chapter-map.csv"
DASHBOARD_FILE="${PROJECT_DIR}/working/dashboard.html"

# --- Validate required files ---
if [[ ! -f "$METADATA_CSV" ]]; then
    echo "ERROR: reference/scenes.csv not found at ${METADATA_CSV}" >&2
    exit 1
fi
if [[ ! -f "$INTENT_CSV" ]]; then
    echo "ERROR: reference/scene-intent.csv not found at ${INTENT_CSV}" >&2
    exit 1
fi

# --- Read project info ---
PROJECT_TITLE=$(read_yaml_field "project.title" 2>/dev/null || read_yaml_field "title" 2>/dev/null || echo "Unknown")
PROJECT_GENRE=$(read_yaml_field "project.genre" 2>/dev/null || read_yaml_field "genre" 2>/dev/null || echo "")
SCENE_COUNT=$(awk -F'|' 'NR>1' "$METADATA_CSV" | wc -l | tr -d ' ')

# --- Dry run ---
if [[ "$DRY_RUN" == true ]]; then
    log "DRY RUN — would generate dashboard at ${DASHBOARD_FILE}"
    log "  Project: ${PROJECT_TITLE}"
    log "  Scenes: ${SCENE_COUNT}"
    log "  Metadata: ${METADATA_CSV}"
    log "  Intent: ${INTENT_CSV}"
    log "  Scores: $([ -f "$SCORES_CSV" ] && echo "$SCORES_CSV" || echo "(not found)")"
    log "  Weights: $([ -f "$WEIGHTS_CSV" ] && echo "$WEIGHTS_CSV" || echo "(not found)")"
    log "  Chapter map: $([ -f "$CHAPTER_MAP_CSV" ] && echo "$CHAPTER_MAP_CSV" || echo "(not found)")"
    exit 0
fi

log "Generating manuscript dashboard for ${PROJECT_TITLE}..."

# --- Build JSON data via Python module ---
DATA_JSON=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.visualize data "$PROJECT_DIR") || {
    echo "ERROR: Failed to load dashboard data via Python module" >&2
    exit 1
}

# --- Generate HTML ---
mkdir -p "$(dirname "$DASHBOARD_FILE")"

cat > "$DASHBOARD_FILE" << 'HTMLEOF'

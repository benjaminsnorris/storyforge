// ============================================================================
// PAGE ROUTER
// ============================================================================

// Router runs AFTER all charts render (see bottom of file)
function _initRouter() {
    // Move sections with data-target-page to the correct page container
    document.querySelectorAll('[data-target-page]').forEach(el => {
        const targetId = 'page-' + el.getAttribute('data-target-page');
        const target = document.getElementById(targetId);
        if (target) target.appendChild(el);
    });

    function showPage(pageId) {
        document.querySelectorAll('.dash-page').forEach(p => {
            p.classList.add('routed');
            p.classList.remove('active');
        });
        document.querySelectorAll('.dash-nav a').forEach(a => a.classList.remove('active'));
        const page = document.getElementById('page-' + pageId);
        if (page) page.classList.add('active');
        const link = document.querySelector('.dash-nav a[data-page="' + pageId + '"]');
        if (link) link.classList.add('active');
    }

    // Handle nav clicks
    document.querySelectorAll('.dash-nav a').forEach(a => {
        a.addEventListener('click', function(e) {
            e.preventDefault();
            const pageId = this.getAttribute('data-page');
            showPage(pageId);
            history.replaceState(null, '', '#' + pageId);
        });
    });

    // Handle initial hash — NOW hide inactive pages (all were visible during rendering)
    const hash = (window.location.hash || '#overview').replace('#', '');
    showPage(hash);
}


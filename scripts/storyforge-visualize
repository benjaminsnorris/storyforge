const openDrawers = [];

function openRationaleDrawer(drawerId, title, contentHtml) {
    const drawer = document.getElementById(drawerId);
    if (!drawer) return;
    drawer.innerHTML = '<div class="rationale-drawer-header">' +
        '<h3>' + title + '</h3>' +
        '<button class="close-btn" onclick="closeRationaleDrawer(\'' + drawerId + '\')">&times;</button>' +
        '</div>' +
        '<div class="rationale-text">' + contentHtml + '</div>';
    drawer.classList.add('open');
    if (openDrawers.indexOf(drawerId) === -1) openDrawers.push(drawerId);
}

function closeRationaleDrawer(drawerId) {
    const drawer = document.getElementById(drawerId);
    if (!drawer) return;
    drawer.classList.remove('open');
    var idx = openDrawers.indexOf(drawerId);
    if (idx !== -1) openDrawers.splice(idx, 1);
    // Clear any group dimming associated with this drawer
    if (drawerId === 'character-drawer') clearGroupDimming('data-char-group');
    if (drawerId === 'act-drawer') clearGroupDimming('data-act-group');
}

function formatPrincipleLabel(key) {
    return key.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
}

function scoreColorClass(val) {
    var n = parseInt(val);
    if (isNaN(n)) return 'var(--text-dim)';
    if (n <= 1) return 'var(--score-low)';
    if (n <= 2) return 'var(--score-mid-low)';
    if (n <= 3) return 'var(--score-mid)';
    if (n <= 4) return 'var(--score-mid-high)';
    return 'var(--score-high)';
}

// Escape closes the most recently opened drawer
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && openDrawers.length > 0) {
        closeRationaleDrawer(openDrawers[openDrawers.length - 1]);
    }
});

function showAllRationales(sceneId) {
    var s = sceneById[sceneId];
    var score = scoreById[sceneId];
    var rat = sceneRationaleById[sceneId];
    if (!s || !rat) return;

    // Group by section using weights
    var sectionMap = {};
    WEIGHTS.forEach(function(w) {
        if (w.section && w.principle) sectionMap[w.principle] = w.section;
    });

    var sections = {};
    var principles = Object.keys(rat).filter(function(k) { return k !== 'id'; });
    principles.forEach(function(p) {
        var sec = sectionMap[p] || 'other';
        if (!sections[sec]) sections[sec] = [];
        sections[sec].push(p);
    });

    var html = '';
    for (var sec in sections) {
        html += '<div class="rationale-principle" style="margin-top:16px;margin-bottom:8px">' +
            sec.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) + '</div>';
        sections[sec].forEach(function(p) {
            if (!rat[p]) return;
            var scoreVal = score ? parseInt(score[p]) : 0;
            var color = scoreColorClass(scoreVal);
            html += '<p><strong style="font-family:var(--font-mono);font-size:10px">' +
                formatPrincipleLabel(p) +
                ' <span style="color:' + color + '">' + scoreVal + '/5</span></strong></p>' +
                '<p>' + rat[p] + '</p>';
        });
    }

    openRationaleDrawer('heatmap-drawer', s.seq + '. ' + s.title + ' — All Rationales', html);
}

function dimGroups(attr, selectedValue) {
    document.querySelectorAll('[' + attr + ']').forEach(function(el) {
        if (el.getAttribute(attr) === selectedValue) {
            el.style.opacity = '';
        } else {
            el.style.opacity = '0.15';
        }
    });
}

function clearGroupDimming(attr) {
    document.querySelectorAll('[' + attr + ']').forEach(function(el) {
        el.style.opacity = '';
    });
}

function showAllCharacterRationales(characterName) {
    var scores = charScoreByName[characterName];
    var rat = charRationaleByName[characterName];
    if (!rat) return;
    dimGroups('data-char-group', characterName);

    var principles = Object.keys(rat).filter(function(k) { return k !== 'character'; });
    var html = '';
    principles.forEach(function(p) {
        if (!rat[p]) return;
        var scoreVal = scores ? parseInt(scores[p]) : 0;
        var color = scoreColorClass(scoreVal);
        html += '<p><strong style="font-family:var(--font-mono);font-size:10px">' +
            formatPrincipleLabel(p) +
            ' <span style="color:' + color + '">' + scoreVal + '/5</span></strong></p>' +
            '<p>' + rat[p] + '</p>';
    });

    openRationaleDrawer('character-drawer', characterName + ' — All Rationales', html);
}

function showAllActRationales(actId) {
    var rat = actRationaleById[actId];
    var scores = ACT_SCORES.filter(function(a) { return a.id === actId; })[0];
    if (!rat) return;
    dimGroups('data-act-group', actId);

    var FRAMEWORK_LABELS = {
        campbells_monomyth: "Campbell's Monomyth",
        three_act: 'Three Act',
        save_the_cat: 'Save the Cat',
        truby_22: 'Truby 22',
        harmon_circle: 'Harmon Circle',
        kishotenketsu: 'Kishotenketsu',
        freytag: "Freytag's Pyramid",
        character_web: 'Character Web',
        character_as_theme: 'Character as Theme'
    };

    var principles = Object.keys(rat).filter(function(k) { return k !== 'id'; });
    var html = '';
    principles.forEach(function(p) {
        if (!rat[p]) return;
        var scoreVal = scores ? parseInt(scores[p]) : 0;
        var color = scoreColorClass(scoreVal);
        var label = FRAMEWORK_LABELS[p] || formatPrincipleLabel(p);
        html += '<p><strong style="font-family:var(--font-mono);font-size:10px">' +
            label +
            ' <span style="color:' + color + '">' + scoreVal + '/5</span></strong></p>' +
            '<p>' + rat[p] + '</p>';
    });

    var actLabel = actId.replace(/-/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
    openRationaleDrawer('act-drawer', actLabel + ' — All Rationales', html);
}

// Generic alias map builder
function buildAliasMap(entries) {
    const map = {};
    entries.forEach(e => {
        if (!e.name) return;
        map[e.name.toLowerCase()] = e.name;
        if (e.aliases) {
            e.aliases.split(';').forEach(a => {
                a = a.trim();
                if (a) map[a.toLowerCase()] = e.name;
            });
        }
    });
    return map;
}

const charAliasMap = buildAliasMap(CHARACTERS);
const motifAliasMap = buildAliasMap(MOTIF_TAXONOMY);
const locationAliasMap = buildAliasMap(LOCATIONS);

// Motif tier lookup: {canonical_name: tier}
const motifTierMap = {};
MOTIF_TAXONOMY.forEach(m => {
    if (m.name && m.tier) motifTierMap[m.name] = m.tier;
});

// Normalize a name against an alias map
function normalizeName(map, name) {
    if (!name) return name;
    return map[name.toLowerCase().trim()] || name.trim();
}
function normalizeChar(name) { return normalizeName(charAliasMap, name); }
function normalizeMotif(name) { return normalizeName(motifAliasMap, name); }
function normalizeLocation(name) {
    if (!name) return name;
    // Try exact match first
    var exact = normalizeName(locationAliasMap, name);
    if (exact !== name.trim()) return exact;
    // Fuzzy: check if the setting starts with any known alias
    var lower = name.toLowerCase().trim();
    var bestKey = '';
    var bestCanonical = '';
    for (var alias in locationAliasMap) {
        if (lower.indexOf(alias) === 0 && alias.length > bestKey.length) {
            bestKey = alias;
            bestCanonical = locationAliasMap[alias];
        }
    }
    return bestCanonical || name.trim();
}

// Parse scenes sorted by seq
const sortedScenes = [...SCENES].sort((a, b) => (+a.seq) - (+b.seq));
const sceneIds = sortedScenes.map(s => s.id);
const sceneCount = sortedScenes.length;

function getWordCount(s) {
    return parseInt(s.word_count) || parseInt(s.target_words) || 0;
}

const totalWords = sortedScenes.reduce((sum, s) => sum + getWordCount(s), 0);

// Shared grid layout constants — all grid visualizations use these so scene columns align
const GRID_LABEL_W = window.innerWidth < 768 ? 100 : 180;
const GRID_RIGHT_PAD = 20;
const GRID_LABEL_TRUNC = window.innerWidth < 768 ? 12 : 24;
// sceneX(index) returns the x position for a scene in any grid visualization
function sceneX(idx, chartW) { return GRID_LABEL_W + (idx / (sceneCount - 1 || 1)) * chartW; }

// SVG namespace
const SVG_NS = 'http://www.w3.org/2000/svg';

function svgEl(tag, attrs) {
    const el = document.createElementNS(SVG_NS, tag);
    for (const [k, v] of Object.entries(attrs || {})) {
        el.setAttribute(k, v);
    }
    return el;
}

function makeSvg(container, width, height) {
    const svg = svgEl('svg', { width, height, viewBox: `0 0 ${width} ${height}` });
    container.appendChild(svg);
    return svg;
}

// ============================================================================
// TOOLTIP
// ============================================================================

const tooltipEl = document.getElementById('tooltip');

function showTooltip(evt, html) {
    tooltipEl.innerHTML = html;
    tooltipEl.classList.add('visible');
    const rect = tooltipEl.getBoundingClientRect();
    let x = evt.clientX + 12;
    let y = evt.clientY - 8;
    if (x + rect.width > window.innerWidth - 8) x = evt.clientX - rect.width - 12;
    if (y + rect.height > window.innerHeight - 8) y = window.innerHeight - rect.height - 8;
    if (y < 8) y = 8;
    tooltipEl.style.left = x + 'px';
    tooltipEl.style.top = y + 'px';
}

function hideTooltip() {
    tooltipEl.classList.remove('visible');
}

// ============================================================================
// SHARED SELECTION
// ============================================================================

let selectedScene = null;

function selectScene(sceneId) {
    selectedScene = sceneId;
    document.querySelectorAll('[data-scene]').forEach(el => {
        if (sceneId) {
            el.classList.toggle('selected', el.dataset.scene === sceneId);
            el.classList.toggle('dimmed', el.dataset.scene !== sceneId);
        } else {
            el.classList.remove('selected', 'dimmed');
        }
    });
    // Show/hide column highlight lines in grid visualizations
    document.querySelectorAll('.scene-col-highlight').forEach(el => el.remove());
    if (sceneId) {
        document.querySelectorAll('[data-scene-col="' + sceneId + '"]').forEach(el => {
            var svg = el.closest('svg');
            if (!svg) return;
            var cx = parseFloat(el.getAttribute('data-col-x'));
            if (isNaN(cx)) return;
            var line = svgEl('line', {
                x1: cx, y1: 0, x2: cx, y2: svg.getAttribute('height'),
                stroke: 'var(--teal)', 'stroke-width': 1.5, opacity: 0.3,
                'class': 'scene-col-highlight'
            });
            svg.insertBefore(line, svg.firstChild);
        });
    }
    updateDetailPanel(sceneId);
}

function attachSceneHandlers(el, sceneId) {
    el.setAttribute('data-scene', sceneId);
    el.addEventListener('click', (e) => {
        e.stopPropagation();
        selectScene(selectedScene === sceneId ? null : sceneId);
    });
    el.addEventListener('mouseenter', (e) => {
        const s = sceneById[sceneId];
        if (!s) return;
        const wc = getWordCount(s);
        showTooltip(e, `<div class="tt-title">${s.seq}. ${s.title}</div><div class="tt-meta">POV: ${s.pov} &middot; ${wc.toLocaleString()} words &middot; ${s.type || 'untyped'}<br>Location: ${(s.location || '').substring(0, 60)}</div>`);
    });
    el.addEventListener('mousemove', (e) => {
        const s = sceneById[sceneId];
        if (!s) return;
        const wc = getWordCount(s);
        showTooltip(e, `<div class="tt-title">${s.seq}. ${s.title}</div><div class="tt-meta">POV: ${s.pov} &middot; ${wc.toLocaleString()} words &middot; ${s.type || 'untyped'}<br>Location: ${(s.location || '').substring(0, 60)}</div>`);
    });
    el.addEventListener('mouseleave', hideTooltip);
}

// Click on body to deselect
document.addEventListener('click', () => selectScene(null));

// ============================================================================
// DETAIL PANEL
// ============================================================================

function toggleMinimizePanel() {
    var panel = document.getElementById('detail-panel');
    var btn = panel.querySelector('.minimize-btn');
    panel.classList.toggle('minimized');
    if (btn) {
        var isMin = panel.classList.contains('minimized');
        btn.innerHTML = isMin ? '&#8593;' : '&#8595;';
        btn.title = isMin ? 'Expand' : 'Minimize';
    }
}

function updateDetailPanel(sceneId) {
    const panel = document.getElementById('detail-panel');
    const content = document.getElementById('detail-content');
    const page = document.querySelector('.page');
    if (!sceneId) {
        panel.classList.remove('visible', 'minimized');
        page.classList.remove('panel-open');
        closeRationaleDrawer('heatmap-drawer');
        return;
    }
    const s = sceneById[sceneId];
    const intent = intentById[sceneId];
    const score = scoreById[sceneId];
    if (!s) return;

    // Reset minimized state when selecting a new scene
    panel.classList.remove('minimized');

    let html = '<h3 style="display:flex;justify-content:space-between;align-items:center">';
    html += '<span>' + s.seq + '. ' + s.title + '</span>';
    html += '<span style="display:flex;gap:4px;flex-shrink:0">';
    html += '<button class="minimize-btn" onclick="event.stopPropagation();toggleMinimizePanel()" title="Minimize">&#8595;</button>';
    html += '<button class="close-btn" onclick="event.stopPropagation();selectScene(null)" title="Close">&times;</button>';
    html += '</span></h3>';
    html += detailRow('POV', s.pov);
    html += detailRow('Location', s.location);
    html += detailRow('Part', s.part);
    html += detailRow('Type', s.type);
    html += detailRow('Words', (+getWordCount(s)).toLocaleString());
    html += detailRow('Status', s.status, true);

    if (intent) {
        let intentHtml = '';
        if (intent.function) intentHtml += detailRow('Function', intent.function.substring(0, 150));
        if (intent.action_sequel) {
            const stFirst = intent.action_sequel.split(/[\s—–]/)[0].trim();
            intentHtml += detailRow('Scene Type', stFirst.charAt(0).toUpperCase() + stFirst.slice(1));
        }
        if (intent.value_at_stake) intentHtml += detailRow('Value at Stake', intent.value_at_stake.split(/[\s—–]/)[0].trim());
        if (intent.value_shift) {
            const vsMatch = intent.value_shift.match(/^([+\-]+)\s*\/\s*([+\-]+)/);
            if (vsMatch) intentHtml += detailRow('Value Shift', vsMatch[1] + ' → ' + vsMatch[2]);
        }
        if (intent.turning_point) {
            const tpFirst = intent.turning_point.split(/[\s—–]/)[0].trim();
            intentHtml += detailRow('Turning Point', tpFirst.charAt(0).toUpperCase() + tpFirst.slice(1));
        }
        if (intent.emotional_arc) intentHtml += detailRow('Emotion', intent.emotional_arc.substring(0, 80));
        if (intent.characters) intentHtml += detailRow('Characters', intent.characters.replace(/;/g, ', '));
        if (intent.threads) intentHtml += detailRow('Threads', intent.threads.replace(/;/g, ', '));
        if (intent.motifs) intentHtml += detailRow('Motifs', intent.motifs.replace(/;/g, ', ').substring(0, 100));
        if (intentHtml) html += '<div class="detail-section-end">' + intentHtml + '</div>';
    }

    // Brief data
    const brief = briefById[sceneId];
    if (brief) {
        let briefHtml = '';
        if (brief.goal) briefHtml += detailRow('Goal', brief.goal.substring(0, 120));
        if (brief.conflict) briefHtml += detailRow('Conflict', brief.conflict.substring(0, 120));
        if (brief.outcome) briefHtml += detailRow('Outcome', brief.outcome.split(/[\s—–]/)[0].trim());
        if (brief.crisis) briefHtml += detailRow('Crisis', brief.crisis.substring(0, 120));
        if (brief.decision) briefHtml += detailRow('Decision', brief.decision.substring(0, 120));
        if (briefHtml) {
            html += '<div style="margin-top:4px"><div class="detail-label" style="margin-bottom:4px">BRIEF</div>';
            html += briefHtml + '</div>';
        }
    }

    // Fidelity scores
    const fidelity = fidelityById[sceneId];
    if (fidelity) {
        html += '<div style="margin-top:4px">';
        html += '<div class="detail-label" style="margin-bottom:4px">FIDELITY</div>';
        html += '<div class="scores-grid">';
        const fElements = ['goal', 'conflict', 'outcome', 'crisis', 'decision', 'key_actions', 'key_dialogue', 'emotions', 'knowledge'];
        fElements.forEach(el => {
            const val = parseInt(fidelity[el]);
            if (isNaN(val)) return;
            const color = val >= 4 ? 'var(--score-mid-high)' : val >= 3 ? 'var(--score-mid)' : 'var(--score-mid-low)';
            html += '<span class="sg-label">' + el.replace(/_/g, ' ') + '</span><span class="sg-value" style="color:' + color + '">' + val + '</span>';
        });
        html += '</div></div>';
    }

    if (score) {
        html += '<div style="margin-top:4px">';
        html += '<div class="detail-label" style="margin-bottom:4px">CRAFT SCORES</div>';
        html += '<div class="scores-grid">';
        for (const [k, v] of Object.entries(score)) {
            if (k === 'id') continue;
            const num = parseInt(v);
            if (isNaN(num)) continue;
            const color = num >= 5 ? 'var(--score-high)' : num >= 4 ? 'var(--score-mid-high)' : num >= 3 ? 'var(--score-mid)' : num >= 2 ? 'var(--score-mid-low)' : 'var(--score-low)';
            html += `<span class="sg-label">${k.replace(/_/g, ' ')}</span><span class="sg-value" style="color:${color}">${num}</span>`;
        }
        html += '</div>';

        const rat = sceneRationaleById[sceneId];
        if (rat) {
            html += '<div style="margin-top:8px;text-align:center">';
            html += '<a href="#" style="font-family:var(--font-mono);font-size:10px;color:var(--teal);text-decoration:none" ';
            html += 'onclick="event.preventDefault();document.getElementById(\'heatmap-drawer\').scrollIntoView({behavior:\'smooth\',block:\'nearest\'})">View rationales &rarr;</a>';
            html += '</div>';
        }

        html += '</div>';
    }

    content.innerHTML = html;
    panel.classList.add('visible');
    page.classList.add('panel-open');

    // Auto-open rationale drawer if data exists
    if (sceneRationaleById[sceneId]) {
        showAllRationales(sceneId);
    }
}

function detailRow(label, value, sectionEnd) {
    if (!value) return '';
    var border = sectionEnd ? 'border-bottom:4px solid var(--border);' : '';
    return `<div class="detail-row" style="${border}"><span class="detail-label">${label}</span><span class="detail-value">${value}</span></div>`;
}


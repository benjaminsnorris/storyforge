#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-migrate — Convert YAML-based project data to pipe-delimited CSV
#
# Usage:
#   ./storyforge-migrate                       # Dry-run (default)
#   ./storyforge-migrate --execute             # Perform migration
#   ./storyforge-migrate --project-dir DIR     # Target specific project
#   ./storyforge-migrate --skip-rename         # Don't rename scene files
#   ./storyforge-migrate --skip-backup         # Skip backup creation
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# shellcheck source=lib/csv.sh
source "${LIB_DIR}/csv.sh"

# ============================================================================
# Argument parsing
# ============================================================================

DRY_RUN=true
SKIP_RENAME=false
SKIP_BACKUP=false
PROJECT_ARG=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --execute)
            DRY_RUN=false
            shift
            ;;
        --project-dir)
            PROJECT_ARG="$2"
            shift 2
            ;;
        --project-dir=*)
            PROJECT_ARG="${1#--project-dir=}"
            shift
            ;;
        --skip-rename)
            SKIP_RENAME=true
            shift
            ;;
        --skip-backup)
            SKIP_BACKUP=true
            shift
            ;;
        -h|--help)
            echo "Usage: storyforge-migrate [--execute] [--dry-run] [--project-dir DIR]"
            echo ""
            echo "Migrates Storyforge project data from YAML to pipe-delimited CSV."
            echo ""
            echo "Options:"
            echo "  --dry-run         Preview changes without modifying files (default)"
            echo "  --execute         Perform the migration"
            echo "  --project-dir DIR Use DIR as project root"
            echo "  --skip-rename     Convert metadata but don't rename scene files"
            echo "  --skip-backup     Skip creating backups"
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            exit 1
            ;;
    esac
done

# --- Detect or set project root ---
if [[ -n "$PROJECT_ARG" ]]; then
    if [[ ! -d "$PROJECT_ARG" ]]; then
        echo "ERROR: Project directory not found: ${PROJECT_ARG}" >&2
        exit 1
    fi
    PROJECT_DIR="$(cd "$PROJECT_ARG" && pwd)"
    export PROJECT_DIR
else
    detect_project_root
fi

# ============================================================================
# Paths
# ============================================================================

SCENE_INDEX="${PROJECT_DIR}/scenes/scene-index.yaml"
SCENES_DIR="${PROJECT_DIR}/scenes"
CHAPTER_MAP_YAML="${PROJECT_DIR}/reference/chapter-map.yaml"
CHAPTER_MAP_CSV="${PROJECT_DIR}/reference/chapter-map.csv"
METADATA_CSV="${SCENES_DIR}/metadata.csv"
INTENT_CSV="${SCENES_DIR}/intent.csv"
PIPELINE_YAML="${PROJECT_DIR}/working/pipeline.yaml"
PIPELINE_CSV="${PROJECT_DIR}/working/pipeline.csv"
BACKUP_DIR="${PROJECT_DIR}/working/backups/pre-migration"

# ============================================================================
# Helpers
# ============================================================================

# Strip surrounding quotes from a value
strip_quotes() {
    local val="$1"
    val="${val#\"}"
    val="${val%\"}"
    val="${val#\'}"
    val="${val%\'}"
    echo "$val"
}

# Read a YAML field from a block of text (single line values only)
# Usage: yaml_field "field_name" <<< "$block"
yaml_field() {
    local field="$1"
    local line
    line=$(grep -E "^[[:space:]]*${field}:" 2>/dev/null | head -1) || true
    if [[ -z "$line" ]]; then
        echo ""
        return
    fi
    local val
    val=$(echo "$line" | sed "s/^[[:space:]]*${field}:[[:space:]]*//" | sed 's/[[:space:]]*$//')
    strip_quotes "$val"
}

# Read a YAML field value from frontmatter of a .md file
# Usage: frontmatter_field <file> <field>
frontmatter_field() {
    local file="$1" field="$2"
    [[ -f "$file" ]] || return 0
    # Extract frontmatter (between --- lines)
    local fm
    fm=$(sed -n '/^---$/,/^---$/p' "$file" 2>/dev/null) || true
    [[ -z "$fm" ]] && return 0
    echo "$fm" | yaml_field "$field"
}

# Read a YAML array field from frontmatter, join items with ||
# Usage: frontmatter_array <file> <field>
frontmatter_array() {
    local file="$1" field="$2"
    [[ -f "$file" ]] || return 0
    local fm
    fm=$(sed -n '/^---$/,/^---$/p' "$file" 2>/dev/null) || true
    [[ -z "$fm" ]] && return 0
    # Find the field, then collect list items (lines starting with "  - ")
    local in_field=false result=""
    while IFS= read -r line; do
        if [[ "$in_field" == true ]]; then
            if echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]'; then
                local val
                val=$(echo "$line" | sed 's/^[[:space:]]*-[[:space:]]*//' | sed 's/[[:space:]]*$//' | sed 's/^["'\'']//' | sed 's/["'\'']*$//')
                if [[ -n "$result" ]]; then
                    result="${result}||${val}"
                else
                    result="$val"
                fi
            else
                # Not a list item — end of array
                break
            fi
        fi
        if echo "$line" | grep -qE "^${field}:"; then
            in_field=true
        fi
    done <<< "$fm"
    echo "$result"
}

# Escape pipe characters in a value (should not appear, but safety)
escape_pipe() {
    echo "$1" | tr '|' ':'
}

# ============================================================================
# create_backup — copy original files before modifying
# ============================================================================

create_backup() {
    if [[ "$SKIP_BACKUP" == true ]]; then
        return 0
    fi

    echo "Creating backup in ${BACKUP_DIR}..."

    if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would create backup directory"
        return 0
    fi

    mkdir -p "$BACKUP_DIR"

    # Backup scene-index.yaml
    if [[ -f "$SCENE_INDEX" ]]; then
        mkdir -p "${BACKUP_DIR}/scenes"
        cp "$SCENE_INDEX" "${BACKUP_DIR}/scenes/"
    fi

    # Backup scene .md files
    for f in "${SCENES_DIR}"/*.md; do
        [[ -f "$f" ]] || continue
        mkdir -p "${BACKUP_DIR}/scenes"
        cp "$f" "${BACKUP_DIR}/scenes/"
    done

    # Backup chapter-map.yaml
    if [[ -f "$CHAPTER_MAP_YAML" ]]; then
        mkdir -p "${BACKUP_DIR}/reference"
        cp "$CHAPTER_MAP_YAML" "${BACKUP_DIR}/reference/"
    fi

    # Backup pipeline.yaml
    if [[ -f "$PIPELINE_YAML" ]]; then
        mkdir -p "${BACKUP_DIR}/working"
        cp "$PIPELINE_YAML" "${BACKUP_DIR}/working/"
    fi

    # Backup evaluation findings
    if [[ -d "${PROJECT_DIR}/working/evaluations" ]]; then
        for eval_dir in "${PROJECT_DIR}/working/evaluations"/*/; do
            [[ -d "$eval_dir" ]] || continue
            local eval_name
            eval_name=$(basename "$eval_dir")
            if [[ -f "${eval_dir}findings.yaml" ]]; then
                mkdir -p "${BACKUP_DIR}/working/evaluations/${eval_name}"
                cp "${eval_dir}findings.yaml" "${BACKUP_DIR}/working/evaluations/${eval_name}/"
            fi
        done
    fi

    # Backup revision plans
    for plan in "${PROJECT_DIR}/working/plans"/revision-plan*.yaml; do
        [[ -f "$plan" ]] || continue
        mkdir -p "${BACKUP_DIR}/working/plans"
        cp "$plan" "${BACKUP_DIR}/working/plans/"
    done

    echo "  Backup complete."
}

# ============================================================================
# migrate_scene_metadata — parse scene-index.yaml into metadata.csv + intent.csv
# ============================================================================

migrate_scene_metadata() {
    if [[ ! -f "$SCENE_INDEX" ]]; then
        echo "  No scene-index.yaml found; skipping scene metadata migration."
        return 0
    fi

    echo "Migrating scene metadata..."

    # Parse scene blocks from YAML
    # Each scene starts with "  - id:" and fields follow indented
    local scene_blocks=()
    local current_block=""
    local in_scene=false

    while IFS= read -r line; do
        # Detect start of scene entry: "  - id: ..."
        if echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]+id:'; then
            if [[ -n "$current_block" ]]; then
                scene_blocks+=("$current_block")
            fi
            # Convert "  - id:" to "  id:" for consistent parsing
            current_block=$(echo "$line" | sed 's/^[[:space:]]*-[[:space:]]*/  /')
            in_scene=true
        elif [[ "$in_scene" == true ]]; then
            # If line is a comment, blank, or another top-level key, check context
            if echo "$line" | grep -qE '^[[:space:]]*#|^$'; then
                # Keep going, skip comments/blanks
                :
            elif echo "$line" | grep -qE '^[[:space:]]+[a-z_]+:'; then
                # Indented field — part of current scene
                current_block="${current_block}"$'\n'"${line}"
            elif echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]+id:'; then
                # New scene
                scene_blocks+=("$current_block")
                current_block=$(echo "$line" | sed 's/^[[:space:]]*-[[:space:]]*/  /')
            else
                # Something else; keep scene open (might be a continuation)
                :
            fi
        fi
    done < "$SCENE_INDEX"

    # Don't forget the last block
    if [[ -n "$current_block" ]]; then
        scene_blocks+=("$current_block")
    fi

    local meta_header="id|seq|title|pov|setting|part|type|timeline_day|time_of_day|status|word_count|target_words"
    local intent_header="id|function|emotional_arc|characters|threads|motifs|notes"

    local meta_rows=()
    local intent_rows=()
    local seq=0

    for block in "${scene_blocks[@]}"; do
        seq=$((seq + 1))

        # Extract fields from the YAML block
        local id title pov setting part scene_type timeline_day time_of_day status word_count target_words
        local func emotional_arc characters threads motifs notes

        id=$(echo "$block" | yaml_field "id")
        title=$(echo "$block" | yaml_field "title")
        pov=$(echo "$block" | yaml_field "pov")
        # Normalize: location → setting
        setting=$(echo "$block" | yaml_field "setting")
        [[ -z "$setting" ]] && setting=$(echo "$block" | yaml_field "location")
        part=$(echo "$block" | yaml_field "part")
        scene_type=$(echo "$block" | yaml_field "type")
        # Normalize: timeline_position → timeline_day
        timeline_day=$(echo "$block" | yaml_field "timeline_day")
        [[ -z "$timeline_day" ]] && timeline_day=$(echo "$block" | yaml_field "timeline_position")
        # Normalize: time → time_of_day
        time_of_day=$(echo "$block" | yaml_field "time_of_day")
        [[ -z "$time_of_day" ]] && time_of_day=$(echo "$block" | yaml_field "time")
        status=$(echo "$block" | yaml_field "status")
        # Normalize: words → word_count
        word_count=$(echo "$block" | yaml_field "word_count")
        [[ -z "$word_count" ]] && word_count=$(echo "$block" | yaml_field "words")
        # Normalize: word_target → target_words
        target_words=$(echo "$block" | yaml_field "target_words")
        [[ -z "$target_words" ]] && target_words=$(echo "$block" | yaml_field "word_target")

        # Intent fields
        func=$(echo "$block" | yaml_field "function")
        emotional_arc=$(echo "$block" | yaml_field "emotional_arc")
        characters=$(echo "$block" | yaml_field "characters")
        threads=$(echo "$block" | yaml_field "threads")
        motifs=$(echo "$block" | yaml_field "motifs")
        notes=$(echo "$block" | yaml_field "notes")
        [[ -z "$notes" ]] && notes=$(echo "$block" | yaml_field "summary")

        # Check scene file frontmatter for ALL fields not yet populated from the index
        local scene_file="${SCENES_DIR}/${id}.md"
        if [[ -f "$scene_file" ]]; then
            local fm_val
            # Metadata fields
            [[ -z "$title" || "$title" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "title"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && title="$fm_val"; }
            [[ -z "$pov" || "$pov" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "pov"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && pov="$fm_val"; }
            [[ -z "$setting" || "$setting" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "setting"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && setting="$fm_val"; }
            [[ -z "$part" || "$part" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "part"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && part="$fm_val"; }
            [[ -z "$scene_type" || "$scene_type" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "type"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && scene_type="$fm_val"; }
            [[ -z "$timeline_day" || "$timeline_day" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "timeline_day"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && timeline_day="$fm_val"; }
            [[ -z "$time_of_day" || "$time_of_day" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "time_of_day"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && time_of_day="$fm_val"; }
            [[ -z "$word_count" || "$word_count" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "word_count"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && word_count="$fm_val"; }
            [[ -z "$status" || "$status" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "status"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && status="$fm_val"; }
            [[ -z "$target_words" || "$target_words" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "target_words"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && target_words="$fm_val"; }
            # Intent fields
            [[ -z "$func" || "$func" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "function"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && func="$fm_val"; }
            [[ -z "$emotional_arc" || "$emotional_arc" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "emotional_arc"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && emotional_arc="$fm_val"; }
            [[ -z "$notes" || "$notes" == "null" ]] && { fm_val=$(frontmatter_field "$scene_file" "notes"); [[ -n "$fm_val" && "$fm_val" != "null" ]] && notes="$fm_val"; }
            # Array fields from frontmatter (characters, threads, motifs)
            if [[ -z "$characters" || "$characters" == "null" ]]; then
                fm_val=$(frontmatter_array "$scene_file" "characters")
                [[ -n "$fm_val" ]] && characters="$fm_val"
            fi
            if [[ -z "$threads" || "$threads" == "null" ]]; then
                fm_val=$(frontmatter_array "$scene_file" "threads")
                [[ -n "$fm_val" ]] && threads="$fm_val"
            fi
            if [[ -z "$motifs" || "$motifs" == "null" ]]; then
                fm_val=$(frontmatter_array "$scene_file" "motifs")
                [[ -n "$fm_val" ]] && motifs="$fm_val"
            fi
        fi

        # Clean up null values
        [[ "$word_count" == "null" ]] && word_count=""
        [[ "$target_words" == "null" ]] && target_words=""
        [[ "$timeline_day" == "null" ]] && timeline_day=""
        [[ "$time_of_day" == "null" ]] && time_of_day=""
        [[ "$status" == "null" ]] && status=""
        [[ "$part" == "null" ]] && part=""
        [[ "$scene_type" == "null" ]] && scene_type=""

        # Escape pipe characters
        title=$(escape_pipe "$title")
        pov=$(escape_pipe "$pov")
        setting=$(escape_pipe "$setting")
        func=$(escape_pipe "$func")
        emotional_arc=$(escape_pipe "$emotional_arc")

        meta_rows+=("${id}|${seq}|${title}|${pov}|${setting}|${part}|${scene_type}|${timeline_day}|${time_of_day}|${status}|${word_count}|${target_words}")
        intent_rows+=("${id}|${func}|${emotional_arc}|${characters}|${threads}|${motifs}|${notes}")
    done

    echo "  Found ${#scene_blocks[@]} scene(s)"

    if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would write ${METADATA_CSV}:"
        echo "    ${meta_header}"
        for row in "${meta_rows[@]}"; do
            echo "    ${row}"
        done
        echo "  [dry-run] Would write ${INTENT_CSV}:"
        echo "    ${intent_header}"
        for row in "${intent_rows[@]}"; do
            echo "    ${row}"
        done
        return 0
    fi

    # Write metadata.csv
    echo "$meta_header" > "$METADATA_CSV"
    for row in "${meta_rows[@]}"; do
        echo "$row" >> "$METADATA_CSV"
    done
    echo "  Wrote ${METADATA_CSV}"

    # Write intent.csv
    echo "$intent_header" > "$INTENT_CSV"
    for row in "${intent_rows[@]}"; do
        echo "$row" >> "$INTENT_CSV"
    done
    echo "  Wrote ${INTENT_CSV}"
}

# ============================================================================
# strip_frontmatter — remove YAML frontmatter from scene .md files
# ============================================================================

strip_frontmatter() {
    echo "Stripping frontmatter from scene files..."

    local count=0
    for f in "${SCENES_DIR}"/*.md; do
        [[ -f "$f" ]] || continue

        # Check if file starts with ---
        local first_line
        first_line=$(head -1 "$f")
        if [[ "$first_line" != "---" ]]; then
            continue
        fi

        count=$((count + 1))
        local fname
        fname=$(basename "$f")

        if [[ "$DRY_RUN" == true ]]; then
            echo "  [dry-run] Would strip frontmatter from ${fname}"
            continue
        fi

        # Find the closing --- line number (second occurrence)
        local end_line
        end_line=$(awk '/^---$/ { count++; if (count == 2) { print NR; exit } }' "$f")

        if [[ -z "$end_line" ]]; then
            echo "  WARNING: No closing --- found in ${fname}; skipping" >&2
            continue
        fi

        # Remove frontmatter (lines 1 through end_line) and leading blank lines
        local tmp="${f}.tmp.$$"
        tail -n "+$((end_line + 1))" "$f" | sed '/./,$!d' > "$tmp"
        mv "$tmp" "$f"

        echo "  Stripped frontmatter from ${fname}"
    done

    echo "  Processed ${count} file(s)"
}

# ============================================================================
# migrate_chapter_map — chapter-map.yaml → chapter-map.csv
# ============================================================================

migrate_chapter_map() {
    if [[ ! -f "$CHAPTER_MAP_YAML" ]]; then
        echo "  No chapter-map.yaml found; skipping."
        return 0
    fi

    echo "Migrating chapter map..."

    local header="seq|title|heading|part|scenes"
    local rows=()
    local seq=0
    local title="" heading="" part="" scenes=""
    local in_chapters=false
    local in_scenes=false

    while IFS= read -r line; do
        # Detect chapters: section
        if echo "$line" | grep -qE '^chapters:'; then
            in_chapters=true
            continue
        fi

        # End of chapters section (hit another top-level key)
        if [[ "$in_chapters" == true ]] && echo "$line" | grep -qE '^[a-z]'; then
            # Save last chapter if any
            if [[ -n "$title" ]]; then
                seq=$((seq + 1))
                rows+=("${seq}|${title}|${heading}|${part}|${scenes}")
                title=""
            fi
            in_chapters=false
            continue
        fi

        if [[ "$in_chapters" != true ]]; then
            continue
        fi

        # New chapter entry: "  - title: ..."
        if echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]+title:'; then
            # Save previous chapter
            if [[ -n "$title" ]]; then
                seq=$((seq + 1))
                rows+=("${seq}|${title}|${heading}|${part}|${scenes}")
            fi
            title=$(echo "$line" | sed 's/.*title:[[:space:]]*//' | sed 's/^["'"'"']//' | sed 's/["'"'"']$//' | sed 's/[[:space:]]*$//')
            heading=""
            part=""
            scenes=""
            in_scenes=false
            continue
        fi

        # Chapter fields
        if echo "$line" | grep -qE '^[[:space:]]+heading:'; then
            heading=$(echo "$line" | sed 's/.*heading:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            heading=$(strip_quotes "$heading")
            continue
        fi

        if echo "$line" | grep -qE '^[[:space:]]+part:'; then
            part=$(echo "$line" | sed 's/.*part:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            part=$(strip_quotes "$part")
            continue
        fi

        if echo "$line" | grep -qE '^[[:space:]]+scenes:'; then
            in_scenes=true
            continue
        fi

        # Scene list items: "      - scene-id"
        if [[ "$in_scenes" == true ]] && echo "$line" | grep -qE '^[[:space:]]+-[[:space:]]'; then
            local scene_id
            scene_id=$(echo "$line" | sed 's/^[[:space:]]*-[[:space:]]*//' | sed 's/[[:space:]]*$//')
            scene_id=$(strip_quotes "$scene_id")
            if [[ -z "$scenes" ]]; then
                scenes="$scene_id"
            else
                scenes="${scenes}||${scene_id}"
            fi
            continue
        fi

        # If we hit a non-scene-list line while in_scenes, stop collecting scenes
        if [[ "$in_scenes" == true ]] && ! echo "$line" | grep -qE '^[[:space:]]*$|^[[:space:]]*#'; then
            in_scenes=false
        fi
    done < "$CHAPTER_MAP_YAML"

    # Save last chapter
    if [[ -n "$title" ]]; then
        seq=$((seq + 1))
        rows+=("${seq}|${title}|${heading}|${part}|${scenes}")
    fi

    echo "  Found ${#rows[@]} chapter(s)"

    if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would write ${CHAPTER_MAP_CSV}:"
        echo "    ${header}"
        for row in "${rows[@]}"; do
            echo "    ${row}"
        done
        return 0
    fi

    mkdir -p "$(dirname "$CHAPTER_MAP_CSV")"
    echo "$header" > "$CHAPTER_MAP_CSV"
    for row in "${rows[@]}"; do
        echo "$row" >> "$CHAPTER_MAP_CSV"
    done
    echo "  Wrote ${CHAPTER_MAP_CSV}"
}

# ============================================================================
# migrate_findings — findings.yaml → findings.csv
# Handles two YAML formats:
#   Format A (test fixture): findings with severity/category/location/finding/suggestion
#   Format B (real projects): findings with id/category/severity/summary/detail/affected_scenes/flagged_by/recommendation
# ============================================================================

migrate_findings() {
    local evals_dir="${PROJECT_DIR}/working/evaluations"
    if [[ ! -d "$evals_dir" ]]; then
        echo "  No evaluations directory found; skipping."
        return 0
    fi

    echo "Migrating evaluation findings..."

    local findings_header="id|evaluator|severity|category|scenes|summary|recommendation|status"
    local count=0

    for eval_dir in "${evals_dir}"/*/; do
        [[ -d "$eval_dir" ]] || continue
        local findings_yaml="${eval_dir}findings.yaml"
        [[ -f "$findings_yaml" ]] || continue

        local eval_name
        eval_name=$(basename "$eval_dir")
        count=$((count + 1))

        echo "  Processing ${eval_name}..."

        # Parse findings section
        local rows=()
        local current_id="" current_severity="" current_category="" current_summary=""
        local current_scenes="" current_flagged="" current_recommendation=""
        local in_findings=false in_scenes=false in_flagged=false
        local auto_id=0

        while IFS= read -r line; do
            # Detect section starts
            if echo "$line" | grep -qE '^findings:'; then
                in_findings=true
                in_scenes=false
                in_flagged=false
                continue
            fi

            # Another top-level key ends findings section
            if [[ "$in_findings" == true ]] && echo "$line" | grep -qE '^[a-z]'; then
                if [[ -n "$current_summary" || -n "$current_id" ]]; then
                    _emit_finding_row
                fi
                in_findings=false
                in_scenes=false
                in_flagged=false
                continue
            fi

            [[ "$in_findings" != true ]] && continue

            # New finding entry (starts with "  - id:" or "  - severity:" or "  - category:")
            if echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]+(id|severity|category):'; then
                # Save previous finding
                if [[ -n "$current_summary" || -n "$current_id" ]]; then
                    _emit_finding_row
                fi
                in_scenes=false
                in_flagged=false
                current_id="" current_severity="" current_category="" current_summary=""
                current_scenes="" current_flagged="" current_recommendation=""

                # Extract the first field from the entry line
                local field_name field_value
                field_name=$(echo "$line" | sed 's/^[[:space:]]*-[[:space:]]*//' | sed 's/:.*//')
                field_value=$(echo "$line" | sed 's/^[^:]*:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                field_value=$(strip_quotes "$field_value")
                case "$field_name" in
                    id) current_id="$field_value" ;;
                    severity) current_severity="$field_value" ;;
                    category) current_category="$field_value" ;;
                esac
                continue
            fi

            # Sub-list items for affected_scenes
            if [[ "$in_scenes" == true ]]; then
                if echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]'; then
                    local scene_val
                    scene_val=$(echo "$line" | sed 's/^[[:space:]]*-[[:space:]]*//' | sed 's/[[:space:]]*$//')
                    scene_val=$(strip_quotes "$scene_val")
                    if [[ -n "$current_scenes" ]]; then
                        current_scenes="${current_scenes}||${scene_val}"
                    else
                        current_scenes="$scene_val"
                    fi
                    continue
                else
                    in_scenes=false
                fi
            fi

            # Sub-list items for flagged_by
            if [[ "$in_flagged" == true ]]; then
                if echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]'; then
                    local flagged_val
                    flagged_val=$(echo "$line" | sed 's/^[[:space:]]*-[[:space:]]*//' | sed 's/[[:space:]]*$//')
                    flagged_val=$(strip_quotes "$flagged_val")
                    if [[ -n "$current_flagged" ]]; then
                        current_flagged="${current_flagged}||${flagged_val}"
                    else
                        current_flagged="$flagged_val"
                    fi
                    continue
                else
                    in_flagged=false
                fi
            fi

            # Field extraction
            if echo "$line" | grep -qE '^[[:space:]]+id:'; then
                current_id=$(echo "$line" | sed 's/.*id:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                current_id=$(strip_quotes "$current_id")
            elif echo "$line" | grep -qE '^[[:space:]]+severity:'; then
                current_severity=$(echo "$line" | sed 's/.*severity:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                current_severity=$(strip_quotes "$current_severity")
            elif echo "$line" | grep -qE '^[[:space:]]+category:'; then
                current_category=$(echo "$line" | sed 's/.*category:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                current_category=$(strip_quotes "$current_category")
            elif echo "$line" | grep -qE '^[[:space:]]+summary:'; then
                current_summary=$(echo "$line" | sed 's/.*summary:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                current_summary=$(strip_quotes "$current_summary")
                current_summary=$(escape_pipe "$current_summary")
            elif echo "$line" | grep -qE '^[[:space:]]+finding:'; then
                # Format A: "finding" field maps to summary
                current_summary=$(echo "$line" | sed 's/.*finding:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                current_summary=$(strip_quotes "$current_summary")
                current_summary=$(escape_pipe "$current_summary")
            elif echo "$line" | grep -qE '^[[:space:]]+recommendation:'; then
                current_recommendation=$(echo "$line" | sed 's/.*recommendation:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                current_recommendation=$(strip_quotes "$current_recommendation")
                current_recommendation=$(escape_pipe "$current_recommendation")
            elif echo "$line" | grep -qE '^[[:space:]]+suggestion:'; then
                # Format A: "suggestion" maps to recommendation
                current_recommendation=$(echo "$line" | sed 's/.*suggestion:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                current_recommendation=$(strip_quotes "$current_recommendation")
                current_recommendation=$(escape_pipe "$current_recommendation")
            elif echo "$line" | grep -qE '^[[:space:]]+location:'; then
                # Format A: "location" maps to scenes
                local loc
                loc=$(echo "$line" | sed 's/.*location:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                loc=$(strip_quotes "$loc")
                current_scenes="$loc"
            elif echo "$line" | grep -qE '^[[:space:]]+affected_scenes:'; then
                in_scenes=true
            elif echo "$line" | grep -qE '^[[:space:]]+flagged_by:'; then
                in_flagged=true
            fi
        done < "$findings_yaml"

        # Save last finding
        if [[ -n "$current_summary" || -n "$current_id" ]]; then
            _emit_finding_row
        fi

        local findings_csv="${eval_dir}findings.csv"

        if [[ "$DRY_RUN" == true ]]; then
            echo "  [dry-run] Would write ${findings_csv} with ${#rows[@]} finding(s)"
            continue
        fi

        echo "$findings_header" > "$findings_csv"
        for row in "${rows[@]}"; do
            echo "$row" >> "$findings_csv"
        done
        echo "  Wrote ${findings_csv} (${#rows[@]} findings)"
    done

    echo "  Processed ${count} evaluation(s)"
}

_emit_finding_row() {
    auto_id=$((auto_id + 1))
    local fid="${current_id:-F${auto_id}}"
    rows+=("${fid}|${current_flagged}|${current_severity}|${current_category}|${current_scenes}|${current_summary}|${current_recommendation}|open")
}

# ============================================================================
# migrate_revision_plans — revision-plan*.yaml → revision-plan.csv
# ============================================================================

migrate_revision_plans() {
    local plans_dir="${PROJECT_DIR}/working/plans"
    if [[ ! -d "$plans_dir" ]]; then
        echo "  No plans directory found; skipping."
        return 0
    fi

    echo "Migrating revision plans..."

    local header="pass|name|purpose|scope|targets|guidance|protection|findings|status|model_tier"
    local count=0

    for plan_yaml in "${plans_dir}"/revision-plan*.yaml; do
        [[ -f "$plan_yaml" ]] || continue
        count=$((count + 1))

        local plan_base
        plan_base=$(basename "$plan_yaml" .yaml)
        local plan_csv="${plans_dir}/${plan_base}.csv"

        local rows=()
        local pass_num=0
        local name="" purpose="" scope="" status=""
        local in_passes=false
        local in_guidance=false
        local guidance_items=""

        while IFS= read -r line; do
            if echo "$line" | grep -qE '^passes:'; then
                in_passes=true
                continue
            fi

            # Another top-level key ends passes
            if [[ "$in_passes" == true ]] && echo "$line" | grep -qE '^[a-z]'; then
                if [[ -n "$name" ]]; then
                    pass_num=$((pass_num + 1))
                    rows+=("${pass_num}|${name}|${purpose}|${scope}|||${guidance_items}||${status}|")
                fi
                in_passes=false
                continue
            fi

            [[ "$in_passes" != true ]] && continue

            # New pass entry: "  - name: ..."
            if echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]+name:'; then
                # Save previous pass
                if [[ -n "$name" ]]; then
                    pass_num=$((pass_num + 1))
                    rows+=("${pass_num}|${name}|${purpose}|${scope}|||${guidance_items}||${status}|")
                fi
                name=$(echo "$line" | sed 's/.*name:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                name=$(strip_quotes "$name")
                purpose=""
                scope=""
                status=""
                guidance_items=""
                in_guidance=false
                continue
            fi

            if echo "$line" | grep -qE '^[[:space:]]+purpose:'; then
                purpose=$(echo "$line" | sed 's/.*purpose:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                purpose=$(strip_quotes "$purpose")
                purpose=$(escape_pipe "$purpose")
                in_guidance=false
                continue
            fi

            if echo "$line" | grep -qE '^[[:space:]]+scope:'; then
                scope=$(echo "$line" | sed 's/.*scope:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                scope=$(strip_quotes "$scope")
                in_guidance=false
                continue
            fi

            if echo "$line" | grep -qE '^[[:space:]]+status:'; then
                status=$(echo "$line" | sed 's/.*status:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                status=$(strip_quotes "$status")
                in_guidance=false
                continue
            fi

            if echo "$line" | grep -qE '^[[:space:]]+guidance:'; then
                in_guidance=true
                continue
            fi

            # Guidance decision items
            if [[ "$in_guidance" == true ]] && echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]+decision:'; then
                local decision
                decision=$(echo "$line" | sed 's/.*decision:[[:space:]]*//' | sed 's/[[:space:]]*$//')
                decision=$(strip_quotes "$decision")
                if [[ -z "$guidance_items" ]]; then
                    guidance_items="$decision"
                else
                    guidance_items="${guidance_items}||${decision}"
                fi
                continue
            fi

            # Non-guidance field ends guidance collection
            if [[ "$in_guidance" == true ]] && echo "$line" | grep -qE '^[[:space:]]+[a-z_]+:' && ! echo "$line" | grep -qE 'rationale:'; then
                in_guidance=false
            fi
        done < "$plan_yaml"

        # Save last pass
        if [[ -n "$name" ]]; then
            pass_num=$((pass_num + 1))
            rows+=("${pass_num}|${name}|${purpose}|${scope}|||${guidance_items}||${status}|")
        fi

        if [[ "$DRY_RUN" == true ]]; then
            echo "  [dry-run] Would write ${plan_csv} with ${#rows[@]} pass(es)"
            continue
        fi

        echo "$header" > "$plan_csv"
        for row in "${rows[@]}"; do
            echo "$row" >> "$plan_csv"
        done
        echo "  Wrote ${plan_csv} (${#rows[@]} passes)"
    done

    echo "  Processed ${count} plan(s)"
}

# ============================================================================
# migrate_pipeline — pipeline.yaml → pipeline.csv
# ============================================================================

migrate_pipeline() {
    if [[ ! -f "$PIPELINE_YAML" ]]; then
        echo "  No pipeline.yaml found; skipping."
        return 0
    fi

    echo "Migrating pipeline manifest..."

    local header="cycle|started|status|evaluation|plan|summary"
    local rows=()
    local in_cycles=false
    local cycle="" started="" status="" evaluation="" plan="" summary=""

    while IFS= read -r line; do
        if echo "$line" | grep -qE '^cycles:'; then
            in_cycles=true
            continue
        fi

        # Another top-level key
        if [[ "$in_cycles" == true ]] && echo "$line" | grep -qE '^[a-z]'; then
            if [[ -n "$cycle" ]]; then
                rows+=("${cycle}|${started}|${status}|${evaluation}|${plan}|${summary}")
            fi
            in_cycles=false
            continue
        fi

        [[ "$in_cycles" != true ]] && continue

        # New cycle entry
        if echo "$line" | grep -qE '^[[:space:]]*-[[:space:]]+id:'; then
            if [[ -n "$cycle" ]]; then
                rows+=("${cycle}|${started}|${status}|${evaluation}|${plan}|${summary}")
            fi
            cycle=$(echo "$line" | sed 's/.*id:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            cycle=$(strip_quotes "$cycle")
            started=""
            status=""
            evaluation=""
            plan=""
            summary=""
            continue
        fi

        if echo "$line" | grep -qE '^[[:space:]]+started:'; then
            started=$(echo "$line" | sed 's/.*started:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            started=$(strip_quotes "$started")
            continue
        fi

        if echo "$line" | grep -qE '^[[:space:]]+status:'; then
            status=$(echo "$line" | sed 's/.*status:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            status=$(strip_quotes "$status")
            continue
        fi

        if echo "$line" | grep -qE '^[[:space:]]+evaluation:'; then
            evaluation=$(echo "$line" | sed 's/.*evaluation:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            evaluation=$(strip_quotes "$evaluation")
            continue
        fi

        if echo "$line" | grep -qE '^[[:space:]]+plan:'; then
            plan=$(echo "$line" | sed 's/.*plan:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            plan=$(strip_quotes "$plan")
            continue
        fi

        if echo "$line" | grep -qE '^[[:space:]]+summary:'; then
            summary=$(echo "$line" | sed 's/.*summary:[[:space:]]*//' | sed 's/[[:space:]]*$//')
            summary=$(strip_quotes "$summary")
            continue
        fi
    done < "$PIPELINE_YAML"

    # Save last cycle
    if [[ -n "$cycle" ]]; then
        rows+=("${cycle}|${started}|${status}|${evaluation}|${plan}|${summary}")
    fi

    echo "  Found ${#rows[@]} cycle(s)"

    if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would write ${PIPELINE_CSV} with ${#rows[@]} cycle(s)"
        return 0
    fi

    mkdir -p "$(dirname "$PIPELINE_CSV")"
    echo "$header" > "$PIPELINE_CSV"
    for row in "${rows[@]}"; do
        echo "$row" >> "$PIPELINE_CSV"
    done
    echo "  Wrote ${PIPELINE_CSV}"
}

# ============================================================================
# Main
# ============================================================================

echo "storyforge-migrate"
echo "Project: ${PROJECT_DIR}"

if [[ "$DRY_RUN" == true ]]; then
    echo "Mode: DRY RUN (use --execute to apply changes)"
else
    echo "Mode: EXECUTE"
fi
echo ""

# Step 1: Backup
create_backup

# Step 2: Scene metadata (YAML → CSV)
migrate_scene_metadata

# Step 3: Strip frontmatter from scene files
strip_frontmatter

# Step 4: Chapter map
migrate_chapter_map

# Step 5: Findings
migrate_findings

# Step 6: Revision plans
migrate_revision_plans

# Step 7: Pipeline
migrate_pipeline

echo ""
if [[ "$DRY_RUN" == true ]]; then
    echo "DRY RUN complete. Re-run with --execute to apply changes."
else
    echo "Migration complete."
fi

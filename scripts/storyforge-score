#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-score — Principled craft scoring for Storyforge projects
#
# Evaluates manuscript scenes against the craft engine's scoring rubrics,
# producing per-scene, per-act, and novel-level scores in CSV format.
#
# Three scoring modes:
#   (default)     Batch API, Opus — best value and judgment (~$12/100 scenes, few minutes)
#   --direct      Direct API, Sonnet — real-time results for interactive use
#   --direct --deep  Direct API, Opus — real-time Opus when you need results now
#
# Usage:
#   ./storyforge-score                        # All scenes, default two-pass
#   ./storyforge-score --quick                # Haiku screen only (fast)
#   ./storyforge-score --deep                 # Full deep evaluation
#   ./storyforge-score --scenes ID,ID         # Specific scenes only
#   ./storyforge-score --act 2                # Scenes in act 2 only
#   ./storyforge-score --interactive          # Enable interactive mode
#   ./storyforge-score --dry-run              # Show what would be scored
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# Python scoring module path
PYTHON_LIB="${SCRIPT_DIR}/lib/python"

# --- Default options ---
DRY_RUN=false
INTERACTIVE=false
SCORE_MODE="batch"     # batch | direct | direct-deep
DIRECT_MODE=false
FILTER_MODE="all"
FILTER_SCENES=""        # Comma-separated scene IDs
FILTER_ACT=""
FILTER_FROM_SEQ=""
PARALLEL=${STORYFORGE_SCORE_PARALLEL:-6}

# --- Argument parsing ---
usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Score manuscript scenes against 25 craft principles (scene craft,
prose craft, character craft, rules to break), plus act-level
framework scores and novel-level character/genre scores. Produces
diagnosis, improvement proposals, and an HTML report.

Modes:
  (default)         Batch API with Opus — submit all scenes, results in minutes (recommended)
  --direct          Direct API with Sonnet — real-time results for interactive use
  --direct --deep   Direct API with Opus — real-time Opus for immediate results

Scope:
  --scenes ID,ID    Score specific scenes only (comma-separated slug IDs)
  --act N           Score scenes in act/part N only
  --from-seq N      Score scenes from sequence number N onward
  --from-seq N-M    Score scenes in sequence range N through M

Options:
  --parallel N      Score N scenes concurrently (default: 6, env: STORYFORGE_SCORE_PARALLEL)
  --interactive, -i Enable interactive mode
  --dry-run         Show what would be scored without invoking Claude
  -h, --help        Show this help

Examples:
  $(basename "$0")                          # Batch Opus — all scenes (recommended)
  $(basename "$0") --direct --scenes my-scene  # Sonnet, one scene, real-time
  $(basename "$0") --direct --deep --act 2     # Opus, act 2, real-time
  $(basename "$0") --from-seq 10-20            # Batch Opus, scenes 10-20
  $(basename "$0") --dry-run                   # Preview cost estimate
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --interactive|-i)
            INTERACTIVE=true
            shift
            ;;
        --direct)
            DIRECT_MODE=true
            SCORE_MODE="direct"
            shift
            ;;
        --deep)
            SCORE_MODE="direct-deep"
            shift
            ;;
        --scenes)
            FILTER_MODE="scenes"
            FILTER_SCENES="${2:?ERROR: --scenes requires comma-separated scene IDs}"
            shift 2
            ;;
        --act)
            FILTER_MODE="act"
            FILTER_ACT="${2:?ERROR: --act requires an act number}"
            shift 2
            ;;
        --from-seq)
            FILTER_MODE="from_seq"
            FILTER_FROM_SEQ="${2:?ERROR: --from-seq requires a sequence number}"
            shift 2
            ;;
        --parallel)
            PARALLEL="${2:?ERROR: --parallel requires a number}"
            shift 2
            ;;
        -*)
            echo "ERROR: Unknown option: $1" >&2
            usage
            ;;
        *)
            echo "ERROR: Unexpected argument: $1" >&2
            usage
            ;;
    esac
done

# --- Detect project root ---
detect_project_root
log "Project root: ${PROJECT_DIR}"

# --- Project info ---
PROJECT_TITLE=$(read_yaml_field "project.title" 2>/dev/null || read_yaml_field "title" 2>/dev/null || echo "Unknown")

# --- Create scoring branch + draft PR ---
if [[ "$DRY_RUN" != true ]]; then
    create_branch "score" "$PROJECT_DIR"
    ensure_branch_pushed "$PROJECT_DIR"
fi

# --- Resolve plugin directory ---
PLUGIN_DIR=$(get_plugin_dir)
PROMPTS_DIR="${SCRIPT_DIR}/prompts/scoring"

# --- Select models ---
SONNET_MODEL=$(select_model "evaluation")
OPUS_MODEL="claude-opus-4-6"

case "$SCORE_MODE" in
    batch)       EVAL_MODEL="$OPUS_MODEL" ;;
    direct)      EVAL_MODEL="$SONNET_MODEL" ;;
    direct-deep) EVAL_MODEL="$OPUS_MODEL" ;;
esac

log "Mode: ${SCORE_MODE}, Model: ${EVAL_MODEL}"

# --- Initialize craft weights ---
PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring init-weights "$PROJECT_DIR" "$PLUGIN_DIR"
WEIGHTS_FILE="${PROJECT_DIR}/working/craft-weights.csv"

# ============================================================================
# Build scene list from metadata.csv
# ============================================================================

METADATA_CSV="${PROJECT_DIR}/reference/scenes.csv"
INTENT_CSV="${PROJECT_DIR}/reference/scene-intent.csv"
BRIEFS_CSV="${PROJECT_DIR}/reference/scene-briefs.csv"
HAS_BRIEFS=false
[[ -f "$BRIEFS_CSV" ]] && HAS_BRIEFS=true
SCENES_DIR="${PROJECT_DIR}/scenes"

build_scene_list "$METADATA_CSV"

# ============================================================================
# Filter scenes based on scope flags
# ============================================================================

case "$FILTER_MODE" in
    all)       apply_scene_filter "$METADATA_CSV" "all" ;;
    scenes)    apply_scene_filter "$METADATA_CSV" "scenes" "$FILTER_SCENES" ;;
    act)       apply_scene_filter "$METADATA_CSV" "act" "$FILTER_ACT" ;;
    from_seq)  apply_scene_filter "$METADATA_CSV" "from_seq" "$FILTER_FROM_SEQ" ;;
esac

# Filter to only scenes that have been drafted
SCENE_IDS=()
MISSING_SCENES=()
for id in "${FILTERED_IDS[@]}"; do
    if [[ -f "${SCENES_DIR}/${id}.md" ]]; then
        SCENE_IDS+=("$id")
    else
        MISSING_SCENES+=("$id")
    fi
done

if [[ ${#SCENE_IDS[@]} -eq 0 ]]; then
    log "ERROR: No drafted scene files found for the selected scope."
    if [[ ${#MISSING_SCENES[@]} -gt 0 ]]; then
        log "Missing scenes: ${MISSING_SCENES[*]}"
    fi
    exit 1
fi

if [[ ${#MISSING_SCENES[@]} -gt 0 ]]; then
    log "WARNING: ${#MISSING_SCENES[@]} scenes not yet drafted (skipping): ${MISSING_SCENES[*]}"
fi

SCENE_COUNT=${#SCENE_IDS[@]}
log "Scoring ${SCENE_COUNT} scenes in ${SCORE_MODE} mode"

# ============================================================================
# Determine cycle number
# ============================================================================

CYCLE=$(get_current_cycle)
if [[ "$CYCLE" == "0" ]]; then
    CYCLE=1
fi

# If no active cycle, find highest existing cycle-N and increment
if [[ "$CYCLE" -eq 1 && -d "${PROJECT_DIR}/working/scores" ]]; then
    highest=0
    for d in "${PROJECT_DIR}/working/scores"/cycle-*; do
        [[ -d "$d" ]] || continue
        n=$(basename "$d" | sed 's/^cycle-//')
        if [[ "$n" =~ ^[0-9]+$ ]] && (( n > highest )); then
            highest="$n"
        fi
    done
    if (( highest > 0 )); then
        CYCLE=$((highest + 1))
    fi
fi

CYCLE_DIR="${PROJECT_DIR}/working/scores/cycle-${CYCLE}"
mkdir -p "$CYCLE_DIR"
LOG_DIR="${PROJECT_DIR}/working/logs"
mkdir -p "$LOG_DIR"

log "Cycle: ${CYCLE} -> ${CYCLE_DIR}"

# ============================================================================
# Cost forecast
# ============================================================================

# Estimate average word count
AVG_WORDS=0
TOTAL_WC=0
WC_COUNT=0
while IFS= read -r wc; do
    [[ -z "$wc" || "$wc" == "0" ]] && continue
    TOTAL_WC=$((TOTAL_WC + wc))
    WC_COUNT=$((WC_COUNT + 1))
done < <(get_csv_column "$METADATA_CSV" "word_count")

if (( WC_COUNT > 0 )); then
    AVG_WORDS=$((TOTAL_WC / WC_COUNT))
fi

if (( AVG_WORDS == 0 )); then
    # Estimate from scene files
    for id in "${SCENE_IDS[@]}"; do
        sf="${SCENES_DIR}/${id}.md"
        if [[ -f "$sf" ]]; then
            wc_val=$(wc -w < "$sf" | tr -d ' ')
            TOTAL_WC=$((TOTAL_WC + wc_val))
            WC_COUNT=$((WC_COUNT + 1))
        fi
    done
    if (( WC_COUNT > 0 )); then
        AVG_WORDS=$((TOTAL_WC / WC_COUNT))
    else
        AVG_WORDS=3000
    fi
fi

# Cost estimate: 1 call per scene
ACT_INVOCATIONS=3
NOVEL_INVOCATIONS=1

SCENE_COST=$(estimate_cost "score" "$SCENE_COUNT" "$AVG_WORDS" "$EVAL_MODEL")
# Batch API is 50% off
if [[ "$SCORE_MODE" == "batch" ]]; then
    SCENE_COST=$(awk "BEGIN { printf \"%.2f\", $SCENE_COST * 0.5 }")
    log "Cost forecast: ~\$${SCENE_COST} (${SCENE_COUNT} Opus calls via Batch API, 50% off)"
else
    log "Cost forecast: ~\$${SCENE_COST} (${SCENE_COUNT} ${EVAL_MODEL} calls via Direct API)"
fi

if [[ "$DRY_RUN" == false ]]; then
    check_cost_threshold "$SCENE_COST" || { log "Cost threshold check declined. Aborting."; exit 1; }
fi

# --- Draft PR ---
if [[ "$DRY_RUN" != true ]]; then
    PR_BODY="## Principled Scoring

**Project:** ${PROJECT_TITLE}
**Mode:** ${SCORE_MODE}
**Scenes:** ${SCENE_COUNT}
**Estimated cost:** ~\$${SCENE_COST}

### Tasks
- [ ] Scene-level scoring (${SCENE_COUNT} scenes)
- [ ] Act-level scoring
- [ ] Novel-level scoring
- [ ] Diagnosis and proposals
- [ ] Improvement cycle
- [ ] Review"

    create_draft_pr "Score: ${PROJECT_TITLE} (${SCORE_MODE}, ${SCENE_COUNT} scenes)" "$PR_BODY" "$PROJECT_DIR" "scoring" 2>/dev/null || true
fi

# ============================================================================
# Helper: submit plugin insight as GitHub issue
# ============================================================================

submit_plugin_insight() {
    local principle="$1" lever="$2" change="$3" avg_improvement="$4"
    local project_title="$5" evidence="$6"

    local auto_issues
    auto_issues=$(read_yaml_field "auto_issues" 2>/dev/null || echo "true")
    [[ "${STORYFORGE_AUTO_ISSUES:-$auto_issues}" == "false" ]] && return 0
    has_gh 2>/dev/null || return 0

    local body="## Plugin Insight: ${principle}

**Source project:** ${project_title}
**Average improvement:** ${avg_improvement}

### Change
${change}

### Evidence
${evidence}"

    gh issue create \
        --repo benjaminsnorris/storyforge \
        --title "Plugin Insight: ${principle} — ${lever}" \
        --body "$body" \
        --label "plugin-insight" \
        2>/dev/null || log "WARNING: Failed to create plugin insight issue"
}

# ============================================================================
# Helper: invoke Claude and parse results (used by act/novel-level scoring)
# ============================================================================

invoke_and_parse() {
    local prompt="$1"
    local log_file="$2"
    local score_file="$3"
    local rationale_file="$4"
    local score_marker="${5:-SCORES}"
    local rationale_marker="${6:-RATIONALE}"
    local invoke_model="${7:-$SONNET_MODEL}"

    if [[ "$DRY_RUN" == true ]]; then
        log "[DRY RUN] Would invoke API (${#prompt} chars prompt)"
        return 0
    fi

    _SF_INVOCATION_START=$(date +%s)
    export _SF_INVOCATION_START

    # Use .json extension for direct API response
    local api_log="${log_file%.log}.json"

    if ! invoke_anthropic_api "$prompt" "$invoke_model" "$api_log" 4096; then
        log "WARNING: API call failed"
        log_api_usage "$api_log" "score" "$(basename "$score_file" .csv)" "$invoke_model"
        return 1
    fi

    log_api_usage "$api_log" "score" "$(basename "$score_file" .csv)" "$invoke_model"

    # Extract text and write to log file for parse_score_output compatibility
    local text_content
    text_content=$(extract_api_response "$api_log") || {
        log "WARNING: No text in API response"
        return 1
    }
    echo "$text_content" > "$log_file"

    PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring parse-output "$log_file" "$score_file" "$rationale_file" --score-marker "$score_marker" --rationale-marker "$rationale_marker"
    return $?
}

# ============================================================================
# Dry-run summary
# ============================================================================

if [[ "$DRY_RUN" == true ]]; then
    log "============================================"
    log "DRY RUN — Scoring Plan"
    log "============================================"
    log "Mode:     ${SCORE_MODE}"
    log "Scenes:   ${SCENE_COUNT}"
    log "Parallel: ${PARALLEL}"
    log "Cycle:    ${CYCLE}"
    log "Model:    ${EVAL_MODEL}"
    log "Estimate: ~\$${SCENE_COST}"
    log ""
    log "Scenes to score:"
    for id in "${SCENE_IDS[@]}"; do
        local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
        log "  - ${id} (${local_title:-untitled})"
    done
    log ""
    case "$SCORE_MODE" in
        batch)
            log "Batch mode: ${SCENE_COUNT} Opus calls via Batch API (50% off)"
            log "  Results typically arrive in 2-10 minutes"
            ;;
        direct)
            log "Direct mode: ${SCENE_COUNT} Sonnet calls, real-time, ${PARALLEL} parallel"
            ;;
        direct-deep)
            log "Direct+deep mode: ${SCENE_COUNT} Opus calls, real-time, ${PARALLEL} parallel"
            ;;
    esac
    log ""
    log "After scene scoring:"
    log "  - Act-level scoring (~${ACT_INVOCATIONS} invocations)"
    log "  - Novel-level character + genre scoring (1 invocation)"
    log "  - Novel-level narrative framework scoring (1 invocation)"
    log ""
    log "Output directory: ${CYCLE_DIR}"
    log "============================================"
    exit 0
fi

# ============================================================================
# Main scoring loop
# ============================================================================

log "============================================"
log "Starting scoring cycle ${CYCLE}"
log "============================================"

SCORED=0
FAILED=0

# ============================================================================
# Scene-level scoring — one Sonnet call per scene, all 25 principles
# ============================================================================

# Require API key for direct API scoring
if [[ "$DRY_RUN" != true && -z "${ANTHROPIC_API_KEY:-}" ]]; then
    log "ERROR: ANTHROPIC_API_KEY not set."
    log "  Scoring uses the Anthropic API directly (no claude -p overhead)."
    log "  Set it with: export ANTHROPIC_API_KEY=your-key"
    exit 1
fi

DIAGNOSTICS_CSV="${PLUGIN_DIR}/references/diagnostics.csv"
GUIDE_FILE="${PLUGIN_DIR}/references/principle-guide.md"
EVAL_TEMPLATE_FILE="${PROMPTS_DIR}/scene-evaluation.md"

if [[ ! -f "$DIAGNOSTICS_CSV" ]]; then
    log "ERROR: Diagnostics CSV not found: ${DIAGNOSTICS_CSV}"
    exit 1
fi
if [[ ! -f "$EVAL_TEMPLATE_FILE" ]]; then
    log "ERROR: Scene evaluation template not found: ${EVAL_TEMPLATE_FILE}"
    exit 1
fi

EVAL_TEMPLATE=$(cat "$EVAL_TEMPLATE_FILE")
EVALUATION_CRITERIA=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring build-evaluation-criteria "$DIAGNOSTICS_CSV" "$GUIDE_FILE")
# Exclude narrative principles from scene-level weighted text (scored at novel level)
WEIGHTED_TEXT=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring weighted-text "$WEIGHTS_FILE" --exclude-section narrative)

log "Evaluation model: ${EVAL_MODEL} (mode: ${SCORE_MODE})"
log ""

log "============================================"
log "Scene-Level Scoring"
log "============================================"

SCORE_START_TIME=$(date +%s)

# --- Helper: build prompt for a scene ---
build_scene_prompt() {
    local id="$1"
    local scene_file="${SCENES_DIR}/${id}.md"
    local scene_text=""
    [[ -f "$scene_file" ]] && scene_text=$(cat "$scene_file")
    local scene_title
    scene_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
    local scene_pov
    scene_pov=$(get_csv_field "$METADATA_CSV" "$id" "pov")
    local scene_function="" scene_emotional_arc=""
    [[ -f "$INTENT_CSV" ]] && scene_function=$(get_csv_field "$INTENT_CSV" "$id" "function")
    [[ -f "$INTENT_CSV" ]] && scene_emotional_arc=$(get_csv_field "$INTENT_CSV" "$id" "emotional_arc")

    local scene_text_numbered
    scene_text_numbered=$(echo "$scene_text" | awk '{ printf "%d: %s\n", NR, $0 }')

    local prompt="$EVAL_TEMPLATE"
    prompt="${prompt//\{\{SCENE_TITLE\}\}/${scene_title:-Unknown}}"
    prompt="${prompt//\{\{SCENE_POV\}\}/${scene_pov:-Unknown}}"
    prompt="${prompt//\{\{SCENE_FUNCTION\}\}/${scene_function:-Not specified}}"
    prompt="${prompt//\{\{SCENE_EMOTIONAL_ARC\}\}/${scene_emotional_arc:-Not specified}}"
    prompt="${prompt//\{\{EVALUATION_CRITERIA\}\}/$EVALUATION_CRITERIA}"
    prompt="${prompt//\{\{WEIGHTED_PRINCIPLES\}\}/$WEIGHTED_TEXT}"
    prompt="${prompt//\{\{SCENE_TEXT\}\}/$scene_text_numbered}"
    echo "$prompt"
}

# --- Helper: parse scene evaluation using Python ---
# Replaces the bash parse_scene_evaluation from scoring.sh.
# Handles both .txt files (batch mode) and .json files (direct mode).
parse_scene_evaluation() {
    local log_file="$1"
    local output_scores="$2"
    local output_rationale="$3"
    local scene_id="$4"

    if [[ ! -f "$log_file" ]]; then
        log "WARNING: Log file not found: $log_file"
        return 1
    fi

    # Extract text content based on file type
    local text_file
    if [[ "$log_file" == *.txt ]]; then
        text_file="$log_file"
    else
        # Extract text from API JSON or stream-json to a temp file
        text_file="${output_scores}.extracted.$$"
        local text_content
        text_content=$(extract_api_response "$log_file" 2>/dev/null) || true
        if [[ -z "$text_content" ]]; then
            text_content=$(extract_claude_response "$log_file") || {
                log "WARNING: No text content found in $log_file"
                return 1
            }
        fi
        echo "$text_content" > "$text_file"
    fi

    # Call Python to parse, pivot, and write score/rationale CSVs
    PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring parse-evaluation \
        "$text_file" "$output_scores" "$output_rationale" "$scene_id" \
        --diagnostics "$DIAGNOSTICS_CSV" 2>/dev/null
    local rc=$?

    # Clean up extracted temp file
    [[ "$log_file" != *.txt ]] && rm -f "$text_file"

    return $rc
}

case "$SCORE_MODE" in

# ================================================================
# BATCH MODE (default): Submit all scenes via Batch API
# ================================================================
batch)
    log ""
    log "Building batch request for ${SCENE_COUNT} scenes..."

    BATCH_FILE="${CYCLE_DIR}/.batch-requests.jsonl"
    rm -f "$BATCH_FILE"

    for id in "${SCENE_IDS[@]}"; do
        prompt=$(build_scene_prompt "$id")
        jq -nc --arg id "$id" --arg model "$EVAL_MODEL" --arg prompt "$prompt" '{
            custom_id: $id,
            params: {
                model: $model,
                max_tokens: 4096,
                messages: [{role: "user", content: $prompt}]
            }
        }' >> "$BATCH_FILE"
    done

    log "Submitting batch ($(wc -c < "$BATCH_FILE" | tr -d ' ') bytes)..."

    BATCH_ID=$(submit_batch "$BATCH_FILE") || { log "ERROR: Batch submission failed"; exit 1; }
    log "Batch submitted: ${BATCH_ID}"
    log "Polling for results..."
    poll_batch "$BATCH_ID"
    log "Results downloaded. Parsing..."
    download_batch_results "$BATCH_ID" "$CYCLE_DIR" "$LOG_DIR"

    # Process parsed results
    for id in "${SCENE_IDS[@]}"; do
        local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
        status_file="${CYCLE_DIR}/.status-${id}"
        text_file="${LOG_DIR}/${id}.txt"
        json_file="${LOG_DIR}/${id}.json"

        if [[ -f "$status_file" ]] && [[ "$(cat "$status_file")" == "ok" ]] && [[ -f "$text_file" ]]; then
            # Log usage from the JSON response
            log_api_usage "$json_file" "score" "$id" "$EVAL_MODEL"

            # Parse the text output into scores
            tmp_scores="${CYCLE_DIR}/.tmp-scores-${id}.csv"
            tmp_rationale="${CYCLE_DIR}/.tmp-rationale-${id}.csv"

            if parse_scene_evaluation "$text_file" "$tmp_scores" "$tmp_rationale" "$id"; then
                PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring merge "${CYCLE_DIR}/scene-scores.csv" "$tmp_scores"
                PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring merge "${CYCLE_DIR}/scene-rationale.csv" "$tmp_rationale"
                SCORED=$((SCORED + 1))
                log "  ${local_title:-$id} scored (${SCORED}/${SCENE_COUNT})"
            else
                FAILED=$((FAILED + 1))
                log "  WARNING: Failed to parse ${id}"
            fi
            rm -f "$tmp_scores" "$tmp_rationale"
        else
            FAILED=$((FAILED + 1))
            log "  WARNING: Failed ${id}"
        fi
        rm -f "$status_file"
    done

    # Clean up batch temp files
    rm -f "$BATCH_FILE"
    ;;

# ================================================================
# DIRECT MODE: Parallel real-time calls
# ================================================================
direct|direct-deep)
    log "Parallel workers: ${PARALLEL}"
    log ""

    batch_start=0
    while (( batch_start < SCENE_COUNT )); do
        batch_pids=()
        batch_ids=()
        batch_end=$(( batch_start + PARALLEL ))
        (( batch_end > SCENE_COUNT )) && batch_end=$SCENE_COUNT
        batch_start_time=$(date +%s)

        log ""
        log "Batch $((batch_start / PARALLEL + 1)): scenes $((batch_start + 1))-${batch_end} of ${SCENE_COUNT}"

        for (( i=batch_start; i<batch_end; i++ )); do
            id="${SCENE_IDS[$i]}"
            batch_ids+=("$id")
            local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
            log "  Scoring ${local_title:-$id} ($((i+1))/${SCENE_COUNT})..."

            (
                prompt=$(build_scene_prompt "$id")
                log_file="${LOG_DIR}/score-${id}.json"

                _SF_INVOCATION_START=$(date +%s)
                export _SF_INVOCATION_START

                if invoke_anthropic_api "$prompt" "$EVAL_MODEL" "$log_file" 4096; then
                    log_api_usage "$log_file" "score" "$id" "$EVAL_MODEL"

                    tmp_scores="${CYCLE_DIR}/.tmp-scores-${id}.csv"
                    tmp_rationale="${CYCLE_DIR}/.tmp-rationale-${id}.csv"

                    if parse_scene_evaluation "$log_file" "$tmp_scores" "$tmp_rationale" "$id"; then
                        log "    [${id}] scored"
                        echo "ok" > "${CYCLE_DIR}/.status-${id}"
                    else
                        log "    [${id}] FAILED (parse error)"
                        echo "fail" > "${CYCLE_DIR}/.status-${id}"
                    fi
                else
                    log "    [${id}] FAILED (API error)"
                    echo "fail" > "${CYCLE_DIR}/.status-${id}"
                fi
            ) &
            batch_pids+=($!)
            register_child_pid $!
        done

        for pid in "${batch_pids[@]}"; do
            wait "$pid" 2>/dev/null || true
            unregister_child_pid "$pid" 2>/dev/null || true
        done

        for id in "${batch_ids[@]}"; do
            local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
            status_file="${CYCLE_DIR}/.status-${id}"
            tmp_scores="${CYCLE_DIR}/.tmp-scores-${id}.csv"
            tmp_rationale="${CYCLE_DIR}/.tmp-rationale-${id}.csv"

            if [[ -f "$status_file" ]] && [[ "$(cat "$status_file")" == "ok" ]]; then
                PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring merge "${CYCLE_DIR}/scene-scores.csv" "$tmp_scores"
                PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring merge "${CYCLE_DIR}/scene-rationale.csv" "$tmp_rationale"
                SCORED=$((SCORED + 1))
                log "  ${local_title:-$id} scored (${SCORED}/${SCENE_COUNT})"
            else
                FAILED=$((FAILED + 1))
                log "  WARNING: Failed to score ${id}"
            fi
            rm -f "$tmp_scores" "$tmp_rationale" "$status_file"
        done

        batch_elapsed=$(( $(date +%s) - batch_start_time ))
        total_elapsed=$(( $(date +%s) - SCORE_START_TIME ))
        log "  Batch done in ${batch_elapsed}s (${SCORED}/${SCENE_COUNT} scored, ${total_elapsed}s elapsed)"

        batch_start=$batch_end
    done
    ;;

esac

log ""
log "Scene scoring complete: ${SCORED} scenes scored, ${FAILED} failures"
update_pr_task "Scene-level scoring (${SCENE_COUNT} scenes)" "$PROJECT_DIR" 2>/dev/null || true

# ============================================================================
# Brief fidelity scoring (elaboration pipeline only)
# ============================================================================

if [[ "$HAS_BRIEFS" == true ]]; then
    # Check if any scenes have brief data
    BRIEF_COUNT=$(tail -n +2 "$BRIEFS_CSV" 2>/dev/null | awk -F'|' '$2 != ""' | wc -l | tr -d ' ')
    if (( BRIEF_COUNT > 0 )); then
        log "Running brief fidelity scoring (${BRIEF_COUNT} scenes with briefs)..."

        FIDELITY_RESULTS="[]"
        for id in "${FILTERED_IDS[@]}"; do
            SCENE_FILE="${SCENES_DIR}/${id}.md"
            [[ ! -f "$SCENE_FILE" ]] && continue

            FIDELITY_PROMPT=$(PYTHONPATH="$PYTHON_LIB" python3 -c "
import sys; sys.path.insert(0, '${PYTHON_LIB}')
from storyforge.scoring import build_fidelity_prompt
print(build_fidelity_prompt('${id}', '${PROJECT_DIR}', '${PLUGIN_DIR}'))
" 2>/dev/null)

            [[ -z "$FIDELITY_PROMPT" ]] && continue

            FIDELITY_LOG="${LOG_DIR}/fidelity-${id}.log"

            if [[ "$SCORE_MODE" == "batch" ]]; then
                # Add to batch file for later submission
                FIDELITY_BATCH="${LOG_DIR}/fidelity-batch-$$.jsonl"
                json_prompt=$(jq -Rs '.' <<< "$FIDELITY_PROMPT")
                printf '{"custom_id":"fidelity-%s","params":{"model":"%s","max_tokens":2048,"messages":[{"role":"user","content":%s}]}}\n' \
                    "$id" "$SONNET_MODEL" "$json_prompt" >> "$FIDELITY_BATCH"
            else
                _SF_INVOCATION_START=$(date +%s); export _SF_INVOCATION_START
                invoke_anthropic_api "$FIDELITY_PROMPT" "$SONNET_MODEL" "$FIDELITY_LOG" 2048 || {
                    log "  WARNING: Fidelity scoring failed for ${id}"
                    continue
                }
                log_api_usage "$FIDELITY_LOG" "score-fidelity" "$id" "$SONNET_MODEL" 2>/dev/null || true
            fi
        done

        # Submit batch if in batch mode
        if [[ "$SCORE_MODE" == "batch" && -f "${FIDELITY_BATCH:-}" ]]; then
            FIDELITY_BATCH_COUNT=$(wc -l < "$FIDELITY_BATCH" | tr -d ' ')
            if (( FIDELITY_BATCH_COUNT > 0 )); then
                log "  Submitting fidelity batch (${FIDELITY_BATCH_COUNT} scenes)..."
                _SF_INVOCATION_START=$(date +%s); export _SF_INVOCATION_START
                begin_healing_zone "fidelity batch"
                FIDELITY_BATCH_ID=$(submit_batch "$FIDELITY_BATCH")
                poll_batch "$FIDELITY_BATCH_ID"
                mkdir -p "${LOG_DIR}/fidelity-output"
                download_batch_results "$FIDELITY_BATCH_ID" "${LOG_DIR}/fidelity-output" "$LOG_DIR"
                end_healing_zone
            fi
            rm -f "$FIDELITY_BATCH"
        fi

        # Process fidelity results
        PYTHONPATH="$PYTHON_LIB" python3 -c "
import sys, os, json; sys.path.insert(0, '${PYTHON_LIB}')
from storyforge.scoring import parse_fidelity_response, write_fidelity_csv, generate_fidelity_diagnosis

log_dir = '${LOG_DIR}'
cycle_dir = '${CYCLE_DIR}'
scene_ids = '''$(printf '%s\n' "${FILTERED_IDS[@]}")'''.strip().split('\n')

results = []
for sid in scene_ids:
    # Try batch output first, then direct log
    for path in [
        os.path.join(log_dir, f'fidelity-{sid}.txt'),
        os.path.join(log_dir, f'fidelity-{sid}.log'),
    ]:
        if not os.path.isfile(path):
            continue
        text = open(path, encoding='utf-8').read()
        # Parse API JSON if needed
        try:
            data = json.loads(text)
            text = ''.join(item.get('text', '') for item in data.get('content', []) if item.get('type') == 'text')
        except (json.JSONDecodeError, KeyError):
            pass
        if text:
            result = parse_fidelity_response(text, sid)
            if result['scores']:
                results.append(result)
            break

if results:
    write_fidelity_csv(results, cycle_dir)
    diagnosis = generate_fidelity_diagnosis(results)

    avg_overall = sum(r['overall'] for r in results) / len(results) if results else 0
    print(f'Fidelity: {len(results)} scenes scored, avg {avg_overall:.1f}/5')

    high_priority = [d for d in diagnosis if d['priority'] == 'high']
    if high_priority:
        print('High-priority fidelity gaps:')
        for d in high_priority:
            print(f'  {d[\"element\"]}: avg {d[\"avg_score\"]}/5 ({d[\"weak_count\"]}/{d[\"total_scenes\"]} weak)')
else:
    print('No fidelity results to process')
" 2>&1 | while IFS= read -r line; do log "  $line"; done

    else
        log "No scenes with brief data — skipping fidelity scoring"
    fi
else
    log "No briefs CSV — skipping fidelity scoring (legacy project)"
fi

# ============================================================================
# Act-level scoring
# ============================================================================

log "Running act-level scoring..."

ACT_TEMPLATE_FILE="${PROMPTS_DIR}/act-level.md"
if [[ -f "$ACT_TEMPLATE_FILE" ]]; then
    ACT_TEMPLATE=$(cat "$ACT_TEMPLATE_FILE")

    # Discover unique acts from metadata
    ACTS=()
    while IFS= read -r act_val; do
        [[ -z "$act_val" ]] && continue
        # Deduplicate
    dup=false
        for existing in "${ACTS[@]+"${ACTS[@]}"}"; do
            [[ "$existing" == "$act_val" ]] && dup=true && break
        done
        [[ "$dup" == false ]] && ACTS+=("$act_val")
    done < <(get_csv_column "$METADATA_CSV" "part")

    for act_label in "${ACTS[@]+"${ACTS[@]}"}"; do
        [[ -z "$act_label" ]] && continue

        # Collect scene texts for this act
        act_scenes_text=""
        act_scene_count=0
        act_id="act-${act_label}"

        for id in "${SCENE_IDS[@]}"; do
            scene_part=$(get_csv_field "$METADATA_CSV" "$id" "part")
            if [[ "$scene_part" == "$act_label" ]]; then
                scene_file="${SCENES_DIR}/${id}.md"
                if [[ -f "$scene_file" ]]; then
                    local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
                    act_scenes_text="${act_scenes_text}

--- Scene: ${local_title:-$id} (${id}) ---

$(cat "$scene_file")
"
                    act_scene_count=$((act_scene_count + 1))
                fi
            fi
        done

        if (( act_scene_count == 0 )); then
            log "  Skipping act ${act_label}: no scored scenes"
            continue
        fi

        # Build rubric content
        narrative_rubric=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring extract-rubric-section "Narrative Frameworks" "$PLUGIN_DIR")
        character_act_rubric=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring extract-rubric-section "Character Craft" "$PLUGIN_DIR")
        weighted_text=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring weighted-text "$WEIGHTS_FILE")

        # Substitute into template
    prompt="$ACT_TEMPLATE"
        prompt="${prompt//\{\{NARRATIVE_FRAMEWORKS_RUBRIC\}\}/$narrative_rubric}"
        prompt="${prompt//\{\{CHARACTER_CRAFT_ACT_RUBRIC\}\}/$character_act_rubric}"
        prompt="${prompt//\{\{ACT_LABEL\}\}/$act_label}"
        prompt="${prompt//\{\{SCENE_COUNT\}\}/$act_scene_count}"
        prompt="${prompt//\{\{ACT_SCENES_TEXT\}\}/$act_scenes_text}"
        prompt="${prompt//\{\{WEIGHTED_PRINCIPLES\}\}/$weighted_text}"
        prompt="${prompt//\{\{ACT_ID\}\}/$act_id}"

    log_file="${LOG_DIR}/score-${act_id}.log"
    tmp_scores="${CYCLE_DIR}/.tmp-act-scores-${act_label}.csv"
    tmp_rationale="${CYCLE_DIR}/.tmp-act-rationale-${act_label}.csv"

        log "  Scoring act ${act_label} (${act_scene_count} scenes)..."

        if invoke_and_parse "$prompt" "$log_file" "$tmp_scores" "$tmp_rationale"; then
            PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring merge "${CYCLE_DIR}/act-scores.csv" "$tmp_scores"
            PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring merge "${CYCLE_DIR}/act-rationale.csv" "$tmp_rationale"
            rm -f "$tmp_scores" "$tmp_rationale"
            log "  Act ${act_label} scored"
        else
            log "  WARNING: Failed to parse act-level scores for ${act_label}"
        fi
    done
else
    log "WARNING: Act-level template not found, skipping"
fi
update_pr_task "Act-level scoring" "$PROJECT_DIR" 2>/dev/null || true

# ============================================================================
# Novel-level scoring
# ============================================================================

log "Running novel-level scoring..."

NOVEL_TEMPLATE_FILE="${PROMPTS_DIR}/novel-level.md"
if [[ -f "$NOVEL_TEMPLATE_FILE" ]]; then
    NOVEL_TEMPLATE=$(cat "$NOVEL_TEMPLATE_FILE")

    # Build manuscript summary
    manuscript_summary="Scene count: ${SCENE_COUNT}"

    # Collect character list from intent.csv if available
    character_list=""
    if [[ -f "$INTENT_CSV" ]]; then
        character_list=$(get_csv_column "$INTENT_CSV" "characters" | tr ';' '\n' | sort -u | grep -v '^$' | head -20 || true)
        if [[ -n "$character_list" ]]; then
            manuscript_summary="${manuscript_summary}

Characters mentioned across scenes:
$(echo "$character_list" | sed 's/^/- /')"
        fi
    fi

    # Read character bible and story architecture if available
    character_bible=""
    story_architecture=""
    for ref in "reference/character-bible.md" "references/character-bible.md"; do
        if [[ -f "${PROJECT_DIR}/${ref}" ]]; then
            character_bible=$(cat "${PROJECT_DIR}/${ref}")
            break
        fi
    done
    for ref in "reference/story-architecture.md" "references/story-architecture.md"; do
        if [[ -f "${PROJECT_DIR}/${ref}" ]]; then
            story_architecture=$(cat "${PROJECT_DIR}/${ref}")
            break
        fi
    done

    # Build rubrics
    character_novel_rubric=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring extract-rubric-section "Character Craft" "$PLUGIN_DIR")
    genre_rubric=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring extract-rubric-section "Tropes and Genre" "$PLUGIN_DIR")
    weighted_text=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring weighted-text "$WEIGHTS_FILE")

    # Substitute into template
    prompt="$NOVEL_TEMPLATE"
    prompt="${prompt//\{\{CHARACTER_CRAFT_NOVEL_RUBRIC\}\}/$character_novel_rubric}"
    prompt="${prompt//\{\{GENRE_RUBRIC\}\}/$genre_rubric}"
    prompt="${prompt//\{\{MANUSCRIPT_SUMMARY\}\}/$manuscript_summary}"
    prompt="${prompt//\{\{CHARACTER_BIBLE\}\}/${character_bible:-No character bible found.}}"
    prompt="${prompt//\{\{STORY_ARCHITECTURE\}\}/${story_architecture:-No story architecture found.}}"
    prompt="${prompt//\{\{WEIGHTED_PRINCIPLES\}\}/$weighted_text}"

    log_file="${LOG_DIR}/score-novel-level.log"

    log "  Scoring novel-level character + genre..."

    if [[ "$DRY_RUN" == false ]]; then
        _SF_INVOCATION_START=$(date +%s)
        export _SF_INVOCATION_START

        api_log="${LOG_DIR}/score-novel-level.json"
        if invoke_anthropic_api "$prompt" "$SONNET_MODEL" "$api_log" 4096; then
            # Extract text for parse_score_output compatibility
            novel_text=$(extract_api_response "$api_log") || true
            echo "$novel_text" > "$log_file"
            log_api_usage "$api_log" "score" "novel-level" "$SONNET_MODEL"
        else
            log "WARNING: Novel-level API call failed"
            log_api_usage "$api_log" "score" "novel-level" "$SONNET_MODEL"
        fi

        # Parse character scores
    char_scores="${CYCLE_DIR}/.tmp-char-scores.csv"
    char_rationale="${CYCLE_DIR}/.tmp-char-rationale.csv"
        PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring parse-output "$log_file" "$char_scores" "$char_rationale" --score-marker CHARACTER_SCORES --rationale-marker CHARACTER_RATIONALE
        if [[ -f "$char_scores" ]]; then
            cp "$char_scores" "${CYCLE_DIR}/character-scores.csv"
            rm -f "$char_scores"
        fi
        if [[ -f "$char_rationale" ]]; then
            cp "$char_rationale" "${CYCLE_DIR}/character-rationale.csv"
            rm -f "$char_rationale"
        fi

        # Parse genre scores
    genre_scores="${CYCLE_DIR}/.tmp-genre-scores.csv"
    genre_rationale="${CYCLE_DIR}/.tmp-genre-rationale.csv"
        PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring parse-output "$log_file" "$genre_scores" "$genre_rationale" --score-marker GENRE_SCORES --rationale-marker GENRE_RATIONALE
        if [[ -f "$genre_scores" ]]; then
            cp "$genre_scores" "${CYCLE_DIR}/genre-scores.csv"
            rm -f "$genre_scores"
        fi
        if [[ -f "$genre_rationale" ]]; then
            cp "$genre_rationale" "${CYCLE_DIR}/genre-rationale.csv"
            rm -f "$genre_rationale"
        fi

        log "  Novel-level scoring complete"
    fi
else
    log "WARNING: Novel-level template not found, skipping"
fi
update_pr_task "Novel-level scoring" "$PROJECT_DIR" 2>/dev/null || true

# ============================================================================
# Novel-level narrative framework scoring
# ============================================================================

log ""
log "============================================"
log "Narrative Framework Scoring"
log "============================================"

NARRATIVE_TEMPLATE_FILE="${PROMPTS_DIR}/novel-narrative.md"
if [[ ! -f "$NARRATIVE_TEMPLATE_FILE" ]]; then
    log "WARNING: Narrative template not found at ${NARRATIVE_TEMPLATE_FILE}, skipping"
else
    NARRATIVE_TEMPLATE=$(cat "$NARRATIVE_TEMPLATE_FILE")

    # Build context: story architecture, scene index, chapter map
    NARR_STORY_ARCH=""
    for ref in "reference/story-architecture.md" "references/story-architecture.md"; do
        if [[ -f "${PROJECT_DIR}/${ref}" ]]; then
            NARR_STORY_ARCH=$(cat "${PROJECT_DIR}/${ref}")
            break
        fi
    done

    NARR_SCENE_INDEX=""
    if [[ -f "$METADATA_CSV" ]]; then
        NARR_SCENE_INDEX=$(awk -F'|' 'NR==1 || $NF != "cut" { print }' "$METADATA_CSV")
    fi

    NARR_CHAPTER_MAP=""
    NARR_CHAPTER_MAP_FILE="${PROJECT_DIR}/reference/chapter-map.csv"
    [[ -f "$NARR_CHAPTER_MAP_FILE" ]] && NARR_CHAPTER_MAP=$(cat "$NARR_CHAPTER_MAP_FILE")

    # Build weighted text for narrative principles only (no exclusion)
    NARR_WEIGHTED_TEXT=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring weighted-text "$WEIGHTS_FILE")

    # Substitute template
    NARRATIVE_PROMPT="$NARRATIVE_TEMPLATE"
    NARRATIVE_PROMPT="${NARRATIVE_PROMPT//\{\{PROJECT_TITLE\}\}/$PROJECT_TITLE}"
    NARRATIVE_PROMPT="${NARRATIVE_PROMPT//\{\{STORY_ARCHITECTURE\}\}/${NARR_STORY_ARCH:-No story architecture found.}}"
    NARRATIVE_PROMPT="${NARRATIVE_PROMPT//\{\{SCENE_INDEX\}\}/${NARR_SCENE_INDEX:-No scene metadata available.}}"
    NARRATIVE_PROMPT="${NARRATIVE_PROMPT//\{\{CHAPTER_MAP\}\}/${NARR_CHAPTER_MAP:-No chapter map available.}}"
    NARRATIVE_PROMPT="${NARRATIVE_PROMPT//\{\{WEIGHTED_PRINCIPLES\}\}/$NARR_WEIGHTED_TEXT}"

    NARRATIVE_LOG="${LOG_DIR}/score-narrative.log"
    NARRATIVE_MODEL=$(select_model "evaluation")

    log "  Scoring narrative frameworks (model: ${NARRATIVE_MODEL})..."

    if [[ "$DRY_RUN" == false ]]; then
        narr_scores="${CYCLE_DIR}/narrative-scores.csv"
        narr_rationale="${CYCLE_DIR}/narrative-rationale.csv"

        if invoke_and_parse "$NARRATIVE_PROMPT" "$NARRATIVE_LOG" "$narr_scores" "$narr_rationale" "SCORES" "RATIONALE" "$NARRATIVE_MODEL"; then
            if [[ -f "$narr_scores" ]]; then
                log "  Narrative scores saved to $(basename "$narr_scores")"
            else
                log "  WARNING: Failed to parse narrative scores"
            fi
        else
            log "  WARNING: Narrative scoring API call failed"
        fi
    fi
fi

# ============================================================================
# Update latest symlink
# ============================================================================

ln -sfn "cycle-${CYCLE}" "${PROJECT_DIR}/working/scores/latest"
log "Updated latest symlink -> cycle-${CYCLE}"

# ============================================================================
# Cost summary
# ============================================================================

echo ""
print_cost_summary "score"

# ============================================================================
# Improvement cycle: diagnosis and proposals
# ============================================================================

log "Running improvement cycle..."

# Determine previous cycle directory
PREV_DIR=""
if (( CYCLE > 1 )); then
    PREV_DIR="${PROJECT_DIR}/working/scores/cycle-$((CYCLE - 1))"
    if [[ ! -d "$PREV_DIR" ]]; then
        PREV_DIR=""
    fi
fi

# Generate diagnosis and proposals
PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring diagnose "$CYCLE_DIR" "${PREV_DIR:-"-"}" "$WEIGHTS_FILE"
PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring propose "$CYCLE_DIR" "$WEIGHTS_FILE"

PROPOSALS_FILE="${CYCLE_DIR}/proposals.csv"
DIAGNOSIS_FILE="${CYCLE_DIR}/diagnosis.csv"

if [[ -f "$PROPOSALS_FILE" ]]; then
    PROPOSAL_COUNT=$(awk -F'|' 'NR > 1 { count++ } END { print count+0 }' "$PROPOSALS_FILE")
    log "Generated ${PROPOSAL_COUNT} improvement proposals"

    if (( PROPOSAL_COUNT > 0 )); then
        # Approval step based on coaching level
        COACHING=$(get_coaching_level 2>/dev/null || echo "full")
        APPLIED=0

        case "$COACHING" in
            full)
                # Auto-approve all proposals
                log "Coaching level: full — auto-approving all proposals"
    tmp_proposals="${PROPOSALS_FILE}.tmp.$$"
                awk -F'|' -v OFS='|' '
                    NR == 1 { print; next }
                    { $7 = "approved"; print }
                ' "$PROPOSALS_FILE" > "$tmp_proposals" && mv "$tmp_proposals" "$PROPOSALS_FILE"
                ;;
            coach)
                # Interactive approval
                log "Coaching level: coach — review proposals below"
                while IFS='|' read -r pid principle lever target change rationale status; do
                    [[ "$pid" == "id" ]] && continue
                    [[ "$status" != "pending" ]] && continue
                    echo ""
                    echo "  Proposal ${pid}: ${principle}"
                    echo "    Lever: ${lever}, Target: ${target}"
                    echo "    Change: ${change}"
                    echo "    Rationale: ${rationale}"
                    read -r -p "  Approve? (y/n) " answer < /dev/tty 2>/dev/null || answer="n"
                    if [[ "$answer" == "y" || "$answer" == "Y" ]]; then
                        update_csv_field "$PROPOSALS_FILE" "$pid" "status" "approved"
                    else
                        update_csv_field "$PROPOSALS_FILE" "$pid" "status" "rejected"
                    fi
                done < "$PROPOSALS_FILE"
                ;;
            strict)
                # Report only — do not approve
                log "Coaching level: strict — diagnosis and proposals generated as report only"
                echo ""
                echo "=== Diagnosis Summary ==="
                if [[ -f "$DIAGNOSIS_FILE" ]]; then
                    awk -F'|' 'NR > 1 && ($6 == "high" || $6 == "medium") {
                        printf "  %s (%s): avg %.1f, priority %s\n", $1, $2, $3, $6
                    }' "$DIAGNOSIS_FILE"
                fi
                echo ""
                echo "=== Proposals (not applied in strict mode) ==="
                awk -F'|' 'NR > 1 {
                    printf "  %s: %s — %s (%s)\n", $1, $2, $5, $6
                }' "$PROPOSALS_FILE"
                echo ""
                ;;
        esac

        # Apply step for approved proposals
        if [[ "$COACHING" != "strict" ]]; then
            while IFS='|' read -r pid principle lever target change rationale status; do
                [[ "$pid" == "id" ]] && continue
                [[ "$status" != "approved" ]] && continue

                case "$lever" in
                    craft_weight)
                        # Extract new weight from change string "weight X → Y"
                        new_val=$(echo "$change" | sed -n 's/.*→ *\([0-9]*\).*/\1/p')
                        if [[ -n "$new_val" ]]; then
                            update_csv_field "$WEIGHTS_FILE" "$principle" "weight" "$new_val" "principle"
                            APPLIED=$((APPLIED + 1))
                            update_csv_field "$PROPOSALS_FILE" "$pid" "status" "applied"
                        fi
                        ;;
                    scene_intent)
                        if [[ -f "$INTENT_CSV" ]]; then
                            # Record as override — scene_intent changes need human/Claude writing
    overrides_file="${PROJECT_DIR}/working/overrides.csv"
                            if [[ ! -f "$overrides_file" ]]; then
                                echo "id|principle|directive|source" > "$overrides_file"
                            fi
                            echo "${target}|${principle}|${change}|${pid}" >> "$overrides_file"
                            APPLIED=$((APPLIED + 1))
                            update_csv_field "$PROPOSALS_FILE" "$pid" "status" "applied"
                        fi
                        ;;
                    voice_guide)
    overrides_file="${PROJECT_DIR}/working/overrides.csv"
                        if [[ ! -f "$overrides_file" ]]; then
                            echo "id|principle|directive|source" > "$overrides_file"
                        fi
                        echo "global|${principle}|${change}|${pid}" >> "$overrides_file"
                        APPLIED=$((APPLIED + 1))
                        update_csv_field "$PROPOSALS_FILE" "$pid" "status" "applied"
                        ;;
                    override)
    overrides_file="${PROJECT_DIR}/working/overrides.csv"
                        if [[ ! -f "$overrides_file" ]]; then
                            echo "id|principle|directive|source" > "$overrides_file"
                        fi
                        echo "${target}|${principle}|${change}|${pid}" >> "$overrides_file"
                        APPLIED=$((APPLIED + 1))
                        update_csv_field "$PROPOSALS_FILE" "$pid" "status" "applied"
                        ;;
                esac
            done < "$PROPOSALS_FILE"

            log "${APPLIED} proposals applied. Run storyforge write to rewrite with updated guidance."
        fi
    fi
else
    log "No proposals generated"
fi
update_pr_task "Diagnosis and proposals" "$PROJECT_DIR" 2>/dev/null || true
update_pr_task "Improvement cycle" "$PROJECT_DIR" 2>/dev/null || true

# Collect exemplars from high-scoring scenes
PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring collect-exemplars "$CYCLE_DIR" "$PROJECT_DIR" "$CYCLE"

# Check for validated patterns from tuning history
validated=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring check-validated-patterns "$PROJECT_DIR")
if [[ -n "$validated" ]]; then
    log "Validated tuning patterns found:"
    project_title=$(read_yaml_field "project.title" 2>/dev/null || read_yaml_field "title" 2>/dev/null || echo "Unknown")
    echo "$validated" | while IFS='|' read -r vp vl vi; do
        log "  ${vp} (${vl}): avg improvement ${vi}"
        # Build evidence from tuning ledger
        evidence=""
        if [[ -f "${PROJECT_DIR}/working/tuning.csv" ]]; then
            evidence=$(awk -F'|' -v p="$vp" -v l="$vl" '
                NR == 1 { next }
                $3 == p && $4 == l && $8 == "true" {
                    printf "- Cycle %s: %s (before: %s, after: %s)\n", $1, $5, $6, $7
                }
            ' "${PROJECT_DIR}/working/tuning.csv")
        fi
        # Submit plugin insight
        submit_plugin_insight "$vp" "$vl" "Validated pattern across 3+ cycles" "$vi" "$project_title" "$evidence"
    done
fi

# ============================================================================
# Git commit and push
# ============================================================================

# ============================================================================
# Generate report and PR comment
# ============================================================================

TOTAL_COST=$(awk -F'|' '
    NR==1 { next }
    $2 == "score" { sum += $9 }
    END { printf "%.2f", sum }
' "${PROJECT_DIR}/working/costs/ledger.csv" 2>/dev/null || echo "0.00")

PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring generate-report "$CYCLE_DIR" "$PROJECT_DIR" "$CYCLE" "$SCORE_MODE" "$SCENE_COUNT" "$TOTAL_COST"

# Post PR comment with scoring summary
if has_gh 2>/dev/null; then
    PR_COMMENT=$(PYTHONPATH="$PYTHON_LIB" python3 -m storyforge.scoring pr-comment "$CYCLE_DIR" "$PROJECT_DIR" "$CYCLE" "$SCORE_MODE" "$SCENE_COUNT" "$TOTAL_COST")
    if [[ -n "$PR_COMMENT" ]]; then
        # Find the PR for the current branch
        CURRENT_PR=$(gh pr view --json number -q '.number' 2>/dev/null || true)
        if [[ -n "$CURRENT_PR" ]]; then
            echo "$PR_COMMENT" | gh pr comment "$CURRENT_PR" --body-file - 2>/dev/null || log "WARNING: Failed to post PR comment"
            log "Posted scoring summary to PR #${CURRENT_PR}"
        fi
    fi
fi

update_pr_task "Review" "$PROJECT_DIR" 2>/dev/null || true

# Regenerate manuscript dashboard with updated score data
VISUALIZE_SCRIPT="${SCRIPT_DIR}/storyforge-visualize"
if [[ -x "$VISUALIZE_SCRIPT" ]]; then
    log "Regenerating manuscript dashboard..."
    "$VISUALIZE_SCRIPT" 2>/dev/null || log "WARNING: Dashboard generation failed"
fi

log "Committing scoring results..."

(
    cd "$PROJECT_DIR"
    git add "working/scores/" 2>/dev/null || true
    git add "working/craft-weights.csv" 2>/dev/null || true
    git add "working/costs/" 2>/dev/null || true
    git add "working/logs/" 2>/dev/null || true
    git add "working/tuning.csv" 2>/dev/null || true
    git add "working/overrides.csv" 2>/dev/null || true
    git add "working/exemplars.csv" 2>/dev/null || true
    git commit -m "Score: cycle ${CYCLE}, ${SCENE_COUNT} scenes (${SCORE_MODE} mode)" 2>/dev/null || true
    git push 2>/dev/null || true
)

log "============================================"
log "Scoring cycle ${CYCLE} complete"
log "Results: ${CYCLE_DIR}"
log "============================================"

#!/bin/bash
set -eo pipefail

# ============================================================================
# storyforge-score — Principled craft scoring for Storyforge projects
#
# Evaluates manuscript scenes against the craft engine's scoring rubrics,
# producing per-scene, per-act, and novel-level scores in CSV format.
#
# Three scoring modes, all diagnostic-based:
#   (default)   Haiku binary screen + Sonnet deep dive for deficit principles
#   --quick     Haiku binary screen only (no Sonnet deep dive)
#   --deep      Haiku binary screen + Sonnet deep dive for ALL principles
#
# Usage:
#   ./storyforge-score                        # All scenes, default two-pass
#   ./storyforge-score --quick                # Haiku screen only (fast)
#   ./storyforge-score --deep                 # Full deep evaluation
#   ./storyforge-score --scenes ID,ID         # Specific scenes only
#   ./storyforge-score --act 2                # Scenes in act 2 only
#   ./storyforge-score --interactive          # Enable interactive mode
#   ./storyforge-score --dry-run              # Show what would be scored
# ============================================================================

# --- Locate script directory and source libraries ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "ERROR: Cannot find lib/common.sh at ${LIB_DIR}" >&2
    exit 1
fi

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# --- Default options ---
DRY_RUN=false
INTERACTIVE=false
SCORE_MODE="default"   # default | quick | deep
FILTER_MODE="all"
FILTER_SCENES=""        # Comma-separated scene IDs
FILTER_ACT=""
FILTER_FROM_SEQ=""
PARALLEL=${STORYFORGE_SCORE_PARALLEL:-6}

# --- Argument parsing ---
usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Score manuscript scenes against 25 craft principles (scene craft,
prose craft, character craft, rules to break), plus act-level
framework scores and novel-level character/genre scores. Produces
diagnosis, improvement proposals, and an HTML report.

Modes:
  (default)         Haiku screen + Sonnet deep dive for deficit principles (recommended)
  --quick           Haiku screen only — no Sonnet deep dive (fast, cheap)
  --deep            Haiku screen + Sonnet deep dive for ALL principles (most thorough)

Scope:
  --scenes ID,ID    Score specific scenes only (comma-separated slug IDs)
  --act N           Score scenes in act/part N only
  --from-seq N      Score scenes from sequence number N onward
  --from-seq N-M    Score scenes in sequence range N through M

Options:
  --parallel N      Score N scenes concurrently (default: 6, env: STORYFORGE_SCORE_PARALLEL)
  --interactive, -i Enable interactive mode
  --dry-run         Show what would be scored without invoking Claude
  -h, --help        Show this help

Examples:
  $(basename "$0")                          # All scenes, default two-pass
  $(basename "$0") --quick                  # Haiku screen only (fast)
  $(basename "$0") --deep --scenes my-scene # Deep evaluation of one scene
  $(basename "$0") --quick --from-seq 32    # Quick screen from scene 32 on
  $(basename "$0") --act 3                  # Score part 3 only
  $(basename "$0") --dry-run               # Preview cost estimate
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --interactive|-i)
            INTERACTIVE=true
            shift
            ;;
        --quick)
            SCORE_MODE="quick"
            shift
            ;;
        --deep)
            SCORE_MODE="deep"
            shift
            ;;
        --scenes)
            FILTER_MODE="scenes"
            FILTER_SCENES="${2:?ERROR: --scenes requires comma-separated scene IDs}"
            shift 2
            ;;
        --act)
            FILTER_MODE="act"
            FILTER_ACT="${2:?ERROR: --act requires an act number}"
            shift 2
            ;;
        --from-seq)
            FILTER_MODE="from_seq"
            FILTER_FROM_SEQ="${2:?ERROR: --from-seq requires a sequence number}"
            shift 2
            ;;
        --parallel)
            PARALLEL="${2:?ERROR: --parallel requires a number}"
            shift 2
            ;;
        -*)
            echo "ERROR: Unknown option: $1" >&2
            usage
            ;;
        *)
            echo "ERROR: Unexpected argument: $1" >&2
            usage
            ;;
    esac
done

# --- Detect project root ---
detect_project_root
log "Project root: ${PROJECT_DIR}"

# --- Project info ---
PROJECT_TITLE=$(read_yaml_field "project.title" 2>/dev/null || read_yaml_field "title" 2>/dev/null || echo "Unknown")

# --- Create scoring branch + draft PR ---
if [[ "$DRY_RUN" != true ]]; then
    create_branch "score" "$PROJECT_DIR"
    ensure_branch_pushed "$PROJECT_DIR"
fi

# --- Resolve plugin directory ---
PLUGIN_DIR=$(get_plugin_dir)
PROMPTS_DIR="${SCRIPT_DIR}/prompts/scoring"

# --- Select models ---
# Haiku for Pass 1 (diagnostic screen), Sonnet for Pass 2 (deep dive) and act/novel scoring
HAIKU_MODEL=$(select_model "extraction")
SONNET_MODEL=$(select_model "evaluation")
log "Models: ${HAIKU_MODEL} (screen) + ${SONNET_MODEL} (deep dive)"

# --- Initialize craft weights ---
init_craft_weights "$PROJECT_DIR" "$PLUGIN_DIR"
WEIGHTS_FILE="${PROJECT_DIR}/working/craft-weights.csv"

# ============================================================================
# Build scene list from metadata.csv
# ============================================================================

METADATA_CSV="${PROJECT_DIR}/reference/scene-metadata.csv"
INTENT_CSV="${PROJECT_DIR}/reference/scene-intent.csv"
# Fallback to old locations
[[ ! -f "$METADATA_CSV" ]] && METADATA_CSV="${PROJECT_DIR}/scenes/metadata.csv"
[[ ! -f "$INTENT_CSV" ]] && INTENT_CSV="${PROJECT_DIR}/scenes/intent.csv"
SCENES_DIR="${PROJECT_DIR}/scenes"

build_scene_list "$METADATA_CSV"

# ============================================================================
# Filter scenes based on scope flags
# ============================================================================

case "$FILTER_MODE" in
    all)       apply_scene_filter "$METADATA_CSV" "all" ;;
    scenes)    apply_scene_filter "$METADATA_CSV" "scenes" "$FILTER_SCENES" ;;
    act)       apply_scene_filter "$METADATA_CSV" "act" "$FILTER_ACT" ;;
    from_seq)  apply_scene_filter "$METADATA_CSV" "from_seq" "$FILTER_FROM_SEQ" ;;
esac

# Filter to only scenes that have been drafted
SCENE_IDS=()
MISSING_SCENES=()
for id in "${FILTERED_IDS[@]}"; do
    if [[ -f "${SCENES_DIR}/${id}.md" ]]; then
        SCENE_IDS+=("$id")
    else
        MISSING_SCENES+=("$id")
    fi
done

if [[ ${#SCENE_IDS[@]} -eq 0 ]]; then
    log "ERROR: No drafted scene files found for the selected scope."
    if [[ ${#MISSING_SCENES[@]} -gt 0 ]]; then
        log "Missing scenes: ${MISSING_SCENES[*]}"
    fi
    exit 1
fi

if [[ ${#MISSING_SCENES[@]} -gt 0 ]]; then
    log "WARNING: ${#MISSING_SCENES[@]} scenes not yet drafted (skipping): ${MISSING_SCENES[*]}"
fi

SCENE_COUNT=${#SCENE_IDS[@]}
log "Scoring ${SCENE_COUNT} scenes in ${SCORE_MODE} mode"

# ============================================================================
# Determine cycle number
# ============================================================================

PIPELINE_YAML="${PROJECT_DIR}/working/pipeline.yaml"
CYCLE=1

# Check pipeline.yaml for active cycle
if [[ -f "$PIPELINE_YAML" ]]; then
    active_cycle=$(grep -E '^\s*cycle:' "$PIPELINE_YAML" 2>/dev/null \
        | head -1 \
        | sed 's/^[[:space:]]*cycle:[[:space:]]*//' \
        | sed 's/[[:space:]]*$//' || true)
    if [[ -n "$active_cycle" && "$active_cycle" =~ ^[0-9]+$ ]]; then
        CYCLE="$active_cycle"
    fi
fi

# If no active cycle, find highest existing cycle-N and increment
if [[ "$CYCLE" -eq 1 && -d "${PROJECT_DIR}/working/scores" ]]; then
    highest=0
    for d in "${PROJECT_DIR}/working/scores"/cycle-*; do
        [[ -d "$d" ]] || continue
        n=$(basename "$d" | sed 's/^cycle-//')
        if [[ "$n" =~ ^[0-9]+$ ]] && (( n > highest )); then
            highest="$n"
        fi
    done
    if (( highest > 0 )); then
        CYCLE=$((highest + 1))
    fi
fi

CYCLE_DIR="${PROJECT_DIR}/working/scores/cycle-${CYCLE}"
mkdir -p "$CYCLE_DIR"
LOG_DIR="${PROJECT_DIR}/working/logs"
mkdir -p "$LOG_DIR"

log "Cycle: ${CYCLE} -> ${CYCLE_DIR}"

# ============================================================================
# Cost forecast
# ============================================================================

# Estimate average word count
AVG_WORDS=0
TOTAL_WC=0
WC_COUNT=0
while IFS= read -r wc; do
    [[ -z "$wc" || "$wc" == "0" ]] && continue
    TOTAL_WC=$((TOTAL_WC + wc))
    WC_COUNT=$((WC_COUNT + 1))
done < <(get_csv_column "$METADATA_CSV" "word_count")

if (( WC_COUNT > 0 )); then
    AVG_WORDS=$((TOTAL_WC / WC_COUNT))
fi

if (( AVG_WORDS == 0 )); then
    # Estimate from scene files
    for id in "${SCENE_IDS[@]}"; do
        sf="${SCENES_DIR}/${id}.md"
        if [[ -f "$sf" ]]; then
            wc_val=$(wc -w < "$sf" | tr -d ' ')
            TOTAL_WC=$((TOTAL_WC + wc_val))
            WC_COUNT=$((WC_COUNT + 1))
        fi
    done
    if (( WC_COUNT > 0 )); then
        AVG_WORDS=$((TOTAL_WC / WC_COUNT))
    else
        AVG_WORDS=3000
    fi
fi

# Cost estimate depends on mode
ACT_INVOCATIONS=3   # Rough estimate for act-level
NOVEL_INVOCATIONS=1

case "$SCORE_MODE" in
    quick)
        # Haiku only, no Sonnet deep dive
        PASS2_ESTIMATE=0
        ;;
    default)
        # Haiku + Sonnet for deficit principles (~40% of scene-principle pairs)
        PASS2_ESTIMATE=$(( SCENE_COUNT * 2 ))
        ;;
    deep)
        # Haiku + Sonnet for ALL principles
        PASS2_ESTIMATE=$(( SCENE_COUNT * 25 ))
        ;;
esac

# Pass 1: 4 Haiku calls per scene (one per section: scene_craft, prose_craft, character_craft, rules)
HAIKU_CALLS=$(( SCENE_COUNT * 4 ))
HAIKU_COST=$(estimate_cost "extraction" "$HAIKU_CALLS" "$AVG_WORDS" "$HAIKU_MODEL")
if (( PASS2_ESTIMATE > 0 )); then
    SONNET_COST=$(estimate_cost "score" "$PASS2_ESTIMATE" "$(( AVG_WORDS / 2 ))" "$SONNET_MODEL")
else
    SONNET_COST="0.00"
fi
SCENE_COST=$(awk "BEGIN { printf \"%.2f\", $HAIKU_COST + $SONNET_COST }")

case "$SCORE_MODE" in
    quick)
        log "Cost forecast: ~\$${SCENE_COST} (${HAIKU_CALLS} Haiku calls, no Sonnet)"
        ;;
    default)
        log "Cost forecast: ~\$${SCENE_COST} (Pass 1: ${HAIKU_CALLS} Haiku, Pass 2: ~${PASS2_ESTIMATE} Sonnet)"
        ;;
    deep)
        log "Cost forecast: ~\$${SCENE_COST} (Pass 1: ${HAIKU_CALLS} Haiku, Pass 2: ${PASS2_ESTIMATE} Sonnet)"
        ;;
esac
log "  Haiku model: ${HAIKU_MODEL}"
log "  Sonnet model: ${SONNET_MODEL}"

if [[ "$DRY_RUN" == false ]]; then
    check_cost_threshold "$SCENE_COST" || { log "Cost threshold check declined. Aborting."; exit 1; }
fi

# --- Draft PR ---
if [[ "$DRY_RUN" != true ]]; then
    PR_BODY="## Principled Scoring

**Project:** ${PROJECT_TITLE}
**Mode:** ${SCORE_MODE}
**Scenes:** ${SCENE_COUNT}
**Estimated cost:** ~\$${SCENE_COST}

### Tasks
- [ ] Scene-level scoring (${SCENE_COUNT} scenes)
- [ ] Act-level scoring
- [ ] Novel-level scoring
- [ ] Diagnosis and proposals
- [ ] Improvement cycle
- [ ] Review"

    create_draft_pr "Score: ${PROJECT_TITLE} (${SCORE_MODE}, ${SCENE_COUNT} scenes)" "$PR_BODY" "$PROJECT_DIR" "scoring" 2>/dev/null || true
fi

# ============================================================================
# Helper: invoke Claude and parse results (used by act/novel-level scoring)
# ============================================================================

invoke_and_parse() {
    local prompt="$1"
    local log_file="$2"
    local score_file="$3"
    local rationale_file="$4"
    local score_marker="${5:-SCORES}"
    local rationale_marker="${6:-RATIONALE}"
    local invoke_model="${7:-$SONNET_MODEL}"

    if [[ "$DRY_RUN" == true ]]; then
        log "[DRY RUN] Would invoke Claude (${#prompt} chars prompt)"
        return 0
    fi

    _SF_INVOCATION_START=$(date +%s)
    export _SF_INVOCATION_START

    begin_healing_zone "scoring invocation"

    claude -p "$prompt" \
        --model "$invoke_model" \
        --dangerously-skip-permissions \
        --output-format stream-json \
        --verbose \
        > "$log_file" 2>&1 || true

    end_healing_zone

    parse_score_output "$log_file" "$score_file" "$rationale_file" "$score_marker" "$rationale_marker"
    local parse_rc=$?

    log_usage "$log_file" "score" "$(basename "$score_file" .csv)" "$invoke_model"

    return $parse_rc
}

# ============================================================================
# Dry-run summary
# ============================================================================

if [[ "$DRY_RUN" == true ]]; then
    log "============================================"
    log "DRY RUN — Scoring Plan"
    log "============================================"
    log "Mode:     ${SCORE_MODE}"
    log "Scenes:   ${SCENE_COUNT}"
    log "Parallel: ${PARALLEL}"
    log "Cycle:    ${CYCLE}"
    log "Models:   ${HAIKU_MODEL} (Pass 1) + ${SONNET_MODEL} (Pass 2)"
    log "Estimate: ~\$${SCENE_COST}"
    log ""
    log "Scenes to score:"
    for id in "${SCENE_IDS[@]}"; do
        local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
        log "  - ${id} (${local_title:-untitled})"
    done
    log ""
    case "$SCORE_MODE" in
        quick)
            log "Quick mode: Haiku binary screen only"
            log "  Pass 1: ${HAIKU_CALLS} Haiku calls (${SCENE_COUNT} scenes x 4 groups)"
            log "  Pass 2: none"
            ;;
        default)
            log "Default mode: Haiku screen + Sonnet deep dive for deficit principles"
            log "  Pass 1: ${HAIKU_CALLS} Haiku calls (${SCENE_COUNT} scenes x 4 groups)"
            log "  Pass 2: ~${PASS2_ESTIMATE} Sonnet calls (estimated)"
            ;;
        deep)
            log "Deep mode: Haiku screen + Sonnet deep dive for ALL principles"
            log "  Pass 1: ${HAIKU_CALLS} Haiku calls (${SCENE_COUNT} scenes x 4 groups)"
            log "  Pass 2: ${PASS2_ESTIMATE} Sonnet calls"
            ;;
    esac
    log ""
    log "After scene scoring:"
    log "  - Act-level scoring (~${ACT_INVOCATIONS} invocations)"
    log "  - Novel-level scoring (1 invocation)"
    log ""
    log "Output directory: ${CYCLE_DIR}"
    log "============================================"
    exit 0
fi

# ============================================================================
# Main scoring loop
# ============================================================================

log "============================================"
log "Starting scoring cycle ${CYCLE}"
log "============================================"

SCORED=0
FAILED=0

# Determine deep-dive threshold based on mode
case "$SCORE_MODE" in
    quick)   DEEP_DIVE_THRESHOLD=0 ;;   # No deep dive
    default) DEEP_DIVE_THRESHOLD=3 ;;   # Deep dive for scores ≤ 3
    deep)    DEEP_DIVE_THRESHOLD=5 ;;   # Deep dive for ALL principles
esac

# ============================================================================
# Diagnostic scoring — all modes use this architecture
# ============================================================================

DIAGNOSTICS_CSV="${PLUGIN_DIR}/references/diagnostics.csv"
GUIDE_FILE="${PLUGIN_DIR}/references/principle-guide.md"
HAIKU_TEMPLATE_FILE="${PROMPTS_DIR}/haiku-diagnostics.md"
DEEP_TEMPLATE_FILE="${PROMPTS_DIR}/sonnet-deep-dive.md"

if [[ ! -f "$DIAGNOSTICS_CSV" ]]; then
    log "ERROR: Diagnostics CSV not found: ${DIAGNOSTICS_CSV}"
    exit 1
fi
if [[ ! -f "$HAIKU_TEMPLATE_FILE" ]]; then
    log "ERROR: Haiku diagnostics template not found: ${HAIKU_TEMPLATE_FILE}"
    exit 1
fi

HAIKU_TEMPLATE=$(cat "$HAIKU_TEMPLATE_FILE")

# Build per-section marker texts for grouped Haiku calls
DIAG_SECTIONS=()
while IFS= read -r sect; do
    DIAG_SECTIONS+=("$sect")
done < <(list_diagnostic_sections "$DIAGNOSTICS_CSV")
DIAG_SECTION_COUNT=${#DIAG_SECTIONS[@]}

# Pre-build marker text for each section
for sect in "${DIAG_SECTIONS[@]}"; do
    sect_markers=$(build_diagnostic_markers "$DIAGNOSTICS_CSV" "$sect")
    sect_count=$(count_diagnostic_markers "$DIAGNOSTICS_CSV" "$sect")
    # Store in temp files (bash 3 compat — no associative arrays)
    echo "$sect_markers" > "${CYCLE_DIR}/.markers-${sect}.txt"
    log "  Section ${sect}: ${sect_count} markers"
done

log "Parallel workers: ${PARALLEL}"
log "Deep-dive threshold: ${DEEP_DIVE_THRESHOLD} (mode: ${SCORE_MODE})"
log ""

# ============================================================================
# Pass 1: Haiku diagnostic screening
# ============================================================================
log "============================================"
log "Pass 1: Haiku Diagnostic Screening"
log "============================================"

SCORE_START_TIME=$(date +%s)
DIAG_DIR="${CYCLE_DIR}/diagnostics"
mkdir -p "$DIAG_DIR"

batch_start=0
while (( batch_start < SCENE_COUNT )); do
    batch_pids=()
    batch_ids=()
    batch_end=$(( batch_start + PARALLEL ))
    (( batch_end > SCENE_COUNT )) && batch_end=$SCENE_COUNT
    batch_start_time=$(date +%s)

    log ""
    log "Batch $((batch_start / PARALLEL + 1)): scenes $((batch_start + 1))-${batch_end} of ${SCENE_COUNT}"

    for (( i=batch_start; i<batch_end; i++ )); do
        id="${SCENE_IDS[$i]}"
        batch_ids+=("$id")
        local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
        log "  Launching diagnostic screen for ${local_title:-$id} ($((i+1))/${SCENE_COUNT})..."

        (
            # Worker subshell — Haiku diagnostic screen for one scene
            # Runs one Haiku call per section, merges results
            scene_file="${SCENES_DIR}/${id}.md"
            scene_text=""
            [[ -f "$scene_file" ]] && scene_text=$(cat "$scene_file")
            scene_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
            scene_pov=$(get_csv_field "$METADATA_CSV" "$id" "pov")

            group_num=0
            group_failed=0
            combined_diag="${DIAG_DIR}/.diag-${id}.csv"
            echo "marker_id|answer|evidence" > "$combined_diag"

            for sect in "${DIAG_SECTIONS[@]}"; do
                group_num=$((group_num + 1))
                markers_file="${CYCLE_DIR}/.markers-${sect}.txt"
                [[ -f "$markers_file" ]] || continue
                sect_markers=$(cat "$markers_file")

                log "    [${id}] Group ${group_num}/${DIAG_SECTION_COUNT}: ${sect}..."

                prompt="$HAIKU_TEMPLATE"
                prompt="${prompt//\{\{SCENE_TITLE\}\}/${scene_title:-Unknown}}"
                prompt="${prompt//\{\{SCENE_POV\}\}/${scene_pov:-Unknown}}"
                prompt="${prompt//\{\{DIAGNOSTIC_MARKERS\}\}/$sect_markers}"
                prompt="${prompt//\{\{SCENE_TEXT\}\}/$scene_text}"

                log_file="${LOG_DIR}/score-diag-${id}-${sect}.log"

                _SF_INVOCATION_START=$(date +%s)
                export _SF_INVOCATION_START

                begin_healing_zone "diagnostic screen ${id}/${sect}"

                claude -p "$prompt" \
                    --model "$HAIKU_MODEL" \
                    --dangerously-skip-permissions \
                    --output-format stream-json \
                    --verbose \
                    > "$log_file" 2>&1 || true

                end_healing_zone

                log_usage "$log_file" "score-diag" "${id}/${sect}" "$HAIKU_MODEL"

                # Parse this section's results into a temp file
                sect_diag="${DIAG_DIR}/.diag-${id}-${sect}.csv"
                if parse_diagnostic_output "$log_file" "$DIAG_DIR" "${id}-${sect}"; then
                    # Append data rows (skip header) to combined file
                    tail -n +2 "$sect_diag" >> "$combined_diag"
                    rm -f "$sect_diag"
                    log "    [${id}] Group ${group_num}/${DIAG_SECTION_COUNT}: ${sect} done"
                else
                    group_failed=$((group_failed + 1))
                    log "    [${id}] Group ${group_num}/${DIAG_SECTION_COUNT}: ${sect} FAILED"
                fi
            done

            if (( group_failed == 0 )); then
                echo "ok" > "${DIAG_DIR}/.status-${id}"
            elif (( group_failed < DIAG_SECTION_COUNT )); then
                # Partial success — still usable
                echo "ok" > "${DIAG_DIR}/.status-${id}"
                log "    [${id}] ${group_failed}/${DIAG_SECTION_COUNT} groups failed (partial results)"
            else
                echo "fail" > "${DIAG_DIR}/.status-${id}"
            fi
        ) &
        batch_pids+=($!)
        register_child_pid $!
    done

    # Wait for batch
    for pid in "${batch_pids[@]}"; do
        wait "$pid" 2>/dev/null || true
        unregister_child_pid "$pid" 2>/dev/null || true
    done

    # Aggregate diagnostic scores for this batch
    for id in "${batch_ids[@]}"; do
        local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
        status_file="${DIAG_DIR}/.status-${id}"
        diag_file="${DIAG_DIR}/.diag-${id}.csv"

        if [[ -f "$status_file" ]] && [[ "$(cat "$status_file")" == "ok" ]] && [[ -f "$diag_file" ]]; then
            tmp_scores="${DIAG_DIR}/.tmp-scores-${id}.csv"
            tmp_rationale="${DIAG_DIR}/.tmp-rationale-${id}.csv"

            if aggregate_diagnostic_scores "$diag_file" "$DIAGNOSTICS_CSV" "$tmp_scores" "$tmp_rationale" "$id"; then
                merge_score_files "${CYCLE_DIR}/scene-scores.csv" "$tmp_scores"
                merge_score_files "${CYCLE_DIR}/scene-rationale.csv" "$tmp_rationale"
                rm -f "$tmp_scores" "$tmp_rationale"
                SCORED=$((SCORED + 1))
                log "  Pass 1: ${local_title:-$id} scored (${SCORED}/${SCENE_COUNT})"
            else
                FAILED=$((FAILED + 1))
                log "  WARNING: Failed to aggregate diagnostics for ${id}"
            fi
        else
            FAILED=$((FAILED + 1))
            log "  WARNING: Failed diagnostic screen for ${id}"
        fi
        rm -f "$status_file"
    done

        batch_elapsed=$(( $(date +%s) - batch_start_time ))
        total_elapsed=$(( $(date +%s) - SCORE_START_TIME ))
        log "  Batch done in ${batch_elapsed}s (${SCORED}/${SCENE_COUNT} scored, ${total_elapsed}s elapsed)"

        batch_start=$batch_end
    done

log ""
log "Pass 1 complete: ${SCORED} scenes screened, ${FAILED} failures"

# ============================================================================
# Pass 2: Sonnet deep dive (skipped in quick mode)
# ============================================================================

if (( DEEP_DIVE_THRESHOLD > 0 )) && [[ -f "$DEEP_TEMPLATE_FILE" ]]; then
    DEEP_TEMPLATE=$(cat "$DEEP_TEMPLATE_FILE")
    weighted_text=$(build_weighted_text "$WEIGHTS_FILE")

    log ""
    log "============================================"
    log "Pass 2: Sonnet Deep Dive (threshold: ≤${DEEP_DIVE_THRESHOLD})"
    log "============================================"

    PASS2_START=$(date +%s)
    DEEP_COUNT=0
    DEEP_FAILED=0

    # Collect all scene-principle pairs needing deep dive
    DEEP_TARGETS=()
    for id in "${SCENE_IDS[@]}"; do
        diag_file="${DIAG_DIR}/.diag-${id}.csv"
        [[ -f "$diag_file" ]] || continue

        targets=$(identify_deep_dive_targets "$diag_file" "$DIAGNOSTICS_CSV" "$DEEP_DIVE_THRESHOLD")
        [[ -z "$targets" ]] && continue

        while IFS='|' read -r principle score deficit_markers; do
            DEEP_TARGETS+=("${id}|${principle}|${score}|${deficit_markers}")
        done <<< "$targets"
    done

    DEEP_TOTAL=${#DEEP_TARGETS[@]}
    log "Identified ${DEEP_TOTAL} scene-principle pairs for deep evaluation"

    if (( DEEP_TOTAL > 0 )); then
        batch_start=0
        while (( batch_start < DEEP_TOTAL )); do
            batch_pids=()
            batch_keys=()
            batch_end=$(( batch_start + PARALLEL ))
            (( batch_end > DEEP_TOTAL )) && batch_end=$DEEP_TOTAL

            for (( i=batch_start; i<batch_end; i++ )); do
                IFS='|' read -r dd_id dd_principle dd_score dd_markers <<< "${DEEP_TARGETS[$i]}"
                batch_keys+=("${dd_id}|${dd_principle}")
                log "  Launching deep dive: ${dd_id} / ${dd_principle} (score: ${dd_score})..."

                (
                    scene_file="${SCENES_DIR}/${dd_id}.md"
                    scene_text=""
                    [[ -f "$scene_file" ]] && scene_text=$(cat "$scene_file")
                    scene_title=$(get_csv_field "$METADATA_CSV" "$dd_id" "title")
                    scene_pov=$(get_csv_field "$METADATA_CSV" "$dd_id" "pov")
                    scene_function=""
                    scene_emotional_arc=""
                    [[ -f "$INTENT_CSV" ]] && scene_function=$(get_csv_field "$INTENT_CSV" "$dd_id" "function")
                    [[ -f "$INTENT_CSV" ]] && scene_emotional_arc=$(get_csv_field "$INTENT_CSV" "$dd_id" "emotional_arc")

                    principle_guide=$(build_principle_guide "$dd_principle" "$GUIDE_FILE")

                    # Build diagnostic results text from deficit markers
                    diag_results=""
                    IFS=';' read -ra marker_arr <<< "$dd_markers"
                    diag_file="${DIAG_DIR}/.diag-${dd_id}.csv"
                    for marker in "${marker_arr[@]}"; do
                        if [[ -f "$diag_file" ]]; then
                            marker_line=$(awk -F'|' -v m="$marker" '$1 == m { print }' "$diag_file")
                            if [[ -n "$marker_line" ]]; then
                                diag_results="${diag_results}
- **${marker}**: $(echo "$marker_line" | cut -d'|' -f3)"
                            fi
                        fi
                    done

                    prompt="$DEEP_TEMPLATE"
                    prompt="${prompt//\{\{SCENE_TITLE\}\}/${scene_title:-Unknown}}"
                    prompt="${prompt//\{\{SCENE_POV\}\}/${scene_pov:-Unknown}}"
                    prompt="${prompt//\{\{SCENE_FUNCTION\}\}/${scene_function:-Not specified}}"
                    prompt="${prompt//\{\{SCENE_EMOTIONAL_ARC\}\}/${scene_emotional_arc:-Not specified}}"
                    prompt="${prompt//\{\{SCENE_ID\}\}/$dd_id}"
                    prompt="${prompt//\{\{PRINCIPLE_NAME\}\}/$dd_principle}"
                    prompt="${prompt//\{\{PRINCIPLE_GUIDE\}\}/$principle_guide}"
                    prompt="${prompt//\{\{DIAGNOSTIC_RESULTS\}\}/$diag_results}"
                    prompt="${prompt//\{\{WEIGHTED_PRINCIPLES\}\}/$weighted_text}"
                    prompt="${prompt//\{\{SCENE_TEXT\}\}/$scene_text}"

                    deep_log="${LOG_DIR}/score-deep-${dd_id}-${dd_principle}.log"

                    _SF_INVOCATION_START=$(date +%s)
                    export _SF_INVOCATION_START

                    begin_healing_zone "deep dive ${dd_id}/${dd_principle}"

                    claude -p "$prompt" \
                        --model "$SONNET_MODEL" \
                        --dangerously-skip-permissions \
                        --output-format stream-json \
                        --verbose \
                        > "$deep_log" 2>&1 || true

                    end_healing_zone

                    log_usage "$deep_log" "score-deep" "${dd_id}/${dd_principle}" "$SONNET_MODEL"

                    deep_scores="${DIAG_DIR}/.deep-scores-${dd_id}-${dd_principle}.csv"
                    deep_rationale="${DIAG_DIR}/.deep-rationale-${dd_id}-${dd_principle}.csv"

                    if parse_score_output "$deep_log" "$deep_scores" "$deep_rationale"; then
                        log "    [${dd_id}/${dd_principle}] deep dive done"
                        echo "ok" > "${DIAG_DIR}/.deep-status-${dd_id}-${dd_principle}"
                    else
                        log "    [${dd_id}/${dd_principle}] deep dive FAILED"
                        echo "fail" > "${DIAG_DIR}/.deep-status-${dd_id}-${dd_principle}"
                    fi
                ) &
                batch_pids+=($!)
                register_child_pid $!
            done

            for pid in "${batch_pids[@]}"; do
                wait "$pid" 2>/dev/null || true
                unregister_child_pid "$pid" 2>/dev/null || true
            done

            for key in "${batch_keys[@]}"; do
                IFS='|' read -r dd_id dd_principle <<< "$key"
                status_file="${DIAG_DIR}/.deep-status-${dd_id}-${dd_principle}"
                deep_scores="${DIAG_DIR}/.deep-scores-${dd_id}-${dd_principle}.csv"
                deep_rationale="${DIAG_DIR}/.deep-rationale-${dd_id}-${dd_principle}.csv"

                if [[ -f "$status_file" ]] && [[ "$(cat "$status_file")" == "ok" ]]; then
                    merge_score_files "${CYCLE_DIR}/deep-scores.csv" "$deep_scores"
                    merge_score_files "${CYCLE_DIR}/deep-rationale.csv" "$deep_rationale"
                    DEEP_COUNT=$((DEEP_COUNT + 1))
                else
                    DEEP_FAILED=$((DEEP_FAILED + 1))
                fi
                rm -f "$deep_scores" "$deep_rationale" "$status_file"
            done

            batch_start=$batch_end
        done
    fi

    pass2_elapsed=$(( $(date +%s) - PASS2_START ))
    log ""
    log "Pass 2 complete: ${DEEP_COUNT} deep evaluations, ${DEEP_FAILED} failures (${pass2_elapsed}s)"
elif (( DEEP_DIVE_THRESHOLD == 0 )); then
    log ""
    log "Quick mode: skipping Pass 2 (Sonnet deep dive)"
fi

# Clean up diagnostic temp files
rm -f "${DIAG_DIR}"/.status-* "${DIAG_DIR}"/.tmp-*


log ""
log "Scene scoring complete: ${SCORED} scenes scored, ${FAILED} failures"
update_pr_task "Scene-level scoring (${SCENE_COUNT} scenes)" "$PROJECT_DIR" 2>/dev/null || true

# ============================================================================
# Act-level scoring
# ============================================================================

log "Running act-level scoring..."

ACT_TEMPLATE_FILE="${PROMPTS_DIR}/act-level.md"
if [[ -f "$ACT_TEMPLATE_FILE" ]]; then
    ACT_TEMPLATE=$(cat "$ACT_TEMPLATE_FILE")

    # Discover unique acts from metadata
    ACTS=()
    while IFS= read -r act_val; do
        [[ -z "$act_val" ]] && continue
        # Deduplicate
    dup=false
        for existing in "${ACTS[@]+"${ACTS[@]}"}"; do
            [[ "$existing" == "$act_val" ]] && dup=true && break
        done
        [[ "$dup" == false ]] && ACTS+=("$act_val")
    done < <(get_csv_column "$METADATA_CSV" "part")

    for act_label in "${ACTS[@]+"${ACTS[@]}"}"; do
        [[ -z "$act_label" ]] && continue

        # Collect scene texts for this act
        act_scenes_text=""
        act_scene_count=0
        act_id="act-${act_label}"

        for id in "${SCENE_IDS[@]}"; do
            scene_part=$(get_csv_field "$METADATA_CSV" "$id" "part")
            if [[ "$scene_part" == "$act_label" ]]; then
                scene_file="${SCENES_DIR}/${id}.md"
                if [[ -f "$scene_file" ]]; then
                    local_title=$(get_csv_field "$METADATA_CSV" "$id" "title")
                    act_scenes_text="${act_scenes_text}

--- Scene: ${local_title:-$id} (${id}) ---

$(cat "$scene_file")
"
                    act_scene_count=$((act_scene_count + 1))
                fi
            fi
        done

        if (( act_scene_count == 0 )); then
            log "  Skipping act ${act_label}: no scored scenes"
            continue
        fi

        # Build rubric content
        narrative_rubric=$(extract_rubric_section "Narrative Frameworks")
        character_act_rubric=$(extract_rubric_section "Character Craft")
        weighted_text=$(build_weighted_text "$WEIGHTS_FILE")

        # Substitute into template
    prompt="$ACT_TEMPLATE"
        prompt="${prompt//\{\{NARRATIVE_FRAMEWORKS_RUBRIC\}\}/$narrative_rubric}"
        prompt="${prompt//\{\{CHARACTER_CRAFT_ACT_RUBRIC\}\}/$character_act_rubric}"
        prompt="${prompt//\{\{ACT_LABEL\}\}/$act_label}"
        prompt="${prompt//\{\{SCENE_COUNT\}\}/$act_scene_count}"
        prompt="${prompt//\{\{ACT_SCENES_TEXT\}\}/$act_scenes_text}"
        prompt="${prompt//\{\{WEIGHTED_PRINCIPLES\}\}/$weighted_text}"
        prompt="${prompt//\{\{ACT_ID\}\}/$act_id}"

    log_file="${LOG_DIR}/score-${act_id}.log"
    tmp_scores="${CYCLE_DIR}/.tmp-act-scores-${act_label}.csv"
    tmp_rationale="${CYCLE_DIR}/.tmp-act-rationale-${act_label}.csv"

        log "  Scoring act ${act_label} (${act_scene_count} scenes)..."

        if invoke_and_parse "$prompt" "$log_file" "$tmp_scores" "$tmp_rationale"; then
            merge_score_files "${CYCLE_DIR}/act-scores.csv" "$tmp_scores"
            merge_score_files "${CYCLE_DIR}/act-rationale.csv" "$tmp_rationale"
            rm -f "$tmp_scores" "$tmp_rationale"
            log "  Act ${act_label} scored"
        else
            log "  WARNING: Failed to parse act-level scores for ${act_label}"
        fi
    done
else
    log "WARNING: Act-level template not found, skipping"
fi
update_pr_task "Act-level scoring" "$PROJECT_DIR" 2>/dev/null || true

# ============================================================================
# Novel-level scoring
# ============================================================================

log "Running novel-level scoring..."

NOVEL_TEMPLATE_FILE="${PROMPTS_DIR}/novel-level.md"
if [[ -f "$NOVEL_TEMPLATE_FILE" ]]; then
    NOVEL_TEMPLATE=$(cat "$NOVEL_TEMPLATE_FILE")

    # Build manuscript summary
    manuscript_summary="Scene count: ${SCENE_COUNT}"

    # Collect character list from intent.csv if available
    character_list=""
    if [[ -f "$INTENT_CSV" ]]; then
        character_list=$(get_csv_column "$INTENT_CSV" "characters" | tr ';' '\n' | sort -u | grep -v '^$' | head -20 || true)
        if [[ -n "$character_list" ]]; then
            manuscript_summary="${manuscript_summary}

Characters mentioned across scenes:
$(echo "$character_list" | sed 's/^/- /')"
        fi
    fi

    # Read character bible and story architecture if available
    character_bible=""
    story_architecture=""
    for ref in "reference/character-bible.md" "references/character-bible.md"; do
        if [[ -f "${PROJECT_DIR}/${ref}" ]]; then
            character_bible=$(cat "${PROJECT_DIR}/${ref}")
            break
        fi
    done
    for ref in "reference/story-architecture.md" "references/story-architecture.md"; do
        if [[ -f "${PROJECT_DIR}/${ref}" ]]; then
            story_architecture=$(cat "${PROJECT_DIR}/${ref}")
            break
        fi
    done

    # Build rubrics
    character_novel_rubric=$(extract_rubric_section "Character Craft")
    genre_rubric=$(extract_rubric_section "Tropes and Genre")
    weighted_text=$(build_weighted_text "$WEIGHTS_FILE")

    # Substitute into template
    prompt="$NOVEL_TEMPLATE"
    prompt="${prompt//\{\{CHARACTER_CRAFT_NOVEL_RUBRIC\}\}/$character_novel_rubric}"
    prompt="${prompt//\{\{GENRE_RUBRIC\}\}/$genre_rubric}"
    prompt="${prompt//\{\{MANUSCRIPT_SUMMARY\}\}/$manuscript_summary}"
    prompt="${prompt//\{\{CHARACTER_BIBLE\}\}/${character_bible:-No character bible found.}}"
    prompt="${prompt//\{\{STORY_ARCHITECTURE\}\}/${story_architecture:-No story architecture found.}}"
    prompt="${prompt//\{\{WEIGHTED_PRINCIPLES\}\}/$weighted_text}"

    log_file="${LOG_DIR}/score-novel-level.log"

    log "  Scoring novel-level character + genre..."

    if [[ "$DRY_RUN" == false ]]; then
        _SF_INVOCATION_START=$(date +%s)
        export _SF_INVOCATION_START

        begin_healing_zone "novel-level scoring"

        claude -p "$prompt" \
            --model "$SONNET_MODEL" \
            --dangerously-skip-permissions \
            --output-format stream-json \
            --verbose \
            > "$log_file" 2>&1 || true

        end_healing_zone

        # Parse character scores
    char_scores="${CYCLE_DIR}/.tmp-char-scores.csv"
    char_rationale="${CYCLE_DIR}/.tmp-char-rationale.csv"
        parse_score_output "$log_file" "$char_scores" "$char_rationale" "CHARACTER_SCORES" "CHARACTER_RATIONALE"
        if [[ -f "$char_scores" ]]; then
            cp "$char_scores" "${CYCLE_DIR}/character-scores.csv"
            rm -f "$char_scores"
        fi
        if [[ -f "$char_rationale" ]]; then
            cp "$char_rationale" "${CYCLE_DIR}/character-rationale.csv"
            rm -f "$char_rationale"
        fi

        # Parse genre scores
    genre_scores="${CYCLE_DIR}/.tmp-genre-scores.csv"
    genre_rationale="${CYCLE_DIR}/.tmp-genre-rationale.csv"
        parse_score_output "$log_file" "$genre_scores" "$genre_rationale" "GENRE_SCORES" "GENRE_RATIONALE"
        if [[ -f "$genre_scores" ]]; then
            cp "$genre_scores" "${CYCLE_DIR}/genre-scores.csv"
            rm -f "$genre_scores"
        fi
        if [[ -f "$genre_rationale" ]]; then
            cp "$genre_rationale" "${CYCLE_DIR}/genre-rationale.csv"
            rm -f "$genre_rationale"
        fi

        log_usage "$log_file" "score" "novel-level" "$SONNET_MODEL"
        log "  Novel-level scoring complete"
    fi
else
    log "WARNING: Novel-level template not found, skipping"
fi
update_pr_task "Novel-level scoring" "$PROJECT_DIR" 2>/dev/null || true

# ============================================================================
# Update latest symlink
# ============================================================================

ln -sfn "cycle-${CYCLE}" "${PROJECT_DIR}/working/scores/latest"
log "Updated latest symlink -> cycle-${CYCLE}"

# ============================================================================
# Cost summary
# ============================================================================

echo ""
print_cost_summary "score"

# ============================================================================
# Improvement cycle: diagnosis and proposals
# ============================================================================

log "Running improvement cycle..."

# Determine previous cycle directory
PREV_DIR=""
if (( CYCLE > 1 )); then
    PREV_DIR="${PROJECT_DIR}/working/scores/cycle-$((CYCLE - 1))"
    if [[ ! -d "$PREV_DIR" ]]; then
        PREV_DIR=""
    fi
fi

# Generate diagnosis and proposals
generate_diagnosis "$CYCLE_DIR" "$PREV_DIR" "$WEIGHTS_FILE"
generate_proposals "$CYCLE_DIR" "$WEIGHTS_FILE"

PROPOSALS_FILE="${CYCLE_DIR}/proposals.csv"
DIAGNOSIS_FILE="${CYCLE_DIR}/diagnosis.csv"

if [[ -f "$PROPOSALS_FILE" ]]; then
    PROPOSAL_COUNT=$(awk -F'|' 'NR > 1 { count++ } END { print count+0 }' "$PROPOSALS_FILE")
    log "Generated ${PROPOSAL_COUNT} improvement proposals"

    if (( PROPOSAL_COUNT > 0 )); then
        # Approval step based on coaching level
        COACHING=$(get_coaching_level 2>/dev/null || echo "full")
        APPLIED=0

        case "$COACHING" in
            full)
                # Auto-approve all proposals
                log "Coaching level: full — auto-approving all proposals"
    tmp_proposals="${PROPOSALS_FILE}.tmp.$$"
                awk -F'|' -v OFS='|' '
                    NR == 1 { print; next }
                    { $7 = "approved"; print }
                ' "$PROPOSALS_FILE" > "$tmp_proposals" && mv "$tmp_proposals" "$PROPOSALS_FILE"
                ;;
            coach)
                # Interactive approval
                log "Coaching level: coach — review proposals below"
                while IFS='|' read -r pid principle lever target change rationale status; do
                    [[ "$pid" == "id" ]] && continue
                    [[ "$status" != "pending" ]] && continue
                    echo ""
                    echo "  Proposal ${pid}: ${principle}"
                    echo "    Lever: ${lever}, Target: ${target}"
                    echo "    Change: ${change}"
                    echo "    Rationale: ${rationale}"
                    read -r -p "  Approve? (y/n) " answer < /dev/tty 2>/dev/null || answer="n"
                    if [[ "$answer" == "y" || "$answer" == "Y" ]]; then
                        update_csv_field "$PROPOSALS_FILE" "$pid" "status" "approved"
                    else
                        update_csv_field "$PROPOSALS_FILE" "$pid" "status" "rejected"
                    fi
                done < "$PROPOSALS_FILE"
                ;;
            strict)
                # Report only — do not approve
                log "Coaching level: strict — diagnosis and proposals generated as report only"
                echo ""
                echo "=== Diagnosis Summary ==="
                if [[ -f "$DIAGNOSIS_FILE" ]]; then
                    awk -F'|' 'NR > 1 && ($6 == "high" || $6 == "medium") {
                        printf "  %s (%s): avg %.1f, priority %s\n", $1, $2, $3, $6
                    }' "$DIAGNOSIS_FILE"
                fi
                echo ""
                echo "=== Proposals (not applied in strict mode) ==="
                awk -F'|' 'NR > 1 {
                    printf "  %s: %s — %s (%s)\n", $1, $2, $5, $6
                }' "$PROPOSALS_FILE"
                echo ""
                ;;
        esac

        # Apply step for approved proposals
        if [[ "$COACHING" != "strict" ]]; then
            while IFS='|' read -r pid principle lever target change rationale status; do
                [[ "$pid" == "id" ]] && continue
                [[ "$status" != "approved" ]] && continue

                case "$lever" in
                    craft_weight)
                        # Extract new weight from change string "weight X → Y"
                        new_val=$(echo "$change" | sed -n 's/.*→ *\([0-9]*\).*/\1/p')
                        if [[ -n "$new_val" ]]; then
                            update_csv_field "$WEIGHTS_FILE" "$principle" "weight" "$new_val" "principle"
                            APPLIED=$((APPLIED + 1))
                            update_csv_field "$PROPOSALS_FILE" "$pid" "status" "applied"
                        fi
                        ;;
                    scene_intent)
                        if [[ -f "$INTENT_CSV" ]]; then
                            # Record as override — scene_intent changes need human/Claude writing
    overrides_file="${PROJECT_DIR}/working/overrides.csv"
                            if [[ ! -f "$overrides_file" ]]; then
                                echo "id|principle|directive|source" > "$overrides_file"
                            fi
                            echo "${target}|${principle}|${change}|${pid}" >> "$overrides_file"
                            APPLIED=$((APPLIED + 1))
                            update_csv_field "$PROPOSALS_FILE" "$pid" "status" "applied"
                        fi
                        ;;
                    voice_guide)
    overrides_file="${PROJECT_DIR}/working/overrides.csv"
                        if [[ ! -f "$overrides_file" ]]; then
                            echo "id|principle|directive|source" > "$overrides_file"
                        fi
                        echo "global|${principle}|${change}|${pid}" >> "$overrides_file"
                        APPLIED=$((APPLIED + 1))
                        update_csv_field "$PROPOSALS_FILE" "$pid" "status" "applied"
                        ;;
                    override)
    overrides_file="${PROJECT_DIR}/working/overrides.csv"
                        if [[ ! -f "$overrides_file" ]]; then
                            echo "id|principle|directive|source" > "$overrides_file"
                        fi
                        echo "${target}|${principle}|${change}|${pid}" >> "$overrides_file"
                        APPLIED=$((APPLIED + 1))
                        update_csv_field "$PROPOSALS_FILE" "$pid" "status" "applied"
                        ;;
                esac
            done < "$PROPOSALS_FILE"

            log "${APPLIED} proposals applied. Run storyforge write to rewrite with updated guidance."
        fi
    fi
else
    log "No proposals generated"
fi
update_pr_task "Diagnosis and proposals" "$PROJECT_DIR" 2>/dev/null || true
update_pr_task "Improvement cycle" "$PROJECT_DIR" 2>/dev/null || true

# Collect exemplars from high-scoring scenes
collect_exemplars "$CYCLE_DIR" "$PROJECT_DIR" "$CYCLE"

# Check for validated patterns from tuning history
validated=$(check_validated_patterns "$PROJECT_DIR")
if [[ -n "$validated" ]]; then
    log "Validated tuning patterns found:"
    project_title=$(read_yaml_field "project.title" 2>/dev/null || read_yaml_field "title" 2>/dev/null || echo "Unknown")
    echo "$validated" | while IFS='|' read -r vp vl vi; do
        log "  ${vp} (${vl}): avg improvement ${vi}"
        # Build evidence from tuning ledger
        evidence=""
        if [[ -f "${PROJECT_DIR}/working/tuning.csv" ]]; then
            evidence=$(awk -F'|' -v p="$vp" -v l="$vl" '
                NR == 1 { next }
                $3 == p && $4 == l && $8 == "true" {
                    printf "- Cycle %s: %s (before: %s, after: %s)\n", $1, $5, $6, $7
                }
            ' "${PROJECT_DIR}/working/tuning.csv")
        fi
        # Submit plugin insight
        submit_plugin_insight "$vp" "$vl" "Validated pattern across 3+ cycles" "$vi" "$project_title" "$evidence"
    done
fi

# ============================================================================
# Git commit and push
# ============================================================================

# ============================================================================
# Generate report and PR comment
# ============================================================================

TOTAL_COST=$(awk -F'|' '
    NR==1 { next }
    $2 == "score" { sum += $9 }
    END { printf "%.2f", sum }
' "${PROJECT_DIR}/working/costs/ledger.csv" 2>/dev/null || echo "0.00")

generate_score_report "$CYCLE_DIR" "$PROJECT_DIR" "$CYCLE" "$SCORE_MODE" "$SCENE_COUNT" "$TOTAL_COST"

# Post PR comment with scoring summary
if has_gh 2>/dev/null; then
    PR_COMMENT=$(build_score_pr_comment "$CYCLE_DIR" "$PROJECT_DIR" "$CYCLE" "$SCORE_MODE" "$SCENE_COUNT" "$TOTAL_COST")
    if [[ -n "$PR_COMMENT" ]]; then
        # Find the PR for the current branch
        CURRENT_PR=$(gh pr view --json number -q '.number' 2>/dev/null || true)
        if [[ -n "$CURRENT_PR" ]]; then
            echo "$PR_COMMENT" | gh pr comment "$CURRENT_PR" --body-file - 2>/dev/null || log "WARNING: Failed to post PR comment"
            log "Posted scoring summary to PR #${CURRENT_PR}"
        fi
    fi
fi

update_pr_task "Review" "$PROJECT_DIR" 2>/dev/null || true

# Regenerate manuscript dashboard with updated score data
VISUALIZE_SCRIPT="${SCRIPT_DIR}/storyforge-visualize"
if [[ -x "$VISUALIZE_SCRIPT" ]]; then
    log "Regenerating manuscript dashboard..."
    "$VISUALIZE_SCRIPT" 2>/dev/null || log "WARNING: Dashboard generation failed"
fi

log "Committing scoring results..."

(
    cd "$PROJECT_DIR"
    git add "working/scores/" 2>/dev/null || true
    git add "working/craft-weights.csv" 2>/dev/null || true
    git add "working/costs/" 2>/dev/null || true
    git add "working/logs/" 2>/dev/null || true
    git add "working/tuning.csv" 2>/dev/null || true
    git add "working/overrides.csv" 2>/dev/null || true
    git add "working/exemplars.csv" 2>/dev/null || true
    git commit -m "Score: cycle ${CYCLE}, ${SCENE_COUNT} scenes (${SCORE_MODE} mode)" 2>/dev/null || true
    git push 2>/dev/null || true
)

log "============================================"
log "Scoring cycle ${CYCLE} complete"
log "Results: ${CYCLE_DIR}"
log "============================================"
